 "linux_64_meta_yaml": {
  "about": {
   "description": "*pyLoad* is a free and open source downloader for 1-click-hosting sites.\nIt supports link decryption as well as all important container formats.\nTargeted for headless NASs it is designed to be extremely lightweight,\nfully customizable and remotely manageable via web interface.\n",
   "dev_url": "https://github.com/pyload/pyload",
   "doc_url": "https://github.com/pyload/pyload/wiki",
   "home": "https://pyload.net",
   "license": "AGPL-3.0-or-later AND gnuplot",
   "license_file": [
    "LICENSE.md",
    "src/pyload/webui/app/static/img/notice.png"
   ],
   "summary": "The free and open-source Download Manager written in pure Python"
  },
  "build": {
   "entry_points": [
    "pyload = pyload.__main__:main"
   ],
   "noarch": "python",
   "number": "3",
   "script": "PYTHON -m pip install . -vv"
  },
  "extra": {
   "recipe-maintainers": [
    "HeavyTony2"
   ]
  },
  "package": {
   "name": "pyload-ng",
   "version": "0.5.0b3.dev87"
  },
  "requirements": {
   "host": [
    "pip",
    "python 3.9",
    "setuptools >=38.3",
    "wheel"
   ],
   "run": [
    "python >=3.9,<3.12",
    "cheroot",
    "flask",
    "flask-babel >=1.0,<2.dev0",
    "flask-caching >=1.9,<2.dev0",
    "flask-compress >=1.8,<2.dev0",

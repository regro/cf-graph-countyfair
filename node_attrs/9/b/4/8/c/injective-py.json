  "raw_meta_yaml": "{% set name = \"injective-py\" %}\n{% set version = \"1.9.1\" %}\n\n# {% set python_min = \"3.10\" %}\npackage:\n  name: {{ name|lower }}\n  version: {{ version }}\n\nsource:\n  url: https://github.com/InjectiveLabs/sdk-python/archive/refs/tags/v{{ version }}.tar.gz\n  sha256: 0f0add094fc0d2973dc8038677b5c041ef6466d296d40d645a55b1dd756c18d9\n  patches:\n    - patches/fix-protobuf-test-fail.patch\n    - patches/clean-lib-dependencies.patch\n\nbuild:\n  # noarch: python\n  skip: true  # [py < 39]\n  script: {{ PYTHON }} -m pip install . -vvv\n  number: 0\n\nrequirements:\n  host:\n    - aiohttp >=3.9.4\n    - pip\n    - poetry-core\n    - python\n  run:\n    - bech32\n    - bip32\n    - ckzg <2  # [py < 313]\n    - ckzg  # [py >= 313]\n    - ecdsa\n    - eip712\n    - eth-abi\n    - grpcio\n    - mnemonic\n    - python\n    - requests\n    - safe-pysha3\n    - web3 >=6.0.0,<7.0.0  # [py < 313]\n    - web3 >=7.0.0,<7.6.0  # [py >= 313]\n\ntest:\n  imports:\n    - pyinjective\n  source_files:\n    - tests\n    - examples\n    - pyproject.toml\n  requires:\n    - pip\n    - poetry\n    - pytest\n    - pytest-asyncio\n    - pytest-grpc\n    - python\n    - requests-mock\n  commands:\n    - pip check\n    # Documented (incorrectly) examples do not work\n    # - poetry run python examples/exchange_client/spot_exchange_rpc/8_StreamOrderbookUpdate.py\n    # - poetry run python examples/chain_client/3_MessageBroadcaster.py\n\n    # All tests are failing\n    # - poetry run pytest -v\n\nabout:\n  home: https://github.com/InjectiveLabs/sdk-python\n  summary: 'Injective Python SDK, with Exchange API client'\n  license: Apache-2.0\n  license_file:\n    - LICENSE.md\n    - NOTICE.md\n\nextra:\n  recipe-maintainers:\n    - MementoRC\n",

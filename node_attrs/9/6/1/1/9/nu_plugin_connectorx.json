  "raw_meta_yaml": "context:\n  version: \"0.1.0\"\n\npackage:\n  name: nu_plugin_connectorx\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/VasanthakumarV/nu_plugin_connectorx/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 5019965c6fd3829d7dbae0536c032bd642bb387469e54773197b6b7a4ac62e99\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then: |\n          if [[ \"${target_platform}\" == linux-* ]]; then\n            export BINDGEN_EXTRA_CLANG_ARGS=\"$CFLAGS\"\n          fi\n          cargo-bundle-licenses --format yaml --output ${SRC_DIR}/THIRDPARTY.yml\n          cargo auditable install --locked --no-track --path . --root ${PREFIX}\n        else: |\n          cargo-bundle-licenses --format yaml --output %SRC_DIR%\\THIRDPARTY.yml\n          cargo auditable install --locked --no-track --path . --root %LIBRARY_PREFIX%\n\nrequirements:\n  build:\n    - ${{ compiler('rust') }}\n    - ${{ stdlib('c') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n    - if: win\n      then: perl\n    - if: unix\n      then: make\n    - if: linux\n      then:\n        - clangdev\n        - pkg-config\n  host:\n    - if: linux\n      then:\n        - openssl\n        - krb5-static\n        - zlib\n\ntests:\n  - script:\n      - nu_plugin_connectorx\n\nabout:\n  homepage: https://github.com/VasanthakumarV/nu_plugin_connectorx\n  license: Apache-2.0 OR MIT\n  license_file:\n    - LICENSE-MIT\n    - LICENSE-APACHE\n    - THIRDPARTY.yml\n  description: \"Load data from DBs in nushell using ConnectorX\"\n  summary: \"Load data from DBs in nushell using ConnectorX\"\n\nextra:\n  recipe-maintainers:\n    - VasanthakumarV\n",

  "raw_meta_yaml": "context:\n  name: perspective\n  version: \"4.4.1\"\n  python_min: \"3.11\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/finos/perspective/releases/download/v${{ version }}/perspective_python-${{ version }}.tar.gz\n  sha256: d3b4cc0f01da5b09dd7c255c3dd6df1eba1eea7c2ebea0167077639069f62ceb\n\nbuild:\n  number: 0\n  python:\n    version_independent: true\n  skip: is_abi3 and not is_python_min or win\n\nrequirements:\n  build:\n    - if: build_platform != target_platform\n      then:\n        - python\n        - cross-python_${{ target_platform }} >=${{ python_min }},<3.12\n        - maturin >=1.4,<2.0\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - git\n    - cmake\n    - make\n    - pkg-config\n  host:\n    - python >=3.11\n    - pip\n    - maturin >=1.4,<2.0\n    - if: is_abi3\n      then:\n        - python-abi3 ==${{ python_min }}\n  run:\n    - python\n  ignore_run_exports:\n    from_package:\n      - cross-python_${{ target_platform }}\n\ntests:\n  - python:\n      imports:\n        - perspective\n      pip_check: true\n      python_version: ${{ python_min }}.*\n  - if: is_abi3\n    then:\n      script:\n        - if: win\n          then: abi3audit %PREFIX%/Lib/site-packages/perspective/perspective.pyd -s -v --assume-minimum-abi3 ${{ python_min }}\n          else:\n            - export SP_DIR=$(python -c \"import site; print(site.getsitepackages()[0])\")\n            - abi3audit $SP_DIR/perspective/perspective.abi3.so -s -v --assume-minimum-abi3 ${{ python_min }}\n      requirements:\n        run:\n          - abi3audit\n\nabout:\n  license: Apache-2.0\n  license_family: Apache\n  license_file:\n    - LICENSE.md\n    - LICENSE_THIRDPARTY_cargo.yml\n    - THIRDPARTY.yml\n  summary: Streaming pivot visualization via WebAssembly\n  homepage: https://perspective-dev.github.io\n  repository: http://github.com/perspective-dev/perspective\n\nextra:\n  recipe-maintainers:\n    - timkpaine\n    - texodus\n    - sc1f\n",

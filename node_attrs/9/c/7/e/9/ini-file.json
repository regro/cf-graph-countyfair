    "about": {
      "description": "ini-file is a command-line tool that allows manipulating INI files.\nIt supports setting, getting, and deleting values in INI files.",
      "dev_url": "https://github.com/bitnami/ini-file",
      "home": "https://github.com/bitnami/ini-file",
      "license": "Apache-2.0",
      "license_family": "Apache-2.0",
      "license_file": "src/LICENSE.md",
      "summary": "A CLI tool for manipulating INI files"
    },
    "build": {
      "number": "1",
      "script": [
        "cd src",
        "BUILD_TIME=\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"",
        "SHORT_COMMIT_HASH=\"$(curl -s \"https://api.github.com/repos/bitnami/ini-file/commits/v${{ version }}\" | jq -r '.sha' | cut -c 1-7)\"",
        "go build -v -o $PREFIX/bin/ini-file -ldflags=\"-s -w -X main.buildDate=${BUILD_TIME} -X main.commit=${SHORT_COMMIT_HASH} -X main.version=${{ version }}\" -trimpath .",
        "go-licenses save . --save_path ../library_licenses"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },

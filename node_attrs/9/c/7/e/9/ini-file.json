  "raw_meta_yaml": "context:\n  version: \"1.4.9\"\n\npackage:\n  name: ini-file\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/bitnami/ini-file/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 3c460cf5d30145d46517b1d95a8bf2e38dc59e2290e70ace89d5ab6d8abbf15b\n  target_directory: src\n\nbuild:\n  number: 1\n  script:\n    - cd src\n    - if: unix\n      then:\n        - BUILD_TIME=\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"\n        - SHORT_COMMIT_HASH=\"$(curl -s \"https://api.github.com/repos/bitnami/ini-file/commits/v${{ version }}\" | jq -r '.sha' | cut -c 1-7)\"\n        - go build -v -o $PREFIX/bin/ini-file -ldflags=\"-s -w -X main.buildDate=${BUILD_TIME} -X main.commit=${SHORT_COMMIT_HASH} -X main.version=${{ version }}\" -trimpath .\n    - if: win\n      then:\n        - for /f \"usebackq delims=\" %%T in (`powershell -Command \"[DateTime]::UtcNow.ToString('yyyy-MM-ddTHH:mm:ssZ')\"`) do set BUILD_TIME=%%T\n        - for /f \"usebackq delims=\" %%T in (`powershell -Command \"((Invoke-RestMethod 'https://api.github.com/repos/bitnami/ini-file/commits/v${{ version }}').sha).Substring(0, 7)\"`) do set SHORT_COMMIT_HASH=%%T\n        - go build -v -o %LIBRARY_BIN%\\ini-file.exe -ldflags=\"-s -w -X main.buildDate=%BUILD_TIME% -X main.commit=%SHORT_COMMIT_HASH% -X main.version=${{ version }}\" -trimpath .\n    - go-licenses save . --save_path ../library_licenses\n\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntests:\n  - script:\n      - if: win\n        then: ini-file --help 2>&1 | findstr /c:\"Usage:\" >nul\n      - if: unix\n        then: ini-file --help 2>&1 | grep -q \"Usage:\"\n  - package_contents:\n      bin:\n        - ini-file\n      strict: true\n\nabout:\n  summary: A CLI tool for manipulating INI files\n  description: |\n    ini-file is a command-line tool that allows manipulating INI files.\n    It supports setting, getting, and deleting values in INI files.\n  license: Apache-2.0\n  license_file:\n    - 
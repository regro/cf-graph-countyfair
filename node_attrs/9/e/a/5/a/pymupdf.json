  "raw_meta_yaml": "context:\n  name: pymupdf\n  version: \"1.27.2.2\"\n  mupdf_version: \"1.27.2\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/pymupdf/PyMuPDF/archive/${{ version }}.tar.gz\n  sha256: 391068b84a5f5e4716168a71b963c6f48a54f232e25494d75be29554fa6ae898\n  patches:\n    - system-mupdf.patch\n\nbuild:\n  number: 1\n  script:\n    - if: unix\n      then: LD=\"$CXX\" PYMUPDF_SETUP_MUPDF_BUILD=\"\" PYMUPDF_SETUP_MUPDF_REBUILD=0 PYMUPDF_MUPDF_LIB=\"$PREFIX/lib\" PYMUPDF_INCLUDES=\"$PREFIX/include:$PREFIX/include/mupdf:$PREFIX/include/freetype2\" pip install . -vv --no-deps --no-build-isolation\n    - if: win\n      then: |\n        set \"CC=\"\n        set \"CXX=\"\n        set \"LD=\"\n        set \"PYMUPDF_SETUP_MUPDF_BUILD=system\"\n        set \"PYMUPDF_SETUP_MUPDF_REBUILD=0\"\n        set \"PYMUPDF_MUPDF_LIB=%LIBRARY_LIB%\"\n        set \"PYMUPDF_INCLUDES=%LIBRARY_INC%\\mupdf\"\n        pip install . -vv --no-deps --no-build-isolation\n\nrequirements:\n  build:\n    - if: build_platform != host_platform\n      then:\n        - python\n        - cross-python_${{ host_platform }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ stdlib(\"c\") }}\n    - swig\n    - mupdf =${{ mupdf_version }}\n  host:\n    - python\n    - pip\n    - setuptools\n    - mupdf =${{ mupdf_version }}\n  run:\n    - python\n    - mupdf =${{ mupdf_version }}\n\ntests:\n  - python:\n      imports:\n        - fitz\n        - pymupdf\n      pip_check: true\n\nabout:\n  summary: A high performance Python library for data extraction, analysis, conversion & manipulation of PDF (and other) documents.\n  license: AGPL-3.0-or-later\n  license_file: COPYING\n  homepage: https://github.com/pymupdf/pymupdf\n\nextra:\n  recipe-maintainers:\n    - jan-janssen\n    - moritzwilksch\n    - benmoss\n",

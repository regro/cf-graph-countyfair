  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  name: fastmcp\n  version: \"3.0.2\"\n  python_min: '3.10'\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/fastmcp-${{ version }}.tar.gz\n  sha256: 6bd73b4a3bab773ee6932df5249dcbcd78ed18365ed0aeeb97bb42702a7198d7\n\nbuild:\n  number: 1\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - fastmcp = fastmcp.cli:app\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - hatchling\n    - uv-dynamic-versioning >=0.7.0\n    - pip\n  run:\n    - python >=${{ python_min }},<4\n    - python-dotenv >=1.1.0\n    - exceptiongroup >=1.2.2\n    - httpx >=0.28.1,<1.0\n    - mcp >=1.24.0,<2.0\n    - openapi-pydantic >=0.5.1\n    - opentelemetry-api >=1.20.0\n    - packaging >=24.0\n    - platformdirs >=4.0.0\n    - rich >=13.9.4\n    - cyclopts >=4.0.0\n    - authlib >=1.6.5\n    - pydantic >=2.11.7\n    # \"pydantic[email]>=2.11.7\",\n    # https://github.com/jlowin/fastmcp/blob/v2.13.0/pyproject.toml#L16\n    # https://github.com/pydantic/pydantic/blob/main/pyproject.toml#L56\n    - email-validator >=2.0.0\n    - pyyaml >=6.0,<7.0\n    - pyperclip >=1.9.0\n    - py-key-value-aio >=0.4.4,<0.5.0\n    # \"py-key-value-aio[filetree,keyring,memory]>=0.2.6,<0.3.0\",\n    # https://github.com/PrefectHQ/fastmcp/blob/v3.0.2/pyproject.toml#L21\n    # https://github.com/strawgate/py-key-value/blob/main/pyproject.toml#L33\n    - aiofile >=3.5.0\n    - anyio >=4.4.0\n    # py-key-value-aio[memory]\n    # https://github.com/strawgate/py-key-value/blob/main/pyproject.toml#L31\n    - cachetools >=5.0.0\n    # py-key-value-aio[keyring]\n    # https://github.com/strawgate/py-key-value/blob/main/pyproject.toml#L43\n    - keyring >=25.6.0\n    - uvicorn >=0.35\n    - websockets >=15.0.1\n    - jsonschema-path >=0.3.4\n    - jsonref >=1.1.0\n    - watchfiles >=1.0.0\n  run_constraints:\n    - openai >=1.102.0\n    - anthropic >=0.40.0\n    - azure-identity >=1.16.0\n    - pydocket >=0.17.2\n\ntests:\n  - python:\n      imports:\n        - fastmcp\n      pip_check: true\n      python_version: ${{ python_min }}.*\n  - requirements:\n      run:\n        - python ${{ python_min }}.*\n        - pip\n    script:\n      - fastmcp --help\n\nabout:\n  summary: The fast, Pythonic way to build MCP servers and clients.\n  homepage: https://github.com/jlowin/fastmcp\n  license: Apache-2.0\n  license_file: LICENSE\n\nextra:\n  recipe-maintainers:\n    - rxm7706\n    - dbast\n",

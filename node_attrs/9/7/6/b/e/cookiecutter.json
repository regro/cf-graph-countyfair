  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  version: \"2.7.1\"\n  python_check_max: \"3.14\"\n  cov_fail_under: \"98\"\n  contains_version: >\n    python -c \"import sys, re; assert re.search('[cC]ookiecutter\\s+${{ version | replace('.', '\\\\.') }}', sys.stdin.read())\"\n\npackage:\n  name: cookiecutter\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/c/cookiecutter/cookiecutter-${{ version }}.tar.gz\n  sha256: ca7bb7bc8c6ff441fbf53921b5537668000e38d56e28d763a1b73975c66c6138\n\nbuild:\n  number: 0\n  noarch: python\n  script:\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation --disable-pip-version-check\n  python:\n    entry_points:\n      - cookiecutter = cookiecutter.__main__:main\n\nrequirements:\n  host:\n    - pip\n    - python ${{ python_min }}.*\n    - setuptools\n  run:\n    - arrow\n    - binaryornot >=0.4.4\n    - click >=7.0,<9.0.0\n    - jinja2 >=2.7,<4.0.0\n    - python >=${{ python_min }}\n    - python-slugify >=4.0.0\n    - pyyaml >=5.3.1\n    - requests >=2.23.0\n    - rich\n\ntests:\n  - python:\n      imports: cookiecutter\n      pip_check: true\n      python_version:\n        - ${{ python_min }}.*\n        - ${{ python_check_max }}.*\n  - files:\n      source:\n        - pyproject.toml\n        - tests/\n    requirements:\n      run:\n        - freezegun\n        - git\n        - mercurial\n        - pytest\n        - pytest-cov\n        - pytest-mock\n        - python ${{ python_min }}.*\n    script:\n      - cookiecutter --version\n      - cookiecutter --version | ${{ contains_version }}\n      - cookiecutter --help\n      - pytest -vv --color=yes --tb=long --cov-fail-under=${{ cov_fail_under }}\n\nabout:\n  license_file: LICENSE\n  license: BSD-3-Clause\n  homepage: https://pypi.org/project/cookiecutter\n  repository: https://github.com/cookiecutter/cookiecutter\n  documentation: https://cookiecutter.readthedocs.io\n  summary: |-\n    A command-line utility that creates projects from project templates, e.g.\n    creating a Python package project from a Python package project template.\n\nextra:\n  recipe-maintainers:\n    - bollwyvl\n    - cadair\n    - jakirkham\n    - pydanny\n",

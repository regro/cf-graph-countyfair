  "raw_meta_yaml": "context:\n  version: \"6.11.0\"\n  maj_min: ${{ (version | split('.'))[:2] | join('.') }}\n\npackage:\n  name: qt6-networkauth\n  version: ${{ version }}\n\nsource:\n  url: https://download.qt.io/official_releases/qt/${{ maj_min }}/${{ version }}/submodules/qtnetworkauth-everywhere-src-${{ version }}.tar.xz\n  md5: c9b177069738bf61b43faea0f84d5e33\n\nbuild:\n  number: 1\n\nrequirements:\n  build:\n    - cmake\n    - ninja\n    - perl\n    - ${{ compiler('cxx') }}\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - if: build_platform != target_platform\n      then: qt6-main ${{ version }}.*\n  host:\n    - qt6-main ${{ version }}.*\n    - if: linux\n      then:\n        - libgl-devel\n        - libegl-devel\n        - libopengl-devel\n  run:\n    - qt6-main ${{ version }}.*\n  run_exports:\n    - ${{ pin_subpackage('qt6-networkauth', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - if: unix\n        then:\n          - test -d $PREFIX/include/qt6/QtNetworkAuth\n          - test -f $PREFIX/lib/libQt6NetworkAuth${SHLIB_EXT}\n        else:\n          - if not exist %PREFIX%\\\\Library\\\\include\\\\qt6\\\\QtNetworkAuth exit 1\n          - if not exist %PREFIX%\\\\Library\\\\lib\\\\Qt6NetworkAuth.lib exit 1\n          - if not exist %PREFIX%\\\\Library\\\\bin\\\\Qt6NetworkAuth.dll exit 1\n\nabout:\n  homepage: http://qt-project.org\n  license: GPL-3.0-only\n  license_file:\n    - LICENSES/GPL-3.0-only.txt\n    - LICENSES/BSD-3-Clause.txt\n    - LICENSES/GFDL-1.3-no-invariants-only.txt\n    - LICENSES/LicenseRef-Qt-Commercial.txt\n  summary: Qt Network Authentication\n  description: |\n    Qt Network Authorization provides a set of APIs that enable Qt applications\n    to obtain limited access to online accounts and HTTP services without\n    exposing users' passwords.\n  documentation: http://doc.qt.io/\n  repository: https://github.com/qt/qtopcua\n\nextra:\n  recipe-maintainers:\n    - hmaarrfk\n    - conda-forge/qt-main\n  feedstock-name: qt-networkauth\n",

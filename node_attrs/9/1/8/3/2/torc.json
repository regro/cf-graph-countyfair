    "about": {
      "description": "Torc is a workflow management system designed for running large-scale\ncomputational workflows with complex dependencies on local machines\nand HPC clusters.",
      "dev_url": "https://github.com/NatLabRockies/torc",
      "doc_url": "https://natlabrockies.github.io/torc/",
      "home": "https://github.com/NatLabRockies/torc",
      "license": "BSD-3-Clause",
      "license_family": "BSD-3-Clause",
      "license_file": "LICENSE",
      "summary": "Distributed workflow orchestration for complex computational pipelines"
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "export OPENSSL_DIR=$PREFIX",
          "cargo auditable install --locked --no-track --bins --no-default-features --features dist --root ${{ PREFIX }} --path .",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols",
          "OPENSSL_NO_VENDOR": "1",
          "SQLX_OFFLINE": "true"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "daniel-thom"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "torc",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable",
            "pkg-config"
          ],
          "host": [
            "openssl"
          ],
          "run": []
        },
        "tests": [
          {
            "script": [
              "torc --version",
              "torc --help",
              "torc-server --help"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "torc",
                "torc-dash",
                "torc-htpasswd",
                "torc-mcp-server",
                "torc-server",
                "torc-slurm-job-runner"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.14.0"
      }
    ],

  "raw_meta_yaml": "context:\n  version: \"1.4.6\"\n\npackage:\n  name: fast-plaid\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/lightonai/fast-plaid/archive/refs/tags/1.4.6.tar.gz\n  sha256: de6959c398307cac64deccd98af925fc8d040656248f21f300dbafd3806829fd\n  patches:\n    # https://github.com/lightonai/fast-plaid/pull/43\n    - remove-runtime-build-tools.patch\n\nbuild:\n  number: 0\n  skip:\n    - win\n  script:\n    env:\n      CARGO_BUILD_JOBS: \"1\"\n      LIBTORCH_USE_PYTORCH: \"1\"\n    content:\n      - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation --config-settings=build-args=--auditwheel=skip\n      - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ compiler('rust') }}\n    - ${{ stdlib('c') }}\n    - cargo-bundle-licenses\n  host:\n    - python\n    - pip\n    - maturin >=1.8.6\n    - numpy >=1.26.4\n    - setuptools >=78.1.1\n    - pytorch >=2.6,<2.10\n    - fastkmeans ==0.5.0\n    - usearch-python >=2.21.0\n  run:\n    - python\n    - fastkmeans ==0.5.0\n    - joblib >=1.5.1\n    - pytorch >=2.6\n    - numpy >=1.26.4\n    - filelock >=3.20.0\n    - usearch-python >=2.21.0\n\ntests:\n  - python:\n      imports:\n        - fast_plaid.search\n        - fast_plaid.filtering\n      pip_check: true\n  - script: python -c \"import tempfile; from fast_plaid import search; idx = search.FastPlaid(index=tempfile.mkdtemp(), device='cpu'); idx.close()\"\n\nabout:\n  homepage: https://github.com/lightonai/fast-plaid\n  summary: High-performance engine for multi-vector search\n  repository: https://github.com/lightonai/fast-plaid\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n\nextra:\n  recipe-maintainers:\n    - moritzwilksch\n",

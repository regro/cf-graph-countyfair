  "raw_meta_yaml": "context:\n  version: \"2.1.11\"\n\npackage:\n  name: libmixmod\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/mixmod/mixmod/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: e95414decf5b2c2c5eebd7fca10e0100f2d753cbfca0694f4ac75da3b39b005e\n\nbuild:\n  number: 2\n\nrequirements:\n  build:\n    - cmake\n    - ninja\n    - ${{ compiler(\"c\") }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler(\"cxx\") }}\n    - if: osx\n      then: llvm-openmp\n    - if: linux\n      then: libgomp\n  host:\n    - eigen\n  run_exports:\n    - ${{ pin_subpackage('libmixmod', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - if: unix\n        then:\n          - test -f ${PREFIX}/include/mixmod.h\n          - test -f ${PREFIX}/lib/libmixmod${SHLIB_EXT}\n        else:\n          - if not exist %PREFIX%\\\\Library\\\\include\\\\mixmod.h exit 1\n          - if not exist %PREFIX%\\\\Library\\\\lib\\\\mixmod.lib exit 1\n\nabout:\n  homepage: https://github.com/mixmod/mixmod\n  license: GPL-3.0-or-later\n  license_family: GPL\n  license_file: UTIL/gpl.txt\n  summary: Supervised, Unsupervised, Semi-Supervised Classification with MIXture MODelling\n\nextra:\n  recipe-maintainers:\n    - jschueller\n",

  "raw_meta_yaml": "context:\n  version: \"0.35.0\"\n\npackage:\n  name: rtk-cli\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/rtk-ai/rtk/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 5df52f759357a87c8252972818637bbd4f59f74ac574c6b144d8318eaca908b0\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n        else:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n\ntests:\n  - script: rtk --help\n  - package_contents:\n      bin:\n        - rtk\n      strict: true\n\nabout:\n  homepage: https://github.com/rtk-ai/rtk\n  summary: CLI proxy that filters and compresses command outputs to reduce LLM token usage\n  description: |\n    RTK is a CLI proxy that filters and compresses command outputs before they\n    reach an LLM's context window, achieving 60-90% token savings on typical\n    dev commands like git, pytest, pip, ruff, docker, and more.\n  license: Apache-2.0\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  repository: https://github.com/rtk-ai/rtk\n\nextra:\n  recipe-maintainers:\n    - moritzwilksch\n",

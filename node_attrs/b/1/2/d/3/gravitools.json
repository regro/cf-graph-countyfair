  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: gravitools\n  version: \"0.2.0\"\n\nrecipe:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/g/gravitools/gravitools-${{ version }}.tar.gz\n  sha256: 5a502256bd4fbc1f7274f28760fc3688a60680856f9bcc341916835285db0233\n\nbuild:\n  number: 0\n\noutputs:\n  - package:\n      name: ${{ name }}\n      version: ${{ version }}\n    build:\n      python:\n        entry_points:\n          - gt-aqg-proc = gravitools.aqg.cli:main\n      noarch: python\n      script: ${{ PYTHON }} -m pip install . -vv\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n        - setuptools\n        - pip\n      run:\n        - python >=${{ python_min }}\n        - allantools\n        - fpdf2\n        - matplotlib-base\n        - netcdf4\n        - numpy\n        - packaging\n        - pandas\n        - pyyaml\n        - requests\n        - xarray\n    tests:\n      - python:\n          imports:\n            - gravitools\n          # issue opened at 'allantools'-feedstock: https://github.com/conda-forge/allantools-feedstock/issues/7 \n          # issue for fixing above: https://github.com/conda-forge/allantools-feedstock/pull/8\n          pip_check: true\n          python_version:\n            - ${{ python_min }}.*\n            - \"*\"\n  - package:\n      name: ${{ name }}-dashboard\n      version: ${{ version }}\n    build:\n      python:\n        entry_points:\n          - gt-aqg-proc = gravitools.aqg.cli:main\n          - gt-aqg-dash = \"gravitools.aqg.dashboard:main\"\n      noarch: python\n      script: ${{ PYTHON }} -m pip install . -vv\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n        - setuptools\n        - pip\n      run:\n        - python >=${{ python_min }}\n        - allantools\n        - fpdf2\n        - matplotlib-base\n        - netcdf4\n        - numpy\n        - packaging\n        - pandas\n        - pyyaml\n        - requests\n        - xarray\n        - pyqtgraph\n        - PySide6\n    tests:\n      - python:\n          imports:\n            - gravitools\n          # issue opened at 'allantools'-feedstock: https://github.com/conda-forge/allantools-feedstock/issues/7 \n          # issue for fixing above: https://github.com/conda-forge/allantools-feedstock/pull/8\n          pip_check: true\n          python_version:\n            - ${{ python_min }}.*\n            - \"*\"\n\nabout:\n  homepage: https://pypi.org/project/gravitools/\n  repository: https://gitlab.opencode.de/bkg/gravitools\n  summary: A collection of tools for gravimeter data analysis\n  documentation: https://gravitools.readthedocs.io/\n  license: EUPL-1.2\n  license_file: LICENSE.txt\n\nextra:\n  recipe-maintainers:\n    - marcianito\n  feedstock-name: gravitools\n",

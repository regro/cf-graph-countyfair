 "raw_meta_yaml": "context:\n  name: docling-core\n  version: 2.4.0\n  python_min: \"3.9\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/docling_core-${{ version }}.tar.gz\n  sha256: 93f817b0105d564bbd334f8314b359b8a3fb234ec47b5013a020c9cb6ebd2e87\n\nbuild:\n  number: 1\n  noarch: python\n  script: python -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - validate = docling_core.utils.validate:main\n      - generate_jsonschema = docling_core.utils.generate_jsonschema:main\n      - generate_docs = docling_core.utils.generate_docs:main\n\nrequirements:\n  host:\n    - python ${{ python_min }}\n    - poetry-core >=1.0.0\n    - pip\n  run:\n    - python >=${{ python_min }}\n    - jsonschema >=4.16.0,<5.0.0\n    - pydantic >=2.6.0,<3.0.0\n    - jsonref >=1.1.0,<2.0.0\n    - tabulate >=0.8.0,<0.10.0\n    - pandas >=2.1.4,<3.0.0\n    - pillow >=10.3.0,<11.0.0\n\ntests:\n  - python:\n      imports:\n        - docling_core\n      pip_check: true\n      python_version: ${{ python_min }}\n  - script:\n      - validate --help\n      - generate_jsonschema --help\n      - generate_docs --help\n    requirements:\n      run:\n        - python ${{ python_min }}\n\nabout:\n  summary: A python library to define and validate data types in Docling.\n  license: MIT\n  license_file: LICENSE\n  homepage: https://ds4sd.github.io/\n\nextra:\n  recipe-maintainers:\n    - hadim\n",

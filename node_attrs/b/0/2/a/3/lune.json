    "about": {
      "description": "Lune is a standalone Luau runtime. Write and run programs, similar to\nruntimes for other languages such as Node, Deno, Bun, or Luvit for\nvanilla Lua. Lune provides fully asynchronous APIs wherever possible,\nand is built in Rust for speed, safety and correctness.",
      "dev_url": "https://github.com/lune-org/lune",
      "doc_url": "https://lune-org.github.io/docs",
      "home": "https://github.com/lune-org/lune",
      "license": "MPL-2.0",
      "license_family": "MPL-2.0",
      "license_file": "LICENSE.txt",
      "summary": "A standalone Luau runtime"
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "cargo auditable install --no-track --bins --root ${{ PREFIX }} --path crates/lune",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [

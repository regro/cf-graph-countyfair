  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  version: \"0.3.5\"\n  maturin_min: \"1.0\"\n  maturin_max: \"2.0\"\n  python_check_max: \"3.14\"\n  abi3_ext: ${{ \"pyd\" if win else \"abi3.so\" }}\n  unix_sp_dir: |-\n    $(python -c \"print(__import__('site').getsitepackages()[-1])\")/nh3\n  win_sp_dir: |-\n    Lib\\site-packages\\nh3\n  sp_dir: |-\n    ${{ \"%PREFIX%\\\\\" ~ win_sp_dir if win else unix_sp_dir }}\n\npackage:\n  name: nh3\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/n/nh3/nh3-${{ version }}.tar.gz\n  sha256: 45855e14ff056064fec77133bfcf7cd691838168e5e17bbef075394954dc9dc8\n\nbuild:\n  number: 1\n  skip: is_abi3 and not is_python_min\n  python:\n    version_independent: ${{ is_abi3 }}\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - ${{ PYTHON }} -m pip install . --no-deps --no-build-isolation --disable-pip-version-check\n      - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ compiler(\"c\") }}\n    - ${{ compiler(\"rust\") }}\n    - ${{ stdlib(\"c\") }}\n    - cargo-bundle-licenses\n  host:\n    - maturin >=${{ maturin_min }},<${{ maturin_max }}\n    - pip\n    - python\n    - if: is_abi3\n      then:\n        - python-abi3\n  run:\n    - python\n\ntests:\n  - if: is_abi3\n    then:\n      python:\n        imports: nh3\n        pip_check: true\n        python_version:\n          - ${{ python_min }}.*\n          - ${{ python_check_max }}.*\n    else:\n      python:\n        imports: nh3\n        pip_check: true\n  - files:\n      source:\n        - tests/\n    requirements:\n      run:\n        - pytest-cov\n        - if: is_abi3\n          then:\n            - python ${{ python_min }}.*\n            - abi3audit\n    script:\n      - coverage run --source=nh3 --branch -m pytest -vv --tb=long --color=yes\n      - coverage report --show-missing --skip-covered --fail-under=83\n      - if: is_abi3\n        then:\n          - cd ${{ sp_dir }}\n          - abi3audit -s -v --assume-minimum-abi3 ${{ python_min }} nh3.${{ abi3_ext }}\n\nabout:\n  summary: Python binding to Ammonia HTML sanitizer Rust crate\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  homepage: https://pypi.org/project/nh3\n  repository: https://github.com/messense/nh3\n  documentation: https://nh3.readthedocs.io\n\nextra:\n  recipe-maintainers:\n    - bollwyvl\n",

 "linux_64_meta_yaml": {
  "about": {
   "description": "Robocop is a tool that performs static code analysis of Robot Framework code.\n\nIt uses official Robot Framework parsing API to parse files and run number of\nchecks, looking for potential errors or violations to code quality standards.\n",
   "doc_url": "https://robocop.readthedocs.io",
   "home": "https://github.com/MarketSquare/robotframework-robocop",
   "license": "Apache-2.0",
   "license_file": "src/LICENSE",
   "summary": "Static code analysis tool (linter) for Robot Framework"
  },
  "build": {
   "entry_points": [
    "robocop=robocop:run_robocop"
   ],
   "noarch": "python",
   "number": "0",
   "script": [
    "cd dist",
    "PYTHON -m pip install . -vv --no-deps --no-build-isolation --disable-pip-version-check"
   ],
   "script_env": [
    "COVERAGE_THRESHOLD=41"
   ]
  },
  "extra": {
   "recipe-maintainers": [
    "bollwyvl"
   ]
  },
  "package": {
   "name": "robotframework-robocop",
   "version": "5.7.0"
  },
  "requirements": {
   "host": [
    "pip",
    "python 3.9",
    "setuptools"
   ],
   "run": [
    "jinja2 >=3.0,<4.0",
    "pathspec >=0.9,<0.13",
    "platformdirs >=3.2.0,<4.3.0",
    "python >=3.9",
    "python-dateutil >=2.8.2",
    "pytz >=2022.7",
    "robotframework >=3.2.2,<7.2",
    "tomli >=2.0.0"
   ]
  },

  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  version: \"4.5.0\"\n  jupyterlab_min: \"4.0.6\"\n  jupyterlab_max: \"5.0.0a0\"\n  python_check_max: \"3.14\"\n\npackage:\n  name: jupyter-server-proxy\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/j/jupyter-server-proxy/jupyter_server_proxy-${{ version }}.tar.gz\n  sha256: 40835ed475fe30bea6e8f2e493fd8dfc700a7f37d86d6e97bc5298034521ac1c\n\nbuild:\n  number: 1\n  noarch: python\n  script: ${{ PYTHON }} -m pip install -vv . --no-deps --no-build-isolation --disable-pip-version-check\n  python:\n    entry_points:\n      - jupyter-standaloneproxy = jupyter_server_proxy.standalone:main\n\nrequirements:\n  host:\n    - hatch-jupyter-builder >=0.8.3\n    - hatchling >=1.18.0\n    - jupyterlab >=${{ jupyterlab_min }},<${{ jupyterlab_max }}\n    - pip\n    - python ${{ python_min }}.*\n  run:\n    - aiohttp\n    - jupyter_server >=1.24.0\n    - simpervisor >=1.0.0\n    - tornado >=6.1.0\n    - traitlets >=5.1.1\n    - python >=${{ python_min }}\n\ntests:\n  - python:\n      imports: jupyter_server_proxy\n      pip_check: true\n      python_version:\n        - ${{ python_min }}.*\n        - ${{ python_check_max }}.*\n  - requirements:\n      run:\n        - jupyterhub-base\n        - jupyterlab ${{ jupyterlab_min }}.*\n        - pip\n        - pytest\n        - python ${{ python_min }}.*\n    script:\n      file: run_test.py\n\nabout:\n  license: BSD-3-Clause\n  license_file:\n    - LICENSE\n    - jupyter_server_proxy/labextension/static/third-party-licenses.json\n  summary: Jupyter server extension to supervise and proxy web services\n  description: |\n    Jupyter Server Proxy lets you run arbitrary external processes (such as\n    RStudio, Shiny Server, syncthing, PostgreSQL, etc) alongside your notebook,\n    and provide authenticated web access to them.\n  homepage: https://pypi.org/project/jupyter-server-proxy\n  repository: https://github.com/jupyterhub/jupyter-server-proxy\n  documentation: https://jupyter-server-proxy.readthedocs.io\n\nextra:\n  recipe-maintainers:\n    - jakirkham\n    - lsetiawan\n    - minrk\n    - ocefpaf\n    - xhochy\n    - consideratio\n    - bollwyvl\n    - manics\n",

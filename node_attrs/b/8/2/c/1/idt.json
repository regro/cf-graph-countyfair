  "linux_64_meta_yaml": {
    "about": {
      "dev_url": "https://github.com/sh-cho/idt",
      "doc_url": "https://sh-cho.github.io/idt",
      "home": "https://github.com/sh-cho/idt",
      "license": "MIT OR Apache-2.0",
      "license_family": "MIT OR Apache-2.0",
      "license_file": "LICENSE-APACHE",
      "summary": "A fast, ergonomic CLI tool for working with various ID formats"
    },
    "build": {
      "number": "1",
      "script": {
        "content": [
          "cargo auditable install --no-track --locked --bins --root \"$PREFIX\" --path .",
          "mkdir -p \"$PREFIX/share/bash-completion/completions\" \"$PREFIX/share/fish/vendor_completions.d\" \"$PREFIX/share/zsh/site-functions\" \"$PREFIX/share/man/man1\"",
          "\"$PREFIX/bin/idt\" completions bash > \"$PREFIX/share/bash-completion/completions/idt\"",
          "\"$PREFIX/bin/idt\" completions fish > \"$PREFIX/share/fish/vendor_completions.d/idt.fish\"",
          "\"$PREFIX/bin/idt\" completions zsh  > \"$PREFIX/share/zsh/site-functions/_idt\"",
          "\"$PREFIX/bin/idt\" manpage            \"$PREFIX/share/man/man1\"",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "idt",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",

      "license_family": "BSD-3-Clause",
      "license_file": "LICENSE",
      "summary": "Bootstrap-based Sphinx theme from the PyData community"
    },
    "build": {
      "noarch": "python",
      "number": "0",
      "script": {
        "content": "${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation --disable-pip-version-check",
        "env": {
          "STB_RELAX_NODE_VERSION_CHECK": "1",
          "STB_USE_SYSTEM_NODE": "1"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "jorisvandenbossche",
        "bollwyvl"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "pydata-sphinx-theme",
        "requirements": {
          "build": [
            "nodejs 22.9.*"
          ],
          "host": [
            "babel",
            "pip",
            "python 3.10.*",
            "setuptools",
            "sphinx-theme-builder >=0.3.2"
          ],
          "run": [
            "accessible-pygments",
            "babel",
            "beautifulsoup4",
            "docutils !=0.17.0",
            "pygments >=2.7",
            "python >=3.10",
            "sphinx >=7.0",
            "typing_extensions"
          ]
        },
        "tests": [
          {
            "python": {
              "imports": [
                "pydata_sphinx_theme"
              ],
              "python_version": [
                "3.10.*",
                "3.14.*"
              ]
            }
          },
          {
            "files": {
              "source": [
                "pyproject.toml",
                "tests/"
              ]
            },
            "requirements": {
              "run": [
                "pytest-cov",
                "pytest-playwright",
                "pytest-regressions",
                "python 3.10.*",
                "sphinx 7.0.*"
              ]
            },
            "script": [
              "coverage run --source=pydata_sphinx_theme --branch -m pytest -vv --tb=long --color=yes -k=\"${{ pytest_k }}\"",
              "coverage report --show-missing --skip-covered --fail-under=${{ cov_fail_under }}"
            ]
          }
        ],
        "version": "0.17.1"
      }

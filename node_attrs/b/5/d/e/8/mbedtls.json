  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: mbedtls\n  version: \"4.1.0\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/Mbed-TLS/mbedtls/releases/download/mbedtls-${{ version }}/mbedtls-${{ version }}.tar.bz2\n  sha256: 377a09cf8eb81b5fb2707045e5522d5489d3309fed5006c9874e60558fc81d10\n\nbuild:\n  number: 1\n\nrequirements:\n  build:\n    - cmake\n    - if: not win\n      then: make\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n  host:\n  run_exports:\n    - ${{ pin_subpackage('mbedtls', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - if: win\n        then:\n          - if not exist %LIBRARY_BIN%\\\\libmbedcrypto.dll exit 1\n          - if not exist %LIBRARY_LIB%\\\\libmbedcrypto.lib exit 1\n          - if not exist %LIBRARY_LIB%\\\\mbedtls.lib exit 1\n          - if not exist %LIBRARY_BIN%\\\\mbedtls.dll exit 1\n      - if: linux\n        then:\n          - test -f ${PREFIX}/lib/libmbedcrypto.so\n          - test -f ${PREFIX}/lib/libmbedtls.so\n      - if: osx\n        then:\n          - test -f ${PREFIX}/lib/libmbedcrypto.dylib\n          - test -f ${PREFIX}/lib/libmbedtls.dylib\n  - package_contents:\n        include:\n          - mbedtls/private/md5.h\n\nabout:\n  license: Apache-2.0\n  license_file: LICENSE\n  summary: An open source, portable, easy to use, readable and flexible SSL library\n  homepage: https://tls.mbed.org/\n  repository: https://github.com/Mbed-TLS/mbedtls\n\nextra:\n  recipe-maintainers:\n    - izahn\n    - carlodri\n    - xhochy\n",

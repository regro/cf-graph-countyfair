 "raw_meta_yaml": "{% set name = \"wetterdienst\" %}\n{% set version = \"0.99.0\" %}\n{% set python_min = \"3.10\" %}\n\npackage:\n  name: {{ name }}-split\n  version: {{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/{{ name[0] }}/{{ name }}/wetterdienst-{{ version }}.tar.gz\n  sha256: 205ad07efa4dad7d9f90b074e29b5e52612513977a60aece99134d20a74dcbca\n\nbuild:\n  number: 0\n  noarch: python\n\nrequirements:\n  host:\n    - python {{ python_min }}\n  run:\n    - python >={{ python_min }}\n\noutputs:\n  - name: {{ name }}\n    script: install_wetterdienst.sh\n    build:\n      noarch: python\n      entry_points:\n        - wetterdienst = wetterdienst.ui.cli:cli\n        - wddump = wetterdienst.provider.dwd.radar.cli:wddump\n\n    requirements:\n      host:\n        - python {{ python_min }}\n        - hatchling\n        - pip\n      run:\n        - python >={{ python_min }},<4.0\n        - aenum >=3\n        # for python < 3.11 but we want to stay noarch\n        - backports-datetime-fromisoformat >=2\n        - cachetools >=5.2\n        - click >=8\n        - click-params >=0.4.1\n        - cloup >=3.0.1\n        - diskcache >=5.4\n        - fastexcel >=0.10.4\n        - fsspec >=2023.1\n        # fsspec[http]\n        - aiohttp !=4.0.0a0,!=4.0.0a1\n        \n        - lxml >=4.9.1\n        - measurement >=3.2\n        - numpy >=1.22\n        - pillow >=10.3\n        - pint >=0.17\n        - platformdirs\n        - polars >=1.0.0\n        - portion >=2.4.2\n        - pyarrow >=13\n        - pydantic >=2.7.3\n        - pydantic-settings >=2.7.0\n        - pypdf >=3.12.1\n        - python-dateutil\n        - rapidfuzz >=3.1\n        - scikit-learn >=1.0.2\n        - stamina >=23\n        - tabulate >=0.8\n        - tqdm >=4\n        - tzfpy >=0.15.2\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n        - wetterdienst --help\n      requires:\n        - pip\n        - python {{ python_min }}\n\n  - name: {{ name }}-with-bufr\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - pdbufr >=0.10.2\n        - pybufrkit >=0.2\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  # sqlalchemy-cratedb not on conda-forge\n  # - name: {{ name }}-with-cratedb\n  #   build:\n  #     noarch: python\n  #   requirements:\n  #     host:\n  #       - python {{ python_min }}\n  #     run:\n  #       - python >={{ python_min }}\n  #       - {{ pin_subpackage(name, exact=True) }}\n  #       - pandas >=2\n  #       - sqlalchemy-cratedb\n\n  #   test:\n  #     imports:\n  #       - wetterdienst\n  #     commands:\n  #       - pip check\n  #     requires:\n  #       - python {{ python_min }}\n  #       - pip\n\n  - name: {{ name }}-with-duckdb\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - duckdb >=0.9\n        - pandas >=2\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-eccodes\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - eccodes >=1.5.2\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-excel\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - xlsxwriter >=3.0.9\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-explorer\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - duckdb >=0.9\n        - plotly >=5.11\n        - statsmodels >=0.14.1\n        - streamlit >=1.27\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-export\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - pandas >=2\n        - sqlalchemy >=2\n        - xarray >=2023.1\n        - xlsxwriter >=3.0.9\n        - zarr >=2.13\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-export-without-zarr\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - pandas >=2\n        - sqlalchemy >=2\n        - xarray >=2023.1\n        - xlsxwriter >=3.0.9\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  # - name: {{ name }}-with-influxdb\n  #   build:\n  #     noarch: python\n  #   requirements:\n  #     host:\n  #       - python {{ python_min }}\n  #     run:\n  #       - python >={{ python_min }}\n  #       - {{ pin_subpackage(name, exact=True) }}\n  #       - influxdb >=5.3\n  #       - influxdb-client >=1.18\n  #       - influxdb3-python >=0.3\n\n  #   test:\n  #     imports:\n  #       - wetterdienst\n  #     commands:\n  #       - pip check\n  #     requires:\n  #       - python {{ python_min }}\n  #       - pip\n\n  - name: {{ name }}-with-interpolation\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - scipy >=1.14.1\n        - shapely >=2\n        - utm >=0.7\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-ipython\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - ipython >=8.5\n        - matplotlib-base >=3.3\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-mpl\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - matplotlib-base >=3.3\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-mysql\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - mysqlclient >=2\n        - pandas >=2\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-postgresql\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - psycopg2-binary >=2\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-radar\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - h5py >=3.1\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-radarplus\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - pybufrkit >=0.2\n        - wradlib >=2.0.1\n        - xradar >=0.2\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-restapi\n    build:\n      noarch: python\n    requirements:\n      host:\n        - python {{ python_min }}\n      run:\n        - python >={{ python_min }}\n        - {{ pin_subpackage(name, exact=True) }}\n        - fastapi >=0.95.1\n        - httpx >=0.24\n        - uvicorn >=0.14\n\n    test:\n      imports:\n        - wetterdienst\n      commands:\n        - pip check\n      requires:\n        - python {{ python_min }}\n        - pip\n\n  - name: {{ name }}-with-sql\n    build:\n      noarch: python\n    requirements:\n      host:\n        
  "linux_64_meta_yaml": {
    "about": {
      "description": "pysepal is a library designed to create elegant Python-based dashboards\nin the SEPAL environment. It is built on top of ipyvuetify and helps\ndevelopers easily create interfaces for their geospatial workflows.\nPreviously published as sepal-ui, the package has been renamed to pysepal.\n",
      "dev_url": "https://github.com/openforis/pysepal",
      "doc_url": "https://sepal-ui.readthedocs.io/en/latest/",
      "home": "https://github.com/openforis/pysepal",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE.txt",
      "summary": "Wrapper for ipyvuetify widgets to unify the display of voila dashboards in SEPAL platform"
    },
    "build": {
      "entry_points": [
        "module_deploy = pysepal.bin.module_deploy:main",
        "module_factory = pysepal.bin.module_factory:main",
        "module_l10n = pysepal.bin.module_l10n:main",
        "module_theme = pysepal.bin.module_theme:main",
        "module_venv = pysepal.bin.module_venv:main",
        "activate_venv = pysepal.bin.activate_venv:main",
        "sepal_ipyvuetify = pysepal.bin.sepal_ipyvuetify:main",
        "entry_point = pysepal.bin.entry_point:main"
      ],
      "noarch": "python",
      "number": "0",
      "script": "PYTHON -m pip install . -vv"
    },
    "extra": {
      "recipe-maintainers": [
        "dfguerrerom",
        "12rambau"
      ]
    },
    "package": {
      "name": "pysepal",
      "version": "3.4.1"
    },

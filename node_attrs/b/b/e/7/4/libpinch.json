  "raw_meta_yaml": "context:\n  name: libpinch\n  version: \"1.2.1\"\n  author: \"mhekkel\"\n\npackage:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/${{ author }}/${{ name }}/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: fc2515ab160be10375bd08760b3940caaa408b60c190752331780f9f36f413f4\n  patches:\n    # Refer to https://github.com/mhekkel/libpinch/pull/1\n    - fix-include-target_sources.patch\n    # Remove the header include since cryptopp/factory.h is not included in conda-forge's cryptopp\n    # Upstream code includes the header but does not use it\n    - remove-include-factory-header.patch\n\nbuild:\n  number: 0\n\nrequirements:\n  build:\n    - ${{ compiler(\"cxx\") }}\n    - ${{ stdlib(\"c\") }}\n    - cmake\n    - pkg-config\n    - if: unix\n      then:\n        - make\n    - if: win\n      then:\n        - jom\n  host:\n    - asio\n    - cryptopp\n    - zlib\n  run_exports:\n    - ${{ pin_subpackage(name, upper_bound=\"x.x.x\") }}\n\ntests:\n  - package_contents:\n      include:\n        - pinch.hpp\n      lib:\n        - pinch\n\nabout:\n  homepage: https://github.com/mhekkel/libpinch\n  repository: https://github.com/mhekkel/libpinch\n  license: BSL-1.0\n  license_file: LICENSE_1_0.txt\n  summary: \"Library for asynchronous SSH\"\n  description: |\n    This library provides asynchronous SSH for use in client applications.\n\nextra:\n  recipe-maintainers:\n    - eunos-1128\n",

  "raw_meta_yaml": "context:\n  name: mip-sdk\n  version: 4.0.0\n\npackage:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/HBK-MicroStrain/mip_sdk/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 0ed3eb4429526c901c1c852201ad6e55453a6b112d7dd71781c3a708d5e0199c\n\nbuild:\n  number: 0\n  script:\n    - if: unix\n      then:\n        - echo ${CMAKE_ARGS}\n        - cmake -S . -B build/\n          ${CMAKE_ARGS}\n          -GNinja\n          -DBUILD_SHARED_LIBS=ON\n          -DMICROSTRAIN_ENABLE_EXTRAS=ON\n          -DMICROSTRAIN_BUILD_TESTS=ON\n          -DDOCTEST_NO_INSTALL=ON\n          -DMICROSTRAIN_BUILD_PACKAGE=OFF\n          -DMICROSTRAIN_BUILD_EXAMPLES=OFF\n          -DMICROSTRAIN_BUILD_DOCUMENTATION_QUIET=OFF\n    - if: win\n      then:\n        - echo %CMAKE_ARGS%\n        - cmake -S . -B build/\n          %CMAKE_ARGS%\n          -GNinja\n          -DBUILD_SHARED_LIBS=ON\n          -DCMAKE_RUNTIME_OUTPUT_DIRECTORY=bin\n          -DCMAKE_LIBRARY_OUTPUT_DIRECTORY=lib\n          -DCMAKE_ARCHIVE_OUTPUT_DIRECTORY=lib\n          -DCMAKE_WINDOWS_EXPORT_ALL_SYMBOLS=ON\n          -DMICROSTRAIN_ENABLE_EXTRAS=ON\n          -DMICROSTRAIN_BUILD_TESTS=OFF\n          -DDOCTEST_NO_INSTALL=ON\n          -DMICROSTRAIN_BUILD_PACKAGE=OFF\n          -DMICROSTRAIN_BUILD_EXAMPLES=OFF\n          -DMICROSTRAIN_BUILD_DOCUMENTATION_QUIET=OFF\n    - cmake --build build/ --config Release\n    - cmake --install build/ --config Release\n    - ctest --test-dir build/ --build-config Release --verbose --output-on-failure\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - cmake\n    - ninja\n  run:\n  run_exports:\n    - ${{ pin_subpackage('mip-sdk', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - cmake-package-check mip --targets\n        mip_extras\n        mip_metadata\n      - cmake-package-check microstrain --targets\n        microstrain_extras\n        microstrain_recording_connection\n        microstrain_serial\n        microstrain_socket\n    requirements:\n      run:\n        - ${{ compiler('c') }}\n        - ${{ compiler('cxx') }}\n        - cmake-package-check\n\nabout:\n  homepage: https://github.com/HBK-MicroStrain/mip_sdk\n  license: MIT\n  license_file: LICENSE\n  repository: https://github.com/HBK-MicroStrain/mip_sdk\n  summary: MicroStrain Communications Library for embedded systems\n\nextra:\n  recipe-maintainers:\n    - diegoferigo\n",

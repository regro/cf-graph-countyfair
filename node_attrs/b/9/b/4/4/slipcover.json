    "about": {
      "description": "SlipCover is a fast code coverage tool. It uses runtime instrumentation\nto track executed code with near-zero overhead, making it ideal for use\nwith test suites. For Python 3.12+, it uses the sys.monitoring API;\nfor earlier versions, it uses bytecode instrumentation.\n",
      "dev_url": "https://github.com/plasma-umass/slipcover",
      "doc_url": "https://github.com/plasma-umass/slipcover#readme",
      "home": "https://github.com/plasma-umass/slipcover",
      "license": "Apache-2.0",
      "license_file": "LICENSE",
      "summary": "Near Zero-Overhead Python Code Coverage"
    },
    "build": {
      "number": "0",
      "script": "PYTHON -m pip install . -vv"
    },

 "raw_meta_yaml": "{% set version = \"2023.11.1\" %}\n{% set min_python = \"python >=3.8\" %}\n\npackage:\n  name: importnb\n  version: {{ version }}\n\nsource:\n  url: https://pypi.io/packages/source/i/importnb/importnb-{{ version }}.tar.gz\n  sha256: 95a745ac7299a81f776e8210e8ad77f05731dfce7bad79eb85e08ed37a2488c0\n\nbuild:\n  number: 0\n  noarch: python\n\nrequirements:\n  host:\n    - {{ min_python }}\n  run:\n    - {{ min_python }}\n\noutputs:\n  - name: importnb\n    build:\n      noarch: python\n      script:\n        - {{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n      entry_points:\n        - importnb = importnb.__main__:main\n    requirements:\n      host:\n        - {{ min_python }}\n        - hatch-vcs\n        - hatchling\n        - pip\n      run:\n        - {{ min_python }}\n        - importlib-metadata >=4.8.3\n    test:\n      requires:\n        - pip\n      imports:\n        - importnb\n      commands:\n        - pip check\n\n  - name: importnb-with-toml\n    build:\n      noarch: python\n    requirements:\n      host:\n        - {{ min_python }}\n      run:\n        - {{ min_python }}\n        - {{ pin_subpackage(\"importnb\", exact=True) }}\n        - tomli\n    test:\n      requires:\n        - pip\n      imports:\n        - importnb\n      commands:\n        - pip check\n\n  - name: importnb-with-yaml\n    build:\n      noarch: python\n    requirements:\n      host:\n        - {{ min_python }}\n      run:\n        - {{ min_python }}\n        - {{ pin_subpackage(\"importnb\", exact=True) }}\n        - ruamel.yaml\n    test:\n      requires:\n        - pip\n      imports:\n        - importnb\n      commands:\n        - pip check\n\n  - name: importnb-with-ipython\n    build:\n      noarch: python\n    requirements:\n      host:\n        - {{ min_python }}\n      run:\n        - {{ min_python }}\n        - {{ pin_subpackage(\"importnb\", exact=True) }}\n        - ipython\n    test:\n      requires:\n        - pip\n      imports:\n        - importnb\n      commands:\n        - pip check\n\n  - name: importnb-with-doit\n    build:\n      noarch: python\n    requirements:\n      host:\n        - {{ min_python }}\n      run:\n        - {{ min_python }}\n        - {{ pin_subpackage(\"importnb\", exact=True) }}\n        - doit\n    test:\n      requires:\n        - pip\n      imports:\n        - importnb\n      commands:\n        - pip check\n\n  - name: importnb-with-all\n    build:\n      noarch: python\n    requirements:\n      host:\n        - {{ min_python }}\n      run:\n        - {{ min_python }}\n        - {{ pin_subpackage(\"importnb-with-doit\", exact=True) }}\n        - {{ pin_subpackage(\"importnb-with-ipython\", exact=True) }}\n        - {{ pin_subpackage(\"importnb-with-toml\", exact=True) }}\n        - {{ pin_subpackage(\"importnb-with-yaml\", exact=True) }}\n        - {{ pin_subpackage(\"importnb\", exact=True) }}\n    test:\n      # files:\n      #   - test_importnb.ipynb\n      source_files:\n        - conftest.py\n        - docs\n      requires:\n        - coverage\n        - pip\n        - pytest\n        - tomli-w\n      imports:\n        - importnb\n      commands:\n        {% set cov = 'coverage run --source=importnb --omit=\"*json_parser*\" --branch --append -m' %}\n        {% set pytest = '-vv --color=yes --tb=long --doctest-modules' %}\n        - pip check\n        - {{ cov }} importnb --help\n        - {{ cov }} pytest {{ pytest }}\n        - {{ cov }} IPython -m pytest -- {{ pytest }}\n        - coverage report --show-missing --skip-covered --fail-under=75\n\nabout:\n  home: https://github.com/deathbeds/importnb\n  license: BSD-3-Clause\n  license_family: BSD\n  license_file: LICENSE\n  summary: import jupyter notebooks as python modules and scripts.\n  doc_url: https://importnb.readthedocs.io\n  doc_source_url: https://github.com/deathbeds/importnb/tree/{{ version }}/docs\n\nextra:\n  feedstock-name: importnb\n  recipe-maintainers:\n    - ocefpaf\n    - bollwyvl\n"
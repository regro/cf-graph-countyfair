  "linux_64_meta_yaml": {
    "about": {
      "description": "SPATULA (Symmetry Pattern Analysis Toolkit for Understanding Local Arrangements) is a\nPython package for computing the continuous symmetry ordering of the neighbors of a\npoint in space. In general, this is to compute the local ordering of particles (molecules)\nin simulations or experiments over time. The package serves as an extension of \n`freud <https://github.com/glotzerlab/freud>`__ with a new order parameters.",
      "dev_url": "https://github.com/glotzerlab/spatula",
      "doc_url": "https://spatula.readthedocs.io/",
      "home": "https://glotzerlab.engin.umich.edu/",
      "license": "BSD-3-Clause AND MIT",
      "license_family": "BSD-3-Clause AND MIT",
      "license_file": "LICENSE",
      "summary": "Python package for calculation of symmetry based order parameters in molecular simulation systems."
    },
    "build": {
      "number": "1",
      "script": "${{ PYTHON }} -m pip install . --ignore-installed --no-cache-dir --no-deps -vv"
    },
    "extra": {
      "recipe-maintainers": [
        "DomFijan",
        "joaander",
        "janbridley"
      ]
    },
    "outputs": [

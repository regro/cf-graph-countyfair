  "hash_type": "sha256",
  "linux_64_meta_yaml": {
    "about": {
      "description": "Select, put and delete data from JSON, TOML, YAML, XML and CSV files with a single\ntool. Supports conversion between formats and can be used as a Go package.",
      "dev_url": "https://github.com/TomWright/dasel",
      "home": "https://daseldocs.tomwright.me/",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "src/dasel/LICENSE",
      "summary": "Dasel (short for data-selector) allows you to query and modify data structures\nusing selector strings."
    },
    "build": {
      "number": "1",
      "script": [
        "cd src/dasel",
        "go build -o \"$PREFIX/bin/dasel\"     -v -trimpath -ldflags \"-s -w -X github.com/tomwright/dasel/v3/internal.Version=v${{ version }}\" ./cmd/dasel",
        "mkdir -p \"$PREFIX/share/man/man1\" \"$PREFIX/share/bash-completion/completions\" \"$PREFIX/share/fish/vendor_completions.d\" \"$PREFIX/share/zsh/site-functions\"",
        "\"$PREFIX/bin/dasel\" man             > \"$PREFIX/share/man/man1/dasel.1\"",
        "\"$PREFIX/bin/dasel\" completion bash > \"$PREFIX/share/bash-completion/completions/dasel\"",
        "\"$PREFIX/bin/dasel\" completion fish > \"$PREFIX/share/fish/vendor_completions.d/dasel.fish\"",
        "\"$PREFIX/bin/dasel\" completion zsh  > \"$PREFIX/share/zsh/site-functions/_dasel\"",
        "go-licenses save ./cmd/dasel --save_path=library_licenses --ignore github.com/mattn/go-localereader"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "tomwright",
        "maresb"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "dasel",
        "requirements": {
          "build": [
            "go-nocgo_compiler_stub",
            "go-licenses"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "dasel --help",
              "dasel version",
              "dasel version | grep v${{ version }}"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "dasel"
              ],
              "files": [
                "share/man/man1/dasel.1",
                "share/bash-completion/completions/dasel",
                "share/fish/vendor_completions.d/dasel.fish",
                "share/zsh/site-functions/_dasel"
              ],
              "strict": true
            }
          }
        ],
        "version": "3.8.0"
      }
    ],
    "package": {
      "name": "dasel",
      "version": "3.8.0"
    },
    "requirements": {
      "build": [
        "go-nocgo_compiler_stub",
        "go-licenses"
      ]
    },
    "schema_version": 1,

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"3.8.0\"\n\npackage:\n  name: dasel\n  version: ${{ version }}\n\nsource:\n  - url: https://github.com/TomWright/dasel/archive/refs/tags/v${{ version }}.tar.gz\n    sha256: 4d09e057c379d9d629e076752bf9ab9f7fab7a48712da4b73a655ea5157246b2\n    target_directory: src/dasel\n  # Windows-only dep `go-localereader` (MIT-licensed) misses standard license file layout,\n  # so we have to manually add the license file\n  - url: https://raw.githubusercontent.com/mattn/go-localereader/master/LICENSE\n    sha256: dceede03550621e65ec7b79fcba87cf6dbb9d31132a8ae71a8fe8ceec0af7da3\n    target_directory: library_licenses_2/github.com/go-localereader\n\nbuild:\n  number: 1\n  script:\n    - cd src/dasel\n    - if: unix\n      then:\n        - go build -o \"$PREFIX/bin/dasel\"     -v -trimpath -ldflags \"-s -w -X github.com/tomwright/dasel/v3/internal.Version=v${{ version }}\" ./cmd/dasel\n        # generate manpage and shell completions\n        - mkdir -p \"$PREFIX/share/man/man1\" \"$PREFIX/share/bash-completion/completions\" \"$PREFIX/share/fish/vendor_completions.d\" \"$PREFIX/share/zsh/site-functions\"\n        - '\"$PREFIX/bin/dasel\" man             > \"$PREFIX/share/man/man1/dasel.1\"'\n        - '\"$PREFIX/bin/dasel\" completion bash > \"$PREFIX/share/bash-completion/completions/dasel\"'\n        - '\"$PREFIX/bin/dasel\" completion fish > \"$PREFIX/share/fish/vendor_completions.d/dasel.fish\"'\n        - '\"$PREFIX/bin/dasel\" completion zsh  > \"$PREFIX/share/zsh/site-functions/_dasel\"'\n    - if: win\n      then:\n        - go build -o \"%LIBRARY_BIN%\\dasel.exe\" -v -trimpath -ldflags \"-s -w -X github.com/tomwright/dasel/v3/internal.Version=v${{ version }}\" ./cmd/dasel\n        # generate manpage and shell completions\n        - mkdir \"%LIBRARY_PREFIX%\\share\\man\\man1\"\n        - mkdir \"%LIBRARY_PREFIX%\\share\\bash-completion\\completions\"\n        - mkdir \"%LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\"\n        - mkdir \"%LIBRARY_PREFIX%\\share\\zsh\\site-functions\"\n        - '\"%LIBRARY_BIN%\\dasel.exe\" man             > \"%LIBRARY_PREFIX%\\share\\man\\man1\\dasel.1\"'\n        - '\"%LIBRARY_BIN%\\dasel.exe\" completion bash > \"%LIBRARY_PREFIX%\\share\\bash-completion\\completions\\dasel\"'\n        - '\"%LIBRARY_BIN%\\dasel.exe\" completion fish > \"%LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\dasel.fish\"'\n        - '\"%LIBRARY_BIN%\\dasel.exe\" completion zsh  > \"%LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_dasel\"'\n    - go-licenses save ./cmd/dasel --save_path=library_licenses --ignore github.com/mattn/go-localereader\n\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntests:\n  - script:\n      - dasel --help\n      - dasel version\n      - if: not win\n        then: dasel version | grep v${{ version }}\n  - package_contents:\n      bin:\n        - dasel\n      files:\n        - if: unix\n          then:\n            - share/man/man1/dasel.1\n            - share/bash-completion/completions/dasel\n            - share/fish/vendor_completions.d/dasel.fish\n            - share/zsh/site-functions/_dasel\n        - if: win\n          then:\n            - Library/share/man/man1/dasel.1\n            - Library/share/bash-completion/completions/dasel\n            - Library/share/fish/vendor_completions.d/dasel.fish\n            - Library/share/zsh/site-functions/_dasel\n      strict: true\n\nabout:\n  license: MIT\n  license_file:\n    - src/dasel/LICENSE\n    - src/dasel/library_licenses/\n  summary: |\n    Dasel (short for data-selector) allows you to query and modify data structures\n    using selector strings.\n  description: |\n    Select, put and delete data from JSON, TOML, YAML, XML and CSV files with a single\n    tool. Supports conversion between formats and can be used as a Go package.\n  homepage: https://daseldocs.tomwright.me\n  repository: https://github.com/TomWright/dasel\n\nextra:\n  recipe-maintainers:\n    - tomwright\n    - maresb\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"2.1.11\"\n\npackage:\n  name: ncview\n  version: ${{ version }}\n\nsource:\n  # url: ftp://cirrus.ucsd.edu/pub/ncview/ncview-${{ version }}.tar.gz\n  # UCSD ftp server is down, so we use MIT mirror instead\n  url: https://mirrors.mit.edu/macports/distfiles/ncview/ncview-${{ version }}.tar.gz\n  sha256: 597cfddf9c2d7993e9b0b86bca1b73839567ee9116ee33f6d750a449b5033d91\n  patches:\n    - 0001-remove-same-compiler-test.patch\n    - 0002-remove-explicit-expat-linking.patch\n    - 0003-fix-xaw-list-pointer-types.patch\n\nbuild:\n  number: 14\n  skip: win\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - make\n    - pkg-config\n  host:\n    - libnetcdf\n    - libpng\n    - udunits2\n    - if: not osx\n      then: xorg-libsm\n    - if: not osx\n      then: xorg-libice\n    - xorg-libxaw\n    - xorg-libxt\n    - xorg-libxmu\n    - xorg-xorgproto\n    - xorg-libx11\n  run:\n    - xorg-libxaw\n\ntests:\n  - script:\n      - test -f $PREFIX/bin/ncview\n      - test -x $PREFIX/bin/ncview\n      - \"ncview -h > ncview.log 2>&1 || test $? -eq 1\"\n      - \"grep -F \\\"Ncview \\\" ncview.log\"\n\nabout:\n  license: GPL-3.0-only\n  license_file: COPYING\n  summary: Visual browser for netCDF format files\n  description: |\n    Ncview is a visual browser for netCDF format files. Typically you\n    would use ncview to get a quick and easy, push-button look at your\n    netCDF files. You can view simple movies of the data, view along\n    various dimensions, take a look at the actual data values, change\n    color maps, invert the data, etc.\n\n\n  homepage: http://meteora.ucsd.edu/~pierce/ncview_home_page.html\n\nextra:\n  recipe-maintainers:\n    - zklaus\n    - ocefpaf\n    - xylar\n",

  "linux_64_meta_yaml": {
    "about": {
      "description": "Beads (bd) is a fast, local-first CLI issue tracker designed for software\nteams and AI agents. It stores issues alongside your code in a Dolt\n(MySQL-compatible) database, supports hierarchical issues, dependencies,\nmolecules (multi-step workflows), integrations with GitHub/GitLab/Jira/Linear,\nand MCP server support for AI agents.",
      "dev_url": "https://github.com/steveyegge/beads",
      "doc_url": "https://github.com/steveyegge/beads/tree/main/docs",
      "home": "https://github.com/steveyegge/beads",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "src/LICENSE",
      "summary": "A developer-centric issue tracker that lives in your Git repo"
    },
    "build": {
      "number": "0",
      "script": [
        "cd src",
        "go build -v -o $PREFIX/bin/bd -ldflags=\"-s -w -X main.version=${{ version }}\" -trimpath ./cmd/bd",
        "mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions",
        "$PREFIX/bin/bd completion bash > $PREFIX/share/bash-completion/completions/bd",
        "$PREFIX/bin/bd completion fish > $PREFIX/share/fish/vendor_completions.d/bd.fish",
        "$PREFIX/bin/bd completion zsh > $PREFIX/share/zsh/site-functions/_bd",
        "go-licenses save ./cmd/bd --save_path ../library_licenses --ignore github.com/mattn/go-localereader"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "maphew",
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "beads",
        "requirements": {
          "build": [
            "go-nocgo_compiler_stub",
            "go-licenses"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "bd --version",
              "bd --help"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "bd"
              ],
              "files": [
                "share/bash-completion/completions/bd",
                "share/fish/vendor_completions.d/bd.fish",
                "share/zsh/site-functions/_bd"
              ],
              "strict": true
            }
          }
        ],
        "version": "1.0.2"
      }
    ],
    "package": {
      "name": "beads",
      "version": "1.0.2"
    },

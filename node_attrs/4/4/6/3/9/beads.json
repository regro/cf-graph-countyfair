  "raw_meta_yaml": "context:\n  version: \"0.63.2\"\n\npackage:\n  name: beads\n  version: ${{ version }}\n\nsource:\n  - url: https://github.com/steveyegge/beads/archive/refs/tags/v${{ version }}.tar.gz\n    sha256: 012e2621f26ab6428a23aa0997b2e8d2ad6b7c32bc7f7e695403445a808d4d66\n    target_directory: src\n   # Windows-only dep `go-localereader` (MIT-licensed) misses standard license file layout,\n   # so we have to manually add it\n  - url: https://raw.githubusercontent.com/mattn/go-localereader/master/LICENSE\n    sha256: dceede03550621e65ec7b79fcba87cf6dbb9d31132a8ae71a8fe8ceec0af7da3\n    target_directory: library_licenses_2/github.com/go-localereader\n\nbuild:\n  number: 0\n  script:\n    - cd src\n    - go-licenses save ./cmd/bd --save_path ../library_licenses --ignore github.com/mattn/go-localereader\n    - if: unix\n      then:\n        - go build -v -o $PREFIX/bin/bd -ldflags=\"-s -w -X main.version=${{ version }}\" ./cmd/bd\n        - mkdir -p $PREFIX/share/zsh/site-functions $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d\n        - $PREFIX/bin/bd completion zsh > $PREFIX/share/zsh/site-functions/_bd\n        - $PREFIX/bin/bd completion bash > $PREFIX/share/bash-completion/completions/bd\n        - $PREFIX/bin/bd completion fish > $PREFIX/share/fish/vendor_completions.d/bd.fish\n      else: go build -v -o %LIBRARY_BIN%\\bd.exe -ldflags=\"-s -X main.version=${{ version }}\" ./cmd/bd\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntests:\n  - script:\n      - bd --version\n      - bd --help\n  - package_contents:\n      bin:\n        - bd\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/bd\n            - share/fish/vendor_completions.d/bd.fish\n            - share/zsh/site-functions/_bd\n      strict: true\n\nabout:\n  homepage: https://github.com/steveyegge/beads\n  summary: A developer-centric issue tracker that lives in your Git repo\n  description: |\n    Beads (bd) is a fast, local-first CLI issue tracker designed for software\n    teams and AI agents. It stores issues alongside your code in a Dolt\n    (MySQL-compatible) database, supports hierarchical issues, dependencies,\n    molecules (multi-step workflows), integrations with GitHub/GitLab/Jira/Linear,\n    and MCP server support for AI agents.\n  license: MIT\n  license_file:\n    - src/LICENSE\n    - library_licenses/\n    - library_licenses_2/\n  documentation: https://github.com/steveyegge/beads/tree/main/docs\n  repository: https://github.com/steveyegge/beads\n\nextra:\n  recipe-maintainers:\n    - maphew\n    - salim-b\n",

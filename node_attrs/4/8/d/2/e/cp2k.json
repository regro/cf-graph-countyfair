  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: cp2k\n  version: \"2026.1\"\n  mpi: openmpi\n  mpi_prefix: \"mpi_${{ mpi }}\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  - url: https://github.com/${{ name }}/${{ name }}/releases/download/v${{ version }}/${{ name }}-${{ version }}.tar.bz2\n    sha256: 4364c74bcffaa474bc234e11686b09550e4d06932acf2147a341e4f7679dd88e\n\nbuild:\n  number: 4\n  script: build.sh\n  skip:\n    - aarch64\n    - osx\n    - win\n\nrequirements:\n  build:\n    - ${{ compiler(\"c\") }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler(\"cxx\") }}\n    - ${{ compiler(\"fortran\") }}\n    - cmake >=3.27\n    - if: linux\n      then: libgomp\n    - if: osx\n      then: llvm-openmp\n    - ninja >=1.13\n    - openmpi-mpifort >=5.0.8\n    - pkgconfig >=1.6\n    - python >=3.11\n  host:\n    - dbcsr >=2.9.0\n    - \"elpa >=2024.05.001 *${{ mpi_prefix }}_*\"\n    - \"fftw >=3.3.10 *${{ mpi_prefix }}_*\"\n    - hdf5 ~=1.14\n    - libint >=2.6.0\n    - libint-fortran-devel >=2.6.0\n    - \"libxc >=7.0.0 *cpu_*\"\n    - \"openblas >=0.3.30 *openmp_*\"\n    - openmpi ~=5.0\n    - \"plumed >=2.9.2 *${{ mpi_prefix }}_*\"\n    - scalapack >=2.2.0\n    - spglib >=2.5\n    - trexio >2.6\n  run:\n    - \"openblas >=0.3.30 *openmp_*\"\n\ntests:\n  - package_contents:\n      bin:\n        - cp2k.psmp\n\nabout:\n  homepage: https://www.cp2k.org\n  license: GPL-2.0-only\n  license_family: GPL\n  license_file: LICENSE\n  summary: Quantum chemistry and solid state physics software package\n  description: |\n    CP2K is a quantum chemistry and solid state physics software package \n    that can perform atomistic simulations of solid state, liquid, \n    molecular, periodic, material, crystal, and biological systems. \n  documentation: https://manual.cp2k.org\n  repository: https://github.com/cp2k/cp2k\n\nextra:\n  recipe-maintainers:\n    - jan-janssen\n    - oschuett\n    - ltalirz\n    - mkrack\n",

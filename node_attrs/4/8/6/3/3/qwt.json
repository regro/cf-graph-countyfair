  "raw_meta_yaml": "context:\n  version: \"6.3.0\"\n\npackage:\n  name: qwt\n  version: ${{ version }}\n\nsource:\n  url: https://sourceforge.net/projects/qwt/files/qwt/${{ version }}/qwt-${{ version }}.tar.bz2\n  sha256: dcb085896c28aaec5518cbc08c0ee2b4e60ada7ac929d82639f6189851a6129a\n  patches:\n    # Can't seem to avoid /usr/local/ install without patch\n    - qwtconfig.pri.patch\n    # build in release mode\n    - windows.patch\n    # for osx/arm64\n    - cmake.patch\n\nbuild:\n  number: 6\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('cxx') }}\n    - if: unix\n      then: make\n    - if: linux\n      then:\n        - libgl-devel\n        - libglx-devel\n        - libegl-devel\n    - if: osx and build_platform != target_platform\n      then:\n        - qt6-main\n        - cmake\n  host:\n    - qt6-main\n    - if: linux\n      then:\n        - libgl-devel\n        - libglx-devel\n        - libegl-devel\n  run:\n    - qt6-main\n  run_exports:\n    - ${{ pin_subpackage('qwt', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - if: unix\n        then:\n          - test -f ${PREFIX}/lib/libqwt${SHLIB_EXT}\n          - test -f ${PREFIX}/include/qwt.h\n        else:\n          - if not exist %PREFIX%\\\\Library\\\\include\\\\qwt.h exit 1\n          - if not exist %PREFIX%\\\\Library\\\\bin\\\\qwt.dll exit 1\n          - if not exist %PREFIX%\\\\Library\\\\lib\\\\qwt.lib exit 1\n\nabout:\n  homepage: http://qwt.sourceforge.net/\n  license: LicenseRef-Qwt\n  license_file: COPYING\n  summary: Qt widgets for technical applications\n  documentation: http://qwt.sourceforge.net/\n  repository: https://sourceforge.net/projects/qwt/\n\nextra:\n  recipe-maintainers:\n    - traversaro\n    - ceholden\n    - jschueller\n    - marcelotrevisani\n",
  "req": {
    "__set__": true,
    "elements": [
      "c_compiler_stub",
      "c_stdlib_stub",
      "cxx_compiler_stub",
      "libegl-devel",

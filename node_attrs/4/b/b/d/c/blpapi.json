  "raw_meta_yaml": "context:\n  name: blpapi\n  version: \"3.26.3.1\"\n  blpapicpp_linux_version: ${{ version }}\n  blpapicpp_win_version: ${{ version }}\n  blpapicpp_osx_version: ${{ version }}\n\nrecipe:\n  name: blpapi-split\n  version: ${{ version }}\n\nsource:\n  - url: https://blpapi.bloomberg.com/repository/releases/python/${{ name }}-${{ version }}.tar.gz\n    sha256: 984cc5986d11d106400280dd42f47c18a0ab34693961f2cc9710542db0fbe58c\n  - if: linux\n    then:\n      url: https://blpapi.bloomberg.com/download/releases/raw/files/blpapi_cpp_${{ blpapicpp_linux_version }}-linux.tar.gz\n      sha256: af0d9f0cadf1f90b1f1a633baf9e33507f28ccc7916f60b2e8f42e5cc2133cf2\n      target_directory: blpapi\n  - if: win\n    then:\n      url: https://blpapi.bloomberg.com/download/releases/raw/files/blpapi_cpp_${{ blpapicpp_win_version }}-windows.zip\n      sha256: 73bbe9a1cefe2b6dd5f54cc8300603537208d54ab7c4414ca8b24edef2ff195b\n      target_directory: blpapi\n  - if: osx and arm64\n    then:\n      url: https://blpapi.bloomberg.com/download/releases/raw/files/blpapi_cpp_${{ blpapicpp_osx_version }}-macos-arm64.tar.gz\n      sha256: 321b9883d57bd185a775aec5281d686c672b6d6fa65d4ecf748a82ce6d4a42b8\n      target_directory: blpapi\n\nbuild:\n  number: 0\n  skip: osx and x86_64\n\noutputs:\n  - package:\n      name: libblpapi\n      version: ${{ version }}\n    build:\n      script:\n        - if: unix\n          then: build-lib.sh\n          else: build-lib.bat\n    requirements:\n      build:\n        - ${{ compiler('cxx') }}\n        - ${{ stdlib(\"c\") }}\n      run_exports:\n        - ${{ pin_subpackage('libblpapi', upper_bound='x.x.x.x') }}\n    tests:\n      - script:\n          - if: unix\n            then:\n              - test -f $PREFIX/lib/libblpapi3_64.so || test -f $PREFIX/lib/libblpapi3_64.dylib\n            else:\n              - if exist %LIBRARY_PREFIX%\\bin\\blpapi3_64.dll (exit 0) else (exit 1)\n\n  - package:\n      name: libblpapi-devel\n      version: ${{ version }}\n    build:\n      script:\n        - if: unix\n          then: build-devel.sh\n          else: build-devel.bat\n    requirements:\n      build:\n        - ${{ compiler('cxx') }}\n        - ${{ stdlib(\"c\") }}\n      host:\n        - ${{ pin_subpackage('libblpapi', exact=True) }}\n      run:\n        - ${{ pin_subpackage('libblpapi', exact=True) }}\n    tests:\n      - script:\n          - if: unix\n            then:\n              - test -f $PREFIX/include/blpapi_session.h\n              - test -d $PREFIX/lib/cmake/blpapi || true\n            else:\n              - if exist %LIBRARY_PREFIX%\\include\\blpapi_session.h (exit 0) else (exit 1)\n              - if exist %LIBRARY_PREFIX%\\lib\\blpapi3_64.lib (exit 0) else (exit 1)\n\n  - package:\n      name: blpapi\n      version: ${{ version }}\n    build:\n      script:\n        - if: unix\n          then: build-py.sh\n          else: build-py.bat\n    requirements:\n      build:\n        - ${{ compiler('cxx') }}\n        - ${{ stdlib(\"c\") }}\n        - if: build_platform != target_platform\n          then:\n            - python\n            - cross-python_${{ target_platform }}\n      host:\n        - python\n        - setuptools\n        - pip\n        - ${{ pin_subpackage('libblpapi-devel', exact=True) }}\n      run:\n        - python\n        - ${{ pin_subpackage('libblpapi', exact=True) }}\n    tests:\n      - python:\n          imports:\n            - blpapi\n          pip_check: false\n\nabout:\n  license: LicenseRef-Bloomberg-BLPAPI\n  license_file: License.txt\n  summary: Python SDK for Bloomberg BLPAPI\n  homepage: https://www.bloomberg.com/professional/support/api-library/\n\nextra:\n  recipe-maintainers:\n    - reggied\n    - matthewgilbert\n    - adament\n    - benmoss\n",

 "raw_meta_yaml": "{% set version = \"0.115.5\" %}\n\n# handle undefined magic python variable\n{% set python_min = python_min | default(\"3.9\") %}\n\npackage:\n  name: fastapi\n  version: {{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/f/fastapi/fastapi-{{ version }}.tar.gz\n  sha256: 0e7a4d0dc0d01c68df21887cce0945e72d3c48b9f4f79dfe7a7d53aa08fbb289\n  patches:\n    # this ships a `bin/fastapi` which says to install `fastapi-cli`\n    # but as this recipe already depends on `fastapi-cli`, it clobbers the working one\n    - 0000-no-broken-cli.patch\n\nbuild:\n  noarch: python\n  number: 0\n  script:\n    - {{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation --disable-pip-version-check\n\nrequirements:\n  host:\n    - pdm-backend\n    - pip\n    - python {{ python_min }}\n  run:\n    - python >={{ python_min }}\n    # [project.dependencies]\n    - starlette >=0.40.0,<0.42.0\n    - typing_extensions >=4.8.0\n    - pydantic >=1.7.4,!=1.8,!=1.8.1,!=2.0.0,!=2.0.1,!=2.1.0,<3.0.0\n    # [project.optional-dependencies.standard]\n    - email_validator >=2.0.0\n    - fastapi-cli >=0.0.5\n    - httpx >=0.23.0\n    - jinja2 >=2.11.2\n    - python-multipart >=0.0.7\n    - uvicorn-standard >=0.12.0\n\ntest:\n  requires:\n    - pip\n    - python {{ python_min }}\n  imports:\n    - fastapi\n    - fastapi.dependencies\n    - fastapi.middleware\n    - fastapi.openapi\n    - fastapi.security\n  commands:\n    - pip check\n    - fastapi --version\n    - fastapi --help\n\nabout:\n  home: https://github.com/fastapi/fastapi\n  license: MIT\n  license_file: LICENSE\n  summary: FastAPI framework, high performance, easy to learn, fast to code, ready for production\n  doc_url: https://fastapi.tiangolo.com\n  dev_url: https://github.com/fastapi/fastapi\n\nextra:\n  recipe-maintainers:\n    - dhirschfeld\n    - tiangolo\n    - synapticarbors\n    - bollwyvl\n",

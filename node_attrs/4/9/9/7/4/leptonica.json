  "raw_meta_yaml": "# TODO: conda-forge giflib missing headers on windows?\nschema_version: 1\n\ncontext:\n  version: \"1.87.0\"\n\npackage:\n  name: leptonica\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/DanBloomberg/leptonica/releases/download/${{ version }}/leptonica-${{ version }}.tar.gz\n  sha256: c73363397f96eb1295602bf44d708a994ad42046c791bf03ea0505d829bdb6a7\n  patches:\n    - if: win\n      then: patches/0001-point-to-our-own-prefix-in-CMake-metadata-on-windows.patch\n\nbuild:\n  number: 1\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - if: not win\n      then: autoconf\n    - if: not win\n      then: automake\n    - if: not win\n      then: make\n    - if: not win\n      then: libtool\n    - if: not win\n      then: m4\n    - if: not win\n      then: pkg-config\n    - if: win\n      then: cmake\n  host:\n    - giflib\n    - libjpeg-turbo\n    - libpng\n    - libtiff\n    - libwebp\n    - openjpeg\n    - liblzma-devel\n    - zlib\n  run_exports:\n    - ${{ pin_subpackage(\"leptonica\", upper_bound='x.x') }}\n\ntests:\n  - package_contents:\n      bin:\n        - convertfilestopdf\n        - convertfilestops\n        - convertformat\n        - convertsegfilestopdf\n        - convertsegfilestops\n        - converttopdf\n        - converttops\n        - fileinfo\n        - xtractprotos\n  - files:\n      recipe:\n        - cmake_test/\n    requirements:\n      run:\n        - ${{ compiler('c') }}\n        - ${{ compiler('cxx') }}\n        - cmake\n        - ninja\n        - pkg-config\n    script:\n      - cd cmake_test\n      - if: unix\n        then: cmake -GNinja -DCMAKE_CXX_STANDARD=17 $CMAKE_ARGS .\n      - if: win\n        then: cmake -GNinja -DCMAKE_CXX_STANDARD=17 %CMAKE_ARGS% .\n\nabout:\n  license: BSD-2-Clause\n  license_file: leptonica-license.txt\n  summary: Useful for image processing and image analysis applications\n  description: |\n    Leptonica is a pedagogically-oriented open source site containing\n    software that is broadly useful for image processing and image\n    analysis applications.\n  homepage: https://github.com/DanBloomberg/leptonica\n  repository: https://github.com/DanBloomberg/leptonica\n  documentation: http://www.leptonica.org/\n\nextra:\n  recipe-maintainers:\n    - CurtLH\n    - izahn\n    - chrisdeutsch\n",

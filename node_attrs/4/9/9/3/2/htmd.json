    "about": {
      "description": "htmd is a command-line tool for converting HTML to Markdown.\nIt supports batch processing of files, directories, and glob patterns,\nwith configurable conversion options.",
      "dev_url": "https://github.com/letmutex/htmd-cli",
      "home": "https://github.com/letmutex/htmd-cli",
      "license": "Apache-2.0",
      "license_family": "Apache-2.0",
      "license_file": "LICENSE",
      "summary": "Command line tool for converting HTML to Markdown"
    },
    "build": {
      "number": "2",
      "script": {
        "content": [
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {

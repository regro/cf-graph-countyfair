  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: GB-code\n  version: \"1.0.0\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/GB_code-${{ version }}.tar.gz\n  sha256: 9e94a011a59700f25144e93149ab38b2493f51ff9910d9ef37d01e4517112011\n  patches:\n    - import.patch\n\nbuild:\n  number: 2\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv\n  python:\n    entry_points:\n      - csl_generator = gb_code.csl_generator:main\n      - gb_generator = gb_code.gb_generator:main\n\nrequirements:\n  host:\n    - pip\n    - python ${{ python_min }}.*\n    - setuptools\n  run:\n    - numpy >=1.14.0\n    - python >=${{ python_min }}\n    - pyyaml\n\ntests:\n  - python:\n      imports:\n        - gb_code\n      pip_check: true\n      python_version: ${{ python_min }}\n  - requirements:\n      run:\n        - pip\n        - python ${{ python_min }}.*\n    script:\n      - csl_generator --help\n      - gb_generator\n\nabout:\n  license: MIT\n  license_file: LICENSE\n  summary: A Grainboundary generation code\n  description: |\n    This python package helps you create orthogonal grain boundary\n    supercells for atomistic calculations. The code is based on the\n    coincident site lattice (CSL) formulations for cubic materials\n    (sc, bcc, fcc, diamond).\n  homepage: https://github.com/oekosheri/GB_code\n  repository: https://github.com/oekosheri/GB_code\n  documentation: https://github.com/oekosheri/GB_code\n\nextra:\n  recipe-maintainers:\n    - jan-janssen\n",

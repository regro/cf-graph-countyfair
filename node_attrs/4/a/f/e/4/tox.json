 "linux_64_meta_yaml": {
  "about": {
   "description": "Tox is a generic virtualenv management and test command line tool you can use for\n- checking your package installs correctly with different Python versions and interpreters\n- running your tests in each of the environments, configuring your test tool of choice\n- acting as a frontend to Continuous Integration servers, greatly reducing boilerplate\n  and merging CI and shell-based testing.\n",
   "dev_url": "https://github.com/tox-dev/tox",
   "doc_source_url": "https://github.com/tox-dev/tox/tree/4.23.2/docs",
   "doc_url": "https://tox.readthedocs.org",
   "home": "https://tox.wiki",
   "license": "MIT",
   "license_family": "MIT",
   "license_file": "LICENSE",
   "summary": "virtualenv-based automation of test activities"
  },
  "build": {
   "entry_points": [
    "tox = tox.run:run"
   ],
   "noarch": "python",
   "number": "1",
   "script": [
    "PYTHON -m pip install . -vv --no-deps --no-build-isolation --disable-pip-version-check"
   ]
  },
  "extra": {
   "recipe-maintainers": [
    "rxm7706",
    "cshaley",
    "kalefranz",
    "sannykr",
    "bollwyvl"
   ]
  },
  "package": {
   "name": "tox",
   "version": "4.23.2"
  },
  "requirements": {
   "host": [
    "python 3.9",
    "hatch-vcs >=0.4",
    "hatchling >=1.25",
    "pip"
   ],
   "run": [
    "python >=3.9",

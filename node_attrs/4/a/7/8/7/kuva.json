    "about": {
      "description": "Command-line front-end for the kuva plotting library. It reads tabular data from a TSV or CSV file (or stdin) and writes an SVG, PNG, PDF, to-a-file, or stdout",
      "home": "https://psy-fer.github.io/kuva/",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Command-line front-end for the kuva plotting library"
    },
    "build": {
      "number": "0",
      "script": {
        "content": "cargo-bundle-licenses --format yaml --output ${SRC_DIR}/THIRDPARTY.yml\ncargo auditable install --path . --bin kuva --features cli,full --locked --no-track --root ${PREFIX}\n",
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "VasanthakumarV"

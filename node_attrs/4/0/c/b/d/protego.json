  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: Protego\n  version: 0.5.0\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ name | lower }}-${{ version }}.tar.gz\n  sha256: 225dee0acfcc71de8c6f7cef9c618e5a9d3e7baa7ae1470b8d076a064033c463\n\nbuild:\n  number: 1\n  noarch: python\n  script:\n    # Avoid packaging thousands of files purely for test, reduces package size from 2MB+ to ~20KB\n    # Test data is discovered dynamically so harmless to just remove\n    - rm -rf tests/top-10000-websites.txt tests/test_data/* && touch tests/test_data/.keep tests/top-10000-websites.txt\n    - ${{ PYTHON }} -m pip install . -vv\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - hatchling\n  run:\n    - python >=${{ python_min }}\n\ntests:\n  - files:\n      source:\n        - tests\n    requirements:\n      run:\n        - pytest\n        - python ${{ python_min }}.*\n    script:\n      - pytest tests\n\nabout:\n  license: BSD-3-Clause-Clear\n  license_file: LICENSE\n  summary: A pure-Python robots.txt parser with support for modern conventions\n  homepage: https://github.com/scrapy/protego\n\nextra:\n  recipe-maintainers:\n    - Gallaecio\n",

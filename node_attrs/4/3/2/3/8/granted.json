  "linux_64_meta_yaml": {
    "about": {
      "description": "Granted is a command line interface (CLI) application which simplifies\naccess to cloud roles and allows multiple cloud accounts to be opened\nin your web browser simultaneously. Granted provides a fast experience\naround finding and assuming AWS roles, leverages native browser\nfunctionality to allow multiple accounts to be accessed at once, and\nencrypts cached credentials to avoid plaintext SSO tokens being saved\non disk.",
      "dev_url": "https://github.com/fwdcloudsec/granted",
      "doc_url": "https://docs.commonfate.io/granted/getting-started",
      "home": "https://granted.dev/",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "src/LICENCE",
      "summary": "The easiest way to access your cloud."
    },
    "build": {
      "number": "0",
      "script": [
        "cd src",
        "go-licenses save ./cmd/granted --save_path ../library_licenses",
        "go build -v -o $PREFIX/bin/granted -ldflags=\"-s -w -X github.com/fwdcloudsec/granted/internal/build.Version=${{ version }}\" ./cmd/granted",
        "ln -sf granted $PREFIX/bin/assumego",
        "cp scripts/assume $PREFIX/bin/assume",
        "cp scripts/assume.fish $PREFIX/bin/assume.fish",
        "cp scripts/assume.tcsh $PREFIX/bin/assume.tcsh",
        "chmod +x $PREFIX/bin/assume $PREFIX/bin/assume.fish $PREFIX/bin/assume.tcsh"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "pavelzw"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "granted",
        "requirements": {
          "build": [
            "go-nocgo_compiler_stub",
            "go-licenses"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "granted --help",
              "granted --version",
              "granted --version | grep ${{ version }}"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "granted",
                "assumego",
                "assume",
                "assume.fish",
                "assume.tcsh"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.39.0"
      }
    ],

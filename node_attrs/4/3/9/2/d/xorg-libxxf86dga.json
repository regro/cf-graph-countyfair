 "raw_meta_yaml": "{% set xorg_name = \"libXxf86dga\" %}\n{% set xorg_category = \"lib\" %}\n{% set name = \"xorg-\" ~ xorg_name %}\n{% set version = \"1.1.6\" %}\n{% set sha256 = \"87c7482b1e29b4eeb415815641c4f69c00545a8138e1b73ff1f361f7d9c22ac4\" %}\n{% set am_version = \"1.15\" %} # keep synchronized with build.sh\n\npackage:\n  name: {{ name|lower }}\n  version: {{ version }}\n\nsource:\n  fn: {{ name }}-{{ version }}.tar.gz\n  url: https://www.x.org/releases/individual/{{ xorg_category }}/{{ xorg_name }}-{{ version }}.tar.gz\n  sha256: {{ sha256 }}\n\nbuild:\n  # libXxf86dga currently has complex POSIX-only dependencies such as fork() or waitpid(), as well as mmap()\n  skip: true  # [win]\n  number: 0\n  detect_binary_files_with_prefix: true\n  run_exports:\n    - {{ pin_subpackage(name|lower) }}\n\nrequirements:\n  build:\n    - m2-autoconf  # [win]\n    - m2-automake{{ am_version }}  # [win]\n    - m2-libtool  # [win]\n    - m2w64-pkg-config  # [win]\n    - make\n    - pkg-config  # [not win]\n    - posix  # [win]\n    - gnuconfig  # [unix]\n    - {{ stdlib('c') }}          # [unix]\n    - {{ compiler('c') }}        # [unix]\n    - {{ compiler('m2w64_c') }}  # [win]\n  host:\n    - xorg-libx11\n    - xorg-libxext\n    - xorg-xf86dgaproto\n    - xorg-xproto\n    - xorg-util-macros\n\ntest:\n  commands:\n    {% set lib_idents = [ \"Xxf86dga\" ] %}\n    {% for lib_ident in lib_idents %}\n    - test -f $PREFIX/lib/lib{{ lib_ident }}.dylib  # [osx]\n    - test -f $PREFIX/lib/lib{{ lib_ident }}.so  # [linux]\n    - if not exist %PREFIX%/Library/lib/lib{{ lib_ident }}.dll.a exit /b 1  # [win]\n    - if not exist %PREFIX%/Library/bin/msys-{{ lib_ident }}-*.dll exit /b 1  # [win]\n    {% endfor %}\n\nabout:\n  home: https://www.x.org/\n  license: MIT\n  license_family: MIT\n  license_file: COPYING\n  summary: Xlib-based library for the XFree86-DGA extension\n\nextra:\n  recipe-maintainers:\n    - ehfd\n",

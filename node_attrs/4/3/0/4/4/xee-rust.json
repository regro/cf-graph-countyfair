    "about": {
      "description": "Xee is an XML Execution Engine written in Rust. It provides\nan almost complete XPath 3.1 implementation and a command-line\ntool that can load XML documents, issue XPath expressions against\nthem (including in a REPL), pretty-print XML documents, and\ntransform XML documents using XSLT stylesheets.",
      "dev_url": "https://github.com/Paligo/xee",
      "doc_url": "https://docs.rs/xee",
      "home": "https://github.com/Paligo/xee",
      "license": "MIT AND Unicode-3.0",
      "license_family": "MIT AND Unicode-3.0",
      "license_file": "LICENSE-MIT",
      "summary": "Xee CLI. Swiss Army knife for XML. XPath and XSLT"
    },
    "build": {
      "number": "1",
      "script": {
        "content": [
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path ./xee",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [

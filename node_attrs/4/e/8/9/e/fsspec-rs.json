  "raw_meta_yaml": "context:\n  version: \"0.1.1\"\n\npackage:\n  name: fsspec-rs\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/f/fsspec_rs/fsspec_rs-${{ version }}.tar.gz\n  sha256: 99d4aafe471f346325dc4dfa6a25307e075bbda6b8d0919a3ddad0bf6926090e\n\nbuild:\n  number: 0\n  python:\n    version_independent: true\n  script:\n    - if: unix\n      then: export PYO3_PYTHON=\"$PYTHON\"\n      else: set \"PYO3_PYTHON=%PYTHON%\"\n    - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  skip: is_abi3 and not is_python_min\n\nrequirements:\n  build:\n    - if: build_platform != target_platform\n      then:\n        - python\n        - cross-python_${{ target_platform }}\n        - crossenv\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n  host:\n    - python\n    - pip\n    - hatchling\n    - hatch-rs\n    - if: is_abi3\n      then:\n      - python-abi3\n  run:\n    - python\n    - fsspec\n  ignore_run_exports:\n    from_package:\n      - cross-python_${{ target_platform }}\n\ntests:\n  - python:\n      imports:\n        - fsspec_rs\n      pip_check: true\n      python_version: ${{ python_min }}.*\n  - if: is_abi3\n    then:\n      script:\n        - if: win\n          then: abi3audit %PREFIX%/Lib/site-packages/fsspec_rs/fsspec_rs.pyd -s -v --assume-minimum-abi3 ${{ python_min }}\n          else:\n            - export SP_DIR=$(python -c \"import site; print(site.getsitepackages()[0])\")\n            - abi3audit $SP_DIR/fsspec_rs/fsspec_rs.abi3.so -s -v --assume-minimum-abi3 ${{ python_min }}\n      requirements:\n        run:\n          - abi3audit\n\nabout:\n  license: Apache-2.0\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  summary: fsspec-compatible backends with Rust accleration\n  homepage: https://github.com/1kbgz/fsspec-rs\n  repository: https://github.com/1kbgz/fsspec-rs\n\nextra:\n  recipe-maintainers:\n    - timkpaine\n",

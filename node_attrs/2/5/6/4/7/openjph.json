 "raw_meta_yaml": "context:\n  version: \"0.17.0\"\n\npackage:\n  name: openjph\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/aous72/OpenJPH/archive/${{ version }}.tar.gz\n  sha256: 9cd09a5f3a8046b10bded787212afd2410836f9c266964a36f61dc4b63f99b6c\n\nbuild:\n  number: 0\n\nrequirements:\n  build:\n    - ${{ compiler('cxx') }}\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - cmake\n    - if: win\n      then:\n        - ninja\n      else:\n        - make\n  host:\n    - libtiff\n  run_exports:\n    - ${{ pin_subpackage('openjph', upper_bound='x.x') }}\n\ntests:\n  - package_contents:\n      include:\n        - openjph/ojph_version.h\n      bin:\n        - ojph_compress\n        - ojph_expand\n      lib:\n        # It is still difficult to use these new style tests on windows\n        # https://github.com/prefix-dev/rattler-build/issues/1116\n        - ${{ \"openjph\" if unix }}\n\nabout:\n  homepage: https://github.com/aous72/OpenJPH\n  license: BSD-2-Clause\n  license_file: LICENSE\n  summary: Open source implementation of High-throughput JPEG2000 (HTJ2K).\n  repository: https://github.com/aous72/OpenJPH\n\nextra:\n  recipe-maintainers:\n    - hmaarrfk\n",

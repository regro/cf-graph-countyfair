  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: 18.1.0\n  version_xy: ${{ (version | split('.'))[:2] | join('.') }}\n  build: 1\n\npackage:\n  name: opencarp\n  version: ${{ version }}\n\nsource:\n  url: https://git.opencarp.org/openCARP/openCARP/-/archive/v${{ version_xy }}/openCARP-v${{ version_xy }}.tar.bz2\n  sha256: 41a67a2b1a45f0df3ab88427b05d53056de9ad9c6fbe837b632efbcd94348da4\n  patches:\n    - cpp-env.patch\n    - build_info.patch\n\nbuild:\n  number: ${{ build }}\n  skip: win\n\nrequirements:\n  build:\n    - git\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ stdlib('c') }}\n    - cmake\n    - make\n    - gengetopt\n    - pkg-config\n    - python ${{ python_min }}.*\n  host:\n    - fftw\n    - libblas\n    - liblapack\n    - ${{ mpi }}\n    - petsc\n    - zlib\n  run:\n    - python\n  run_exports:\n    - ${{ pin_subpackage(\"opencarp\", upper_bound=\"x.x\") }}\n\ntests:\n  - script:\n      - bench\n\nabout:\n  license: LicenseRef-AcademicPublicLicense\n  license_file: LICENSE.md\n  summary: Cardiac Electrophysiology Simulator\n  homepage: https://opencarp.org\n  repository: https://git.opencarp.org/openCARP/openCARP\n\nextra:\n  recipe-maintainers:\n    - minrk\n",

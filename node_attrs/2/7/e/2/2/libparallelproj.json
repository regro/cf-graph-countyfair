  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"2.0.3\"\n  build_number: 0\n  python_min: \"3.12\"\n  cuda_version: ${{ env.get(\"CONDA_OVERRIDE_CUDA\", default=\"None\") }}\n  cuda: ${{ \"ON\" if cuda_version != \"None\" else \"OFF\" }}\n\nrecipe:\n  name: libparallelproj-split\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/KUL-recon-lab/libparallelproj/archive/v${{ version }}.tar.gz\n  sha256: ef1b8bdc88c620df28c8f83951d7131f57d4fe24aa767e4461c90516e1fbfcdd\n\nbuild:\n  number: ${{ build_number }}\n\noutputs:\n  - package:\n      name: libparallelproj\n\n    build:\n      script:\n        - if: win\n          then: |\n            cmake -S \"%SRC_DIR%\" -B \"%SRC_DIR%/_build_lib\" -GNinja ^\n              %CMAKE_ARGS% ^\n              -DCMAKE_BUILD_TYPE=Release ^\n              -DPROJECT_VERSION_OVERRIDE=${{ version }} ^\n              -DCMAKE_INSTALL_PREFIX=\"%PREFIX%\" ^\n              -DCMAKE_INSTALL_LIBDIR=lib ^\n              -DUSE_CUDA=${{ cuda }} ^\n              -DBUILD_LIBRARY=ON ^\n              -DINSTALL_DEVEL=ON ^\n              -DBUILD_PYTHON=OFF ^\n              -DBUILD_TESTS=OFF ^\n              -DCMAKE_PREFIX_PATH=\"%PREFIX%\"\n            cmake --build \"%SRC_DIR%\\_build_lib\"\n            cmake --install \"%SRC_DIR%\\_build_lib\"\n          else: |\n            cmake -S \"$SRC_DIR\" -B \"$SRC_DIR/_build_lib\" -GNinja \\\n              ${CMAKE_ARGS} \\\n              -DCMAKE_BUILD_TYPE=Release \\\n              -DPROJECT_VERSION_OVERRIDE=${{ version }} \\\n              -DCMAKE_INSTALL_PREFIX=\"$PREFIX\" \\\n              -DCMAKE_INSTALL_LIBDIR=lib \\\n              -DUSE_CUDA=${{ cuda }} \\\n              -DBUILD_LIBRARY=ON \\\n              -DINSTALL_DEVEL=ON \\\n              -DBUILD_PYTHON=OFF \\\n              -DBUILD_TESTS=OFF \\\n              -DCMAKE_PREFIX_PATH=\"$PREFIX\" \\\n              -DCMAKE_FIND_FRAMEWORK=NEVER \\\n              -DCMAKE_FIND_APPBUNDLE=NEVER\n            cmake --build \"$SRC_DIR/_build_lib\"\n            cmake --install \"$SRC_DIR/_build_lib\"\n\n      variant:\n        use_keys:\n          - cuda_version\n        down_prioritize_variant: ${{ 0 if cuda == \"ON\" else 1 }}\n\n    requirements:\n      build:\n        - ${{ compiler('cxx') }}\n        - ${{ stdlib('c') }}\n        - cmake\n        - ninja\n        - if: cuda == \"ON\"\n          then:\n            - ${{ compiler('cuda') }}\n      host:\n        - if: osx\n          then: llvm-openmp\n        - if: cuda == \"ON\"\n          then:\n            - cuda-version ==${{ cuda_version }}\n      run:\n        - if: osx\n          then: llvm-openmp\n        - if: cuda == \"ON\"\n          then:\n            - __cuda\n            - cuda-cudart\n      run_exports:\n        - ${{ pin_subpackage('libparallelproj', upper_bound='x.x') }}\n\n    tests:\n      - package_contents:\n          files:\n            exists:\n              - if: win\n                then: bin/parallelproj.dll\n              - if: win\n                then: lib/parallelproj.lib\n              - if: linux\n                then: lib/libparallelproj.so\n              - if: osx\n                then: lib/libparallelproj.dylib\n\n              - lib/cmake/parallelproj/parallelprojConfig.cmake\n              - lib/cmake/parallelproj/parallelprojConfigVersion.cmake\n              - lib/cmake/parallelproj/parallelprojTargets.cmake\n\n              - include/cuda_compat.h\n              - include/cuda_utils.h\n              - include/debug.h\n              - include/parallelproj.h\n              - include/parallelproj_export.h\n              - include/utils.h\n\n  - package:\n      name: parallelproj-core\n\n    build:\n      skip: ${{ cuda == \"ON\" }}\n      python:\n        version_independent: true\n      script:\n        - if: win\n          then: |\n            cmake -S \"%SRC_DIR%\" -B \"%SRC_DIR%/_build_py\" -GNinja ^\n              %CMAKE_ARGS%^\n              -DCMAKE_BUILD_TYPE=Release ^\n              -DPROJECT_VERSION_OVERRIDE=${{ version }} ^\n              -DCMAKE_INSTALL_PREFIX=\"%PREFIX%\" ^\n              -DUSE_CUDA=OFF ^\n              -DBUILD_LIBRARY=OFF ^\n              -DINSTALL_DEVEL=OFF ^\n              -DBUILD_PYTHON=ON ^\n              -DBUILD_TESTS=OFF ^\n              -DCMAKE_PREFIX_PATH=\"%PREFIX%\" ^\n              -DPython_EXECUTABLE=\"%PYTHON%\" ^\n              -DPython_ROOT_DIR=\"%PREFIX%\"\n            cmake --build \"%SRC_DIR%\\_build_py\"\n            cmake --install \"%SRC_DIR%\\_build_py\"\n          else: |\n            cmake -S \"$SRC_DIR\" -B \"$SRC_DIR/_build_py\" -GNinja \\\n              ${CMAKE_ARGS} \\\n              -DCMAKE_BUILD_TYPE=Release \\\n              -DPROJECT_VERSION_OVERRIDE=${{ version }} \\\n              -DCMAKE_INSTALL_PREFIX=\"$PREFIX\" \\\n              -DUSE_CUDA=OFF \\\n              -DBUILD_LIBRARY=OFF \\\n              -DINSTALL_DEVEL=OFF \\\n              -DBUILD_PYTHON=ON \\\n              -DBUILD_TESTS=OFF \\\n              -DCMAKE_PREFIX_PATH=\"$PREFIX\" \\\n              -DPython_EXECUTABLE=\"$PYTHON\" \\\n              -DPython_ROOT_DIR=\"$PREFIX\" \\\n              -DCMAKE_FIND_FRAMEWORK=NEVER \\\n              -DCMAKE_FIND_APPBUNDLE=NEVER\n            cmake --build \"$SRC_DIR/_build_py\"\n            cmake --install \"$SRC_DIR/_build_py\"\n\n      files:\n        - lib/python*/site-packages/parallelproj_core*.so\n        - lib/python*/site-packages/parallelproj_core*.dylib\n        - lib/site-packages/parallelproj_core*.pyd\n        - lib/site-packages/parallelproj_core*.dll\n        - Lib/site-packages/parallelproj_core*.pyd\n        - Lib/site-packages/parallelproj_core*.dll\n\n    requirements:\n      build:\n        - ${{ compiler('cxx') }}\n        - ${{ stdlib('c') }}\n        - cmake\n        - ninja\n        - if: build_platform != target_platform\n          then:\n            - python ${{ python_min }}.*\n            - python-abi3 ${{ python_min }}.*\n            - cross-python_${{ target_platform }} ${{ python_min }}.*\n\n      host:\n        - python ${{ python_min }}.*\n        - python-abi3 ${{ python_min }}.*\n        - nanobind\n        - libparallelproj\n\n      run:\n        - python >=${{ python_min }}\n        - python-abi3 >=${{ python_min }}\n        - ${{ pin_subpackage(\"libparallelproj\", upper_bound=\"x.x\") }}\n\n    tests:\n      - script:\n        - python -c \"import parallelproj_core as m; print(m.__file__, ', cuda_enabled =', int(m.cuda_enabled))\"\n        - pytest -v ./tests\n\n        requirements:\n          run:\n            - pytest\n            - numpy\n            - array-api-compat\n            - array-api-strict\n        files:\n          source:\n            - tests/**/*.py\n            - tests/vstart.txt\n            - tests/vend.txt\n            - tests/img.txt\n            - tests/expected_fwd_vals.txt\n\nabout:\n  homepage: https://github.com/KUL-recon-lab/libparallelproj\n  license: Apache-2.0\n  license_file: LICENSE\n  documentation: https://libparallelproj.readthedocs.io\n  repository: https://github.com/KUL-recon-lab/libparallelproj\n  summary: C++/CUDA backend projector library (parallelproj) and python API for tomographic reconstruction\n  description: |\n    libparallelproj builds and installs the parallelproj shared library (CPU/OpenMP or CUDA),\n    public headers, and a CMake package configuration for downstream CMake projects.\n    parallelproj-core is a Python extension module built with nanobind that provides a Python API for the parallelproj C++/CUDA library\n\nextra:\n  recipe-maintainers:\n    - gschramm\n  feedstock-name: libparallelproj\n",

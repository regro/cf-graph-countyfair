    "about": {
      "description": "libparallelproj builds and installs the parallelproj shared library (CPU/OpenMP or CUDA),\npublic headers, and a CMake package configuration for downstream CMake projects.\nparallelproj-core is a Python extension module built with nanobind that provides a Python API for the parallelproj C++/CUDA library",
      "dev_url": "https://github.com/KUL-recon-lab/libparallelproj",
      "doc_url": "https://libparallelproj.readthedocs.io/",
      "home": "https://github.com/KUL-recon-lab/libparallelproj",
      "license": "Apache-2.0",
      "license_family": "Apache-2.0",
      "license_file": "LICENSE",
      "summary": "C++/CUDA backend projector library (parallelproj) and python API for tomographic reconstruction"
    },
    "build": {
      "number": "0",
      "run_exports": {
        "weak": [
          "libparallelproj"
        ]
      },
      "script": "cmake -S \"$SRC_DIR\" -B \"$SRC_DIR/_build_lib\" -GNinja \\\n  ${CMAKE_ARGS} \\\n  -DCMAKE_BUILD_TYPE=Release \\\n  -DPROJECT_VERSION_OVERRIDE=${{ version }} \\\n  -DCMAKE_INSTALL_PREFIX=\"$PREFIX\" \\\n  -DCMAKE_INSTALL_LIBDIR=lib \\\n  -DUSE_CUDA=${{ cuda }} \\\n  -DBUILD_LIBRARY=ON \\\n  -DINSTALL_DEVEL=ON \\\n  -DBUILD_PYTHON=OFF \\\n  -DBUILD_TESTS=OFF \\\n  -DCMAKE_PREFIX_PATH=\"$PREFIX\" \\\n  -DCMAKE_FIND_FRAMEWORK=NEVER \\\n  -DCMAKE_FIND_APPBUNDLE=NEVER\ncmake --build \"$SRC_DIR/_build_lib\"\ncmake --install \"$SRC_DIR/_build_lib\"\n"
    },
    "extra": {
      "feedstock-name": "libparallelproj",
      "recipe-maintainers": [
        "gschramm"
      ]
    },

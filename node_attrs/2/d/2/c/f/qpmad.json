  "raw_meta_yaml": "context:\n  name: qpmad\n  version: 1.4.0\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/asherikov/qpmad/archive/refs/tags/${{ version }}.zip\n  sha256: 2d3e8890a5538ec78f83c47a30df05531f5bf18960d948179bcce0ec4e30df3d\n  patches:\n    - use-cmake-config-for-eigen.patch\n    - boost-1.90-cmake-tests.patch\n\nbuild:\n  number: 1\n  script:\n    - if: win\n      then: |\n        cmake -S %SRC_DIR% -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DQPMAD_BUILD_TESTS=ON -DCMAKE_INSTALL_PREFIX=%LIBRARY_PREFIX% -DCMAKE_POLICY_VERSION_MINIMUM=3.5\n        cmake --build build -v\n        cmake --install build --prefix %LIBRARY_PREFIX%\n        ctest --test-dir build --output-on-failure\n      else: |\n        cmake -S $SRC_DIR -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DQPMAD_BUILD_TESTS=ON -DCMAKE_INSTALL_PREFIX=$PREFIX -DCMAKE_POLICY_VERSION_MINIMUM=3.5\n        cmake --build build -v\n        cmake --install build --prefix $PREFIX\n        ctest --test-dir build --output-on-failure\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ stdlib('c') }}\n    - cmake\n    - ninja\n  host:\n    - eigen\n    - libboost-devel >=1.74\n  run:\n    - eigen\n\n  ignore_run_exports:\n    from_package:\n      - libboost-devel\n\ntests:\n  - package_contents:\n      include:\n        - qpmad/solver.h\n        - qpmad/config.h\n      files:\n        - ${{ \"Library/\" if win }}share/qpmad/cmake/qpmadConfig.cmake\n        - ${{ \"Library/\" if win }}share/qpmad/cmake/qpmadConfigVersion.cmake\n\nabout:\n  homepage: https://github.com/asherikov/qpmad\n  license: Apache-2.0\n  license_file: LICENSE\n  summary: QPMAD - Quadratic Programming solver\n\nextra:\n  feedstock-name: qpmad\n  recipe-maintainers:\n    - ahoarau\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: newton\n  version: 1.0.0\n  build_number: 0\n\nrecipe:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/newton-physics/newton/archive/refs/tags/v${{ version }}.zip\n  sha256: 24f21045efe162153cd6b9831599989ead2c5a5ef54c15fedea0f6ec9b23650d\n\nbuild:\n  noarch: python\n  number: ${{ build_number }}\n\n# https://github.com/newton-physics/newton/blob/main/pyproject.toml\noutputs:\n  # ======\n  # newton\n  # ======\n  - package:\n      name: newton\n    build:\n      script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n        - pip\n        - hatchling\n      run:\n        - python >=${{ python_min }}\n        - warp-lang >=1.12.0\n        - newton-actuators >=0.1.0\n  # ===========\n  # newton[all]\n  # ===========\n  - package:\n      name: newton-all\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n      # Any modifications to the subpackages pin should be propagated also\n      # to the newton[examples] run dependencies.\n      # We cannot use `newton-all` because it would be a dependency cycle.\n      run:\n        - python >=${{ python_min }}\n        - ${{ pin_subpackage('newton', exact=True) }}\n        - ${{ pin_subpackage('newton-sim', exact=True) }}\n        - ${{ pin_subpackage('newton-importers', exact=True) }}\n        - ${{ pin_subpackage('newton-remesh', exact=True) }}\n        - ${{ pin_subpackage('newton-examples', exact=True) }}\n        # This can be removed in the recipe of the feedstock (needed only in staged-recipes).\n        - newton-actuators >=0.1.0\n        - newton-usd-schemas >=0.1.0\n    tests:\n      - python:\n          imports:\n            - newton\n          pip_check: true\n          # There are deps solver problems on Python 3.10, and the environment cannot be solved.\n          # Testing imports on Python 3.11 until those problems are resolved.\n          python_version: 3.11.*\n      - script:\n          - python -m newton.tests\n        requirements:\n          run:\n            - python 3.11.*\n  # ===========\n  # newton[sim]\n  # ===========\n  - package:\n      name: newton-sim\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n      run:\n        - ${{ pin_subpackage('newton', exact=True) }}\n        - python >=${{ python_min }}\n        - mujoco-warp >=3.5.0.2\n        - mujoco >=3.5.0\n        # This can be removed in the recipe of the feedstock (needed only in staged-recipes).\n        - newton-actuators >=0.1.0\n        - newton-usd-schemas >=0.1.0\n  # =================\n  # newton[importers]\n  # =================\n  - package:\n      name: newton-importers\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n      run:\n        - ${{ pin_subpackage('newton', exact=True) }}\n        - python >=${{ python_min }}\n        - requests >=2.25.0\n        - scipy\n        - fast-simplification >=0.1.11\n        - alphashape >=1.3.1\n        - coacd >=1.0.7\n        - trimesh >=4.6.8\n        - meshio >=5.3.0\n        - pycollada >=0.9\n        - resolve-robotics-uri-py >=0.4.0\n        - openusd >=25.5\n        - newton-usd-schemas >=0.1.0\n        # This can be removed in the recipe of the feedstock (needed only in staged-recipes).\n        - newton-actuators >=0.1.0\n  # ==============\n  # newton[remesh]\n  # ==============\n  - package:\n      name: newton-remesh\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n      run:\n        - ${{ pin_subpackage('newton', exact=True) }}\n        - python >=${{ python_min }}\n        - open3d >=0.18.0\n        - pyfqmr >=0.5.0\n        # Fix missing open3d-cpu dependencies.\n        # https://github.com/conda-forge/open3d-feedstock/issues/49\n        - configargparse\n        - nbformat\n        # This can be removed in the recipe of the feedstock (needed only in staged-recipes).\n        - newton-actuators >=0.1.0\n        - newton-usd-schemas >=0.1.0\n  # ================\n  # newton[examples]\n  # ================\n  - package:\n      name: newton-examples\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n      run:\n        # The following list should be newton[all] minus newton-examples.\n        - ${{ pin_subpackage('newton', exact=True) }}\n        - ${{ pin_subpackage('newton-sim', exact=True) }}\n        - ${{ pin_subpackage('newton-importers', exact=True) }}\n        - ${{ pin_subpackage('newton-remesh', exact=True) }}\n        # Additional deps to run examples.\n        - python >=${{ python_min }}\n        - pyglet >=2.1.6,<3\n        - gitpython >=3.1.44\n        - imgui-bundle >=1.92.0\n        - pyyaml >=6.0.2\n        - cbor2 >=5.7.0\n        - pillow >= 9.0.0\n        # Additional deps to run examples.\n        - importlib_resources\n        # This can be removed in the recipe of the feedstock (needed only in staged-recipes).\n        - newton-actuators >=0.1.0\n        - newton-usd-schemas >=0.1.0\n      run_constraints:\n        - pytorch >=2.7.0\n\nabout:\n  homepage: https://newton-physics.github.io/newton/\n  license: Apache-2.0\n  license_file: LICENSE.md\n  repository: https://github.com/newton-physics/newton\n  summary: An open-source, GPU-accelerated physics simulation engine built upon NVIDIA Warp, specifically targeting roboticists and simulation researchers.\n\nextra:\n  feedstock-name: newton\n  recipe-maintainers:\n    - adenzler-nvidia\n    - diegoferigo\n    - eric-heiden\n",

  "raw_meta_yaml": "{% set version = \"1.1.7\" %}\n\npackage:\n  name: vcstool\n  version: {{ version }}\n\nsource:\n  # This source is not actually used, but it is a simple way to trigger a new release of the\n  # vcstool shim package for every new vcs2l release\n  url: https://pypi.org/packages/source/v/vcs2l/vcs2l-{{ version }}.tar.gz\n  sha256: 1d86e685f9e01dda271b89df1b2bd42ca5555f5c0dcbef5cc727d443f25738cd\n\nbuild:\n  noarch: generic\n  number: 0\n  script: 'echo \"this is a dummy package that just depends on vcs2l, no package is actually built\"'\n\nrequirements:\n  run:\n    - vcs2l {{ version }}.*\n\ntest:\n  commands:\n    - vcs --help\n    - vcs-branch --help\n    - vcs-bzr --help\n    - vcs-custom --help\n    - vcs-diff --help\n    - vcs-export --help\n    - vcs-git --help\n    - vcs-help --help\n    - vcs-hg --help\n    - vcs-import --help\n    - vcs-log --help\n    - vcs-pull --help\n    - vcs-push --help\n    - vcs-remotes --help\n    - vcs-status --help\n    - vcs-svn --help\n    - vcs-validate --help\n\nabout:\n  home: https://github.com/dirk-thomas/vcstool\n  license: Apache-2.0\n  license_family: Apache\n  license_file: LICENSE\n  summary: |\n    vcstool provides a command line tool to invoke vcs commands on multiple repositories.\n\nextra:\n  recipe-maintainers:\n    - traversaro\n    - seanyen\n    - wolfv\n",

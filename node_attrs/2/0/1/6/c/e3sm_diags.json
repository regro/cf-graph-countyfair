  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: e3sm_diags\n  version: \"3.1.1\"\n  python_min: \"3.11\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/E3SM-Project/e3sm_diags/archive/v${{ version }}.tar.gz\n  sha256: c62ffafca10547e1ae9bcb9c03ee13d028bdd24fecd6d02c8e0b02873ac38f04\n\nbuild:\n  number: 1\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . --no-deps -vv\n  python:\n    entry_points:\n      - e3sm_diags = e3sm_diags.e3sm_diags_driver:main\n      - e3sm_diags_vars = e3sm_diags.e3sm_diags_vars:main\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools\n  run:\n    - python >=${{ python_min }}\n    - pip\n    - beautifulsoup4\n    # Temporary constrain cartopy <0.25.0 to prevent plot regression issues.\n    # Related: https://github.com/E3SM-Project/e3sm_diags/issues/1026\n    - cartopy >=0.17.0,<0.25.0\n    - cartopy_offlinedata\n    - cf-units\n    - dask !=2024.12.0,!=2024.12.1\n    - esmf >=8.8.0 nompi_*\n    - lxml\n    - mache >=0.15.0\n    - matplotlib-base >=3.8.2\n    - netcdf4\n    - output_viewer >=1.3.0\n    - numpy >=2.0.0,<3.0.0\n    - pywavelets\n    - scipy\n    - uxarray >=2023.3.0\n    - xarray >=2024.3.0\n    - xcdat >=0.11.1,<1.0.0\n    - xesmf >=0.8.7\n    - xskillscore >=0.0.20\n\n    # temporarily constraint this xcdat dependency to get pip check to pass\n    - regionmask >=0.6.2\n\ntests:\n  - python:\n      imports:\n        - e3sm_diags\n      pip_check: true\n      python_version: ${{ python_min }}.*\n  - requirements:\n      run:\n        - python ${{ python_min }}.*\n        - pip\n    script:\n      - e3sm_diags --help\n\nabout:\n  homepage: https://github.com/E3SM-Project/e3sm_diags\n  license: BSD-3-Clause\n  license_file: LICENSE\n  summary: |\n    Diagnostics package for the DOE's Energy Exascale Earth System Model\n    (E3SM) project.\n  documentation: https://e3sm-project.github.io/e3sm_diags/docs/html/index.h
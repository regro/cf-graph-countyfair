    "about": {
      "description": "A package to analyze data from Transition Matrix Monte Carlo (tmmc)\nsimulation. The main output from TMMC simulations, \"lnPi\", provides a\nmeans to calculate a host of thermodynamic properties. Moreover, if \"lnPi\"\nis calculated at a specific chemical potential, it can be reweighted to provide\nthermodynamic information at a different chemical potential.\n",
      "home": "https://github.com/usnistgov/tmmc-lnpy",
      "license": "NIST-PD",
      "license_file": "LICENSE",
      "summary": "Analysis of lnPi results from TMMC simulation"
    },
    "build": {
      "noarch": "python",
      "number": "0",
      "script": "PYTHON -m pip install . -vv --no-deps --no-build-isolation"
    },

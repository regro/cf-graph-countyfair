  "raw_meta_yaml": "context:\n  name: lerna\n  version: \"2.0.2\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ name }}-${{ version }}.tar.gz\n  sha256: 37b28573a6605a72ff64a1d8d4554af64d7f640db076d0ad4a7ff29d3ea15278\n\nbuild:\n  number: 0\n  python:\n    version_independent: true\n  script:\n    - if: unix\n      then: export PYO3_PYTHON=\"$PYTHON\"\n      else: set \"PYO3_PYTHON=%PYTHON%\"\n    - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  skip: is_abi3 and not is_python_min\n\nrequirements:\n  build:\n    - if: build_platform != target_platform\n      then:\n        - python\n        - cross-python_${{ target_platform }}\n        - crossenv\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n  host:\n    - python\n    - pip\n    - hatchling\n    - hatch-rs\n    - if: is_abi3\n      then:\n      - python-abi3\n  run:\n    - python\n    - omegaconf >=2.2.3,<2.4\n    - packaging\n  ignore_run_exports:\n    from_package:\n      - cross-python_${{ target_platform }}\n\ntests:\n  - python:\n      imports:\n        - lerna\n      pip_check: true\n      python_version: ${{ python_min }}.*\n\nabout:\n  license: Apache-2.0\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  summary: |\n    A high-performance configuration framework for Python applications, built with Rust.\n    Lerna is a rewrite of Facebook's Hydra configuration framework.\n  homepage: https://github.com/nbprint/lerna\n  repository: https://github.com/nbprint/lerna\n\nextra:\n  recipe-maintainers:\n    - timkpaine\n",

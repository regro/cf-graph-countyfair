  "linux_64_meta_yaml": {
    "about": {
      "description": "yamllint does not only check for syntax validity, but for weirdnesses like\nkey repetition and cosmetic problems such as lines length, trailing spaces,\nindentation, etc.\n",
      "doc_source_url": "https://github.com/adrienverge/yamllint/blob/master/docs/index.rst\n",
      "doc_url": "https://yamllint.readthedocs.io",
      "home": "https://github.com/adrienverge/yamllint",
      "license": "GPL-3.0-only",
      "license_family": "GPL",
      "license_file": "LICENSE",
      "summary": "A linter for YAML files."
    },
    "build": {
      "entry_points": [
        "yamllint = yamllint.cli:run"
      ],
      "noarch": "python",
      "number": "0",
      "script": "PYTHON -m pip install --no-deps --no-build-isolation ."
    },
    "extra": {
      "recipe-maintainers": [
        "proinsias",
        "bollwyvl"
      ]
    },
    "package": {
      "name": "yamllint",
      "version": "1.36.0"
    },
    "requirements": {
      "host": [
        "pip",
        "python 3.9",
        "setuptools >=61"
      ],
      "run": [
        "pathspec >=0.5.3",
        "python >=3.9",
        "pyyaml"
      ]
    },
    "schema_version": 0,
    "source": {
      "sha256": "3835a65994858679ea06fd998dd968c3f71935cd93742990405999d888e21130",
      "url": "https://pypi.org/packages/source/y/yamllint/yamllint-1.36.0.tar.gz"
    },
    "test": {
      "commands": [
        "pip check",
        "yamllint --help",
        "yamllint --version",
        "pytest -vv --color=yes --cov=yamllint --cov-branch --cov-report=term-missing:skip-covered --cov-fail-under=98"
      ],
      "imports": [
        "yamllint"
      ],
      "requires": [
        "pip",
        "pytest",
        "pytest-cov",
        "python 3.9"
      ],
      "source_files": [
        "tests"
      ]
    }
  },

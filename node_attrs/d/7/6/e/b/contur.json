  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"3.1.3\"\n  # Need Python 3.10+ to avoid rivet/libfastjet.so.0 ImportError\n  python_min: \"3.10\"\n\npackage:\n  name: contur\n  version: ${{ version }}\n\nsource:\n  # No sdists on PyPI yet so fall back to Git source\n  # c.f. https://gitlab.com/hepcedar/contur/-/work_items/541\n  # url: https://pypi.org/packages/source/c/contur/contur-${{ version }}.tar.gz\n  url: https://gitlab.com/hepcedar/contur/-/archive/contur-${{ version }}/contur-contur-${{ version }}.tar.gz\n  sha256: c65af001a1695477a02d48d76f1efb6ef8f721b3a87ad07bcb86b556a06805c8\n\nbuild:\n  number: 0\n  noarch: python\n  script:\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n\n    # Add the post activate/deactivate scripts\n\n    # The scripts are executed in lexicographical order, so use zzz-/0- to ensure\n    # last/first to manipulate RIVET environment variables\n    # (lowercase letters have highest value)\n\n    - mkdir -p \"${PREFIX}/etc/conda/activate.d\"\n    # Run **after** anything else that might set Rivet environment variables\n    - cp \"${RECIPE_DIR}/activate.sh\" \"${PREFIX}/etc/conda/activate.d/zzz-activate-${PKG_NAME}.sh\"\n    - cp \"${RECIPE_DIR}/activate.csh\" \"${PREFIX}/etc/conda/activate.d/zzz-activate-${PKG_NAME}.csh\"\n    - cp \"${RECIPE_DIR}/activate.fish\" \"${PREFIX}/etc/conda/activate.d/zzz-activate-${PKG_NAME}.fish\"\n\n    - mkdir -p \"${PREFIX}/etc/conda/deactivate.d\"\n    # Run **before** anything else that might unset Rivet environment variables\n    - cp \"${RECIPE_DIR}/deactivate.sh\" \"${PREFIX}/etc/conda/deactivate.d/0-deactivate-${PKG_NAME}.sh\"\n    - cp \"${RECIPE_DIR}/deactivate.csh\" \"${PREFIX}/etc/conda/deactivate.d/0-deactivate-${PKG_NAME}.csh\"\n    - cp \"${RECIPE_DIR}/deactivate.fish\" \"${PREFIX}/etc/conda/deactivate.d/0-deactivate-${PKG_NAME}.fish\"\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools >=64\n  run:\n    - python >=${{ python_min }}\n    - click\n    - configobj\n    - matplotlib-base\n    - numpy\n    - pandas\n    - pathos\n    - pyslha\n    - pyyaml\n    - scikit-learn\n    - scipy\n    - tqdm\n    - uncertainties\n    - pytest\n    - rivet\n    # Needed to create \"${CONTUR_USER_DIR}/analysis-list\" in activate.sh\n    - cxx-compiler\n    - make\n    # Avoid broken installs on Windows given rivet is unix only\n    - __unix\n\ntests:\n  - package_contents:\n      # FIXME: Relocate python-scripts/ contents to bin/\n      files:\n        - python-scripts/contur\n        - python-scripts/contur-batch\n        - python-scripts/contur-export\n        - python-scripts/contur-extract-xs-bf\n        - python-scripts/contur-gridtool\n        - python-scripts/contur-init\n        - python-scripts/contur-mapmerge\n        - python-scripts/contur-mkbib\n        - python-scripts/contur-mkthy\n        - python-scripts/contur-oracle\n        - python-scripts/contur-plot\n        - python-scripts/contur-profile\n        - python-scripts/contur-rivetplots\n        - python-scripts/contur-scan-xs-bf\n        - python-scripts/contur-scan-xs-bf-alt\n        - python-scripts/contur-smtest\n  - python:\n      imports:\n        - contur\n      pip_check: true\n      python_version:\n        - ${{ python_min }}.*\n        - \"*\"\n  - script:\n      - contur --version\n      - contur --help\n\nabout:\n  license: GPL-3.0-or-later\n  license_file: COPYING\n  summary: Package for model interpretation of collider-physics measurements\n  description: |\n    Contur is a procedure and toolkit designed to probe theories Beyond the\n    Standard Model using measurements at particle colliders.\n  homepage: https://hepcedar.gitlab.io/contur-webpage/\n  repository: https://gitlab.com/hepcedar/contur\n  documentation: https://hepcedar.gitlab.io/contur-webpage/\n\nextra:\n  recipe-maintainers:\n    - matthewfeickert\n    - conda-forge/hepmc3\n",

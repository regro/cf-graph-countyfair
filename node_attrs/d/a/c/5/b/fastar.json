  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  version: \"0.9.0\"\n  maturin_min: \"1.9\"\n  maturin_max: \"2.0\"\n  cov_fail_linux: \"83\"\n\npackage:\n  name: fastar\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/f/fastar/fastar-${{ version }}.tar.gz\n  sha256: d49114d5f0b76c5cc242875d90fa4706de45e0456ddedf416608ecd0787fb410\n\nbuild:\n  number: 0\n  script:\n    env:\n      ZSTD_SYS_USE_PKG_CONFIG: \"1\"\n    content:\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n    - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ compiler(\"rust\") }}\n    - ${{ compiler(\"c\") }}\n    - ${{ stdlib(\"c\") }}\n    - cargo-bundle-licenses\n    - pkg-config\n    - if: target_platform != host_platform\n      then:\n        - maturin >=${{ maturin_min }},<${{ maturin_max }}\n        - python\n  host:\n    - maturin >=${{ maturin_min }},<${{ maturin_max }}\n    - pip\n    - python\n    - zstd\n  run:\n    - python\n\ntests:\n  - python:\n      imports: fastar\n      pip_check: true\n  - files:\n      source:\n        - tests/\n    requirements:\n      run:\n        - backports.zstd\n        - mypy\n        - psutil\n        - pytest-codspeed\n        - pytest-cov\n    script:\n      env:\n        # upstream tests on linux; most of the below are due to OS-level\n        # differences in error message strings\n        PYTEST_ADDOPTS: |-\n          ${{\n            '-k \"not unpack_raises_if_file_would_overwrite_existing_directory\"'\n            if osx\n          }}${{\n            ('-k \"not (' ~ ( [\n              'append_preserves_directory_permissions',\n              'append_preserves_file_permissions',\n              'close_closes_archive',\n              'context_manager_closes_archive',\n              'open_raises_if_file_does_not_exist',\n              'open_raises_if_insufficient_permissions',\n              'open_raises_if_no_permissions',\n              'open_raises_if_path_is_directory',\n              'unpack_keeps_contents_of_conflicting_directories',\n              'unpack_overwrites_permissions_of_conflicting_directories',\n              'unpack_overwrites_permissions_of_conflicting_files',\n              'unpack_preserves_directory_permissions',\n              'unpack_preserves_file_permissions',\n              'unpack_raises_if_file_would_overwrite_existing_directory',\n            ] | join(' or ') ) ~ ')\"')\n            if win\n          }}\n      content:\n        - coverage run --source=fastar --branch -m pytest -vv --tb=long --color=yes\n        - coverage report --show-missing --skip-covered ${{ '--fail-under ' ~ cov_fail_linux if linux }}\n        - mypy -p fastar\n\nabout:\n  summary: High-level bindings for the Rust tar crate\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  homepage: https://pypi.org/project/fastar\n  repository: https://github.com/DoctorJohn/fastar\n\nextra:\n  recipe-maintainers:\n    - bollwyvl\n",

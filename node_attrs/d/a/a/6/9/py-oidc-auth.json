  "raw_meta_yaml": "context:\n  version: \"2603.0.2\"\n\nrecipe:\n  name: py-oidc-auth-split\n  version: ${{ version }}\n\nsource:\n  - url: https://pypi.org/packages/source/p/py-oidc-auth/py_oidc_auth-${{ version }}.tar.gz\n    sha256: 025c81f952dc2ec182f14a52c55a41e9cfad35d760e663bc3049262faf4ad2d7\n\nbuild:\n  number: 0\n\noutputs:\n  - package:\n      name: py-oidc-auth\n    build:\n      script: ${{ PYTHON }} -m pip install . --no-deps -vv\n      noarch: python\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n        - flit-core\n        - pip\n        - glib >=2.66\n        - gtk3\n        - libxml2\n      run:\n        - python >=${{ python_min }}\n        - httpx\n        - pydantic\n        - cryptography\n        - pyjwt\n        - typing-extensions\n    tests:\n      - python:\n          imports:\n            - py_oidc_auth\n          pip_check: true\n          python_version:\n            - ${{ python_min }}.*\n            - \"*\"\n\n  - package:\n      name: py-oidc-auth-fastapi\n    build:\n      noarch: generic\n    requirements:\n      run:\n        - ${{ pin_subpackage('py-oidc-auth', exact=True) }}\n        - fastapi\n        - python-multipart\n        - uvicorn\n    tests:\n      - python:\n          imports:\n            - py_oidc_auth\n\n  - package:\n      name: py-oidc-auth-flask\n    build:\n      noarch: generic\n    requirements:\n      run:\n        - ${{ pin_subpackage('py-oidc-auth', exact=True) }}\n        - flask\n    tests:\n      - python:\n          imports:\n            - py_oidc_auth\n\n  - package:\n      name: py-oidc-auth-quart\n    build:\n      noarch: generic\n    requirements:\n      run:\n        - ${{ pin_subpackage('py-oidc-auth', exact=True) }}\n        - quart\n    tests:\n      - python:\n          imports:\n            - py_oidc_auth\n\n  - package:\n      name: py-oidc-auth-tornado\n    build:\n      noarch: generic\n    requirements:\n      run:\n        - ${{ pin_subpackage('py-oidc-auth', exact=True) }}\n        - tornado\n    tests:\n      - python:\n          imports:\n            - py_oidc_auth\n\n  - package:\n      name: py-oidc-auth-litestar\n    build:\n      noarch: generic\n    requirements:\n      run:\n        - ${{ pin_subpackage('py-oidc-auth', exact=True) }}\n        - litestar\n    tests:\n      - python:\n          imports:\n            - py_oidc_auth\n\n  - package:\n      name: py-oidc-auth-django\n    build:\n      noarch: generic\n    requirements:\n      run:\n        - ${{ pin_subpackage('py-oidc-auth', exact=True) }}\n        - django >=4.0\n    tests:\n      - python:\n          imports:\n            - py_oidc_auth\n\nabout:\n  summary: Pluggable OIDC/OAuth 2.1 authentication routes and token validation.\n  description: A small, typed OpenID Connect helper for authentication and authorization.\n  homepage: https://github.com/freva-org/py-oidc-auth\n  license: BSD-3-Clause\n  license_file:\n    - LICENSE\n\nextra:\n  feedstock-name: py-oidc-auth\n  recipe-maintainers:\n    - antarcticrainforest\n",

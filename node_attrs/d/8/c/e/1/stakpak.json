  "raw_meta_yaml": "context:\n  version: \"0.3.73\"\n\npackage:\n  name: stakpak\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/stakpak/agent/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 71b891e098b257a450d5ce6caa712fe5bd0b0987e15d9aa83605ccbf1ff8d5fb\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - cd cli\n      - if: linux\n        then:\n          # cf. https://github.com/stakpak/agent/blob/main/cli/src/main.rs#L17\n          - cargo auditable install --locked --no-track --bins --features jemalloc --root ${{ PREFIX }} --path .\n      - if: osx\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n      - if: win\n        then:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n      - cargo-bundle-licenses --format yaml --output ../THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n    - pkg-config\n    - if: linux\n      then: make\n\ntests:\n  - script:\n      - stakpak help\n      - stakpak version\n  - package_contents:\n      bin:\n        - stakpak\n      strict: true\n\nabout:\n  homepage: https://stakpak.io\n  summary: Stakpak – Ship your code, on autopilot.\n  description: |\n    Stakpak is the open source DevOps agent that helps you with securing, deploying, and maintaining production ready infrastructure and only pings when it needs a human.\n    Generate infrastructure code, debug Kubernetes, configure CI/CD, automate deployments, without giving an LLM the keys to production.\n  license: Apache-2.0\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  repository: https://github.com/stakpak/agent\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: las-geoh5\n  version: \"0.3.2\"\n  python_min: '3.10'\n  module_name: ${{ name|lower|replace(\"-\", \"_\") }}\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/MiraGeoscience/${{ name }}/archive/v${{ version }}.tar.gz\n  sha256: b417ccfe9c025ce0ac9590753204c86192948bef27852c81a0087bb02e151771\n\nbuild:\n  number: 0\n  noarch: python\n  script:\n    - export POETRY_DYNAMIC_VERSIONING_BYPASS=${{ version }}\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - geoh5_to_las = las_geoh5.scripts.geoh5_to_las:main\n      - las_to_geoh5 = las_geoh5.scripts.las_to_geoh5:main\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - poetry-core >=1.8.0\n    - poetry-dynamic-versioning >=1.9, 1.*\n    - setuptools\n  run:\n    - python >=${{ python_min }}\n    # Mira packages\n    - geoh5py 0.12.*\n    # direct dependencies\n    - lasio 0.31.*\n    - numpy 1.26.*\n    - pydantic >=2.5.2, 2.*\n    - tqdm >=4.66.1, 4.*\n\ntests:\n  - python:\n      python_version: ${{ python_min }}.*\n      imports:\n        - ${{ module_name }}\n        - ${{ module_name }}._version\n        # dependency imports\n        - geoh5py\n        - lasio\n      pip_check: true\n  - script:\n      - pytest --ignore=tests/version_test.py\n    requirements:\n      run:\n        - pytest\n    files:\n      source:\n        - tests/\n  - package_contents:\n      files:\n        - site-packages/${{ module_name }}/_version.py\n\nabout:\n  summary: Import/Export LAS files to/from geoh5 format.\n  description: |\n    Import/Export LAS files to/from geoh5 format.\n\n    This package allows for import and export of LAS files to and from a drillhole group.\n    There is a module each for import and export operations. Each of these includes a driver and a ui.json \n    that parameterizes the driver and renders a UI for use within Geoscience ANALYST Pro.\n  license: MIT\n  license_file:\n    - LICENSE\n    - docs/source/THIRD_PARTY_SOFTWARE.rst\n  homepage: https://www.mirageoscience.com/mining-industry-software/python-integration/\n  repository: https://github.com/MiraGeoscience/las-geoh5\n  documentation: https://mirageoscience-las-geoh5.readthedocs-hosted.com/\n\nextra:\n  recipe-maintainers:\n    - conda-forge/geoh5py\n",

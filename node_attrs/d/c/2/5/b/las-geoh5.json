      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Import/Export LAS files to/from geoh5 format."
    },
    "build": {
      "noarch": "python",
      "number": "0",
      "script": [
        "export POETRY_DYNAMIC_VERSIONING_BYPASS=${{ version }}",

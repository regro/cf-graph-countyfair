    "about": {
      "description": "A simple HTTP(S) server for static files, written in Rust. Supports directory listing, upload, basic auth, range requests, compression, CORS, SPA fallback,\nand PKCS #12 files.",
      "dev_url": "https://github.com/TheWaWaR/simple-http-server",
      "home": "https://github.com/TheWaWaR/simple-http-server",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Simple HTTP server in Rust"
    },
    "build": {
      "number": "1",
      "script": {
        "content": [
          "cargo auditable install --locked --no-track --bins --features tls --root ${{ PREFIX }} --path .",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols",
          "OPENSSL_NO_VENDOR": "1"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "simple-http-server",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable",
            "pkg-config"
          ],
          "host": [
            "openssl"
          ],
          "run": []
        },
        "tests": [
          {
            "script": "simple-http-server --help"
          },
          {
            "script": "simple-http-server --version"
          },
          {
            "package_contents": {
              "bin": [

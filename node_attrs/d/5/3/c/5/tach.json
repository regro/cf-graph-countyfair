      ],
      "host": [
        "maturin >=1.5,<2.0",
        "pip",
        "python",
        "python-abi3"
      ],
      "run": [
        "gitpython >=3.1,<4.0",
        "networkx >=2.6,<4.0",
        "prompt-toolkit >=3.0,<4.0",
        "pydot >=2,<4",
        "python",
        "pyyaml >=6.0,<7.0",

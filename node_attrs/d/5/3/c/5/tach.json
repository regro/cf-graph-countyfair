        "stdlib-list >=0.10.0",
        "tomli >=1.2.2",
        "tomli-w >=1.0,<2.0"
      ]
    },
    "schema_version": 1,
    "source": {
      "patches": [
        "0000-no-pyo3-auto-initialize.patch"
      ],
      "sha256": "0c221a51ddfce5a4d65183f0ff2ebda6fd4230c36eb39cf2021c1aeea84be81a",
      "url": "https://pypi.org/packages/source/t/tach/tach-0.27.0.tar.gz"

  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  version: 0.27.0\n  maturin_min: \"1.5\"\n  maturin_max: \"2.0\"\n\npackage:\n  name: tach\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/t/tach/tach-${{ version }}.tar.gz\n  sha256: 0c221a51ddfce5a4d65183f0ff2ebda6fd4230c36eb39cf2021c1aeea84be81a\n  patches:\n    - 0000-no-pyo3-auto-initialize.patch\n\nbuild:\n  number: 1\n  skip: not (match(python, python_min ~ \".*\") and is_abi3 == \"true\")\n  python:\n    version_independent: true\n    entry_points:\n      - tach = tach.start:start\n  script:\n    file: build-tach\n\nrequirements:\n  build:\n    - ${{ compiler(\"rust\") }}\n    - ${{ stdlib(\"c\") }}\n    - cargo-bundle-licenses\n    - if: build_platform != target_platform\n      then:\n        - python\n        - cross-python_${{ target_platform }}\n        - crossenv\n        - maturin >=${{ maturin_min }},<${{ maturin_max }}\n    - if: unix\n      then:\n        - ${{ compiler(\"c\") }}\n  host:\n    - maturin >=${{ maturin_min }},<${{ maturin_max }}\n    - pip\n    - python\n    - python-abi3\n  run:\n    - gitpython >=3.1,<4.0\n    - networkx >=2.6,<4.0\n    - prompt-toolkit >=3.0,<4.0\n    - pydot >=2,<4\n    - python\n    - pyyaml >=6.0,<7.0\n    - rich >=13.0,<14.0\n    - stdlib-list >=0.10.0\n    - tomli >=1.2.2\n    - tomli-w >=1.0,<2.0\n\ntests:\n  - python:\n      pip_check: true\n      python_version: ${{ python_min }}.*\n      imports: tach\n  - files:\n      source:\n        - python/tests/\n        - pyproject.toml\n    requirements:\n      run:\n        - coverage\n        - pytest\n        - pytest-mock\n        - if: win\n          then:\n            - m2-grep\n        # apparently some lingering abi3 issues\n        - if: build_platform == target_platform\n          then:\n            - python !=${{ python_min }}.*\n          else:\n            - python ${{ python_min }}.*\n    script:\n      - tach --help\n      - tach --version\n      - tach --version | grep -iE \"${{ version | replace('.', '\\\\.') }}\"\n      # windows tests don't exit/cleanup properly, and generally have path issues\n      - if: unix\n        then:\n          - coverage run --source=tach --branch -m pytest -vv --tb=long --color=yes\n          - coverage report --show-missing --skip-covered --fail-under=49\n\nabout:\n  summary: A Python tool to maintain a modular package architecture.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  homepage: https://github.com/gauge-sh/tach\n  documentation: https://docs.gauge.sh\n\nextra:\n  recipe-maintainers:\n    - bollwyvl\n",

{
  "archived": false,
  "branch": "main",
  "conda-forge.yml": {
    "bot": {
      "inspection": "hint-all"
    },
    "build_platform": {
      "linux_aarch64": "linux_64",
      "linux_ppc64le": "linux_64",
      "osx_arm64": "osx_64"
    },
    "conda_build": {
      "error_overlinking": true
    },
    "conda_build_tool": "rattler-build",
    "conda_forge_output_validation": true,
    "github": {
      "branch_name": "main",
      "tooling_branch_name": "main"
    },
    "shellcheck": {
      "enabled": true
    },
    "test": "native_and_emulated"
  },
  "feedstock_name": "tach",
  "hash_type": "sha256",
  "linux_64_meta_yaml": {
    "about": {
      "doc_url": "https://docs.gauge.sh/",
      "home": "https://github.com/gauge-sh/tach",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "A Python tool to maintain a modular package architecture."
    },
    "build": {
      "number": "1",
      "script": {
        "file": "build-tach"
      }
    },
    "extra": {
      "recipe-maintainers": [
        "bollwyvl"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "tach",
        "requirements": {
          "build": [
            "rust_compiler_stub",
            "c_stdlib_stub",
            "cargo-bundle-licenses",
            "c_compiler_stub"
          ],
          "host": [
            "maturin >=1.5,<2.0",
            "pip",
            "python",
            "python-abi3"
          ],
          "run": [
            "gitpython >=3.1,<4.0",
            "networkx >=2.6,<4.0",
            "prompt-toolkit >=3.0,<4.0",
            "pydot >=2,<4",
            "python",
            "pyyaml >=6.0,<7.0",
            "rich >=13.0,<14.0",
            "stdlib-list >=0.10.0",
            "tomli >=1.2.2",
            "tomli-w >=1.0,<2.0"
          ]
        },
        "tests": [
          {
            "python": {
              "imports": [
                "tach"
              ],
              "python_version": "3.9.*"
            }
          },
          {
            "files": {
              "source": [
                "python/tests/**",
                "pyproject.toml"
              ]
            },
            "requirements": {
              "run": [
                "coverage",
                "pytest",
                "pytest-mock",
                "python !=3.9.*"
              ]
            },
            "script": [
              "tach --help",
              "tach --version",
              "tach --version | grep -iE \"${{ version | replace('.', '\\\\.') }}\"",
              "coverage run --source=tach --branch -m pytest -vv --tb=long --color=yes",
              "coverage report --show-missing --skip-covered --fail-under=49"
            ]
          }
        ]
      }
    ],
    "package": {
      "name": "tach",
      "version": "0.27.0"
    },
    "requirements": {
      "build": [
        "rust_compiler_stub",
        "c_stdlib_stub",
        "cargo-bundle-licenses",

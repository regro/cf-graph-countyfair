  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"1.28.2\"\n\npackage:\n  name: gst-rtsp-server\n  version: ${{ version }}\n\nsource:\n  - url: https://gstreamer.freedesktop.org/src/gst-rtsp-server/gst-rtsp-server-${{ version }}.tar.xz\n    sha256: 917c58b9ff14f91a6b5cd1c3af16c9fcfdf5d8d78d3d167c7e8fa5bdda35f947\n\nbuild:\n  number: 1\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - ${{ compiler('cxx') }}\n    - pkg-config\n    - meson\n    - ninja\n    - gettext-tools\n    - gobject-introspection\n    - if: build_platform != target_platform\n      then: cross-python_${{ target_platform }}\n    - python <${{ 3.15 }}\n    - setuptools <81\n  host:\n    - gstreamer 1.28.2.*\n    - gst-plugins-base 1.28.2.*\n    - gobject-introspection\n    - glib\n    - if: not linux\n      then: libintl-devel\n    - libiconv\n    - zlib\n  run:\n    - gstreamer 1.28.2.*\n    - gst-plugins-base 1.28.2.*\n    - if: not ppc64le\n      then: libsoup\n    - if: not ppc64le\n      then: glib-networking\n  ignore_run_exports:\n    from_package:\n      - if: build_platform != target_platform\n        then: python\n      - if: build_platform != target_platform\n        then: python_abi\n\ntests:\n  - script:\n      - if: unix\n        then: \n            - test -f $PREFIX/include/gstreamer-1.0/gst/rtsp-server/rtsp-server.h\n            - test -f $PREFIX/lib/libgstrtspserver-1.0${SHLIB_EXT}\n            - test -f $PREFIX/lib/gstreamer-1.0/libgstrtspclientsink${SHLIB_EXT}\n      - if: win\n        then: \n            - if not exist %LIBRARY_INC%\\\\gstreamer-1.0\\\\gst\\\\rtsp-server\\\\rtsp-server.h exit 1\n            - if not exist %LIBRARY_BIN%\\\\gstrtspserver-1.0-0.dll exit 1\n            - if not exist %LIBRARY_LIB%\\\\gstreamer-1.0\\\\gstrtspclientsink.dll exit 1\n            - gst-inspect-1.0 --plugin rtspclientsink\n\nabout:\n  summary: GStreamer RTSP Server\n  description: |\n    GStreamer RTSP Server is a library on top of GStreamer for building an RTSP server.\n  license: LGPL-2.1-or-later\n  license_file: COPYING\n  homepage: http://gstreamer.freedesktop.org/\n  repository: https://gitlab.freedesktop.org/gstreamer/gstreamer/-/tree/main/subprojects/gst-rtsp-server\n  documentation: https://gstreamer.freedesktop.org/modules/gst-rtsp-server.html\n\nextra:\n  recipe-maintainers:\n    - tjwilli58\n",

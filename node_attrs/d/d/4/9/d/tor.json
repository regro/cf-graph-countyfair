  "raw_meta_yaml": "context:\n  name: tor\n  version: \"0.4.8.16\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://www.torproject.org/dist/${{ name }}-${{ version }}.tar.gz\n  sha256: 6540dd377a120fb8e7d27530aa3b7ff72a0fa5b4f670fe1d64c987c1cfd390cb\n\nbuild:\n  skip:\n    - win\n  number: 0\n  script:\n    - if: osx\n      then:\n        # config.sub is outdated so we need to regenerate it\n        - autoreconf -fiv\n    - if: linux\n      then:\n        # https://gitlab.torproject.org/tpo/core/tor/-/blob/tor-0.4.8.16/src/lib/log/util_bug.h#L56\n        - export CPPFLAGS=\"${CPPFLAGS/-DNDEBUG/}\"\n        - echo $CPPFLAGS\n    - ./configure --prefix=\"$PREFIX\"\n    - make install\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ stdlib('c') }}\n    - make\n    - pkg-config\n    - if: osx\n      then:\n        - autoconf\n        - libtool\n        - automake\n  host:\n    - libevent\n    - libscrypt\n    - openssl\n    - zlib\n    - liblzma-devel\n    - zstd\n\ntests:\n  - script:\n      - tor --version\nabout:\n  homepage: https://torproject.org\n  summary: Anonymizing overlay network for TCP\n  license: BSD-2-Clause AND BSD-3-Clause AND MIT AND NCSA\n  license_file: LICENSE\n  repository: https://gitlab.torproject.org/tpo/core/tor\n\nextra:\n  recipe-maintainers:\n    - pavelzw\n",

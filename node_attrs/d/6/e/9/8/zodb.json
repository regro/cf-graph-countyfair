  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: ZODB\n  version: \"6.3\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ name | lower }}-${{ version }}.tar.gz\n  sha256: 2da749cf21c709058b2957bb1bc3d3a5d6e86b456246cb48acb5197173367c9f\n\nbuild:\n  number: 1\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv\n  python:\n    entry_points:\n      - fsdump=ZODB.FileStorage.fsdump:main\n      - fsoids=ZODB.scripts.fsoids:main\n      - fsrefs=ZODB.scripts.fsrefs:main\n      - fstail=ZODB.scripts.fstail:Main\n      - repozo=ZODB.scripts.repozo:main\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools <80\n  run:\n    - python >=${{ python_min }}\n    - setuptools\n    - persistent >=4.2.0\n    - btrees >=4.2.0\n    - zconfig\n    - transaction >=2.0.3\n    - six\n    - zc.lockfile\n    - zope.interface\n    - zodbpickle >=0.6.0\n    - setuptools <80\n\ntests:\n  - python:\n      imports:\n        - ZODB\n        - ZODB.FileStorage\n        - ZODB.scripts\n        - ZODB.scripts.tests\n        - ZODB.tests\n      pip_check: true\n      python_version: ${{ python_min }}\n  - requirements:\n      run:\n        - pip\n        - python ${{ python_min }}.*\n    script:\n      - repozo --help\n\nabout:\n  license_file: LICENSE.txt\n  license: ZPL-2.1\n  summary: ZODB, a Python object-oriented database\n  homepage: http://www.zodb.org/\n  repository: https://github.com/zopefoundation/ZODB\n  documentation: http://www.zodb.org/en/latest/\n\nextra:\n  recipe-maintainers:\n    - jan-janssen\n",

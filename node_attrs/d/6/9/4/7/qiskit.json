        "BastianZim",
        "wshanks"
      ]
    },
    "package": {
      "name": "qiskit",
      "version": "1.4.1"
    },
    "requirements": {
      "build": [
        "rust_compiler_stub",
        "c_compiler_stub",
        "c_stdlib_stub",
        "cargo-bundle-licenses"
      ],
      "host": [
        "pip",
        "python",
        "setuptools",
        "setuptools-rust",
        "wheel"
      ],
      "run": [
        "typing_extensions",
        "rustworkx >=0.15.0",
        "python",
        "numpy <3,>=1.17",
        "scipy >=1.5",
        "sympy >=1.3",
        "dill >=0.3",
        "python-dateutil >=2.8.0",
        "stevedore >=3.0.0",
        "python-symengine <0.14,>=0.11"
      ],
      "run_constrained": [
        "matplotlib >=3.3",
        "matplotlib-base >=3.3",
        "pillow >=4.2.1",
        "pylatexenc >=1.4",
        "python-constraint >=1.4",
        "seaborn >=0.9.0",
        "z3-solver >=4.7",
        "qiskit-terra >=1.0"
      ]
    },

  "raw_meta_yaml": "context:\n  name: qiskit\n  python_name: qiskit\n  version: \"2.0.1\"\n  python_min: \"3.9\"\n\npackage:\n  name: qiskit\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/qiskit-${{ version }}.tar.gz\n  sha256: c48b44501eeec09885c1df8bdb2471b6f2732b836f59cd20085544aef2a2dcf8\n\nbuild:\n  number: 1\n  script:\n    - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n    - ${{ PYTHON }} -m pip install . -vv\n  skip: not (match(python, python_min ~ \".*\") and is_abi3)\n  python:\n    version_independent: true\n\nrequirements:\n  build:\n    - if: build_platform != target_platform\n      then:\n      - python\n      - cross-python_${{ target_platform }}\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n  host:\n    - pip\n    - python\n    - python-abi3\n    - setuptools\n    - setuptools-rust\n  run:\n    - dill >=0.3\n    - numpy <3,>=1.17\n    - python\n    - python-dateutil >=2.8.0\n    - python-symengine <0.14,>=0.11\n    - rustworkx >=0.15.0\n    - scipy >=1.5\n    - stevedore >=3.0.0\n    - sympy >=1.3\n    - typing_extensions\n\n  run_constraints:\n    - matplotlib >=3.3\n    - matplotlib-base >=3.3\n    - pillow >=4.2.1\n    - pylatexenc >=1.4\n    - python-constraint >=1.4\n    - seaborn >=0.9.0\n\ntests:\n  - python:\n      imports:\n        - qiskit\n      python_version: [\"${{ python_min ~ '.*' }}\"]  \n  - script:\n      - pip check\n    requirements:\n      run:\n        - pip\n\nabout:\n  homepage: https://www.ibm.com/quantum/qiskit\n  summary: SDK for working with quantum computers at the level of extended quantum circuits, operators, and primitives.\n  documentation: https://docs.quantum.ibm.com\n  repository: https://github.com/Qiskit/qiskit\n  license: Apache-2.0\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n\nextra:\n  recipe-maintainers:\n    - BastianZim\n    - wshanks\n",

  "linux_64_meta_yaml": {
    "about": {
      "description": "release-plz automates the release process for Rust crates. It analyzes\nconventional commits to determine the next semantic version, updates\nchangelogs, creates release PRs on GitHub/Gitea/GitLab, and publishes\ncrates to crates.io.",
      "dev_url": "https://github.com/release-plz/release-plz",
      "doc_url": "https://release-plz.dev/docs",
      "home": "https://release-plz.dev/",
      "license": "MIT OR Apache-2.0",
      "license_family": "MIT OR Apache-2.0",
      "license_file": "LICENSE-APACHE",
      "summary": "Automate versioning, changelogs, and releases for Rust projects."
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "export OPENSSL_DIR=\"${PREFIX}\"",
          "export OPENSSL_NO_VENDOR=1",
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path crates/release_plz",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml",
          "mkdir -p $PREFIX/share/zsh/site-functions $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d",
          "$PREFIX/bin/release-plz generate-completions bash > $PREFIX/share/bash-completion/completions/release-plz",
          "$PREFIX/bin/release-plz generate-completions zsh > $PREFIX/share/zsh/site-functions/_release-plz",
          "$PREFIX/bin/release-plz generate-completions fish > $PREFIX/share/fish/vendor_completions.d/release-plz.fish"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "Hofer-Julian"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "release-plz",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable",
            "pkg-config"
          ],
          "host": [
            "openssl"
          ],
          "run": []
        },
        "tests": [
          {
            "script": "release-plz --help"
          },
          {
            "package_contents": {
              "bin": [
                "release-plz"
              ],
              "files": [
                "share/bash-completion/completions/release-plz",
                "share/fish/vendor_completions.d/release-plz.fish",
                "share/zsh/site-functions/_release-plz"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.3.157"
      }
    ],

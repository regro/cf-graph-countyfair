  "raw_meta_yaml": "{% set name = \"veloxchem\" %}\n{% set gitsha = \"48cdb961adfe8a0789487b6a3ae766fa6a8c62be\" %}\n{% set sha256 = \"dc2a720d5de4f963bca5ef57f542b60ba1d2a54e84f2b0f5f52edbd1701ef8be\" %}\n{% set version = \"1.0\" %}\n{% set pre = \"rc4\" %}\n\npackage:\n  name: {{ name|lower }}\n  version: \"{{ version }}\"\n\nsource:\n  url: https://github.com/VeloxChem/VeloxChem/archive/{{ gitsha }}.tar.gz\n  sha256: {{ sha256 }}\n\nbuild:\n  number: 1\n  entry_points:\n    - vlx=veloxchem.main:main\n\nrequirements:\n  build:\n    - python  # [build_platform != target_platform]\n    - cross-python_{{ target_platform }}  # [build_platform != target_platform]\n    - numpy  # [build_platform != target_platform]\n    - pybind11  # [build_platform != target_platform]\n    - cmake >=3.18\n    - {{ compiler(\"cxx\") }}\n    - {{ stdlib(\"c\") }}\n    - libgomp  # [linux]\n    - llvm-openmp  # [osx or win]\n    - ninja\n  host:\n    - pybind11\n    - python\n    - pybind11-abi =4\n    - eigen\n    - libboost-headers\n    - libxc-c >=7.0.0\n  run:\n    - psutil\n    - geometric\n    - h5py\n    - python\n    - mpi4py\n    - numpy\n  run_constrained:\n    # NOTE newer builds of xtb fail the tests\n    - xtb 6.7.1 *_3  # [win]\n\ntest:\n  requires:\n    - pytest\n    - dftd4-python\n    - xtb-python\n    - pip\n    - scipy\n    - openmm\n    - matplotlib\n    - rdkit\n    - pymbar\n    - mdanalysis\n    - binutils  # [win]\n  source_files:\n    - tests/\n  imports:\n    - veloxchem\n  commands:\n    - pip check\n    # verify we can execute the CLI\n    - vlx --version\n    - vlx --help\n    # inspect linkage\n    - ldd -v $SP_DIR/veloxchem/veloxchemlib*.so  # [linux]\n    - otool -L $SP_DIR/veloxchem/veloxchemlib*.so  # [osx]\n    - objdump.exe -p %SP_DIR%\\\\veloxchem\\\\veloxchemlib.*.pyd | findstr /i \"dll\"  # [win]\n    # run integration tests on unix-like systems\n    # for now we only run selected tests on osx-64 and osx-arm64 due to time and resources\n    - export OMP_NUM_THREADS=$CPU_COUNT  # [unix]\n    - mpiexec -n 1 $PYTHON -m pytest -ra --capture=no --log-cli-level=INFO -m \"not timeconsuming\"  # [linux]\n    - mpiexec -n 1 $PYTHON -m pytest -ra --capture=no --log-cli-level=INFO -m \"not timeconsuming\"  # [osx and arm64]\n    - mpiexec -n 1 $PYTHON -m pytest -ra --capture=no --log-cli-level=INFO -m \"not timeconsuming and not solvers\"  # [osx and x86_64]\n    - export MPI_NUM_PROCS=2  # [unix]\n    - export OMP_NUM_THREADS=$(($CPU_COUNT/$MPI_NUM_PROCS))  # [unix]\n    - mpiexec -n $MPI_NUM_PROCS $PYTHON -m pytest -ra --capture=no --log-cli-level=INFO -m solvers  # [linux]\n    - mpiexec -n $MPI_NUM_PROCS $PYTHON -m pytest -ra --capture=no --log-cli-level=INFO -m solvers -k \"TestScf or TestGrad or TestRI or TestCPP or TestRPA\"  # [osx and arm64]\n    # run integration tests on windows\n    - set OMP_NUM_THREADS=%CPU_COUNT%  # [win]\n    - mpiexec -n 1 %PYTHON% -m pytest -ra --capture=no --log-cli-level=INFO -m \"not timeconsuming\"  # [win]\n    - set MPI_NUM_PROCS=2  # [win]\n    - set /A OMP_NUM_THREADS=\"%CPU_COUNT%/%MPI_NUM_PROCS%\"  # [win]\n    - mpiexec -n %MPI_NUM_PROCS% %PYTHON% -m pytest -ra --capture=no --log-cli-level=INFO -m solvers  # [win]\n\nabout:\n  home: https://veloxchem.org\n  dev_url: https://github.com/VeloxChem/VeloxChem\n  doc_url: https://veloxchem.org\n  license: BSD-3-Clause\n  license_url: https://opensource.org/license/BSD-3-Clause\n  license_file:\n    - LICENSE\n    - LICENSE-THIRD-PARTY\n  license_family: BSD\n  summary: A Python-based, open source quantum chemistry program package\n\nextra:\n  recipe-maintainers:\n    - robertodr\n",

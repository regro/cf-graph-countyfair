  "raw_meta_yaml": "context:\n  version: \"3.15\"\n\npackage:\n  name: \"hydra-image-processor\"\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/ericwait/hydra-image-processor/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 3f24e4eaef9da55af2bb88b0ff72494dcfde13aa8df6d2b5da0210d06726d81f\n  patches:\n    - update-cuda-compatibility.patch\n    - add-cmake-install-target.patch\n\nbuild:\n  skip:\n    - osx\n    - match(cuda_compiler_version, \"==None\")\n    # Skip only during the conda-forge/staged-recipes submission process as\n    # there is no CI process that supports Windows and CUDA\n    - win\n  script:\n    - if: win\n      then: set \"CXXFLAGS=%CXXFLAGS% /openmp:llvm\"\n    - cmake ${CMAKE_ARGS} -G Ninja -S . -B build\n    - cmake --build build --parallel ${CPU_COUNT}\n    - cmake --install build\n  # Example: cuda129_np2_py314_h<hash>_<build_number>\n  string: cuda${{ cuda_compiler_version | version_to_buildstring }}_np${{ numpy | version_to_buildstring }}_py${{ python | version_to_buildstring }}_h${{ hash }}_${{ build_number }}\n  number: 2\n\n# c.f. https://github.com/conda-forge/cuda-feedstock/blob/main/recipe/doc/recipe_guide.md\nrequirements:\n  build:\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler(\"cxx\") }}\n    - ${{ compiler(\"cuda\") }}\n    - if: linux and aarch64\n      then: arm-variant * ${{ arm_variant_type }}\n    - cmake\n    - ninja\n    - if: build_platform != host_platform\n      then:\n        - cross-python_${{ host_platform }}\n        - python\n        - numpy\n  host:\n    - cuda-version ${{ cuda_compiler_version }}.*\n    - python\n    - numpy\n    - if: linux\n      then: libgomp\n      else: llvm-openmp\n  run:\n    - ${{ pin_compatible(\"cuda-version\", lower_bound=\"x\", upper_bound=\"x\") }}\n    - python\n\ntests:\n  - python:\n      imports:\n        - HIP\n\nabout:\n  summary: \"GPU accelerated image processing library\"\n  description: |\n    Hydra Image Processor is a hardware accelerated signal processing library\n    written with CUDA. HIP aims to create a signal processing library that can\n    be incorporated into many software tools.\n  license: BSD-3-Clause\n  license_file: license.txt\n  homepage: https://hydraimageprocessor.com/\n  repository: https://github.com/ericwait/hydra-image-processor\n  documentation: https://hydraimageprocessor.com/\n\nextra:\n  recipe-maintainers:\n    - ericwait\n    - matthewfeickert\n",

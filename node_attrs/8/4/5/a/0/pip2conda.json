  "linux_64_meta_yaml": {
    "about": {
      "description": "`pip2conda` is a tool to translate `pip`-style requirements into `conda`\nrequirements.\n\n`pip2conda2` uses [`build`](https://github.com/pypa/build) to generate\nthe metadata for a project, and then parses out the build and\nruntime requirements for the project - including unpackging extras and\nevaluating environment markers - before matching translating each requirement\ninto a conda-forge requirement suitable for installation with `conda/mamba`.",
      "dev_url": "https://gitlab.com/gwpy/pip2conda.git",
      "doc_url": "https://pip2conda.readthedocs.io/",
      "home": "https://gitlab.com/gwpy/pip2conda/",
      "license": "GPL-3.0-or-later",
      "license_family": "GPL-3.0-or-later",
      "license_file": "LICENSE",
      "summary": "Translate pip requirements into conda requirements"
    },
    "build": {
      "noarch": "python",
      "number": "0",
      "script": "${{ PYTHON }} -m pip install . -vv"
    },
    "extra": {
      "recipe-maintainers": [
        "duncanmmacleod"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "pip2conda",
        "requirements": {
          "build": [],
          "host": [
            "pip",
            "python 3.11.*",
            "setuptools >=61.0",
            "setuptools-scm >=3.4.3"
          ],
          "run": [
            "grayskull >=2.9.2",
            "packaging >=25.0",
            "py-rattler >=0.23.2",
            "python >=3.11",
            "python-build >=1.0.0",
            "requests >=2.32.5",
            "ruamel.yaml >=0.18.15",
            "wheel >=0.46.2"
          ]
        },
        "tests": [
          {
            "requirements": {
              "run": [
                "pip",
                "pytest >=8.4.1",
                "python 3.11.*"
              ]
            },
            "script": [
              "python -m pip check pip2conda",
              "python -m pip show pip2conda",
              "python -m pytest -ra -v --pyargs pip2conda.tests -k \"not real\"",
              "pip2conda --help"
            ]
          }
        ],
        "version": "0.10.0"
      }
    ],

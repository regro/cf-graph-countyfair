  "raw_meta_yaml": "context:\n  name: ruby\n  version: \"4.0.2\"\n  major_minor: ${{ (version | split('.'))[0:2] | join('.') }}\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://cache.ruby-lang.org/pub/ruby/${{ major_minor }}/ruby-${{ version }}.tar.gz\n  sha256: 51502b26b50b68df4963336ca41e368cde92c928faf91654de4c4c1791f82aac\n  patches:\n    - 0001-fix-rubygems-generate-plugins-nil.patch\n\nbuild:\n  number: 0\n\nrequirements:\n  build:\n    # ruby for bootstrapping itself\n    - ruby\n    - if: unix\n      then: gnuconfig\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler(\"rust\") }}\n    - if: unix\n      then:\n        - autoconf\n        - automake\n        - make\n    - pkg-config\n  host:\n    - if: x86 and unix\n      then: gdbm\n    - if: osx\n      then: gettext\n    - libffi\n    - if: linux\n      then: libxcrypt\n    - if: unix\n      then:\n        - ncurses\n        - readline\n        - gmp\n    - openssl\n    - yaml\n    - zlib\n  run:\n    - if: osx\n      then: gettext\n  run_exports:\n    - ${{ pin_subpackage(name, upper_bound='x.x') }}\n  ignore_run_exports:\n    from_package:\n      # We need CXX during build time to generate rbconfig.rb\n      - ${{ compiler('cxx') }}\n\ntests:\n  - requirements:\n      run:\n        - ${{ compiler('c') }}\n        - ${{ compiler('cxx') }}\n        - if: unix\n          then: make\n    files:\n      recipe:\n        - native/hello.c\n        - native/config.rb\n    script:\n      - ruby --version\n      - gem --version\n      - ruby -e 'puts \"Hi, from Ruby!\"'\n      - ruby -r rubygems -e 'puts \"Has gems.\"; exit 0'\n      - ruby -r fiddle -r openssl -r yaml -r zlib -e 'puts \"Has all dependencies.\"; exit 0'\n      - if: unix\n        then: ruby -r readline -e 'puts \"Has readline.\"; exit 0'\n      # Tests it can build libraries with native dependencies\n      - if: unix\n        then:\n          - cd native\n          - ruby config.rb\n          - make\n          - ruby -r ./hello.so -e 'hello'\n\nabout:\n  homepage: https://www.ruby-lang.org/\n  license: BSD-2-Clause\n  license_file: COPYING\n  summary: A dynamic, open source programming language with a focus on simplicity and productivity.\n  description: |\n    A dynamic, open source programming language with a focus on simplicity and productivity.\n    It has an elegant syntax that is natural to read and easy to write.\n  documentation: https://www.ruby-lang.org/en/documentation/\n  repository: https://svn.ruby-lang.org/cgi-bin/viewvc.cgi/\n\nextra:\n  recipe-maintainers:\n    - scopatz\n    - jimmynguyc\n    - sodre\n    - wolfv\n    - xhochy\n",

  "raw_meta_yaml": "context:\n  name: cherab-lhd\n  version: \"0.1.1\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/munechika-koyo/cherab_lhd/archive/v${{ version }}.tar.gz\n  sha256: 256d8fce5e331d0929be6726e04e9a6627866700d4529dee4e22118175d4af67\n\nbuild:\n  skip:\n    - win\n    - match(python, \">3.12\")\n    - match(python, \"<3.10\")\n  script: python -m pip install --no-deps --no-build-isolation .\n  number: 1\n\nrequirements:\n  build:\n    - ${{ compiler(\"c\") }}\n    - ${{ stdlib(\"c\") }}\n    - ninja\n    - if: build_platform != target_platform\n      then:\n        - python\n        - cross-python_${{ target_platform }}\n        - pkg-config\n        - meson-python\n        - cython\n        - numpy\n        - cherab\n        - if: osx\n          then:\n            - llvm-openmp\n  host:\n    - python\n    - pip\n    - pkg-config\n    - meson-python\n    - cython\n    - numpy\n    - cherab\n    - if: osx\n      then:\n        - llvm-openmp\n    - if: match(python, \"<3.11\")\n      then:\n        - tomli\n  run:\n    - python\n    - scipy\n    - matplotlib-base\n    - plotly\n    - h5py\n    - xarray\n    - netcdf4\n    - rich\n    - pooch\n    - paramiko\n    - tqdm\n\ntests:\n  - python:\n      imports:\n        - cherab.lhd\n        - cherab.lhd.emc3\n        - cherab.lhd.machine\n        - cherab.lhd.observer\n        - cherab.lhd.tools\n      pip_check: false\n\n  - script:\n      - pytest ./tests\n    requirements:\n      run:\n        - pytest\n        - pytest-cov\n    files:\n      source:\n        - tests/\n\nabout:\n  homepage: https://github.com/munechika-koyo/cherab_lhd\n  summary: \"CHERAB LHD machine-dependent extension\"\n  description: |\n    CHERAB-LHD is the Large Helical Device (LHD) machine-dependent extensions of cherab code.\n    LHD is a helical magnetic confinement fusion device in the National Institute for Fusion Science (NIFS) in Japan.\n  license: BSD-3-Clause\n  license_file: LICENSE.md\n  documentation: https://cherab-lhd.readthedocs.io/\n  repository: https://github.com/munechika-koyo/cherab_lhd\n\nextra:\n  recipe-maintainers:\n    - munechika-koyo\n",

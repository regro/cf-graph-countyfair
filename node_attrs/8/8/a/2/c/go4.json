  "name": "go4",
  "osx_64_meta_yaml": {
    "about": {
      "description": "Go4 separates analysis and GUI in two tasks which could run on different nodes.\nCommunication is done through threads and sockets. The GUI is built with the\nQt widget library using the Qt designer. Qt and ROOT are interfaced by QtROOT.\nFull ROOT functionality including menus and graphics is available without modifications.\nThe Go4 analysis framework provides the syntax to organize the analysis in steps\nwhich can be controlled from the GUI. Each step has its own IO and processing classes. \nThe Go4 event classes can be used to construct at runtime complex (composite) events which\nare stored by Go4 in trees and branches without explicit programming. The Go4 GUI includes\na browser and tree viewer which can be used without analysis to process standard ROOT files.\nThe tree viewer resolves arbitrary hierarchy levels of composite event trees.",
      "dev_url": "https://github.com/gsi-ee/go4",
      "doc_url": "https://www.gsi.de/en/work/research/experiment_electronics/data_processing/data_analysis/the_go4_home_page/documentation",
      "home": "https://www.gsi.de/en/work/research/experiment_electronics/data_processing/data_analysis/the_go4_home_page",
      "license": "GPL-3.0-or-later",
      "license_family": "GPL-3.0-or-later",
      "license_file": "LICENSE",
      "summary": "The object-oriented system Go4 (GSI Object Oriented On-line Off-line system)\nis based on ROOT (R. Brun et al.) with the specific requirements of the low\nand medium energy nuclear and atomic physics experiments implemented as extensions."
    },
    "build": {
      "number": "0",
      "script": "$RECIPE_DIR/build.sh"
    },
    "extra": {
      "recipe-maintainers": [
        "HLinde"
      ]
    },

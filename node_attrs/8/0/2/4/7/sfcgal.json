  "linux_64_meta_yaml": {
    "about": {
      "description": "SFCGAL is a C++ wrapper library around CGAL with the aim of supporting ISO 19107:2013 and OGC Simple Features Access 1.2 for 3D operations.\nSFCGAL provides standard compliant geometry types and operations. PostGIS uses the C API, to expose some SFCGAL's functions in spatial databases (cf. PostGIS manual).",
      "dev_url": "https://gitlab.com/sfcgal/SFCGAL",
      "doc_url": "https://sfcgal.gitlab.io/SFCGAL/",
      "home": "https://sfcgal.gitlab.io/SFCGAL/",
      "license": "LGPL-2.0-or-later",
      "license_family": "LGPL-2.0-or-later",
      "license_file": "LICENSE",
      "summary": "A wrapper around CGAL that intents to implement 2D and 3D operations on OGC standards models"
    },
    "build": {
      "number": "0",
      "script": [
        "export CXXFLAGS=\"$CXXFLAGS -Wno-template-body\"",
        "cmake -S . -B build -G Ninja -Wno-dev ${CMAKE_ARGS}",
        "cmake --build build --parallel ${{ CPU_COUNT }}",
        "ctest --test-dir build --output-on-failure",
        "cmake --install build"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "multimeric"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "sfcgal",
        "requirements": {
          "build": [
            "cxx_compiler_stub",
            "c_stdlib_stub",
            "cmake",
            "ninja",
            "pkg-config"
          ],
          "host": [
            "cgal-cpp >=5.6",
            "gmp",
            "mpfr",
            "libboost-devel",
            "nlohmann_json"
          ],
          "run": []
        },
        "tests": [
          {
            "package_contents": {
              "files": [
                "lib/pkgconfig/sfcgal.pc"
              ],
              "include": [
                "SFCGAL/config.h"
              ],
              "lib": [
                "SFCGAL"
              ]
            }
          },
          {
            "script": [
              "sfcgal-config --version",
              "sfcgal-config --libs"
            ]
          }
        ],
        "version": "2.2.0"
      }
    ],

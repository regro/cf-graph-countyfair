  "raw_meta_yaml": "context:\n  version: \"0.3.25\"\n\npackage:\n  name: phraze\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/sts10/phraze/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: dd8697f531afcda654d610570f5d754ceb08f36e98f8dacb46963b511f218b49\n\nbuild:\n  number: 1\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n          # copy shell completion files and man page\n          - mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions $PREFIX/share/man/man1\n          - cp target/completions/phraze.bash $PREFIX/share/bash-completion/completions/phraze\n          - cp target/completions/phraze.fish $PREFIX/share/fish/vendor_completions.d/phraze.fish\n          - cp target/completions/_phraze     $PREFIX/share/zsh/site-functions/_phraze\n          - cp target/man/phraze.1            $PREFIX/share/man/man1/phraze.1\n      - if: win\n        then:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n          # copy shell completion files and man page\n          - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n          - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n          - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n          - mkdir %LIBRARY_PREFIX%\\share\\man\\man1\n          - powershell -Command \"Copy-Item -Path 'target\\completions\\phraze.bash' -Destination '%LIBRARY_PREFIX%\\share\\bash-completion\\completions\\phraze'\"\n          - powershell -Command \"Copy-Item -Path 'target\\completions\\phraze.fish' -Destination '%LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\phraze.fish'\"\n          - powershell -Command \"Copy-Item -Path 'target\\completions\\_phraze'     -Destination '%LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_phraze'\"\n          - powershell -Command \"Copy-Item -Path 'target\\man\\phraze.1'            -Destination '%LIBRARY_PREFIX%\\share\\man\\man1\\phraze.1'\"\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n\ntests:\n  - script:\n      - phraze --help\n      - phraze --version\n  - package_contents:\n      bin:\n        - phraze\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/phraze\n            - share/fish/vendor_completions.d/phraze.fish\n            - share/zsh/site-functions/_phraze\n            - share/man/man1/phraze.1\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/phraze\n            - Library/share/fish/vendor_completions.d/phraze.fish\n            - Library/share/zsh/site-functions/_phraze\n            - Library/share/man/man1/phraze.1\n      strict: true\n\nabout:\n  homepage: https://github.com/sts10/phraze\n  summary: Random passphrase generator\n  description: |\n    Phraze is a random passphrase generator that generates passphrases with\n    user-configurable entropy, word counts, and built-in word lists. It is\n    fast, supports a variety of separator options, and can include numbers,\n    symbols, and capital letters.\n  license: MPL-2.0\n  license_file:\n    - LICENSE.txt\n    - THIRDPARTY.yml\n  repository: https://github.com/sts10/phraze\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

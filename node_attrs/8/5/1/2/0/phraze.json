  "linux_64_meta_yaml": {
    "about": {
      "description": "Phraze is a random passphrase generator that generates passphrases with\nuser-configurable entropy, word counts, and built-in word lists. It is\nfast, supports a variety of separator options, and can include numbers,\nsymbols, and capital letters.",
      "dev_url": "https://github.com/sts10/phraze",
      "home": "https://github.com/sts10/phraze",
      "license": "MPL-2.0",
      "license_family": "MPL-2.0",
      "license_file": "LICENSE.txt",
      "summary": "Random passphrase generator"
    },
    "build": {
      "number": "1",
      "script": {
        "content": [
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .",
          "mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions $PREFIX/share/man/man1",
          "cp target/completions/phraze.bash $PREFIX/share/bash-completion/completions/phraze",
          "cp target/completions/phraze.fish $PREFIX/share/fish/vendor_completions.d/phraze.fish",
          "cp target/completions/_phraze     $PREFIX/share/zsh/site-functions/_phraze",
          "cp target/man/phraze.1            $PREFIX/share/man/man1/phraze.1",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "phraze",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "phraze --help",
              "phraze --version"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "phraze"
              ],
              "files": [
                "share/bash-completion/completions/phraze",
                "share/fish/vendor_completions.d/phraze.fish",
                "share/zsh/site-functions/_phraze",
                "share/man/man1/phraze.1"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.3.25"
      }
    ],

  "feedstock_name": "flyctl",
  "hash_type": "sha256",
  "linux_64_meta_yaml": {
    "about": {
      "description": "flyctl is the command-line interface for the fly.io platform for\ndeploying and running applications on scalable hardware-isolated sandboxes.\nUse flyctl to launch apps, manage deployments, scale machines, handle\nsecrets, configure networking, and more.",
      "dev_url": "https://github.com/superfly/flyctl",
      "doc_url": "https://fly.io/docs/flyctl/",
      "home": "https://fly.io/",
      "license": "Apache-2.0",
      "license_family": "Apache-2.0",
      "license_file": "src/LICENSE",
      "summary": "CLI for deploying and managing applications on fly.io"
    },
    "build": {
      "number": "0",
      "script": [
        "cd src",
        "go-licenses save . --ignore=github.com/in-toto/attestation/go/v1 --ignore=github.com/in-toto/in-toto-golang --ignore=github.com/jmespath/go-jmespath --ignore=github.com/launchdarkly/go-jsonstream/v3 --ignore=github.com/launchdarkly/go-sdk-common/v3 --save_path=../library_licenses",
        "BUILD_TIME=\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"",
        "SHORT_COMMIT_HASH=\"$(curl -s \"https://api.github.com/repos/superfly/flyctl/commits/v${{ version }}\" | jq -r '.sha' | cut -c 1-7)\"",
        "go build -v -o $PREFIX/bin/flyctl -ldflags=\"-s -w -X github.com/superfly/flyctl/internal/buildinfo.buildVersion=${{ version }} -X github.com/superfly/flyctl/internal/buildinfo.buildDate=${BUILD_TIME} -X github.com/superfly/flyctl/internal/buildinfo.commit=${SHORT_COMMIT_HASH}\" -trimpath -tags production .",
        "mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions",
        "$PREFIX/bin/flyctl completion bash > $PREFIX/share/bash-completion/completions/flyctl",
        "$PREFIX/bin/flyctl completion fish > $PREFIX/share/fish/vendor_completions.d/flyctl.fish",
        "$PREFIX/bin/flyctl completion zsh > $PREFIX/share/zsh/site-functions/_flyctl"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "flyctl",
        "requirements": {
          "build": [
            "go-nocgo_compiler_stub",
            "go-licenses"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "flyctl help",
              "flyctl version"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "flyctl"
              ],
              "files": [
                "share/bash-completion/completions/flyctl",
                "share/fish/vendor_completions.d/flyctl.fish",
                "share/zsh/site-functions/_flyctl"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.4.41"
      }
    ],
    "package": {
      "name": "flyctl",
      "version": "0.4.41"
    },
    "requirements": {
      "build": [
        "go-nocgo_compiler_stub",
        "go-licenses"
      ]

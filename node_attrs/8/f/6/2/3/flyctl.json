et SHORT_COMMIT_HASH=%%T\n        - go build -v -o %LIBRARY_BIN%\\flyctl.exe -ldflags=\"-s -w -X github.com/superfly/flyctl/internal/buildinfo.buildVersion=${{ version }} -X github.com/superfly/flyctl/internal/buildinfo.buildDate=%BUILD_TIME% -X github.com/superfly/flyctl/internal/buildinfo.commit=%SHORT_COMMIT_HASH%\" -trimpath -tags production .\n        # generate shell completions\n        - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n        - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n        - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n        - '%LIBRARY_BIN%\\flyctl.exe completion bash > %LIBRARY_PREFIX%\\share\\bash-completion\\completions\\flyctl'\n        - '%LIBRARY_BIN%\\flyctl.exe completion fish > %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\flyctl.fish'\n        - '%LIBRARY_BIN%\\flyctl.exe completion zsh > %LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_flyctl'\n\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntests:\n  - script:\n      - flyctl help\n      - flyctl version\n  - package_contents:\n      bin:\n        - flyctl\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/flyctl\n            - share/fish/vendor_completions.d/flyctl.fish\n            - share/zsh/site-functions/_flyctl\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/flyctl\n            - Library/share/fish/vendor_completions.d/flyctl.fish\n            - Library/share/zsh/site-functions/_flyctl\n      strict: true\n\nabout:\n  homepage: https://fly.io\n  summary: CLI for deploying and managing applications on fly.io\n  description: |\n    flyctl is the command-line interface for the fly.io platform for\n    deploying and running applications on scalable hardware-isolated sandboxes.\n    Use flyctl to launch apps, manage deployments, scale machines, handle\n    secrets, configure networking, and more.\n  l
  "raw_meta_yaml": "context:\n  version: \"4.2.2\"\n\npackage:\n  name: libcuba\n  version: ${{ version }}\n\nsource:\n  url: https://feynarts.de/cuba/Cuba-${{ version }}.tar.gz\n  sha256: 8d9f532fd2b9561da2272c156ef7be5f3960953e4519c638759f1b52fe03ed52\n\n  # from https://github.com/jschueller/cuba.git, author did not respond yet\n  patches:\n    - 0001-Add-CMake-script.patch\n    - 0002-Fix-build-on-MinGW.patch\n    - 0003-Fix-build-on-MSVC.patch\n    - 0005-Hardlink-KorobovCoeff.c.patch\n\nbuild:\n  number: 2\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - cmake\n    - ninja\n  run_exports:\n    - ${{ pin_subpackage('libcuba', upper_bound='x.x') }}\n\ntests:\n  - script:\n    - if: unix\n      then:\n        - test -f ${PREFIX}/include/cuba.h\n        - test -f ${PREFIX}/lib/libcuba${SHLIB_EXT}\n      else:\n        - if not exist %PREFIX%\\\\Library\\\\include\\\\cuba.h exit 1\n        - if not exist %PREFIX%\\\\Library\\\\lib\\\\cuba.lib exit 1\n\nabout:\n  homepage: \"https://feynarts.de/cuba/\"\n  license: LGPL-3.0-only\n  license_family: LGPL\n  license_file: COPYING\n  summary: \"Cuba - a library for multidimensional numerical integration\"\n  \nextra:\n  recipe-maintainers:\n    - jschueller\n",

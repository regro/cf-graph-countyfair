  "raw_meta_yaml": "{% set version = \"0.15.0\" %}\n\npackage:\n  name: qtkeychain\n  version: {{ version }}\n\nsource:\n  url: https://github.com/frankosterfeld/qtkeychain/archive/{{ version }}.tar.gz\n  sha256: f4254dc8f0933b06d90672d683eab08ef770acd8336e44dfa030ce041dc2ca22\n  # Various issues with cmake finding qtpaths with Qt6. Seems to try\n  # cmake instead. Patch below hardcodes name\n  patches:\n    - qtpaths.patch\n\nbuild:\n  skip: true  # [(win and vc<14) or ppc64le]\n  number: 1\n  run_exports:\n    - {{ pin_subpackage('qtkeychain', max_pin='x.x') }}\n\nrequirements:\n  build:\n    - pkg-config  # [unix]\n    - cmake\n    - make  # [unix]\n    - {{ compiler('c') }}\n    - {{ stdlib(\"c\") }}\n    - {{ compiler('cxx') }}\n  host:\n    - qt-main    \n    - libsecret  # [linux]\n    - glib       # [linux]\n    - zlib       # [linux]\n  run:\n    - qt-main\n    - libsecret  # [linux]\n    - zlib       # [linux]\ntest:\n  commands:\n    - test -f ${PREFIX}/lib/libqt5keychain${SHLIB_EXT}  # [not win]\n    - if not exist %LIBRARY_BIN%\\\\qt5keychain.dll exit 1  # [win]\n    - if not exist %LIBRARY_LIB%\\\\qt5keychain.lib exit 1  # [win]\n\noutputs:\n  - name: qtkeychain\n  - name: qtkeychain-qt6\n    script: build_qt6.sh  # [unix]\n    script: bld_qt6.bat  # [win]\n    run_exports:\n      - {{ pin_subpackage('qtkeychain-qt6', max_pin='x.x') }}\n    requirements:\n      build:\n        - pkg-config  # [unix]\n        - cmake\n        - make  # [unix]\n        - {{ compiler('c') }}\n        - {{ stdlib(\"c\") }}\n        - {{ compiler('cxx') }}\n        - qt6-main    # [build_platform != target_platform]\n      host:\n        - qt6-main\n        - libsecret  # [linux]\n        - glib       # [linux]\n        - zlib       # [linux]\n      run:\n        - qt6-main\n        - libsecret  # [linux]\n        - zlib       # [linux]\n    test:\n      commands:\n        - test -f ${PREFIX}/lib/libqt6keychain${SHLIB_EXT}  # [not win]\n        - if not exist %LIBRARY_BIN%\\\\qt6keychain.dll exit 1  # [win]\n        - if not exist %LIBRARY_LIB%\\\\qt6keychain.lib exit 1  # [win]\n\nabout:\n  home: https://github.com/frankosterfeld/qtkeychain\n  license: BSD-3-Clause\n  license_file: COPYING\n  summary: QtKeychain is a Qt API to store passwords and other secret data securely\n\nextra:\n  recipe-maintainers:\n    - ceholden\n    - gillins\n",

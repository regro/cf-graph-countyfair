  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: refnx\n  version: \"0.1.63\"\n  sha256: 1782542622889ba726138c480e8025ff0bcaca01e553a40792830f2f379f94ec\n  numpy: \"2.0.0\"\n  python_min: \"3.11\"\n\npackage:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  url: https://files.pythonhosted.org/packages/source/r/refnx/refnx-${{ version }}.tar.gz\n  sha256: ${{ sha256 }}\n\nbuild:\n  number: 1\n  skip: is_abi3 and not python_min\n  python:\n    version_independent: ${{ is_abi3 }}\n  script:\n    # rattler-build figures out the {.sh,.bat} extensions\n    - build\n\nrequirements:\n  build:\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - if: osx\n      then: llvm-openmp\n    - if: build_platform != target_platform\n      then:\n        - python ${{ python_min }}.*\n        - if: is_abi3\n          then: python-abi3\n        - cross-python_${{ target_platform }}\n        - numpy >=${{ numpy }}\n        - cython\n        - meson-python\n        - ninja\n  host:\n    - python ${{ python_min }}.*\n    - if: is_abi3\n      then: python-abi3\n    - numpy >=${{ numpy }}\n    - cython\n    - meson-python\n    - ninja\n    - pip\n    - python-build\n    - if: osx\n      then: llvm-openmp\n  run:\n    - python >=${{ python_min }}\n    - scipy\n    - orsopy\n    - if: osx\n      then: llvm-openmp\n\ntests:\n  - python:\n      imports:\n        - refnx\n      python_version:\n        - if: is_abi3\n          then: ${{ python_min }}.*\n        - \"*\"\n  - requirements:\n      run:\n        - pytest\n        - if: osx and win\n          then: pytest-qt\n        - if: is_abi3\n          then: abi3audit\n        - scipy >=1.2.0\n        - matplotlib\n        - ipywidgets\n        - traitlets\n        - corner\n        - tqdm\n        - attrs\n        - qtpy\n        - pyside6\n        - periodictable\n    script:\n      - python -c \"import refnx;refnx.test(tests=['refnx.reflect.tests.test_reflect'])\"\n      - if: unix\n        then: abi3audit $SP_DIR/refnx/reflect/_creflect.abi3.so -s -v --assume-minimum-abi3 ${{ python_min }}\n\nabout:\n  license: BSD-3-Clause\n  license_file: LICENSE\n  summary: Neutron and X-ray Reflectometry Analysis\n  homepage: https://github.com/refnx/refnx\n  documentation: https://refnx.github.io\n\nextra:\n  recipe-maintainers:\n    - andyfaff\n",

  "raw_meta_yaml": "context:\n  version: \"0.10.1\"\n\npackage:\n  name: dra\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/devmatteini/dra/archive/refs/tags/${{ version }}.tar.gz\n  sha256: 81fc4e6bd174d238932a6415db7029a84acda5f4dc84a285ee0a10c6b3cb3580\n\nbuild:\n  number: 2\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n          # generate shell completions\n          - mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions\n          - $PREFIX/bin/dra completion bash > $PREFIX/share/bash-completion/completions/dra\n          - $PREFIX/bin/dra completion fish > $PREFIX/share/fish/vendor_completions.d/dra.fish\n          - $PREFIX/bin/dra completion zsh > $PREFIX/share/zsh/site-functions/_dra\n      - if: win\n        then:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n          # generate shell completions\n          - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n          - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n          - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n          - '%LIBRARY_BIN%\\dra.exe completion bash > %LIBRARY_PREFIX%\\share\\bash-completion\\completions\\dra'\n          - '%LIBRARY_BIN%\\dra.exe completion fish > %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\dra.fish'\n          - '%LIBRARY_BIN%\\dra.exe completion zsh > %LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_dra'\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n\ntests:\n  - script:\n      - dra --help\n      - dra --version\n  - package_contents:\n      bin:\n        - dra\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/dra\n            - share/fish/vendor_completions.d/dra.fish\n            - share/zsh/site-functions/_dra\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/dra\n            - Library/share/fish/vendor_completions.d/dra.fish\n            - Library/share/zsh/site-functions/_dra\n      strict: true\n\nabout:\n  homepage: https://github.com/devmatteini/dra\n  summary: Download and install release assets from GitHub\n  description: |\n    dra eases downloading and installing release assets from GitHub:\n    no authentication needed for public repositories, built-in generation\n    of patterns to select an asset to download, automatic selection based\n    on your operating system and architecture, and support for downloading\n    and installing assets in the most common formats.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  repository: https://github.com/devmatteini/dra\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

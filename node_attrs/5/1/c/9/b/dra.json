  "linux_64_meta_yaml": {
    "about": {
      "description": "dra eases downloading and installing release assets from GitHub:\nno authentication needed for public repositories, built-in generation\nof patterns to select an asset to download, automatic selection based\non your operating system and architecture, and support for downloading\nand installing assets in the most common formats.",
      "dev_url": "https://github.com/devmatteini/dra",
      "home": "https://github.com/devmatteini/dra",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Download and install release assets from GitHub"
    },
    "build": {
      "number": "2",
      "script": {
        "content": [
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .",
          "mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions",
          "$PREFIX/bin/dra completion bash > $PREFIX/share/bash-completion/completions/dra",
          "$PREFIX/bin/dra completion fish > $PREFIX/share/fish/vendor_completions.d/dra.fish",
          "$PREFIX/bin/dra completion zsh > $PREFIX/share/zsh/site-functions/_dra",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "dra",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "dra --help",
              "dra --version"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "dra"
              ],
              "files": [
                "share/bash-completion/completions/dra",
                "share/fish/vendor_completions.d/dra.fish",
                "share/zsh/site-functions/_dra"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.10.1"
      }
    ],
    "package": {
      "name": "dra",
      "version": "0.10.1"
    },

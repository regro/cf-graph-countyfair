  "raw_meta_yaml": "# Jinja variables help maintain the recipe as you'll update the version only here.\n# sha256 is the prefered checksum -- you can get it for a file with:\n#  `openssl sha256 <file name>`.\n# You may need the openssl package, available on conda-forge\n#  `conda install openssl -c conda-forge``\nschema_version: 1\n\ncontext:\n  name: nibabel\n  version: 5.3.2\n  sha256: 0bdca6503b1c784b446c745a4542367de7756cfba0d72143b91f9ffb78be569b\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ name }}-${{ version }}.tar.gz\n  sha256: ${{ sha256 }}\n\nbuild:\n  number: 2\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv\n  python:\n    entry_points:\n      - nib-conform  = nibabel.cmdline.conform:main\n      - nib-convert  = nibabel.cmdline.convert:main\n      - nib-dicomfs  = nibabel.cmdline.dicomfs:main\n      - nib-diff     = nibabel.cmdline.diff:main\n      - nib-ls       = nibabel.cmdline.ls:main\n      - nib-nifti-dx = nibabel.cmdline.nifti_dx:main\n      - nib-roi      = nibabel.cmdline.roi:main\n      - nib-stats    = nibabel.cmdline.stats:main\n      - nib-tck2trk  = nibabel.cmdline.tck2trk:main\n      - nib-trk2tck  = nibabel.cmdline.trk2tck:main\n      - parrec2nii   = nibabel.cmdline.parrec2nii:main\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - hatchling\n    - hatch-vcs\n    - setuptools_scm\n  run:\n    - python >=${{ python_min }}\n    - packaging >=20\n    - numpy >=1.22\n    - importlib_resources >=5.12\n    - typing_extensions >=4.6\n\ntests:\n  - python:\n      imports:\n        - nibabel\n      python_version: ${{ python_min }}.*\n  - requirements:\n      run:\n        - python ${{ python_min }}.*\n        - pytest\n        - pytest-doctestplus\n        - pytest-httpserver\n        - pytest-xdist\n        - scipy\n        - pillow\n        - h5py\n        - indexed_gzip\n        - matplotlib\n        - pydicom\n        - pyzstd\n    script:\n      - nib-conform --help\n      - nib-convert --help\n      - nib-dicomfs --help\n      - nib-diff --help\n      - nib-ls --help\n      - nib-nifti-dx --help\n      - nib-roi --help\n      - nib-stats --help\n      - nib-tck2trk --help\n      - nib-trk2tck --help\n      - parrec2nii --help\n      - pytest --doctest-modules --doctest-plus --pyargs nibabel -n auto\n\nabout:\n  license: MIT\n  license_file: COPYING\n  summary: Python package to access a cacophony of neuro-imaging file formats\n  homepage: https://nipy.org/nibabel\n\nextra:\n  recipe-maintainers:\n    - arokem\n    - grlee77\n    - effigies\n",

  "linux_64_meta_yaml": {
    "about": {
      "description": "Flux is a tool for keeping Kubernetes clusters in sync with sources of\nconfiguration (like Git repositories and OCI artifacts), and automating\nupdates to configuration when there is new code to deploy. Flux v2 is\nbuilt from the ground up to use Kubernetes' API extension system, and to\nintegrate with Prometheus and other core components of the Kubernetes\necosystem.",
      "dev_url": "https://github.com/fluxcd/flux2",
      "doc_url": "https://fluxcd.io/flux/",
      "home": "https://fluxcd.io/",
      "license": "Apache-2.0",
      "license_family": "Apache-2.0",
      "license_file": "src/LICENSE",
      "summary": "Flux CLI - the command line tool for Flux v2"
    },
    "build": {
      "number": "0",
      "script": [
        "cd src",
        "bash manifests/scripts/bundle.sh",
        "go-licenses save ./cmd/flux --save_path ../library_licenses",
        "go build -v -o $PREFIX/bin/flux -ldflags=\"-s -w -X main.VERSION=${{ version }}\" ./cmd/flux"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "ytausch"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "flux",
        "requirements": {

  "raw_meta_yaml": "context:\n  version: \"0.9.0\"\n\npackage:\n  name: air\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/posit-dev/air/archive/refs/tags/${{ version }}.tar.gz\n  sha256: 55cae527153badeb348b7b04ffb3c9f1d9f20e27e388edeae694a05a5e32f289\n\nbuild:\n  number: 2\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --no-track --locked --bins --all-features --root ${{ PREFIX }} --path crates/air\n          # generate shell completions\n          - mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions\n          - $PREFIX/bin/air generate-shell-completion bash > $PREFIX/share/bash-completion/completions/air\n          - $PREFIX/bin/air generate-shell-completion fish > $PREFIX/share/fish/vendor_completions.d/air.fish\n          - $PREFIX/bin/air generate-shell-completion zsh > $PREFIX/share/zsh/site-functions/_air\n      - if: win\n        then:\n          - set CARGO_HOME=C:\\.cargo # work around cargo/libgit2 Windows MAX_PATH (260 char) limitation, cf. https://github.com/libgit2/libgit2/blob/main/docs/win32-longpaths.md\n          - cargo auditable install --no-track --locked --bins --all-features --root %LIBRARY_PREFIX% --path crates/air\n          # generate shell completions\n          - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n          - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n          - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n          - '%LIBRARY_BIN%\\air.exe generate-shell-completion bash > %LIBRARY_PREFIX%\\share\\bash-completion\\completions\\air'\n          - '%LIBRARY_BIN%\\air.exe generate-shell-completion fish > %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\air.fish'\n          - '%LIBRARY_BIN%\\air.exe generate-shell-completion zsh > %LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_air'\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-auditable\n    - cargo-bundle-licenses\n\ntests:\n  - script:\n      - air --help\n      - air --version\n  - package_contents:\n      bin:\n        - air\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/air\n            - share/fish/vendor_completions.d/air.fish\n            - share/zsh/site-functions/_air\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/air\n            - Library/share/fish/vendor_completions.d/air.fish\n            - Library/share/zsh/site-functions/_air\n      strict: true\n\nabout:\n  homepage: https://posit-dev.github.io/air/\n  repository: https://github.com/posit-dev/air\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  summary: An R formatter and language server\n  description: |\n    Air is an R formatter and language server, written in Rust.\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

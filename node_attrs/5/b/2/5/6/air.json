  "linux_64_meta_yaml": {
    "about": {
      "description": "Air is an R formatter and language server, written in Rust.",
      "dev_url": "https://github.com/posit-dev/air",
      "home": "https://posit-dev.github.io/air/",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "An R formatter and language server"
    },
    "build": {
      "number": "2",
      "script": {
        "content": [
          "cargo auditable install --no-track --locked --bins --all-features --root ${{ PREFIX }} --path crates/air",
          "mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions",
          "$PREFIX/bin/air generate-shell-completion bash > $PREFIX/share/bash-completion/completions/air",
          "$PREFIX/bin/air generate-shell-completion fish > $PREFIX/share/fish/vendor_completions.d/air.fish",
          "$PREFIX/bin/air generate-shell-completion zsh > $PREFIX/share/zsh/site-functions/_air",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "air",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-auditable",
            "cargo-bundle-licenses"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "air --help",
              "air --version"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "air"
              ],
              "files": [
                "share/bash-completion/completions/air",
                "share/fish/vendor_completions.d/air.fish",
                "share/zsh/site-functions/_air"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.9.0"
      }
    ],
    "package": {
      "name": "air",
      "version": "0.9.0"
    },

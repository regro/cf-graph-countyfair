  "raw_meta_yaml": "{% set name = \"pybammsolvers\" %}\n{% set version = \"0.7.0\" %}\n\npackage:\n  name: {{ name|lower }}\n  version: {{ version }}\n\nsource:\n  - url: https://github.com/pybamm-team/{{ name }}/archive/v{{ version }}.tar.gz\n    sha256: dc29a7d9765e85a508c2fa49ffc790f4e538ba6aea4a6da54b1eb179ab3668a3\n  - patches:\n    # use conda-forge CasADi\n    - 0001-Fix-USE_PYTHON_CASADI.patch\n    # remove CXX11 ABI definition to avoid incompatibility\n    - 0002-Remove-CXX11-ABI-Definition.patch\n    # find BLAS but still set SUNDIALS_LIBRARIES for pybammsolvers\n    - 0003-Fix-Windows-cmake-prefix-path.patch\n \nbuild:\n  number: 1\n  skip: true\n  script:\n    # it is recommended to use the llvm-openmp package on windows\n    # as vcomp14 is not updated by Microsoft anymore\n    - set \"CXXFLAGS=%CXXFLAGS% /openmp:llvm\"  # [win]\n    - {{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  \nrequirements:\n  build:\n    - {{ compiler('c') }}\n    - {{ stdlib(\"c\") }}\n    - {{ compiler('cxx') }}\n    - cmake\n    - make\n  host:\n    - python\n    - setuptools >=71\n    - casadi\n    - pybind11\n    - pip\n    - suitesparse\n    # need sundials 7.6+ for openmp support on osx builds\n    # remove once there is a migrator for sundials 7.7\n    - sundials ==7.7.*\n    - llvm-openmp  # [not linux]\n    - libgomp  # [linux]\n  run:\n    - python\n    - casadi\n    - numpy\n\ntest:\n  imports:\n    - pybammsolvers\n  commands:\n    - pip check\n  requires:\n    - pip\n\nabout:\n  home: https://github.com/pybamm-team/pybammsolvers\n  summary: Python interface for the IDAKLU solver\n  license: BSD-3-Clause\n  license_file: LICENSE\n\nextra:\n  recipe-maintainers:\n    - prady0t\n    - Saransh-cpp\n    - agriyakhetarpal\n",

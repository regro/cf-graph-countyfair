  "raw_meta_yaml": "context:\n  version: \"3.11.4\"\n\npackage:\n  name: dart-sdk\n  version: ${{ version }}\n\nsource:\n  - if: linux and x86_64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-linux-x64-release.zip\n      sha256: 52d62f05b007ccb7117cf41c19beda1c87c144b27ea600b16b4c9c8ea8fc8fd4\n  - if: linux and aarch64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-linux-arm64-release.zip\n      sha256: c35ba6f0de1f5ebbf23506612bffc347c7ba94c3a4c75110cab1157892166d3c\n  - if: win and x86_64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-windows-x64-release.zip\n      sha256: c7ba740dd776a18a492b7ef8691e389665f34076f91ede818b864dbc2ef517c3\n  - if: osx and x86_64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-macos-x64-release.zip\n      sha256: 1874e34c72666c83dfb006c5e009b18c31134b0f580f4e3fea519e7287b5c6b0\n  - if: osx and arm64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-macos-arm64-release.zip\n      sha256: 0f0c99b407992ee697d8c1553f384446215e5f8e7023db13738636495a29444f\n\nbuild:\n  number: 0\n  skip:\n    - ppc64le\n  dynamic_linking:\n    binary_relocation: false\n    missing_dso_allowlist:\n      # normal linux stuff that would go away if we had libgcc-ng in the run deps\n      - \"*/ld-linux.so.2\"\n      - \"*/lib64/ld-linux-x86-64.so.2\"\n      - \"*/libpthread.so.0\"\n      - \"*/libdl.so.2\"\n      - \"*/libm.so.6\"\n      - \"*/libc.so.6\"\n\ntests:\n  - package_contents:\n      bin:\n        - if: win\n          then: dart.exe\n  - script:\n      - dart --help\n\nabout:\n  homepage: https://dart.dev/\n  license: BSD-3-Clause\n  license_file: LICENSE\n  summary: a client-optimized language for developing fast apps on any platform\n  repository: https://github.com/dart-lang/sdk\n  documentation: https://dart.dev/\n\nextra:\n  recipe-maintainers:\n    - msarahan\n    - munechika-koyo\n",

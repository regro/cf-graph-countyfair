  "raw_meta_yaml": "context:\n  version: \"3.11.5\"\n\npackage:\n  name: dart-sdk\n  version: ${{ version }}\n\nsource:\n  - if: linux and x86_64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-linux-x64-release.zip\n      sha256: 57f3ab5ac24883060b1ff12bcdac472ed76563ec7364e88f8a6d41e4f0db075f\n  - if: linux and aarch64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-linux-arm64-release.zip\n      sha256: 50e9aba58f8717943854778a73074e63a80c42054355d35e2732a0cc0824a2fb\n  - if: win and x86_64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-windows-x64-release.zip\n      sha256: 044b9c58f45c7e8b67467395eaad469f67cd8797a73fbd1d2bb8a89a53b2dcba\n  - if: osx and x86_64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-macos-x64-release.zip\n      sha256: 94de6a18049c354026f5422446b311cfc96b51db6d316eeb7ca46ff14c0b8aaa\n  - if: osx and arm64\n    then:\n      url: https://storage.googleapis.com/dart-archive/channels/stable/release/${{ version }}/sdk/dartsdk-macos-arm64-release.zip\n      sha256: 3fd03deb3b0c7897a9896c3f5f3dda4a9fe63c43b14364ee928ec6db348be0ac\n\nbuild:\n  number: 0\n  skip:\n    - ppc64le\n  dynamic_linking:\n    binary_relocation: false\n    missing_dso_allowlist:\n      # normal linux stuff that would go away if we had libgcc-ng in the run deps\n      - \"*/ld-linux.so.2\"\n      - \"*/lib64/ld-linux-x86-64.so.2\"\n      - \"*/libpthread.so.0\"\n      - \"*/libdl.so.2\"\n      - \"*/libm.so.6\"\n      - \"*/libc.so.6\"\n\ntests:\n  - package_contents:\n      bin:\n        - if: win\n          then: dart.exe\n  - script:\n      - dart --help\n\nabout:\n  homepage: https://dart.dev/\n  license: BSD-3-Clause\n  license_file: LICENSE\n  summary: a client-optimized language for developing fast apps on any platform\n  repository: https://github.com/dart-lang/sdk\n  documentation: https://dart.dev/\n\nextra:\n  recipe-maintainers:\n    - msarahan\n    - munechika-koyo\n",

  "raw_meta_yaml": "context:\n  name: async-tiff\n  version: \"0.7.1\"\n  python_min: \"3.11\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/async_tiff-${{ version }}.tar.gz\n  sha256: dbef87b2696bea06161c5fd0d9546700b8a30c04d3033c9b68b4b162c4cfa2dc\n\nbuild:\n  number: 0\n  python:\n    version_independent: true\n  script:\n    env:\n      MATURIN_PEP517_ARGS: \"--features=abi3-py311,extension-module,lerc\"\n    content:\n      - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n      - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n\nrequirements:\n  build:\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler(\"c\") }}\n    - ${{ compiler(\"cxx\") }}\n    - ${{ compiler(\"rust\") }}\n    - cargo-bundle-licenses\n    - clangdev\n  host:\n    - maturin >=1.7,<2.0\n    - pip\n    - python ${{ python_min }}.*\n    - if: is_abi3\n      then:\n        - python-abi3 ${{ python_min }}.*\n  run:\n    - python >= ${{ python_min }}\n    - obspec\n\ntests:\n  - python:\n      imports:\n        - async_tiff\n      pip_check: true\n      python_version: [\"${{ python_min ~ '.*' }}\"]\n  - script:\n      # NOTE: we must manually set SP_DIR since it is not set.\n      # Can be removed once https://github.com/prefix-dev/rattler-build/issues/1733 is fixed.\n      - if: unix and is_abi3\n        then:\n          - abi3audit $SP_DIR/async_tiff/_async_tiff.abi3.so -s -v --assume-minimum-abi3 ${{ python_min }}\n      - if: win and is_abi3\n        then:\n          - abi3audit %SP_DIR%\\\\async_tiff\\\\_async_tiff.pyd -s -v --assume-minimum-abi3 ${{ python_min }}\n    requirements:\n      run:\n        - abi3audit\n\nabout:\n  homepage: http://developmentseed.org/async-tiff\n  repository: https://github.com/developmentseed/async-tiff\n  summary: Low-level asynchronous TIFF reader.\n  license: MIT OR Apache-2.0\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n\nextra:\n  recipe-maintainers:\n    - gadomski\n    - kylebarron\n    - weiji14\n",

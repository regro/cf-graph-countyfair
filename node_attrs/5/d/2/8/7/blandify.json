  "raw_meta_yaml": "context:\n  version: \"0.1.0\"\n  python_min: \"3.12\"\n\nrecipe:\n  name: blandify-split\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/moritzwilksch/blandify/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 2d4861ec7c16fe3fcb5079cc62c5e4903855bba62aa6aebe24144ff70a6f8009\n\nbuild:\n  number: 0\n\noutputs:\n  - package:\n      name: blandify-cli\n      version: ${{ version }}\n    build:\n      number: 0\n      script:\n        env:\n          CARGO_PROFILE_RELEASE_STRIP: symbols\n          CARGO_PROFILE_RELEASE_LTO: fat\n        content:\n          - if: unix\n            then:\n              - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n            else:\n              - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n          - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n    requirements:\n      build:\n        - ${{ stdlib('c') }}\n        - ${{ compiler('c') }}\n        - ${{ compiler('rust') }}\n        - cargo-bundle-licenses\n        - cargo-auditable\n    tests:\n      - script: blandify --help\n      - package_contents:\n          bin:\n            - blandify\n    about:\n      homepage: https://github.com/moritzwilksch/blandify\n      summary: CLI tool for Unicode normalization to strip LLM artifacts\n      description: |\n        blandify is a Unicode normalization tool that converts fancy Unicode\n        characters (smart quotes, em-dashes, special symbols) into plain ASCII\n        equivalents. This package provides the command-line interface.\n      license: MIT\n      license_file:\n        - LICENSE\n        - THIRDPARTY.yml\n      repository: https://github.com/moritzwilksch/blandify\n\n  - package:\n      name: blandify-python\n      version: ${{ version }}\n    build:\n      number: 0\n      script:\n        content:\n          - cd python && python -m pip install . -vv --no-deps --no-build-isolation\n    requirements:\n      build:\n        - ${{ stdlib('c') }}\n        - ${{ compiler('c') }}\n        - ${{ compiler('rust') }}\n        - cargo-bundle-licenses\n        - if: build_platform != target_platform\n          then:\n            - cross-python_${{ target_platform }}\n            - python ${{ python_min }}.*\n            - maturin >=1.0,<2.0\n      host:\n        - python ${{ python_min }}.*\n        - pip\n        - maturin >=1.0,<2.0\n      run:\n        - python >=${{ python_min }}\n    tests:\n      - python:\n          imports:\n            - blandify\n          pip_check: true\n          python_version: ${{ python_min }}.*\n    about:\n      homepage: https://github.com/moritzwilksch/blandify\n      summary: Python bindings for Unicode normalization to strip LLM artifacts\n      description: |\n        blandify is a Unicode normalization library that converts fancy Unicode\n        characters (smart quotes, em-dashes, special symbols) into plain ASCII\n        equivalents. This package provides the Python bindings via PyO3.\n      license: MIT\n      license_file:\n        - LICENSE\n      repository: https://github.com/moritzwilksch/blandify\n\nabout:\n  homepage: https://github.com/moritzwilksch/blandify\n  summary: Unicode normalization to strip LLM artifacts\n  description: |\n    blandify is a Unicode normalization tool that converts fancy Unicode\n    characters (smart quotes, em-dashes, special symbols) into plain ASCII\n    equivalents. Available as both a CLI tool and Python library.\n  license: MIT\n  license_file: LICENSE\n  repository: https://github.com/moritzwilksch/blandify\n\nextra:\n  feedstock-name: blandify\n  recipe-maintainers:\n    - moritzwilksch\n",

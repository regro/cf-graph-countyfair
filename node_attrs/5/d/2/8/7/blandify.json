    "about": {
      "description": "blandify is a Unicode normalization tool that converts fancy Unicode\ncharacters (smart quotes, em-dashes, special symbols) into plain ASCII\nequivalents. This package provides the command-line interface.",
      "dev_url": "https://github.com/moritzwilksch/blandify",
      "home": "https://github.com/moritzwilksch/blandify",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "CLI tool for Unicode normalization to strip LLM artifacts"
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"1.30.0\"\n  llvm_version: \"21\"\n\npackage:\n  name: ispc\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/ispc/ispc/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 73b30c74fdfc56c3097015476df14d0a4bcb6705d9e286c6d51c1ed578d49e22\n\nbuild:\n  number: 0\n  skip: not linux\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ stdlib('c') }}\n    - python *\n    - cmake\n    - clang     ${{ llvm_version }}.*\n    - clangxx   ${{ llvm_version }}.* \n    - clangdev  ${{ llvm_version }}.*\n    - llvmdev   ${{ llvm_version }}.*\n    - if: unix\n      then:\n        - make\n        - flex\n        - bison\n    - if: win\n      then:\n        - m2-flex\n        - m2-bison\n        - m2-m4\n\n  host:\n    - clangdev  ${{ llvm_version }}.*\n    - llvmdev   ${{ llvm_version }}.*\n    - llvm      ${{ llvm_version }}.*\n    - if: unix\n      then: ncurses\n    - zlib\n\ntests:\n  - script:\n      - ispc --version\n      - ispc --help\n\nabout:\n  homepage: https://ispc.github.io\n  license: BSD-3-Clause\n  license_file: LICENSE.txt\n  summary: 'Intel SPMD Program Compiler'\n  documentation: https://ispc.github.io/documentation.html\n  repository: https://github.com/ispc/ispc\n  description: |\n    `ispc` is a compiler for a variant of the C programming language, with\n    extensions for [single program, multiple\n    data](http://en.wikipedia.org/wiki/SPMD) programming.  Under the SPMD model,\n    the programmer writes a program that generally appears to be a regular serial\n    program, though the execution model is actually that a number of *program\n    instances* execute in parallel on the hardware.\n\nextra:\n  recipe-maintainers:\n    - isuruf\n    - eunos-1128\n",

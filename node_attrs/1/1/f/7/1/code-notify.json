      "description": "Code-Notify provides desktop notifications for AI coding tools.\nGet alerts when tasks complete or input is needed. Supports\nClaude Code, OpenAI Codex, and Google Gemini CLI.",
      "dev_url": "https://github.com/mylee04/code-notify",
      "home": "https://github.com/mylee04/code-notify",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Cross-platform desktop notifications for AI coding tools"
    },
    "build": {
      "noarch": "generic",
      "number": "0",
      "script": [
        "mkdir -p $PREFIX/bin $PREFIX/lib/code-notify",
        "cp bin/code-notify $PREFIX/bin/code-notify",
        "chmod +x $PREFIX/bin/code-notify",
        "ln -s code-notify $PREFIX/bin/cn",
        "ln -s code-notify $PREFIX/bin/cnp",
        "cp -r lib/code-notify/* $PREFIX/lib/code-notify/"
      ]
    },
    "extra": {

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"1.56.2\"\n\npackage:\n  name: broot\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/Canop/broot/archive/v${{ version }}.tar.gz\n  sha256: 3e7be4252c76565f6d71b34bd07d26e1444b9ac2e1c8271c724f6e866fe75565\n\nbuild:\n  number: 2\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --features clipboard --root ${{ PREFIX }} --path .\n          # copy shell completion files and prebuilt man page\n          - mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions $PREFIX/share/man/man1\n          - cp target/*/release/build/broot-*/out/broot.bash   $PREFIX/share/bash-completion/completions/broot\n          - cp target/*/release/build/broot-*/out/broot.fish   $PREFIX/share/fish/vendor_completions.d/broot.fish\n          - cp target/*/release/build/broot-*/out/_broot       $PREFIX/share/zsh/site-functions/_broot\n          - cp man/page                                        $PREFIX/share/man/man1/broot.1\n      - if: win\n        then:\n          - cargo auditable install --locked --no-track --bins --features clipboard --root %LIBRARY_PREFIX% --path .\n          # copy shell completion files and prebuilt man page\n          - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n          - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n          - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n          - mkdir %LIBRARY_PREFIX%\\share\\man\\man1\n          - powershell -Command \"Copy-Item -Path 'target\\release\\build\\broot-*\\out\\broot.bash' -Destination '%LIBRARY_PREFIX%\\share\\bash-completion\\completions\\broot'\"\n          - powershell -Command \"Copy-Item -Path 'target\\release\\build\\broot-*\\out\\broot.fish' -Destination '%LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\broot.fish'\"\n          - powershell -Command \"Copy-Item -Path 'target\\release\\build\\broot-*\\out\\_broot'     -Destination '%LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_broot'\"\n          - powershell -Command \"Copy-Item -Path 'man\\page'                                    -Destination '%LIBRARY_PREFIX%\\share\\man\\man1\\broot.1'\"\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-auditable\n    - cargo-bundle-licenses\n\ntests:\n  - script:\n      - broot --help\n      - broot --version\n  - package_contents:\n      bin:\n        - broot\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/broot\n            - share/fish/vendor_completions.d/broot.fish\n            - share/zsh/site-functions/_broot\n            - share/man/man1/broot.1\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/broot\n            - Library/share/fish/vendor_completions.d/broot.fish\n            - Library/share/zsh/site-functions/_broot\n            - Library/share/man/man1/broot.1\n      strict: true\n\nabout:\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  summary: Broot is a better way to navigate directories, find files, and launch commands.\n  description: |\n    Broot is a high-performance terminal file manager and navigator designed to provide a comprehensive overview of\n    large directory structures using a balanced, tree-based visualization. It enables users to instantly locate files\n    through fuzzy searching, navigate deeply nested hierarchies without losing context, and perform file manipulations\n    or custom shell commands directly from the interface.\n  homepage: https://dystroy.org/broot/\n  documentation: https://dystroy.org/broot/\n  repository: https://github.com/Canop/broot\n \nextra:\n  recipe-maintainers:\n    - dbast\n",

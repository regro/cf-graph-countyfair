  "linux_64_meta_yaml": {
    "about": {
      "description": "Broot is a high-performance terminal file manager and navigator designed to provide a comprehensive overview of\nlarge directory structures using a balanced, tree-based visualization. It enables users to instantly locate files\nthrough fuzzy searching, navigate deeply nested hierarchies without losing context, and perform file manipulations\nor custom shell commands directly from the interface.",
      "dev_url": "https://github.com/Canop/broot",
      "doc_url": "https://dystroy.org/broot/",
      "home": "https://dystroy.org/broot/",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Broot is a better way to navigate directories, find files, and launch commands."
    },
    "build": {
      "number": "2",
      "script": {
        "content": [
          "cargo auditable install --locked --no-track --bins --features clipboard --root ${{ PREFIX }} --path .",
          "mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions $PREFIX/share/man/man1",
          "cp target/*/release/build/broot-*/out/broot.bash   $PREFIX/share/bash-completion/completions/broot",
          "cp target/*/release/build/broot-*/out/broot.fish   $PREFIX/share/fish/vendor_completions.d/broot.fish",
          "cp target/*/release/build/broot-*/out/_broot       $PREFIX/share/zsh/site-functions/_broot",
          "cp man/page                                        $PREFIX/share/man/man1/broot.1",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "dbast"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "broot",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-auditable",
            "cargo-bundle-licenses"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "broot --help",
              "broot --version"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "broot"
              ],
              "files": [
                "share/bash-completion/completions/broot",
                "share/fish/vendor_completions.d/broot.fish",
                "share/zsh/site-functions/_broot",
                "share/man/man1/broot.1"
              ],
              "strict": true
            }
          }
        ],
        "version": "1.56.2"
      }
    ],

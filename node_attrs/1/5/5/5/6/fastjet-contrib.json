      "osx_arm64": "osx_64"
    },
    "conda_build": {
      "error_overlinking": true
    },
    "conda_build_tool": "rattler-build",
    "conda_forge_output_validation": true,
    "conda_install_tool": "pixi",
    "github": {
      "branch_name": "main",
      "tooling_branch_name": "main"
    },
    "provider": {
      "linux_aarch64": "default",
      "linux_ppc64le": "default"
    },
    "test": "native_and_emulated"
  },
  "feedstock_name": "fastjet-contrib",
  "hash_type": "sha256",
  "linux_64_meta_yaml": {
    "about": {
      "description": "The fastjet-contrib space is intended to provide a common location for\naccess to 3rd party extensions of FastJet.",
      "dev_url": "https://github.com/fjcontrib/fjcontrib",
      "doc_url": "https://fastjet.hepforge.org/contrib/",
      "home": "https://fastjet.hepforge.org/contrib/",
      "license": "GPL-2.0-or-later",
      "license_family": "GPL-2.0-or-later",
      "license_file": "COPYING",
      "summary": "FastJet Contrib: 3rd party extensions of FastJet"
    },
    "build": {
      "number": "1",
      "script": [
        "cp $BUILD_PREFIX/share/gnuconfig/config.* .",
        "./configure --help",
        "./configure --list",
        "./configure --fastjet-config=$(command -v fastjet-config) --prefix=$PREFIX CXX=$CXX",
        "make --jobs=\"${CPU_COUNT}\"",
        "make check --jobs=\"${CPU_COUNT}\"",
        "make install"
      ]
    },
    "extra": {
      "feedstock-name": "fastjet-contrib",
      "recipe-maintainers": [
        "kratsg",
        "matthewfeickert",
        "lgray"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "fastjet-contrib-static",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "cxx_compiler_stub",
            "automake",
            "libtool",
            "make",
            "pkg-config",
            "gnuconfig"
          ],
          "host": [
            "fastjet-cxx"
          ],
          "run": [
            "fastjet-cxx"
          ]
        },
        "tests": [
          {
            "requirements": {
              "run": [
                "cxx_compiler_stub",

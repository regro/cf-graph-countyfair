  "raw_meta_yaml": "context:\n  version: \"2.0.1\"\n\npackage:\n  name: libmcfp\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/mhekkel/libmcfp/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: bf09e0ac20767e0f37abfe5723545c8890b9adffe0fd80b1a818edc70b490ac2\n  patches:\n    - fix-error-category-singleton_refactor-last-option-storage.patch\n\nbuild:\n  number: 0\n  script:\n    - if: unix\n      then: |\n        set -exo pipefail\n        export CXXFLAGS=\"${CXXFLAGS} -D_LIBCPP_DISABLE_AVAILABILITY\"\n        cmake -S . -B build \\\n          ${CMAKE_ARGS} \\\n          -DBUILD_SHARED_LIBS=ON \\\n          -DBUILD_TESTING=ON\n        cmake --build build --parallel ${CPU_COUNT}\n        ctest -V --test-dir build\n        cmake --install build\n    - if: win\n      then: |\n        @echo on\n        cmake -S . -B build -G \"NMake Makefiles JOM\" %CMAKE_ARGS% -DBUILD_SHARED_LIBS=ON -DCMAKE_WINDOWS_EXPORT_ALL_SYMBOLS=ON -DBUILD_TESTING=ON\n        if errorlevel 1 exit 1\n        cmake --build build --parallel %CPU_COUNT%\n        if errorlevel 1 exit 1\n        set \"PATH=%SRC_DIR%\\build;%PATH%\"\n        if errorlevel 1 exit 1\n        ctest -V --test-dir build\n        if errorlevel 1 exit 1\n        cmake --install build\n        if errorlevel 1 exit 1\n\nrequirements:\n  build:\n    - ${{ compiler(\"cxx\") }}\n    - ${{ stdlib(\"c\") }}\n    - cmake\n    - if: unix\n      then: make\n    - if: win\n      then: jom\n  host:\n    - catch2\n    - fast_float\n  run_exports:\n    - ${{ pin_subpackage(\"libmcfp\", upper_bound=\"x\") }}\n  ignore_run_exports:\n    from_package:\n      - catch2\n\ntests:\n  - package_contents:\n      include:\n        - mcfp/mcfp.hpp\n        - mcfp/options.hpp\n        - mcfp/sections.hpp\n        - mcfp/error.hpp\n        - mcfp/charconv.hpp\n        - mcfp/text.hpp\n      lib:\n        - mcfp\n\nabout:\n  homepage: https://mhekkel.github.io/libmcfp\n  repository: https://github.com/mhekkel/libmcfp\n  documentation: https://mhekkel.github.io/libmcfp/api/library_root.html\n  license: BSD-2-Clause AND MIT AND LicenseRef-CC0-1.0\n  license_file: LICENSES/\n  summary: \"A library for parsing command line arguments and configuration files and making them available throughout a program.\"\n  description: |\n    This library attempts to implement the POSIX.1-2017 standard for parsing arguments passed to an application.\n    These arguments are delivered to the main function as the well known argc and argv parameters.\n    This library allows you to parse the contents of these variables and then provides easy access to the information.\n    The library also contains code to parse configuration files\n\nextra:\n  recipe-maintainers:\n    - eunos-1128\n",

  "raw_meta_yaml": "context:\n  version: \"20.0.0\"\n\npackage:\n  name: cargo-update\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/nabijaczleweli/cargo-update/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 7e9898ae686fe64c4cf75be5c4e9e6d5f6141371182a12e4bdaa806cfe321806\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --no-track --bins --root ${{ PREFIX }} --path .\n        else:\n          - cargo auditable install --no-track --bins --root %LIBRARY_PREFIX% --path .\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n  host:\n    - openssl\n    - libgit2\n    - if: unix\n      then: pkg-config\n\ntests:\n  - script:\n      - cargo install-update --help\n      - cargo install-update --version\n      - cargo help install-update\n      - cargo install update --help\n    requirements:\n      run:\n        - ${{ compiler('rust') }}\n  - package_contents:\n      bin:\n        - cargo-install-update\n        - cargo-install-update-config\n      strict: true\n\nabout:\n  homepage: https://github.com/nabijaczleweli/cargo-update\n  summary: A cargo subcommand for checking and applying updates to installed executables\n  description: |\n    cargo-update provides the `cargo install-update` subcommand for cargo,\n    allowing you to check for and apply updates to all installed cargo binaries.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  documentation: https://github.com/nabijaczleweli/cargo-update#readme\n  repository: https://github.com/nabijaczleweli/cargo-update\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

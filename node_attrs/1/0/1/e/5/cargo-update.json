    "about": {
      "description": "cargo-update provides the `cargo install-update` subcommand for cargo,\nallowing you to check for and apply updates to all installed cargo binaries.",
      "dev_url": "https://github.com/nabijaczleweli/cargo-update",
      "doc_url": "https://github.com/nabijaczleweli/cargo-update#readme",
      "home": "https://github.com/nabijaczleweli/cargo-update",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "A cargo subcommand for checking and applying updates to installed executables"
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "cargo auditable install --no-track --bins --root ${{ PREFIX }} --path .",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "cargo-update",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable"
          ],
          "host": [
            "openssl",
            "libgit2",
            "pkg-config"
          ],
          "run": []
        },
        "tests": [
          {
            "requirements": {
              "run": [
                "rust_compiler_stub"
              ]
            },
            "script": [
              "cargo install-update --help",
              "cargo install-update --version",
              "cargo help install-update",
              "cargo install update --help"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "cargo-install-update",
                "cargo-install-update-config"
              ],
              "strict": true
            }
          }
        ],
        "version": "20.0.0"
      }

  "raw_meta_yaml": "context:\n  version: 1.97.3\n\npackage:\n  name: dart-sass\n  version: ${{ version }}\n\nsource:\n  - if: osx and arm64\n    then:\n      url: https://github.com/sass/dart-sass/releases/download/${{ version }}/dart-sass-${{ version }}-macos-arm64.tar.gz\n      sha256: b73fda91716e9f4fa2e997d89eb4988adb1ba9718c715516743380f797309d0d\n    else:\n      url: https://github.com/sass/dart-sass/archive/refs/tags/${{ version }}.tar.gz\n      sha256: 22ea1f689060edf10ee533047f553ad1c558209ea642687998f4ccb465faa9fc\n\nbuild:\n  number: 0\n  dynamic_linking:\n    binary_relocation: false\n  skip:\n    # we don't have dart-sdk on ppc64le, so we can't build this.\n    - ppc64le\n\nrequirements:\n  host:\n    - if: not (osx and arm64)\n      then:\n        - dart-sdk\n        - buf\n\ntests:\n  - script:\n      - sass --version\n      - sass test.sass\n    files:\n      recipe:\n        - test.sass\n\nabout:\n  homepage: https://sass-lang.com/dart-sass\n  license: MIT\n  license_file:\n    - if: osx and arm64\n      then: src/LICENSE\n      else: LICENSE\n  summary: Dart implementation of Sass. Sass makes CSS fun again.\n  documentation: https://sass-lang.com/dart-sass\n  repository: https://github.com/sass/dart-sass\n\nextra:\n  recipe-maintainers:\n    - msarahan\n    - munechika-koyo\n",

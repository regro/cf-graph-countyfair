 "raw_meta_yaml": "context:\n  name: docling\n  version: 2.6.0\n  python_min: \"3.10\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/docling-${{ version }}.tar.gz\n  sha256: 282755472a1a1d4a4088d794c6a89f399a5b7fbcea8b5f45012c441670b538d5\n  patches:\n    # lower the scipy lower bounds to match with c-f and avoid conflicts\n    - fix-deps.patch\n\nbuild:\n  number: 0\n  noarch: python\n  script: python -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - docling = docling.cli.main:app\n\nrequirements:\n  host:\n    - python ${{ python_min }}\n    - poetry-core\n    - pip\n  run:\n    - python >=${{ python_min }}\n    - pydantic >=2.0.0,<3.0.0\n    - docling-core >=2.3.0,<3.0.0\n    - docling-ibm-models >=2.0.3,<3.0.0\n    - deepsearch-glm >=0.26.1,<0.27.0\n    - filetype >=1.2.0,<2.0.0\n    - pypdfium2 >=4.30.0,<5.0.0\n    - pydantic-settings >=2.3.0,<3.0.0\n    - huggingface_hub >=0.23,<1\n    - requests >=2.32.3,<3.0.0\n    - easyocr >=1.7.0,<2.0.0\n    - docling-parse >=2.0.2,<3.0.0\n    - certifi >=2024.7.4\n    - rtree >=1.3.0,<2.0.0\n    - scipy >=1.13.1,<2.0.0\n    - pyarrow >=16.1.0,<17.0.0\n    - typer >=0.12.5,<0.13.0\n    - python-docx >=1.1.2,<2.0.0\n    - python-pptx >=1.0.2,<2.0.0\n    - beautifulsoup4 >=4.12.3,<5.0.0\n    - pandas >=2.1.4,<3.0.0\n    - marko >=2.1.2,<3.0.0\n    - openpyxl >=3.1.5,<4.0.0\n  run_constraints:\n    - tesserocr >=2.7.1,<3.0.0\n\ntests:\n  - python:\n      imports:\n        - docling\n      # `pip check` fails because:\n      # - \"easyocr 1.7.1 requires ninja, which is not installed\". See https://github.com/conda-forge/easyocr-feedstock/pull/12#issuecomment-2484602055\n      # - \"scikit-image 0.24.0 has requirement numpy>=1.23, but you have numpy 1.22.4.\"\n      pip_check: false\n      python_version: ${{ python_min }}\n  - script:\n      - docling --help\n    requirements:\n      run:
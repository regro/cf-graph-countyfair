  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"1.0.3\"\n\npackage:\n  name: \"abscab-cpp\"\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/jonathanschilling/abscab-cpp/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: d7d4d8060117ac047ca7a3c5824f79cc7d8f42c538e542946650b188c7d2e145\n\nbuild:\n  number: 0\n  skip:\n    # Windows can be supported, but skipping for simplicity\n    - win\n  script:\n    # Repository uses Bazel, but building manually to avoid having to use Bazel in conda-forge\n    - cd ./abscab\n    - $CXX ./abscab.cc -o $PREFIX/lib/libabscab${SHLIB_EXT} $CXXFLAGS -shared $LDFLAGS\n    - mkdir -p $PREFIX/include/abscab-cpp\n    - mv ./abscab.hh $PREFIX/include/abscab-cpp/\n\nrequirements:\n  run_exports:\n    - ${{ pin_subpackage(\"abscab-cpp\", upper_bound=\"x.x\") }}\n  build:\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler(\"cxx\") }}\n  # c.f. https://conda-forge.org/docs/maintainer/knowledge_base/#openmp\n  # Run exports from the host packages ensure that OpenMP runtime is available\n  host:\n    - if: linux\n      then: libgomp\n    - if: osx\n      then: llvm-openmp\n\ntests:\n  - package_contents:\n      strict: true\n      lib:\n        - abscab\n      include:\n        - abscab-cpp/abscab.hh\n      files:\n        - etc/conda/test-files/abscab-cpp/*\n\n  - files:\n      source:\n        - abscab/demo_abscab.cc\n        - test_util/test_util.hh\n        - test_util/test_util.cc\n    requirements:\n      run:\n        - ${{ compiler(\"cxx\") }}\n        - sed\n    script:\n      - mv ./abscab/demo_abscab.cc .\n      - sed -i 's|abscab-cpp/||g' demo_abscab.cc\n      - sed -i 's|abscab-cpp/||g' test_util/test_util.cc\n      - $CXX ./demo_abscab.cc ./test_util/test_util.cc -o ./DemoAbscab $CXXFLAGS -I${CONDA_PREFIX}/include/abscab-cpp -I. -fopenmp $LDFLAGS -labscab\n      - ./DemoAbscab\n\nabout:\n  summary: Accurate Biot-Savart routines with Correct Asymptotic Behaviour (C++)\n  license: Apache-2.0\n  license_file: LICENSE\n  homepage: https://github.com/jonathanschilling/abscab-cpp\n  repository: https://github.com/jonathanschilling/abscab-cpp\n  documentation: https://github.com/jonathanschilling/abscab-cpp\n\n\nextra:\n  recipe-maintainers:\n    - matthewfeickert\n",

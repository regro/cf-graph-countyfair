  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: ifermi\n  version: \"0.3.7\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/ifermi-${{ version }}.tar.gz\n  sha256: 142528ad302f511e31b641d40f42dde2d412bb1b7a4cccf42d0c04be2ae14a95\n\nbuild:\n  number: 1\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv\n  python:\n    entry_points:\n      - ifermi = ifermi.cli:cli\n\nrequirements:\n  host:\n    - pip\n    - python ${{ python_min }}.*\n    - packaging\n    - setuptools\n  run:\n    - boltztrap2\n    - click\n    - dataclasses >=0.6\n    - matplotlib-base\n    - meshcut\n    - monty\n    - networkx\n    - numpy\n    - plotly\n    - psutil\n    - pyfftw\n    - pymatgen >=2017.12.30\n    - python >=${{ python_min }}\n    - scikit-image\n    - scipy\n    - spglib\n    - tabulate\n    - trimesh\n\ntests:\n  - python:\n      imports:\n        - ifermi\n      pip_check: true\n      python_version: ${{ python_min }}\n  - requirements:\n      run:\n        - pip\n        - python ${{ python_min }}.*\n    script:\n      - ifermi --help\n\nabout:\n  license: MIT\n  license_file: LICENSE\n  summary: Fermi surface generation, analysis and visualisation.\n  description: |\n    IFermi is a Python (3.6+) library and set of command-line tools for\n    the generation, analysis, and visualisation of Fermi surfaces and\n    Fermi slices. The goal of the library is to provide fully featured\n    FermiSurface and FermiSlice objects that allow for easy manipulation\n    and analysis.\n  homepage: https://github.com/fermisurfaces/IFermi\n  repository: https://github.com/fermisurfaces/IFermi\n  documentation: https://fermisurfaces.github.io/IFermi\n\nextra:\n  recipe-maintainers:\n    - jan-janssen\n",

  "raw_meta_yaml": "context:\n  version: \"3.0.0\"\n\npackage:\n  name: artem\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/FineFindus/artem/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: d180ff37691654744891de77d956c83cc334c82e2377d1cfe4b795234753781a\n\nbuild:\n  number: 1\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n          # copy shell completion files and man page\n          - mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions $PREFIX/share/man/man1\n          - cp target/*/release/build/artem-*/out/artem.bash   $PREFIX/share/bash-completion/completions/artem\n          - cp target/*/release/build/artem-*/out/artem.fish   $PREFIX/share/fish/vendor_completions.d/artem.fish\n          - cp target/*/release/build/artem-*/out/_artem       $PREFIX/share/zsh/site-functions/_artem\n          - cp target/*/release/build/artem-*/out/artem.1      $PREFIX/share/man/man1/artem.1\n      - if: win\n        then:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n          # copy shell completion files and man page\n          - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n          - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n          - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n          - mkdir %LIBRARY_PREFIX%\\share\\man\\man1\n          - powershell -Command \"Copy-Item -Path 'target\\release\\build\\artem-*\\out\\artem.bash' -Destination '%LIBRARY_PREFIX%\\share\\bash-completion\\completions\\artem'\"\n          - powershell -Command \"Copy-Item -Path 'target\\release\\build\\artem-*\\out\\artem.fish' -Destination '%LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\artem.fish'\"\n          - powershell -Command \"Copy-Item -Path 'target\\release\\build\\artem-*\\out\\_artem'     -Destination '%LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_artem'\"\n          - powershell -Command \"Copy-Item -Path 'target\\release\\build\\artem-*\\out\\artem.1'    -Destination '%LIBRARY_PREFIX%\\share\\man\\man1\\artem.1'\"\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n\ntests:\n  - script:\n      - artem --help\n      - artem --version\n  - package_contents:\n      bin:\n        - artem\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/artem\n            - share/fish/vendor_completions.d/artem.fish\n            - share/zsh/site-functions/_artem\n            - share/man/man1/artem.1\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/artem\n            - Library/share/fish/vendor_completions.d/artem.fish\n            - Library/share/zsh/site-functions/_artem\n            - Library/share/man/man1/artem.1\n      strict: true\n\nabout:\n  summary: Convert images from multiple formats (jpg, png, webp, etc.) to ASCII art\n  description: |\n    artem is a small CLI program written in Rust to easily convert images to ASCII art.\n    It supports conversion from multiple image formats (jpg, png, webp, gif and many more)\n    to ASCII art, with truecolor support by default.\n  license: MPL-2.0\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  homepage: https://github.com/FineFindus/artem\n  repository: https://github.com/FineFindus/artem\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

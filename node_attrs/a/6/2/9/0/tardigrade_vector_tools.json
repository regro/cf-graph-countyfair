  "linux_64_meta_yaml": {
    "about": {
      "description": "tardigrade_vector_tools A collection of tools for C++ that make interfacing with vectors easier\nand less prone to error. These tools also allow the user access to the powerful Eigen library which provides matrix\nutilities in such a way that Eigen does not need to be used explicitly in the user's code.\n",
      "dev_url": "https://github.com/UCBoulder/tardigrade_vector_tools",
      "home": "https://github.com/UCBoulder/tardigrade_vector_tools",
      "license": "BSD-3-Clause",
      "license_file": "LICENSE",
      "summary": "A collection of tools for vector manipulation"
    },
    "build": {
      "number": "0",
      "script": [
        "set -x",
        "cmake -S . -B build -DCMAKE_BUILD_TYPE=Release ${CMAKE_ARGS}",
        "cmake --install build --prefix ${PREFIX}"
      ],
      "script_env": [
        "SETUPTOOLS_SCM_PRETEND_VERSION=0.8.7"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "NateAM",
        "kbrindley"
      ]
    },
    "package": {
      "name": "tardigrade_vector_tools",
      "version": "0.8.7"
    },
    "requirements": {
      "build": [
        "c_compiler_stub",
        "c_stdlib_stub",
        "cxx_compiler_stub",
        "make",
        "cmake >=3.18",
        "tardigrade_error_tools >=0.9.7"
      ],
      "host": [
        "breathe >=4.3.0",
        "sphinx >=3.0.4",
        "sphinx_rtd_theme >=0.4.3",
        "sphinxcontrib-bibtex",
        "setuptools >=62",
        "setuptools_scm >=6.2",
        "eigen >=3.3.7",

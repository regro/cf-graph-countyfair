        "doxygen"
      ],
      "run": [
        "python",
        "eigen >=3.3.7",
        "tardigrade_error_tools >=0.9.7"
      ]
    },
    "schema_version": 0,
    "source": {
      "sha256": "ba24dcf6d1cf60cf3e851629588334556aef16c372d3cb634aaed69d2bba7e36",
      "url": "https://github.com/UCBoulder/tardigrade_vector_tools/archive/refs/tags/0.8.7.tar.gz"
    },
    "test": {
      "commands": [
        "echo running tests",
        "set -x",
        "cmake -S . -B build -DCMAKE_BUILD_TYPE=conda-test -DCMAKE_INSTALL_LIBDIR=lib",
        "cmake --build build --verbose --parallel 4",
        "ctest --test-dir build --output-on-failure -R 'test_' --parallel 4"
      ],
      "requires": [
        "cxx_compiler_stub",

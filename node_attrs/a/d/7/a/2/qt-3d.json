  "raw_meta_yaml": "context:\n  version: \"6.11.0\"\n  maj_min: ${{ (version | split('.'))[:2] | join('.') }}\n\npackage:\n  name: qt6-3d\n  version: ${{ version }}\n\nsource:\n  url: https://download.qt.io/official_releases/qt/${{ maj_min }}/${{ version }}/submodules/qt3d-everywhere-src-${{ version }}.tar.xz\n  md5: c269ed568bc2faa4493b09821c5c82e9\n  patches:\n    # qt tries to run assimp and fails on win32 although assimp is found \n    - patches/0033-qt3d-disable-assimp-compile-test.patch\n\nbuild:\n  number: 1\n\nrequirements:\n  build:\n    - cmake\n    - ninja\n    - perl\n    - ${{ compiler('cxx') }}\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - if: build_platform != target_platform\n      then: qt6-main ${{ version }}.*\n  host:\n    - qt6-main ${{ version }}.*\n    - assimp\n    - libzlib\n    - if: linux\n      then:\n        - libgl-devel\n        - libegl-devel\n        - libopengl-devel\n    - if: not osx\n      then:\n        - libvulkan-headers\n        - libvulkan-loader\n  run:\n    - qt6-main ${{ version }}.*\n  run_exports:\n    - ${{ pin_subpackage('qt6-3d', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - if: unix\n        then:\n          - test -d $PREFIX/include/qt6/Qt3DAnimation\n          - test -d $PREFIX/include/qt6/Qt3DCore\n          - test -d $PREFIX/include/qt6/Qt3DExtras\n          - test -d $PREFIX/include/qt6/Qt3DLogic\n          - test -d $PREFIX/include/qt6/Qt3DRender\n          - test -f $PREFIX/lib/libQt63DAnimation${SHLIB_EXT}\n        else:\n          - if not exist %PREFIX%\\\\Library\\\\include\\\\qt6\\\\Qt3DAnimation exit 1\n          - if not exist %PREFIX%\\\\Library\\\\lib\\\\Qt63DAnimation.lib exit 1\n          - if not exist %PREFIX%\\\\Library\\\\bin\\\\Qt63DAnimation.dll exit 1\n\nabout:\n  homepage: http://qt-project.org\n  license: LGPL-3.0-only\n  license_file: LICENSES/LGPL-3.0-only.txt\n  summary: Qt is a cross-platform application and UI framework.\n  description: |\n    Qt helps you create connected devices, UIs & applications that run\n    anywhere on any device, on any operating system at any time.\n  documentation: http://doc.qt.io/\n  repository: https://github.com/qt/qt3d\n\nextra:\n  recipe-maintainers:\n    - jschueller\n  feedstock-name: qt-3d\n",

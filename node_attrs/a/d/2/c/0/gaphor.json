  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  name: gaphor\n  version: \"3.3.1\"\n  python_min: \"3.12\"\n  # segfaults if missing on e.g. a gtk3-based distro\n  linux_extra: libgles\n  osx_extra: pyobjc-framework-cocoa >=9.0.1\n  # nothing yet\n  win_extra: python *\n  noarch_extra: |-\n    ${{ linux_extra if noarch_platform == \"linux\" }}\n    ${{ osx_extra if noarch_platform == \"osx\" }}\n    ${{ win_extra if noarch_platform == \"win\" }}\n  python_check_max: \"3.14\"\n\npackage:\n  name: gaphor\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/g/gaphor/gaphor-${{ version }}.tar.gz\n  sha256: 5aee13a496e3b867a04a72c9af4a602dea4780bf59c65d3b78d2d2e07fd618ff\n\nbuild:\n  number: 1\n  noarch: python\n  script:\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation --disable-pip-version-check\n  python:\n    entry_points:\n      - gaphor = gaphor.main:main\n\nrequirements:\n  host:\n    - pip\n    - poetry-core >=2.0.0,<3.0.0\n    - python ${{ python_min }}.*\n  run:\n    - __${{ noarch_platform }}\n    - ${{ noarch_extra | trim }}\n    # from pyproject.toml\n    - babel >=2.10.3\n    - better-exceptions >=0.3.3\n    - defusedxml >=0.7.1\n    - dulwich >=0.25.0\n    - gaphas >=5.1\n    - jedi >=0.18.1,<0.20.0\n    - pillow >=10.0.0\n    - pycairo >=1.22.0\n    - pydot >=1.4.2\n    - pygobject >=3.52\n    - python >=${{ python_min }}\n    - python-generic >=1.0.0\n    - tinycss2 >=1.0.2\n    # not on PyPI\n    - adwaita-icon-theme\n    - gtk4\n    - gtksourceview\n    - libadwaita\n\ntests:\n  - python:\n      imports: gaphor\n      pip_check: true\n      python_version:\n        - ${{ python_min }}.*\n        - ${{ python_check_max }}.*\n  - files:\n      recipe:\n        - run_test.py\n    requirements:\n      run:\n        - psutil\n        - pytest\n        - python ${{ python_min }}.*\n    script:\n      env:\n        # for xvfb-run on linux\n        DISPLAY: \":1\"\n        # for anything on windows\n        PYTHONIOENCODING: utf-8\n      content:\n        - if: win\n          then:\n            - md c:\\temp\\conda-forge-gaphor-test\n            - copy run_test.py c:\\temp\\conda-forge-gaphor-test\n            - cd c:\\temp\\conda-forge-gaphor-test\n        - python run_test.py\n        - if: win\n          then:\n            # workaround for rattler-build failing to clean up the\n            # test folder if any processes are still running; this\n            # \"waits a long\", as the most reliable `sleep` equivalent\n            - ping -n 31 127.0.0.1 >nul 2>&1\n\nabout:\n  summary: Gaphor is the simple modeling tool written in Python.\n  license: Apache-2.0\n  license_file:\n    - LICENSES/Apache-2.0.txt\n    - LICENSES/BSD-3-Clause.txt\n    - LICENSES/GPL-2.0-or-later.txt\n    - LICENSES/LGPL-2.1-or-later.txt\n  homepage: https://gaphor.org\n  repository: https://github.com/gaphor/gaphor\n  documentation: https://docs.gaphor.org\n\nextra:\n  recipe-maintainers:\n    - danyeaw\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: gaphor\n  version: 3.2.0\n  python_min: \"3.12\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/gaphor-${{ version }}.tar.gz\n  sha256: b2dcc1b1c67ec4094c92c0929b3c8156a53d7ad9acdb05ce7c11840482474412\n\nbuild:\n  number: 0\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  noarch: python\n  python:\n    entry_points:\n      - gaphor = gaphor.main:main\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - poetry-core\n    - pip\n  run:\n    - python >=${{ python_min }}\n    - pycairo >=1.22.0\n    - pygobject >=3.52\n    - gaphas >=5.0\n    - python-generic >=1.0.0\n    - tinycss2 >=1.0.2\n    - babel >=2.10.3\n    - jedi >=0.18.1,<0.20.0\n    - better-exceptions >=0.3.3\n    - pydot >=1.4.2,<4.0.0\n    - pillow >=10.0.0\n    - defusedxml >=0.7.1\n    - dulwich >=0.21.7,<0.23.0\n    - gtk4\n    - libadwaita\n    - adwaita-icon-theme\n    - gtksourceview\n    - if: osx\n      then:\n        - __osx\n        - pyobjc-framework-cocoa >=9.0.1,<11.0.0\n\ntests:\n  - python:\n      imports:\n        - gaphor\n      pip_check: true\n      python_version:\n        - ${{ python_min }}.*\n        - \"*\"\n  - requirements:\n      run:\n        - pip\n        - gtk4\n        - libadwaita\n        - gtksourceview\n    script:\n      - gaphor --help\n\nabout:\n  summary: Gaphor is the simple modeling tool written in Python.\n  license: Apache-2.0\n  license_file:\n    - LICENSES/Apache-2.0.txt\n    - LICENSES/BSD-3-Clause.txt\n    - LICENSES/GPL-2.0-or-later.txt\n    - LICENSES/LGPL-2.1-or-later.txt\n  homepage: https://gaphor.org\n  repository: https://github.com/gaphor/gaphor\n  documentation: https://docs.gaphor.org\n\nextra:\n  recipe-maintainers:\n    - danyeaw\n",

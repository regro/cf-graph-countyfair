  "raw_meta_yaml": "{% set version = \"2.1.0\" %}\n{% set maj_min_patch_ver = \"_\".join(version.split(\".\")) %}\n{% set maj_min_ver = \"_\".join(version.split(\".\")[:2]) %}\n{% set build = 2 %}\n\n# recipe-lint fails if mpi is undefined\n{% set mpi = mpi or 'nompi' %}\n{% if mpi == \"nompi\" %}\n# prioritize nompi via build number\n{% set build = build + 100 %}\n{% endif %}\n\n{% if mpi != \"nompi\" %}\n{% set mpi_prefix = \"mpi_\" + mpi %}\n{% else %}\n{% set mpi_prefix = \"nompi\" %}\n{% endif %}\n# add build string so packages can depend on\n# mpi or nompi variants\n# dependencies:\n# `hdf5 * mpi_mvapich_*` for mvapich\n# `hdf5 * mpi_mpich_*` for mpich\n# `hdf5 * mpi_*` for any mpi\n# `hdf5 * nompi_*` for no mpi\n\n# mpi builds require the right mpi\n# non-mpi builds *do not* appear to require non-mpi builds\n# at least not always\n\n{% if mpi != 'nompi' %}\n{% set build_pin = mpi_prefix + '_*' %}\n{% else %}\n{% set build_pin = '' %}\n{% endif %}\n\npackage:\n  name: hdf5\n  version: {{ version }}\n\nsource:\n  url: https://github.com/HDFGroup/hdf5/releases/download/{{ version }}/hdf5-{{ version }}.tar.gz\n  sha256: ce7f5515a95d588b8606c3fb50643f8b88ac52ffbbde9c63bb1edca6a256e964\n  patches:\n    # hmaarrfk - 2026/03/15 - remove in version 2.1.1 or later\n    # Upstream devs asked to wait for a release to include this patch\n    # https://github.com/conda-forge/hdf5-feedstock/pull/281#issuecomment-4026792144\n    # But we can readily backport a 2 line fix\n    - 6267-Fix-HL-Fortran-soversion-interface-variable-typo.patch\n\nbuild:\n  number: {{ build }}\n  string: {{ mpi_prefix }}_h{{ PKG_HASH }}_{{ build }}\n  run_exports:\n    - {{ pin_subpackage('hdf5', max_pin='x') }} {{ build_pin }}\n  ignore_run_exports:\n    - libacl\n\nrequirements:\n  build:\n    - {{ compiler('c') }}\n    - {{ stdlib('c') }}\n    - {{ compiler('cxx') }}\n    - {{ compiler('fortran') }}\n    - cmake\n    - ninja\n    - {{ mpi }}  # [build_platform != target_platform and mpi != 'nompi']\n    # Keep both versions of openssl in sync\n    - openssl\n    - diffutils   # [linux]\n    - pkg-config\n  host:\n    - {{ mpi }}   # [mpi != 'nompi' and mpi != 'impi']\n    - impi-devel  # [mpi == 'impi']\n    - zlib\n    - libaec\n    - libacl      # [linux]\n    - libcurl\n    - openssl\n    - aws-c-io\n    - aws-c-s3\n    - aws-c-auth\n    - aws-c-http\n    - aws-c-common\n    - aws-c-sdkutils\n\ntest:\n  requires:\n    - {{ compiler('c') }}\n    - {{ compiler('cxx') }}\n    - {{ compiler('fortran') }}  # [not win]\n    - pkg-config                 # [not win]\n    - cmake                      # [not win]\n    - make                       # [not win]\n    # Need zlib to compile test programs\n    - zlib\n    # ensure new libgfortran is co-installable; in July 2025, there were resolution errors\n    # with hdfs5 depending on `libgfortran =5` (either real or hallucinated). This check can\n    # be dropped again in 1-3 years if the issue does not keep recurring in the meantime.\n    - libgfortran5 >=13.3.0      # [not win]\n  files:\n    - test\n  commands:\n    # Verify UNIX CLI tools.\n    {% if mpi == 'nompi' %}\n    {% set h5_compilers = [\n        \"h5c++\",\n        \"h5cc\",\n        \"h5fc\",\n    ] %}\n    {% else %}\n    # no p on parallel h5c++!\n    {% set h5_compilers = [\n        \"h5c++\",\n        \"h5pcc\",\n        \"h5pfc\",\n    ] %}\n    {% endif %}\n    {% set hdf5_unix_cmds = h5_compilers %}\n    {% if build_platform == target_platform %}\n    {% set hdf5_unix_cmds = hdf5_unix_cmds + [\n        \"h5perf_serial\",\n    ] %}\n    {% endif %}\n    {% for each_hdf5_unix_cmd in hdf5_unix_cmds %}\n    - command -v {{ each_hdf5_unix_cmd }}   # [not win]\n    {% endfor %}\n    # Verify CLI tools.\n    {% set hdf5_cmds = [\n        \"h5copy\",\n        \"h5debug\",\n        \"h5diff\",\n        \"h5dump\",\n        \"h5import\",\n        \"h5jam\",\n        \"h5ls\",\n        \"h5mkgrp\",\n        \"h5repack\",\n        \"h5repart\",\n        \"h5stat\",\n        \"h5unjam\",\n    ] %}\n    {% if mpi != 'nompi' %}\n    {% set hdf5_cmds = hdf5_cmds + [\n        \"ph5diff\",\n    ] %}\n    {% endif %}\n    {% for each_hdf5_cmd in hdf5_cmds %}\n    - command -v {{ each_hdf5_cmd }}  # [not win]\n    - where {{ each_hdf5_cmd }}  # [win]\n    {% endfor %}\n    # Verify libraries.\n    {% set hdf5_libs = [\n        \"hdf5\",\n        \"hdf5_cpp\",\n        \"hdf5_hl\",\n        \"hdf5_hl_cpp\"\n    ] %}\n    {% for each_hdf5_lib in hdf5_libs %}\n    - test -f $PREFIX/lib/lib{{ each_hdf5_lib }}${SHLIB_EXT}  # [not win]\n    - if not exist %PREFIX%\\\\Library\\\\lib\\\\{{ each_hdf5_lib }}.lib exit 1  # [win]\n    - if not exist %PREFIX%\\\\Library\\\\bin\\\\{{ each_hdf5_lib }}.dll exit 1  # [win]\n    {% endfor %}\n    # Check ros3 driver\n    - AWS_REGION=us-east-2 h5dump --filedriver=ros3 \"https://s3.amazonaws.com/hdfgroup/data/hdf5demo/tall.h5\" | grep '^HDF5'  # [unix]\n    # Jan 2023 -- hmaarrfk. Tests will fail on windows without --s3-cred specified\n    # https://github.com/HDFGroup/hdf5/issues/2406\n    #- h5dump --filedriver=ros3 --s3-cred=\"(,,)\" \"https://s3.amazonaws.com/hdfgroup/data/hdf5demo/tall.h5\" | findstr \"^HDF5\"  # [win]\n\nabout:\n  home: https://www.hdfgroup.org/solutions/hdf5/\n  license: BSD-3-Clause\n  license_family: BSD\n  license_file: LICENSE\n  summary: HDF5 is a data model, library, and file format for storing and managing data\n  dev_url: https://github.com/HDFGroup/hdf5\n  doc_url: https://support.hdfgroup.org/documentation/hdf5/latest/\n\nextra:\n  recipe-maintainers:\n    - hmaarrfk\n    - jakirkham\n    - gillins\n    - groutr\n    - ocefpaf\n    - astrofrog\n    - marcelotrevisani\n    - scopatz\n    - davidbrochart\n    - SylvainCorlay\n    - varlackc\n    - zklaus\n",

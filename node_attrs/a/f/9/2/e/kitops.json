  "raw_meta_yaml": "context:\n  version: \"1.13.0\"\n\npackage:\n  name: kitops\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/kitops-ml/kitops/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: d71e7d77aa9100eea1162daa6c64ea7a911d2f13c4507ed0fd006a0d85a6b6b9\n  target_directory: src\n\nbuild:\n  number: 2\n  script:\n    - cd src\n    - go-licenses save . --save_path ../library_licenses\n    - if: unix\n      then:\n        - BUILD_TIME=\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"\n        - SHORT_COMMIT_HASH=\"$(curl -s \"https://api.github.com/repos/kitops-ml/kitops/commits/v${{ version }}\" | jq -r '.sha' | cut -c 1-7)\"\n        - go build -v -o $PREFIX/bin/kit -ldflags=\"-s -w -X github.com/kitops-ml/kitops/pkg/lib/constants.Version=${{ version }} -X github.com/kitops-ml/kitops/pkg/lib/constants.BuildTime=${BUILD_TIME} -X github.com/kitops-ml/kitops/pkg/lib/constants.GitCommit=${SHORT_COMMIT_HASH}\" -trimpath .\n        # generate shell completions\n        - mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions\n        - $PREFIX/bin/kit completion bash > $PREFIX/share/bash-completion/completions/kit\n        - $PREFIX/bin/kit completion fish > $PREFIX/share/fish/vendor_completions.d/kit.fish\n        - $PREFIX/bin/kit completion zsh > $PREFIX/share/zsh/site-functions/_kit\n    - if: win\n      then:\n        - for /f \"usebackq delims=\" %%T in (`powershell -Command \"[DateTime]::UtcNow.ToString('yyyy-MM-ddTHH:mm:ssZ')\"`) do set BUILD_TIME=%%T\n        - for /f \"usebackq delims=\" %%T in (`powershell -Command \"((Invoke-RestMethod 'https://api.github.com/repos/kitops-ml/kitops/commits/v${{ version }}').sha).Substring(0, 7)\"`) do set SHORT_COMMIT_HASH=%%T\n        - go build -v -o %LIBRARY_BIN%\\kit.exe -ldflags=\"-s -w -X github.com/kitops-ml/kitops/pkg/lib/constants.Version=${{ version }} -X github.com/kitops-ml/kitops/pkg/lib/constants.BuildTime=%BUILD_TIME% -X github.com/kitops-ml/kitops/pkg/lib/constants.GitCommit=%SHORT_COMMIT_HASH%\" -trimpath .\n        # generate shell completions\n        - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n        - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n        - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n        - '%LIBRARY_BIN%\\kit.exe completion bash > %LIBRARY_PREFIX%\\share\\bash-completion\\completions\\kit'\n        - '%LIBRARY_BIN%\\kit.exe completion fish > %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\kit.fish'\n        - '%LIBRARY_BIN%\\kit.exe completion zsh > %LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_kit'\n\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntests:\n  - script:\n      - kit --help\n      - kit version\n  - package_contents:\n      bin:\n        - kit\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/kit\n            - share/fish/vendor_completions.d/kit.fish\n            - share/zsh/site-functions/_kit\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/kit\n            - Library/share/fish/vendor_completions.d/kit.fish\n            - Library/share/zsh/site-functions/_kit\n      strict: true\n\nabout:\n  homepage: https://kitops.ml\n  summary: An open source MLOps tool for packaging, versioning, and sharing AI/ML projects\n  description: \"KitOps is an open source tool that allows to package, version, share, and\\ndeploy AI/ML models and their associated artifacts using familiar DevOps practices and\\nOCI standards. It facilitates collaborative work on self-hosted AI/ML models and makes\\nsharing, automating, and deploying those models as simple as managing containerized apps. \\n\"\n  license: Apache-2.0\n  license_file:\n    - src/LICENSE\n    - library_licenses/\n  repository: https://github.com/kitops-ml/kitops\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: mjlab\n  version: 1.2.0\n  build_number: 1\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/mujocolab/mjlab/archive/refs/tags/v${{ version }}.zip\n  sha256: 79aa96c2bc1d7d1c1689287357a47f3af68e37c2851886e9e9869b096df3c3e5\n\nbuild:\n  number: ${{ build_number }}\n  script:\n    - if: not linux\n      then:\n        - sed -i '' \"s/\\\"torchrunx\\([^\\\"]*\\)\\\"/\\\"torchrunx\\1; sys_platform == 'linux'\\\"/\" pyproject.toml\n        - cat pyproject.toml\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  noarch: python\n\nrequirements:\n  host:\n    - pip\n    - python ${{ python_min }}.*\n    - uv-build\n  run:\n    - python >=${{ python_min }}\n    - prettytable\n    - tqdm\n    - tyro >=1.0.1\n    - pytorch >=2.7.0\n    - if: linux\n      then:\n        - __linux\n        - torchrunx >=0.3.4\n    - warp-lang >=1.12.0\n    - mujoco-warp >=3.5.0\n    - mujoco >=3.5.0\n    - trimesh >=4.8.3\n    - viser >=1.0.24\n    - mediapy >=1.2.6\n    - imageio-ffmpeg\n    - tensordict\n    - rsl-rl-lib ==5.0.1\n    - tensorboard >=2.20.0\n    - onnxscript >=0.5.4\n    - wandb >=0.22.3\n  run_constraints:\n    - if: not linux\n      then:\n        - __linux ==0.0.0\n\ntests:\n  - python:\n      imports:\n        - mjlab\n      pip_check: true\n      python_version: 3.11.*\n  - script:\n      - pytest tests/\n        --deselect \"tests/test_tyro_flags.py::test_tyro_cli_calls_have_tyro_flags\"\n    files:\n      source:\n        - pyproject.toml\n        - src/mjlab/asset_zoo\n        - tests/\n    requirements:\n      run:\n        - pytest\n        - python 3.11.*\n        - scipy\n\nabout:\n  homepage: https://mujocolab.github.io/mjlab/\n  license: Apache-2.0\n  license_file: LICENSE\n  repository: https://github.com/mujocolab/mjlab\n  summary: Isaac Lab API, powered by MuJoCo-Warp, for RL and robotics research.\n\nextra:\n  recipe-maintainers:\n    - kevinzakka\n    - diegoferigo\n",

  "linux_64_meta_yaml": {
    "about": {
      "description": "SWIG is an interface compiler that connects programs written in C and C++\nwith scripting languages such as Perl, Python, Ruby, and Tcl. It works by\ntaking the declarations found in C/C++ header files and using them to\ngenerate the wrapper code that scripting languages need to access the\nunderlying C/C++ code. In addition, SWIG provides a variety of\ncustomization features that let you tailor the wrapping process to suit\nyour application.",
      "dev_url": "https://github.com/swig/swig",
      "doc_url": "https://www.swig.org/doc.html",
      "home": "http://www.swig.org/",
      "license": "GPL-3.0-or-later",
      "license_family": "GPL-3.0-or-later",
      "license_file": "LICENSE",
      "summary": "C/C++ parser code generator"
    },
    "build": {
      "number": "0",
      "script": "${RECIPE_DIR}/build_swig.sh"
    },
    "extra": {
      "feedstock-name": "swig",
      "recipe-maintainers": [
        "jakirkham",

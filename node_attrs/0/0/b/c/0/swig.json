  "raw_meta_yaml": "context:\n  version: \"4.4.1\"\n  abi_version: \"5\"\n\nrecipe:\n  name: swig-split\n  version: ${{ version }}\n\nsource:\n  url: https://prdownloads.sourceforge.net/swig/swig-${{ version }}.tar.gz\n  sha256: 40162a706c56f7592d08fd52ef5511cb7ac191f3593cf07306a0a554c6281fcf\n\nbuild:\n  number: 0\n\noutputs:\n  - package:\n      name: swig-abi\n      version: ${{ abi_version }}\n    build:\n      noarch: generic\n    requirements:\n      run_constraints:\n        - swig-abi ==${{ abi_version }}\n      run_exports:\n        - swig-abi ==${{ abi_version }}\n    tests:\n      - script:\n          - python check_swig_runtime_version.py ${{ abi_version }}\n        requirements:\n          run:\n            - python ==${{ python_min }}\n        files:\n          recipe:\n            - check_swig_runtime_version.py\n          source:\n            - Lib/swigrun.swg\n\n  - package:\n      name: swig\n      version: ${{ version }}\n    build:\n      script:\n        - if: not win\n          then: ${RECIPE_DIR}/build_swig.sh\n          else: \"%RECIPE_DIR%\\\\bld_swig.bat\"\n    requirements:\n      build:\n        - ${{ compiler('c') }}\n        - ${{ stdlib(\"c\") }}\n        - ${{ compiler('cxx') }}\n        - if: unix\n          then:\n            - make\n            - gnuconfig\n          else:\n            - cmake\n            - winflexbison\n      host:\n        - pcre2\n      run_constraints:\n        - swig-abi ==${{ abi_version }}\n    tests:\n      - script:\n          - swig -help\n          - swig -swiglib\n\nabout:\n  homepage: http://www.swig.org/\n  license: GPL-3.0-or-later\n  license_family: GPL\n  license_file: LICENSE\n  summary: C/C++ parser code generator\n  description: |\n    SWIG is an interface compiler that connects programs written in C and C++\n    with scripting languages such as Perl, Python, Ruby, and Tcl. It works by\n    taking the declarations found in C/C++ header files and using them to\n    generate the wrapper code that
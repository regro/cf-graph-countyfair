  "raw_meta_yaml": "context:\n  version: \"0.1.19\"\n\npackage:\n  name: undoc\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/iyulab/undoc/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 5402020632d6d7dc2c1440845a8f7c99606ad72c9d9ef7a6497c53f5750a98ae\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path cli\n        else:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path cli\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n    - if: unix\n      then:\n        - pkg-config\n        - make\n  host:\n    - if: unix\n      then:\n        - openssl\n\ntests:\n  - script: undoc --help\n  - package_contents:\n      bin:\n        - undoc\n\nabout:\n  homepage: https://github.com/iyulab/undoc\n  summary: High-performance Microsoft Office document extraction to Markdown, text, and JSON\n  description: |\n    undoc is a high-performance Rust library and CLI tool for extracting\n    content from Microsoft Office documents (DOCX, XLSX, PPTX) to structured\n    Markdown, plain text, and JSON. It supports structure preservation,\n    smart heading detection, table cell alignment, CJK text, asset\n    extraction, footnotes/endnotes, and text cleanup presets for LLM\n    training data preparation.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  documentation: https://docs.rs/undoc\n  repository: https://github.com/iyulab/undoc\n\nextra:\n  recipe-maintainers:\n    - hadim\n",

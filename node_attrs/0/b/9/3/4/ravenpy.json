    "about": {
      "description": "RavenPy is a Python wrapper for Raven, accompanied by utility functions that\nfacilitate model configuration, calibration, and evaluation.\n",
      "dev_url": "https://github.com/CSHS-CWRA/RavenPy",
      "doc_url": "https://ravenpy.readthedocs.io/",
      "home": "https://github.com/CSHS-CWRA/RavenPy",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "A Python wrapper for configuring and running the hydrologic modelling framework Raven."
    },
    "build": {
      "noarch": "python",
      "number": "2",
      "script": "PYTHON -m pip install . -vv",
      "script_env": [
        "CONDA_BUILD"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "Zeitsperre",
        "huard",
        "cjauvin"
      ]
    },
    "package": {
      "name": "ravenpy",
      "version": "0.21.0"
    },
    "requirements": {
      "host": [
        "python 3.10",
        "flit-core >=3.11.0,<4.0",
        "pip >=26.0.1"
      ],
      "run": [
        "python >=3.10",
        "affine >=2.4.0",
        "cf_xarray >=0.9.3",

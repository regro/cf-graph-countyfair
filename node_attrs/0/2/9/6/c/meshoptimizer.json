  "linux_64_meta_yaml": {
    "about": {
      "description": "When a GPU renders triangle meshes, various stages of the GPU pipeline have to process vertex and index data.\nThe efficiency of these stages depends on the data you feed to them;\nthis library provides algorithms to help optimize meshes for these stages,\nas well as algorithms to reduce the mesh complexity and storage overhead.",
      "dev_url": "https://github.com/zeux/meshoptimizer",
      "doc_url": "https://meshoptimizer.org/",
      "home": "https://meshoptimizer.org/",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE.md",
      "summary": "Mesh optimization library that makes meshes smaller and faster to render"
    },
    "build": {
      "number": "0",
      "script": [
        "cmake -S . -B build -G Ninja ${CMAKE_ARGS} -DCMAKE_BUILD_TYPE=Release -DMESHOPT_BUILD_SHARED_LIBS=ON -DMESHOPT_STABLE_EXPORTS=ON -DMESHOPT_INSTALL=ON -DMESHOPT_BUILD_DEMO=ON -DMESHOPT_BUILD_GLTFPACK=OFF",
        "cmake --build build --parallel ${{ CPU_COUNT }}",
        "ctest --test-dir build --output-on-failure",
        "cmake --install build",
        "mkdir -p $PREFIX/bin",
        "install -m 755 build/meshoptdemo $PREFIX/bin/meshoptdemo"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "multimeric"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "meshoptimizer",

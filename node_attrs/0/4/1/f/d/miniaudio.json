  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"1.61\"\n\npackage:\n  name: miniaudio\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/m/miniaudio/miniaudio-${{ version }}.tar.gz\n  sha256: e88e97837d031f0fb6982394218b6487de02eaa382ad273b8fca37791a2b4b15\n  # The extension is CFFI-based and thus independent from the Python version.\n  # Mark it as ABI3 to save some CI resources.\n  patches:\n    - abi3-wheel-tag.patch\n\nbuild:\n  number: 0\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    version_independent: true\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n  host:\n    - python      ${{ python_min }}.*\n    - python-abi3 ${{ python_min }}.*\n    - setuptools >=42\n    - wheel\n    - cffi >=1.12.0\n    - pip\n  run:\n    - python >=${{ python_min }}\n    - cffi >=1.12.0\n\ntests:\n  - python:\n      python_version:\n        - ${{ python_min }}.*\n        - '*'\n      imports:\n        - miniaudio\n      pip_check: true\n  - script:\n      - if: unix\n        then: abi3audit ${SP_DIR}/_miniaudio.abi3.so -s -v --assume-minimum-abi3 ${{ python_min }}\n        else: abi3audit %SP_DIR%/_miniaudio.pyd -s -v --assume-minimum-abi3 ${{ python_min }}\n    requirements:\n      run:\n        - abi3audit\n\nabout:\n  summary: python bindings for the miniaudio library and its decoders (mp3, flac, ogg vorbis, wav)\n  license: MIT\n  license_file: LICENSE\n  homepage: https://github.com/irmen/pyminiaudio\n\nextra:\n  recipe-maintainers:\n    - xhochy\n",

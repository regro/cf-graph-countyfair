  "linux_64_meta_yaml": {
    "about": {
      "description": "Provides R bindings to y-crdt, a Rust implementation of the Yjs CRDT\n(Conflict-free Replicated Data Type) framework.",
      "dev_url": "https://github.com/y-crdt/yr",
      "home": "https://github.com/y-crdt/yr",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Y-CRDT Bindings to R"
    },
    "build": {
      "number": "0",
      "script": {
        "content": "# Make libR findable for Cargo and R wrapper scripts\nexport RUSTFLAGS=\"-C link-arg=-L${PREFIX}/lib/R/lib ${RUSTFLAGS}\"\nexport LD_LIBRARY_PATH=\"${PREFIX}/lib/R/lib:${LD_LIBRARY_PATH:-}\"\nexport DYLD_LIBRARY_PATH=\"${PREFIX}/lib/R/lib:${DYLD_LIBRARY_PATH:-}\"\n\n${R} CMD INSTALL --build . ${R_ARGS}\n\n# Bundle third party licenses from statically linked crates\ncd src/rust\ncargo-bundle-licenses --format yaml --output \"${SRC_DIR}/THIRDPARTY.yml\"\n",
        "env": {
          "DISABLE_AUTOBREW": "1",
          "NOT_CRAN": "1"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "AntoinePrv"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "r-yr",
        "requirements": {
          "build": [

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"0.1.1\"\n\npackage:\n  name: r-yr\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/y-crdt/yr/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: e858d06ab55612c6b3bce7805f5682bdd631151fec57fcf3242de3a91370cbd6\n  patches:\n    - patches/0001-libdir-cargo-build-target.patch\n\nbuild:\n  skip: win\n  number: 0\n  dynamic_linking:\n    rpaths:\n      - lib/R/lib/\n      - lib/\n  script:\n    env:\n      NOT_CRAN: \"1\"\n      DISABLE_AUTOBREW: \"1\"\n    content:\n      - |\n        # Make libR findable for Cargo and R wrapper scripts\n        export RUSTFLAGS=\"-C link-arg=-L${PREFIX}/lib/R/lib ${RUSTFLAGS}\"\n        export LD_LIBRARY_PATH=\"${PREFIX}/lib/R/lib:${LD_LIBRARY_PATH:-}\"\n        export DYLD_LIBRARY_PATH=\"${PREFIX}/lib/R/lib:${DYLD_LIBRARY_PATH:-}\"\n\n        ${R} CMD INSTALL --build . ${R_ARGS}\n\n        # Bundle third party licenses from statically linked crates\n        cd src/rust\n        cargo-bundle-licenses --format yaml --output \"${SRC_DIR}/THIRDPARTY.yml\"\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - autoconf\n    - automake\n    - pkg-config\n    - make\n  host:\n    - r-base\n  run:\n    - r-base\n\ntests:\n  - r:\n      libraries:\n        - yr\n  - script:\n      - Rscript -e 'yr::Doc$new()'\n\nabout:\n  homepage: https://github.com/y-crdt/yr\n  summary: Y-CRDT Bindings to R\n  description: |\n    Provides R bindings to y-crdt, a Rust implementation of the Yjs CRDT\n    (Conflict-free Replicated Data Type) framework.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  repository: https://github.com/y-crdt/yr\n\nextra:\n  recipe-maintainers:\n    - AntoinePrv\n",

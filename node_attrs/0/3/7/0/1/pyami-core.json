  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"5.1.4\"\n  build_number: 1\n\nrecipe:\n  name: pyami-core\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/p/pyami-core/pyAMI_core-${{ version }}.tar.gz\n  sha256: 1f246990b52a659361a2658648c551990e8d554aada7efe90a8a21452b118ae4\n  patches:\n    - patches/0001-drop-old-dependencies.patch\n    - patches/0002-fix-httpsconnection.patch\n    - patches/0003-add-main-function-for-entrypoint.patch\n    - patches/0004-add-lxml-dep.patch\n    - patches/0005-raw-strings-for-W.patch\n\nbuild:\n  number: ${{ build_number }}\n\noutputs:\n  - package:\n      name: pyami-core\n      version: ${{ version }}\n    build:\n      noarch: python\n      script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n        - pip\n        - setuptools\n      run:\n        - python >=${{ python_min }}\n        - lxml\n    tests:\n      - python:\n          imports:\n            - pyAMI\n          pip_check: true\n          python_version:\n            - ${{ python_min }}.*\n            - \"*\"\n\n  - package:\n      name: pyami-core-cli\n      version: ${{ version }}\n    build:\n      noarch: python\n      script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n      python:\n        entry_points:\n          - ami=pyAMI.app:main\n    requirements:\n      host:\n        - python ${{ python_min }}.*\n        - pip\n        - setuptools\n      run:\n        - python >=${{ python_min }}\n        - pyami-core\n    tests:\n      - script:\n          - ami --help\n        requirements:\n          run:\n            - python ${{ python_min }}.*\n\n\nabout:\n  summary: Python ATLAS Metadata Interface (pyAMI)\n  homepage: http://ami.in2p3.fr/\n  repository: https://github.com/ami-team/pyAMI-core\n  documentation: https://ami.in2p3.fr/pyAMI/pyAMI5_core_api.html\n  license: LGPL-2.1-only\n  license_file: pyAMI/LICENSE.txt\n\nextra:\n  recipe-maintainers:\n    - kratsg\n",

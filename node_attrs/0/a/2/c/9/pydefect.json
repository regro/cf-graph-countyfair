  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: pydefect\n  version: 0.9.12\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/pydefect-${{ version }}.tar.gz\n  sha256: 5f4ee5dc48fc5d377a174afb441498c213c87ca1c5fdb69647a68ba1438c147b\n  patches:\n    - requirements.patch\n\nbuild:\n  number: 1\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - pydefect = pydefect.cli.main:main\n      - pydefect_util = pydefect.cli.main_util:main\n      - pydefect_vasp = pydefect.cli.vasp.main_vasp:main\n      - pydefect_vasp_util = pydefect.cli.vasp.main_vasp_util:main\n      - pydefect_print = pydefect.cli.main_print_json:main\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools\n  run:\n    - scikit-image\n    - python >=${{ python_min }}\n    - numpy\n    - monty\n    - pymatgen\n    - vise\n    - tabulate\n    - adjusttext\n    - matplotlib-label-lines\n\ntests:\n  - python:\n      imports:\n        - pydefect\n      python_version: ${{ python_min }}.*\n  - requirements:\n      run:\n        - pip\n        - python ${{ python_min }}.*\n    script:\n      - pip check\n\nabout:\n  summary: Integrated environment for first-principles point-defect calculations\n  license: MIT\n  license_file: LICENSE\n  homepage: https://github.com/kumagai-group/pydefect\n\nextra:\n  recipe-maintainers:\n    - jan-janssen\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: mujoco-warp\n  version: 3.6.0\n  build_number: 1\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/mujoco_warp-${{ version }}.tar.gz\n  sha256: 3c4111a4e13dc61268ddac52593ac5032c05a7d80f0c5e3c98bf5881e32b5d06\n\nbuild:\n  noarch: python\n  number: ${{ build_number }}\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools\n  run:\n    - absl-py\n    - mujoco >=3.5.0\n    - numpy\n    - python >=${{ python_min }}\n    - warp-lang >=1.12\n    # etils[epath] dependencies.\n    # https://github.com/google/etils/blob/main/pyproject.toml\n    - etils\n    - fsspec\n    - typing-extensions\n    - zipp\ntests:\n  - python:\n      imports:\n        - mujoco_warp\n      pip_check: true\n      # Tests fail with default python_min (3.10) because a very old version of jaxlib is installed.\n      # https://github.com/conda-forge/warp-lang-feedstock/issues/83\n      python_version: 3.11.*\n  - script:\n      # The mujoco_warp package bundles the tests in the package, so we can run them from there.\n      - if: not win\n        then:\n          - pytest --pyargs mujoco_warp\n        else:\n          - pytest --pyargs mujoco_warp -k \"not test_collision20\"\n    files:\n      source:\n        - pyproject.toml\n    requirements:\n      run:\n        - pip\n        - pytest\n        - python 3.11.*\n        # jax_test.py uses `scipy.linalg.tril`, which was removed in scipy 1.13.0.\n        - scipy <1.13.0\n\nabout:\n  homepage: https://github.com/google-deepmind/mujoco_warp\n  license: Apache-2.0\n  license_file: LICENSE\n  repository: https://github.com/google-deepmind/mujoco_warp\n  summary: GPU-optimized version of the MuJoCo physics simulator, designed for NVIDIA hardware.\n\nextra:\n  recipe-maintainers:\n    - diegoferigo\n    - oursland\n    - traversaro\n",

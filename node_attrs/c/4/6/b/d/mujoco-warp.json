  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: mujoco-warp\n  version: \"3.7.0.1\"\n  build_number: 0\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/mujoco_warp-${{ version }}.tar.gz\n  sha256: 7c664139ef038212c2c4f4d355a154f70fcaffe9a308f95bfe7b50ab5df8802f\n\nbuild:\n  noarch: python\n  number: ${{ build_number }}\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - mjwarp-testspeed = mujoco_warp.testspeed:main\n      - mjwarp-viewer = mujoco_warp.viewer:main\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools\n  run:\n    - absl-py\n    - mujoco >=3.6.0\n    - numpy\n    - python >=${{ python_min }}\n    - warp-lang >=1.12\n    # etils[epath] dependencies.\n    # https://github.com/google/etils/blob/main/pyproject.toml\n    - etils\n    - fsspec\n    - typing-extensions\n    - zipp\n\ntests:\n  - python:\n      imports:\n        - mujoco_warp\n      pip_check: true\n      python_version: ${{ python_min }}.*\n  - script:\n      # The mujoco_warp package bundles the tests in the package, so we can run them from there.\n      - if: not win\n        then:\n          - which mjwarp-testspeed\n          - which mjwarp-viewer\n          - pytest --pyargs mujoco_warp\n        else:\n          - where mjwarp-testspeed\n          - where mjwarp-viewer\n          - pytest --pyargs mujoco_warp -k \"not test_collision20\"\n    files:\n      source:\n        - pyproject.toml\n    requirements:\n      run:\n        - pip\n        - pytest\n        - python ${{ python_min }}.*\n        - scipy\n\nabout:\n  documentation: https://mujoco.readthedocs.io\n  homepage: https://github.com/google-deepmind/mujoco_warp\n  license: Apache-2.0\n  license_file: LICENSE\n  repository: https://github.com/google-deepmind/mujoco_warp\n  summary: GPU-optimized version of the MuJoCo physics simulator, designed for NVIDIA hardware.\n\nextra:\n  recipe-maintainers:\n    - diegoferigo\n    - oursland\n    - traversaro\n",

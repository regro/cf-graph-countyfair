  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: proxystore\n  version: \"1.0.0\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/proxystore-${{ version }}.tar.gz\n  sha256: 1d6b6edd5fdc31ac6fa096b09025b8adb1c8e25e16d2a4380b588501cdee5bac\n\nbuild:\n  number: 0\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - proxystore-endpoint = proxystore.endpoint.cli:cli\n      - proxystore-globus-auth = proxystore.globus.cli:cli\n      - proxystore-relay = proxystore.p2p.relay.run:cli\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - setuptools >=77.0\n    - setuptools-scm\n    - pip\n  run:\n    - python >=${{ python_min }}\n    - click !=8.1.4\n    - cloudpickle >=3\n    - cryptography >=39.0.1\n    - globus-sdk >=4,<5\n    - pydantic >=2,<3\n    # for all python, not just py<3.11, to stay noarch: python\n    - tomli\n    - tomli-w\n    - typing_extensions >=4.3.0\n\ntests:\n  - python:\n      imports:\n        - proxystore\n      pip_check: true\n      python_version: ${{ python_min }}\n  - requirements:\n      run:\n        - python ${{ python_min }}.*\n        - pip\n        - websockets\n        - tosholi\n        - pydantic\n    script:\n      - proxystore-globus-auth --help\n      - proxystore-relay --help\n\nabout:\n  summary: Lazy object proxy interface for distributed stores.\n  license: MIT\n  license_file: LICENSE\n  homepage: https://github.com/gpauloski/ProxyStore\n\nextra:\n  recipe-maintainers:\n    - WardLT\n    - jan-janssen\n    - xylar\n",

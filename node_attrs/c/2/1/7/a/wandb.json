 "linux_64_meta_yaml": {
  "about": {
   "dev_url": "https://github.com/wandb/client",
   "doc_url": "https://docs.wandb.com/",
   "home": "https://github.com/wandb/client",
   "license": "MIT",
   "license_file": "LICENSE",
   "summary": "A CLI and library for interacting with the Weights and Biases API."
  },
  "build": {
   "entry_points": [
    "wandb=wandb.cli.cli:cli",
    "wb=wandb.cli.cli:cli"
   ],
   "number": "0",
   "script": [
    "PYTHON -m pip install . -vv --no-deps --no-build-isolation",
    "cd core && cp ../LICENSE . && go-licenses save . --save_path=\"./license-files/\""
   ],
   "script_env": [
    "WANDB_BUILD_SKIP_APPLE=true"
   ]
  },
  "extra": {
   "recipe-maintainers": [
    "mxr-conda",
    "rluria14",
    "oblute",
    "ndmaxar",
    "vanpelt",
    "andrewtruong",
    "raubitsj",
    "kptkin",
    "dmitryduev",
    "timoffex"
   ]
  },
  "package": {
   "name": "wandb",
   "version": "0.17.3"
  },
  "requirements": {
   "build": [
    "c_stdlib_stub",
    "c_compiler_stub",
    "go-cgo_compiler_stub",
    "go-licenses"
   ],
   "host": [
    "pip",
    "python",
    "hatchling",
    "setuptools"
   ],
   "run": [
    "python",
    "appdirs >=1.4.3",
    "click >=7.1,!=8.0.0",
    "docker-pycreds >=0.4.0",
    "gitpython >=1.0.0,!=3.1.29",
    "platformdirs",
    "protobuf >=3.19.0,!=4.21.0,<5",
    "psutil >=5.0.0",
    "pyyaml",
    "requests >=2.0.0,<3",
    "sentry-sdk >=1.0.0",
    "setproctitle",
    "typing_extensions"
   ]
  },
  "schema_version": 0,
  "source": {
   "sha256": "2e5704b131533862d68a2efcde082276948d32e38a8310d9ecb165517ba1bee3",
   "url": "https://github.com/wandb/wandb/archive/v0.17.3.tar.gz"
  },
  "test": {
   "commands": [
    "pip check",
    "wandb --help",
    "wb --help",
    "python -c \"import wandb; wandb.require('core')\""
   ],
   "imports": [
    "wandb"
   ],
   "requires": [
    "pip"
   ]
  }
 },

      "description": "MNE-Connectivity is an open-source Python package for connectivity and\nrelated measures of MEG, EEG, or iEEG data built on top of the MNE-Python\nAPI. It includes modules for data input/output, visualization, common\nconnectivity analysis, and post-hoc statistics and processing.\n",
      "dev_url": "https://github.com/mne-tools/mne-connectivity",
      "home": "https://mne.tools/mne-connectivity",
      "license": "BSD-3-Clause",
      "license_family": "BSD",
      "license_file": "LICENSE",
      "summary": "mne-connectivity: A module for connectivity data analysis with MNE."
    },
    "build": {
      "noarch": "python",
      "number": "0",
      "script": "PYTHON -m pip install . -vv --no-deps --no-build-isolation"
    },
    "extra": {
      "recipe-maintainers": [
        "hoechenberger",
        "larsoner"
      ]
    },
    "package": {
      "name": "mne-connectivity",
      "version": "0.8.1"
    },

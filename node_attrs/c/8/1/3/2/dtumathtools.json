  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: dtumathtools\n  version: \"2025.2.0\"\n  python_min: \"3.10\"\n  python_max: \"3.12\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ name }}-${{ version }}.tar.gz\n  sha256: 4f6d66d1578b44b9bf20da276cb8b05dc09cc04ebb6c0669eee0e8837f207fd7\n\nbuild:\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv\n  number: 3\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools_scm >=6.2\n    - pyproject-metadata\n  run:\n    - python >=${{ python_min }},<=${{ python_max }}\n    - sympy ~=1.12\n    - matplotlib >=3.8,<3.10\n    - jupyter >=1.0.0\n    - numpy >=1.24,<2\n    - sympy_plot_backends >=3.4,<4\n  run_constraints:\n    - vtk\n    - k3d >=2.9.7\n    - ipympl >=0.7.0\n    - plotly >=4.14.3\n    - panel >=1.0.0\n    - ipywidgets_bokeh\n    - colorcet\n    - pyqt ~=5.15.9\n    - ipyevents\n    - mayavi ~=4.8,>=4.8.2\n\ntests:\n  - python:\n      python_version:\n        - \"${{ python_min }}\"\n        - \"${{ python_max }}\"\n      imports:\n        - dtumathtools\n      pip_check: true\n  - requirements:\n      run:\n        # Our most important things is to test\n        # against a newer python version (than the 3.9).\n        # Hence we test on a more recent python version.\n        # It is not ideal, but good enough.\n        - pip\n        - pytest\n        - vtk\n        - k3d\n        - ipympl\n        - plotly\n        - panel\n        - ipywidgets-bokeh\n        - colorcet\n        - pyqt\n        - ipyevents\n    files:\n      source:\n        - tests\n    script:\n      - pip install deepcomparer\n      - pytest tests -k \"not test_boundary and not test_quiver and not test_scatterplot\"\n\nabout:\n  summary: A plotting package for the Mathematics 1a/1b course at the Technical University of Denmark\n  description: A plotting package for the Mathematics 1a/1b course at the Technical University of Denmark\n  license: BSD-3-Clause\n  license_file: LICENSE\n  homepage: https://github.com/dtudk/dtumathtools\n  repository: https://github.com/dtudk/dtumathtools\n  documentation: https://github.com/dtudk/dtumathtools\n\nextra:\n  recipe-maintainers:\n    - nicpa-dtu\n    - zerothi\n    - Chrillebon\n",

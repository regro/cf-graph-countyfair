  "raw_meta_yaml": "context:\n  version: \"1.3.11\"\n\npackage:\n  name: cminpack\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/devernay/cminpack/archive/v${{ version }}.tar.gz\n  sha256: 45675fac0a721a1c7600a91a9842fe1ab313069db163538f2923eaeddb0f46de\n\nbuild:\n  number: 1\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - cmake\n    - ninja\n    - if: win\n      then: m2-dos2unix\n  host:\n    - libblas\n  run_exports:\n    - ${{ pin_subpackage('cminpack', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - if: win\n        then:\n          - if not exist %LIBRARY_LIB%\\\\cminpack.lib exit 1\n          - if not exist %LIBRARY_BIN%\\\\cminpack.dll exit 1\n          - if not exist %LIBRARY_INC%\\\\cminpack-1\\\\cminpack.h exit 1\n          - if not exist %LIBRARY_INC%\\\\cminpack-1\\\\minpack.h exit 1\n          - if not exist %LIBRARY_PREFIX%\\\\share\\\\cminpack\\\\CMinpackConfig.cmake exit 1\n      - if: unix\n        then:\n          - test -a $PREFIX/lib/libcminpack$SHLIB_EXT\n          - test -f $PREFIX/include/cminpack-1/cminpack.h\n          - test -f $PREFIX/include/cminpack-1/minpack.h\n          - test -f $PREFIX/share/cminpack/CMinpackConfig.cmake\n\nabout:\n  homepage: http://devernay.free.fr/hacks/cminpack/index.html\n  license: LicenseRef-MINPACK  # Custom BSD-like\n  license_family: BSD\n  summary: CMinpack includes software for solving nonlinear equations and nonlinear least squares problems\n  license_file: CopyrightMINPACK.txt\n  repository: https://github.com/devernay/cminpack\n\nextra:\n  recipe-maintainers:\n    - tadeu\n    - jschueller\n",

  "linux_64_meta_yaml": {
    "about": {
      "description": "A cargo subcommand for displaying when Rust dependencies are out of date.",
      "dev_url": "https://github.com/kbknapp/cargo-outdated",
      "doc_url": "https://github.com/kbknapp/cargo-outdated",
      "home": "https://github.com/kbknapp/cargo-outdated",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE-MIT",
      "summary": "Cargo subcommand for displaying when dependencies are out of date"
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "export OPENSSL_DIR=$PREFIX",
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "pavelzw"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "cargo-outdated",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable"
          ],
          "host": [
            "openssl"
          ],
          "run": []
        },
        "tests": [
          {
            "script": "cargo-outdated --help"
          },
          {
            "package_contents": {
              "bin": [
                "cargo-outdated"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.17.0"

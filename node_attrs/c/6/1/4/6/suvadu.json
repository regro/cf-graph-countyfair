  "raw_meta_yaml": "context:\n  version: \"0.3.2\"\n\npackage:\n  name: suvadu\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/AppachiTech/suvadu/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 50f50a8e2abcf0e7c51f99dff340abc8ec58e2450b658f38e3a1f535c1ce8293\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n          # generate manpage and shell completions\n          - mkdir -p $PREFIX/share/man/man1 $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions\n          - $PREFIX/bin/suv man > $PREFIX/share/man/man1/suv.1\n          - $PREFIX/bin/suv completions bash > $PREFIX/share/bash-completion/completions/suv\n          - $PREFIX/bin/suv completions fish > $PREFIX/share/fish/vendor_completions.d/suv.fish\n          - $PREFIX/bin/suv completions zsh > $PREFIX/share/zsh/site-functions/_suv\n        else:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n          # generate manpage and shell completions\n          - mkdir %LIBRARY_PREFIX%\\share\\man\\man1\n          - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n          - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n          - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n          - '%LIBRARY_BIN%\\suv.exe man > %LIBRARY_PREFIX%\\share\\man\\man1\\suv.1'\n          - '%LIBRARY_BIN%\\suv.exe completions bash > %LIBRARY_PREFIX%\\share\\bash-completion\\completions\\suv'\n          - '%LIBRARY_BIN%\\suv.exe completions fish > %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\suv.fish'\n          - '%LIBRARY_BIN%\\suv.exe completions zsh > %LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_suv'\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n\ntests:\n  - script:\n      - suv help\n      - suv version\n  - package_contents:\n      bin:\n        - suv\n      files:\n        - if: unix\n          then:\n            - share/man/man1/suv.1\n            - share/bash-completion/completions/suv\n            - share/fish/vendor_completions.d/suv.fish\n            - share/zsh/site-functions/_suv\n        - if: win\n          then:\n            - Library/share/man/man1/suv.1\n            - Library/share/bash-completion/completions/suv\n            - Library/share/fish/vendor_completions.d/suv.fish\n            - Library/share/zsh/site-functions/_suv\n      strict: true\n\nabout:\n  homepage: https://suvadu.sh\n  summary: Total recall for your terminal. A database-backed shell history with fuzzy search.\n  description: |\n    Suvadu replaces your shell history with a SQLite-backed store. Every command gets\n    structured context — exit code, duration, directory, executor, session. AI agents\n    can query it via MCP. 100% local. Features include <2ms recording overhead,\n    <10ms search across 1M+ entries, AI agent tracking, an interactive TUI, and an\n    MCP server providing history context and tools including risk assessment.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  repository: https://github.com/AppachiTech/suvadu\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

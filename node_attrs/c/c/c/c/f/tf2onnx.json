  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: tf2onnx\n  version: \"1.17.0\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/onnx/tensorflow-onnx/archive/v${{ version }}.tar.gz\n  sha256: 50b4157931b8046c86a1f23820d04b8f64c727b92f8b2bc71d61f10b70f3684f\n\nbuild:\n  number: 0\n  noarch: python\n  script:\n    # We will manage the build time requirements in conda\n    # In 2023/09/17 they had a frivolous constrainst on pytest-runner at build time\n    - sed -i \"/setup_requires=/d\" setup.py\n    # We will manage our own constraints for protobuf in conda\n    - sed -i \"s/'protobuf.*'/'protobuf'/g\" setup.py\n    - ${{ PYTHON }} -m pip install . --no-deps -vv\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools\n    - sed\n  run:\n    - python >=${{ python_min }}\n    - onnx >=1.14.0\n    - numpy >=1.23.5\n    - requests\n    - python-flatbuffers >=1.12\n    - tensorflow >=2.6\n\ntests:\n  - requirements:\n      run:\n        - pip\n        - python ${{ python_min }}.*\n    script:\n      - pip check\n      - python -m tf2onnx.convert --help\n\nabout:\n  license: Apache-2.0\n  license_file: LICENSE\n  summary: Tensorflow to ONNX converter\n  description: tf2onnx - convert TensorFlow models to ONNX models.\n  homepage: https://github.com/onnx/tensorflow-onnx\n  repository: https://github.com/onnx/tensorflow-onnx\n  documentation: http://simplejson.readthedocs.io/\n\nextra:\n  recipe-maintainers:\n    - marcelotrevisani\n    - xhochy\n",

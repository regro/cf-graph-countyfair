  "linux_64_meta_yaml": {
    "about": {
      "dev_url": "https://github.com/unitreerobotics/unitree_sdk2",
      "home": "https://support.unitree.com/home/zh/developer",
      "license": "BSD-3-Clause",
      "license_family": "BSD-3-Clause",
      "license_file": "LICENSE",
      "summary": "Unitree robot sdk version 2."
    },
    "build": {
      "number": "2",
      "script": [
        "cd thirdparty/lib/x86_64",
        "patchelf --replace-needed libddsc.so.0 libddsc_unitree.so.0 libddscxx.so",
        "patchelf --set-soname libddsc_unitree.so libddsc.so",
        "patchelf --set-soname libddscxx_unitree.so libddscxx.so",
        "mv libddsc.so libddsc_unitree.so",
        "mv libddscxx.so libddscxx_unitree.so",
        "rm libddsc.so.0 libddscxx.so.0",
        "ln -s libddsc_unitree.so libddsc_unitree.so.0",
        "ln -s libddscxx_unitree.so libddscxx_unitree.so.0",
        "cd -",
        "cmake -S . -B build/ -GNinja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=$PREFIX -DBUILD_EXAMPLES=OFF -DCMAKE_FIND_ROOT_PATH_MODE_LIBRARY=NEVER -DCMAKE_POLICY_DEFAULT_CMP0109=NEW",
        "cmake --build build/ --target install"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "diegoferigo"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "unitree-sdk2",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "cxx_compiler_stub",
            "cmake",
            "ninja",
            "patchelf"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "requirements": {
              "run": [
                "c_compiler_stub",
                "cxx_compiler_stub",
                "cmake-package-check"
              ]
            },
            "script": "cmake-package-check unitree_sdk2 --targets unitree_sdk2 ddsc ddscxx"
          },
          {
            "requirements": {
              "run": [
                "cf-nvidia-tools"
              ]
            },
            "script": [
              "echo \"Checking stdlib compatibility of installed shared libraries...\"",
              "export c_stdlib_version=${{ c_stdlib_version }}",
              "check-glibc lib/*.so* lib/*.a*"
            ]
          },
          {
            "files": {
              "source": [
                "example/"
              ]
            },
            "requirements": {
              "run": [
                "c_compiler_stub",
                "cxx_compiler_stub",
                "cmake",
                "eigen",
                "ninja",
                "yaml-cpp"
              ]
            },
            "script": [
              "ldd $PREFIX/lib/libddsc_unitree.so",
              "ldd $PREFIX/lib/libddscxx_unitree.so",
              "touch CMakeLists.txt",
              "echo \"cmake_minimum_required(VERSION 3.16)\" >> CMakeLists.txt",
              "echo \"project(unitree_examples CXX)\" >> CMakeLists.txt",
              "echo \"find_package(unitree_sdk2 CONFIG REQUIRED)\" >> CMakeLists.txt",
              "echo \"add_subdirectory(example)\" >> CMakeLists.txt",
              "cmake -S . -B build/ -GNinja -DCMAKE_BUILD_TYPE=Release -DCMAKE_PREFIX_PATH=$PREFIX",
              "cmake --build build/"
            ]
          }
        ],
        "version": "2.0.2"
      }
    ],

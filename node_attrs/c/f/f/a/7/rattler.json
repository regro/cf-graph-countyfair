  "linux_64_meta_yaml": {
    "about": {
      "dev_url": "https://github.com/conda/rattler/tree/main/crates/rattler-bin",
      "doc_url": "https://docs.rs/crate/rattler-bin",
      "home": "https://github.com/conda/rattler",
      "license": "BSD-3-Clause",
      "license_family": "BSD-3-Clause",
      "license_file": "LICENSE",
      "summary": "Rust binary for common Conda operations"
    },
    "build": {
      "number": "1",
      "script": {
        "content": [
          "export OPENSSL_DIR=$PREFIX",
          "cd crates/rattler-bin",
          "cargo-bundle-licenses --format yaml --output ../../THIRDPARTY.yml",
          "cargo auditable install --no-track --locked --features native-tls,s3,gcs --no-default-features --root ${{ PREFIX }} --path .",
          "mkdir -p $PREFIX/share/zsh/site-functions $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d",
          "$PREFIX/bin/rattler completion --shell zsh > $PREFIX/share/zsh/site-functions/_rattler",
          "$PREFIX/bin/rattler completion --shell bash > $PREFIX/share/bash-completion/completions/rattler",
          "$PREFIX/bin/rattler completion --shell fish > $PREFIX/share/fish/vendor_completions.d/rattler.fish"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "baszalmstra",
        "pavelzw"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "rattler",
        "requirements": {
          "build": [
            "c_compiler_stub",
            "cxx_compiler_stub",
            "c_stdlib_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable",
            "cmake",
            "make"
          ],
          "host": [
            "openssl"
          ],
          "run": []
        },
        "tests": [
          {
            "script": "rattler --version"
          },
          {
            "package_contents": {
              "bin": [
                "rattler"
              ],
              "files": [
                "share/bash-completion/completions/rattler",
                "share/fish/vendor_completions.d/rattler.fish",
                "share/zsh/site-functions/_rattler"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.1.4"
      }
    ],

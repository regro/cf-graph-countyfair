  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: nomad-lab\n  version: \"1.4.2\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ name | replace('-', '_') }}-${{ version }}.tar.gz\n  sha256: f3effff6f14c2fde0aef7c513ac6572aee8d07b3f043c58647148429ea029808\n  patches:\n    - pyspy.patch\n\nbuild:\n  number: 1\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv\n  python:\n    entry_points:\n      - nomad = nomad.cli:run_cli\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - setuptools >=77\n    - setuptools-scm\n    - pip\n  run:\n    - python >=${{ python_min }}\n    - ase >=3.25.0\n    - bitarray >=2.3.5\n    - cachetools >=4.2.4\n    - click >=7.1.2\n    - docstring_parser >=0.12\n    - elasticsearch >=7.17.3\n    - elasticsearch-dsl >=7,<8\n    - h5py >=3.6.0\n    - httpx >=0.23.3,<0.28\n    - jmespath >=0.10.0\n    - jsonpath-ng\n    - python-kaleido <=0.2.1\n    - lxml >=5.2\n    - matid >=2.1.3\n    - msgpack-python >=1\n    - msgspec\n    - numpy >=1.22.4,<2\n    - openpyxl\n    - orjson >=1.0\n    - pandas >=2\n    - pint >=0.23\n    - plotly <6\n    - py-spy\n    - pydantic >=2\n    - pyinstrument\n    - pymatgen >=2023.5.10\n    - python-keycloak >=0.26.1\n    - python-magic\n    - pytz >=2022.7.1\n    - pyyaml >=6.0\n    - requests >=2.27.1,<2.32.0\n    - rfc3161ng >=2.1.3\n    - scipy >=1.7.1\n    - unidecode\n    - xarray >=0.20.2\n    - json_stream\n    - pathvalidate\n    - fsspec\n    - molid\n\ntests:\n  - python:\n      imports:\n        - nomad\n      pip_check: true\n      python_version: ${{ python_min }}\n\nabout:\n  license: Apache-2.0\n  license_file: LICENSE\n  summary: The NOvel MAterials Discovery (NOMAD) Python package\n  description: |\n    This project implements the new nomad@FAIRDI infrastructure. Contrary\n    to its NOMAD CoE predecessor, it implements the NOMAD Repository and\n    NOMAD Archive f
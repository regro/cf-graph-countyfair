  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  version: \"3.14.0\"\n  go_min: \"1.25.3\"\n  go_mod: github.com/errata-ai/vale\n  go_build: go build -v --buildmode=pie -trimpath -modcacherw -ldflags \"-s -w -X main.version=${{ version }}\"\n  go_bin: ${{ \"$PREFIX/bin/$PKG_NAME\" if unix else \"%PREFIX%\\\\bin\\\\%PKG_NAME%.exe\" }}\n  go_mod_xz: github.com/xi2/xz\n  go_mod_ts_julia: github.com/jdkato/go-tree-sitter-julia/julia\n  license_ignore: ${{ go_mod_xz }} ${{ go_mod_ts_julia }} ${{ go_mod }}\n  var_src_dir: ${{ \"$SRC_DIR\" if unix else \"%SRC_DIR%\" }}\n  var_conda_prefix: ${{ \"$CONDA_PREFIX\" if unix else \"%CONDA_PREFIX%\" }}\n  mkdir: ${{ \"mkdir -p\" if unix else \"md\" }}\n  grep: ${{ \"grep -iE \" if unix else \"findstr /c:\" }}\n  ls: ${{ \"ls -lathr\" if unix else \"dir\" }}\n  slash: ${{ \"/\" if unix else \"\\\\\" }}\n\nrecipe:\n  name: vale\n  version: ${{ version }}\n\nsource:\n  - url: https://${{ go_mod }}/archive/refs/tags/v${{ version }}.tar.gz\n    sha256: fcc7177d2715283eede6482c80cdba1aa385cf8ea6046de2efabb6a068a6929e\n    target_directory: src/${{ go_mod }}\n    patches:\n      - 0000-use-conda-prefix.patch\n  - url: https://raw.githubusercontent.com/xi2/xz/refs/heads/master/LICENSE\n    sha256: 5c640056d513f276d56635af7a0bed81cb7eac02a31b6e56d40c416557a8d8ce\n    target_directory: license-files-manual/${{ go_mod_xz }}\n\nbuild:\n  number: 0\n\noutputs:\n  - package:\n      name: vale\n    build:\n      script:\n        env:\n          GOPATH: ${{ var_src_dir }}\n        content:\n          - cd \"src/${{ go_mod }}\"\n          - ${{ go_build }} -o \"${{ go_bin }}\" ./cmd/vale\n          - ${{ ls }} \"${{ go_bin }}\"\n          - |-\n            go-licenses save ./cmd/vale --save_path \"${{ var_src_dir }}/license-files\"\n              {%- for i in license_ignore | split %} --ignore=${{ i }}{% endfor %}\n          - ${{ ls }} \"${{ var_src_dir }}/license-files\"\n\n    requirements:\n      build:\n        - ${{ compiler(\"go-cgo\") }}\n        - go-licenses\n        - go >=${{ go_min }}\n        - if: unix\n          then:\n            - ${{ compiler(\"c\") }}\n            - ${{ compiler(\"cxx\") }}\n            - ${{ stdlib(\"c\") }}\n          else:\n            - ${{ compiler(\"m2w64_c\") }}\n            - ${{ compiler(\"m2w64_cxx\") }}\n            - ${{ stdlib(\"m2w64_c\") }}\n\n    tests:\n      - script:\n          - vale --version\n          - vale --help\n          - vale --version | ${{ grep }}\"${{ version | replace(\".\", \"\\\\.\") }}\"\n          - vale ls-dirs\n          - ${{ mkdir }} \"${{ var_conda_prefix }}/share/vale/styles\"\n          - vale ls-dirs\n          - vale ls-dirs | ${{ grep }}\"${{ var_conda_prefix }}${{ slash }}share\"\n          - ${{ mkdir }} \"${{ var_conda_prefix }}/etc/vale\"\n          - echo \"\" > \"${{ var_conda_prefix }}/etc/vale/.vale.ini\"\n          - vale ls-dirs\n          - vale ls-dirs | ${{ grep }}\"${{ var_conda_prefix }}${{ slash }}etc\"\n\nabout:\n  license: MIT\n  license_file:\n    - src/${{ go_mod }}/LICENSE\n    - license-files/\n    - license-files-manual/\n  summary: A syntax-aware linter for prose built with speed and extensibility in mind.\n  homepage: https://vale.sh\n  repository: https://${{ go_mod }}\n  documentation: https://vale.sh/docs\n\nextra:\n  feedstock-name: vale\n  recipe-maintainers:\n    - bollwyvl\n",

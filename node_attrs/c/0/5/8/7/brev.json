  "raw_meta_yaml": "context:\n  version: \"0.6.322\"\n\npackage:\n  name: brev\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/brevdev/brev-cli/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 0e5d5617ec1397367cda5239bff686825b393744dd7fa45e2aa63f57303ea869\n\nbuild:\n  number: 0\n  skip:\n    - win\n  script:\n    # go-nvml uses dlopen/dlsym to resolve NVML symbols at runtime. On systems\n    # without NVIDIA drivers, go-nvml detects the missing library and gracefully\n    # degrades without calling the NVML functions. Set '-z lazy' linker flag to\n    # ensure the symbols are only resolved when actually called, allowing for use\n    # without NVIDIA drivers.\n    # c.f. https://sourceware.org/binutils/docs/ld/Options.html\n    - export CGO_LDFLAGS=\"${CGO_LDFLAGS} -Wl,-z,lazy\"\n\n    # Set the plt compiler flag to ensure a Procedure Linkage Table (PLT) for\n    # indirect function calls. The alternative is the default for conda-forge's c-compiler\n    # flags, of -fno-plt which uses a Global Offset Table (GOT). This would lead\n    # to R_*_GLOB_DAT symbols that are always resolved eagerly at load time, even\n    # if '-Wl,-z,lazy' is used. As go-nvml uses dlopen/dlsym to resolve NVML\n    # symbols at runtime, the PLT is necessary to allow lazy binding of these\n    # symbols with '-Wl,-z,lazy'.\n    # c.f. https://gcc.gnu.org/onlinedocs/gcc/Code-Gen-Options.html#index-fno-plt\n    - export CGO_CFLAGS=\"${CGO_CFLAGS} -fplt\"\n\n    - go-licenses save --save_path $SRC_DIR/library_licenses . --ignore=\"buf.build/gen/go/brevdev/protoc-gen-gotag/protocolbuffers/go/tagger\"\n    - GOOS=\"${GOOS}\" GOARCH=\"${GOARCH}\" go build -ldflags=\"-s -w -X github.com/brevdev/brev-cli/pkg/cmd/version.Version=v${{ version }}\" -v -o ${PREFIX}/bin/brev\n    # Default to no cross-compile\n    - export BREV=\"${PREFIX}/bin/brev\"\n    - if: unix and target_platform != build_platform\n      then:\n        # Need to compile for the build_platform arch\n        - if: build_platform == \"linux-64\" or build_platform == \"osx-64\"\n          # Fail if build_platform changes in future to non-x86_64 arch\n          then: export GOARCH=amd64\n        # For cross-compiling, override CONDA_BUILD_SYSROOT to point to the\n        # sysroot for the build platform (x86-64), and use the appropriate CC\n        # for the build platform ($CC_FOR_BUILD) to compile against the correct\n        # headers.\n        - CONDA_BUILD_SYSROOT=\"${BUILD_PREFIX}/x86_64-conda-linux-gnu/sysroot\" CC=\"${CC_FOR_BUILD}\" GOOS=\"${GOOS}\" GOARCH=\"${GOARCH}\" go build -ldflags=\"-s -w -X github.com/brevdev/brev-cli/pkg/cmd/version.Version=v${{ version }}\" -v -o ${BUILD_PREFIX}/bin/brev\n        - export BREV=\"${BUILD_PREFIX}/bin/brev\"\n\n    # Install bash, zsh, and fish completions\n    - mkdir -p ${PREFIX}/share/bash-completion/completions\n    - ${BREV} completion bash > ${PREFIX}/share/bash-completion/completions/brev\n    - mkdir -p ${PREFIX}/share/zsh/site-functions\n    - ${BREV} completion zsh > ${PREFIX}/share/zsh/site-functions/_brev\n    - mkdir -p ${PREFIX}/share/fish/vendor_completions.d\n    - ${BREV} completion fish > ${PREFIX}/share/fish/vendor_completions.d/brev.fish\n\nrequirements:\n  build:\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler(\"cxx\") }}\n    - ${{ compiler(\"go-cgo\") }}\n    - go-licenses\n\ntests:\n  - package_contents:\n      strict: true\n      files:\n        - bin/brev\n        - share/bash-completion/completions/brev\n        - share/zsh/site-functions/_brev\n        - share/fish/vendor_completions.d/brev.fish\n\n  - script:\n      - brev --version\n      - brev --help\n\nabout:\n  homepage: https://docs.nvidia.com/brev/\n  summary: 'Brev CLI'\n  description: |\n    CLI tool for managing workspaces provided by brev.nvidia.com\n  license: MIT\n  license_file:\n    - LICENSE\n    - library_licenses/**/**/LICENSE*\n    - library_licenses/**/**/NOTICE*\n  documentation: https://docs.nvidia.com/brev/\n  repository: https://github.com/brevdev/brev-cli\n\nextra:\n  recipe-maintainers:\n    - ruben-arts\n    - matthewfeickert\n",

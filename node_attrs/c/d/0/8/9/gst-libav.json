  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"1.28.2\"\n\npackage:\n  name: gst-libav\n  version: ${{ version }}\n\nsource:\n  url: https://gstreamer.freedesktop.org/src/gst-libav/gst-libav-${{ version }}.tar.xz\n  sha256: 45ba65535870aa7c026119d2e90b35dc760e1cf6f50bffbfe8d71223a3043a4e\n\nbuild:\n  number: 1\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - ${{ compiler('cxx') }}\n    - meson\n    - ninja\n    - pkg-config\n    - if: win\n      then: m2-patch\n  host:\n    - setuptools <81\n    - ffmpeg\n    - gstreamer         1.28.2.*\n    - gst-plugins-base  1.28.2.*\n    - glib\n    # Needed for gstreamer-audio-1.0 dependency?\n    # Not sure why, zlib should be a private dependency\n    - zlib\n    - expat\n    - liblzma-devel\n    - if: win\n      then: x265\n    - if: win\n      then: libxml2-devel\n  run:\n    # We want to pin harder than the run_export from gstreamer\n    - gstreamer         1.28.2.*\n    - expat\n    - if: win\n      then: libxml2-devel\n  run_exports:\n    - ${{ pin_subpackage('gst-libav', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - if: not win\n        then: test -f ${PREFIX}/lib/gstreamer-1.0/libgstlibav${SHLIB_EXT}\n      - if: win\n        then: if not exist %LIBRARY_LIB%\\\\gstreamer-1.0\\\\gstlibav.dll exit 1\n      - gst-inspect-1.0 --plugin libav\n\nabout:\n  license: LGPL-2.1-or-later\n  license_file: COPYING\n  summary: GStreamer plugin for the FFmpeg libav* libraries\n  homepage: http://gstreamer.freedesktop.org/\n  repository: https://gitlab.freedesktop.org/gstreamer/gst-libav\n  documentation: https://gstreamer.freedesktop.org/modules/gst-libav.html\n\nextra:\n  recipe-maintainers:\n    - yishai1999\n    - tjwilli58\n    - scopatz\n    - kuepe-sl\n",

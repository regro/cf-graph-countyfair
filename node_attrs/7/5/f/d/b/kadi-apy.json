  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: kadi-apy\n  version: \"0.49.0\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://gitlab.com/iam-cms/kadi-apy/-/archive/v${{ version }}/kadi-apy-v${{ version }}.tar.gz\n  sha256: 3fb2c6e965aa51737e0661eb09ca0033167c333a152d012c27fa3a561143da33\n\nbuild:\n  number: 1\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - kadi-apy=kadi_apy.cli.main:kadi_apy\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools\n  run:\n    - python >=${{ python_min }}\n    - click >=8.0.0,<9.0.0\n    - jsonref >=1.1.0,<2.0.0\n    - python-dateutil >=2.8.2,<3.0.0\n    - rdflib >=7.0.0,<8.0.0\n    - niquests >=3.13.0,<4.0.0\n    - xmlhelpy >=0.14.0,<0.15.0\n\ntests:\n  - python:\n      imports:\n        - kadi_apy\n      pip_check: true\n      python_version: ${{ python_min }}\n  - requirements:\n      run:\n        - pip\n        - python ${{ python_min }}.*\n    script:\n      - kadi-apy --help\n\nabout:\n  summary: Python API wrapper for Kadi4Mat\n  description: |\n    Kadi-APY is a library for use in tandem with Kadi4Mat. The REST-like API of\n    Kadi4Mat makes it possible to programmatically interact with most of the\n    resources that can be used through the web interface by sending suitable HTTP\n    requests to the different endpoints the API provides.\n  license: Apache-2.0\n  license_file: LICENSE\n  homepage: https://gitlab.com/iam-cms/kadi-apy\n\nextra:\n  recipe-maintainers:\n    - jan-janssen\n",

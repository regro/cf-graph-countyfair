 "raw_meta_yaml": "{% set name = \"libflint\" %}\n{% set version = \"3.1.2\" %}\n{% set build = 0 %}\n\n{% if WITH_NTL is undefined %}\n{% set WITH_NTL = \"0\" %}\n{% endif %}\n{% if WITH_NTL == \"1\" %}\n{% set build = build + 100 %}\n{% endif %}\n\npackage:\n  name: {{ name|lower }}\n  version: {{ version }}\n\nsource:\n  url: https://flintlib.org/flint-{{ version }}.tar.gz\n  sha256: fdb3a431a37464834acff3bdc145f4fe8d0f951dd5327c4c6f93f4cbac5c2700\n\nbuild:\n  number: {{ build }}\n  {% if WITH_NTL == \"1\" %}\n  string: h{{ PKG_HASH }}_ntl_{{ build }}\n  {% else %}\n  string: h{{ PKG_HASH }}_nontl_{{ build }}\n  {% endif %}\n  skip: true  # [win and vc<14]\n  # The Windows build has been temporarily disabled. The cmake build we used before is not supported anymore and we couldn't figure out how to make autotools_clang_conda work here., see https://github.com/conda-forge/libflint-feedstock/pull/32/.\n  skip: true  # [win]\n  run_exports:\n    - {{ pin_subpackage('libflint', max_pin='x.x') }}\n  {% if WITH_NTL == \"0\" and (linux or osx) %}\n  track_features:\n    - flint_with_nontl\n  {% endif %}\n\nrequirements:\n  build:\n    - {{ compiler('c') }}\n    - {{ stdlib('c') }}\n    {% if WITH_NTL == \"1\" %}\n    - {{ compiler('cxx') }}\n    {% endif %}\n    - libtool                # [unix]\n    - m4                     # [unix]\n    - make                   # [unix]\n    - binutils               # [win]\n    - autotools_clang_conda  # [win]\n  host:\n    - gmp\n    - mpfr\n  {% if WITH_NTL == \"1\" %}\n    - ntl\n  {% endif %}\n\ntest:\n  commands:\n    - test -f $PREFIX/include/flint/flint.h   # [unix]\n    - test -f $PREFIX/lib/libflint.so         # [linux]\n    - test -f $PREFIX/lib/libflint.dylib      # [osx]\n    - if not exist %LIBRARY_BIN%\\flint-18.dll exit 1   # [win]\n    - if not exist %LIBRARY_LIB%\\flint.lib exit 1   # [win]\n    - if not exist %LIBRARY_INC%\\flint\\flint.h exit 1   # [win]\n\nabout:\n  home: http://flintlib.org\n  license: LGPL-3.0-or-later\n  license_file:\n    - COPYING\n    - COPYING.LESSER\n  summary: Fast Library for Number Theory\n\nextra:\n  recipe-maintainers:\n    - isuruf\n    - saraedum\n",

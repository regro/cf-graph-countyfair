  "raw_meta_yaml": "context:\n  version: \"0.8.21\"\n\npackage:\n  name: biomcp\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/genomoncology/biomcp/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: fdd10287f45714f0fc3dc53e3d41137f2f79ffc8be7b14e28952a457cb76894f\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      # LTO=fat is too slow on the QEMU-emulated linux-aarch64 Azure runner\n      # (Azure has a 3h job timeout). Use thin LTO there to stay within budget.\n      # Trade-off on aarch64 only: binary is ~5-15% larger and runtime is\n      # ~1-5% slower, which is negligible for this I/O-bound CLI.\n      CARGO_PROFILE_RELEASE_LTO: ${{ \"thin\" if linux and aarch64 else \"fat\" }}\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n        else:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - libprotobuf\n    - cargo-bundle-licenses\n    - cargo-auditable\n\ntests:\n  - script:\n      - biomcp --help\n      - biomcp version\n  - package_contents:\n      bin:\n        - biomcp\n        - biomcp-cli\n      strict: true\n\nabout:\n  homepage: https://biomcp.org\n  summary: Biomedical CLI and MCP server for querying genes, variants, trials, articles, drugs, diseases, and more.\n  description: |\n    BioMCP is a single-binary CLI and MCP server for querying biomedical\n    databases. One command grammar, compact markdown output, 12 entities\n    across 15+ data sources including PubMed, ClinicalTrials.gov, MyGene.info,\n    ClinVar, UniProt, Reactome, and more.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  documentation: https://biomcp.org\n  repository: https://github.com/genomoncology/biomcp\n\nextra:\n  recipe-maintainers:\n    - hadim\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"9.2.1\"\n\npackage:\n  name: superlu_dist\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/xiaoyeli/superlu_dist/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: c80a1c2edaaa451ee9a54e005e5f3f56dc55cabe2b0a8d7acf5a1447a648157a\n  patches:\n    # patches from debian to remove mc64,\n    # which has a non-free license that doesn't permit redistribution\n    - mc64ad_dist-stub.patch\n    - rowperm_default_NOROWPERM_not_MC64.patch\n\nbuild:\n  number: 1\n  skip: win\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('cxx') }}\n    - ${{ compiler('fortran') }}\n    - if: osx\n      then:\n        - llvm-openmp\n    - if: linux\n      then:\n        - libgomp\n    - cmake\n    - make\n    - if: build_platform != target_platform and mpi == \"openmpi\"\n      then:\n        - ${{ mpi }}\n  host:\n    - ${{ mpi }}\n    - metis\n    - parmetis\n    - libblas\n    - liblapack\n  run_exports:\n    - ${{ pin_subpackage('superlu_dist', upper_bound='x') }}\n\ntests:\n  - package_contents:\n      files:\n        not_exists:\n          - lib/libsuperlu_dist.a\n          - lib/libsuperlu_dist_fortran.a\n          - lib/EXAMPLE\n      lib:\n        exists:\n          - superlu_dist\n          - superlu_dist_fortran\n        not_exists:\n          - superlu_dist_python\n\n      include:\n        exists:\n          - superlu-dist/superlu_defs.h\n          - superlu-dist/superlu_dist_config.fh\n          - superlu-dist/superlu_mod.mod\n        not_exists: \n          - colamd.h\n          - supermatrix.h\n  - files:\n      source:\n        - EXAMPLE/\n        - FORTRAN/\n    requirements:\n      run:\n        - pkg-config\n        - ${{ compiler('c') }}\n        - ${{ compiler('fortran') }}\n    script:\n      - pkg-config --cflags --libs superlu_dist\n\nabout:\n  license: BSD-3-Clause\n  license_file: License.txt\n  summary: |\n    Supernodal LU, solvers for large, sparse, nonsymmetric systems of linear\n    equations. SuperLU_DIST is a parallel extension to the serial SuperLU library.\n  homepage: https://portal.nersc.gov/project/sparse/superlu/\n  repository: https://github.com/xiaoyeli/superlu_dist/\n  documentation: https://portal.nersc.gov/project/sparse/superlu/superlu_dist_code_html/index.html\n\nextra:\n  recipe-maintainers:\n    - awvwgk\n    - minrk\n    - davidbrochart\n    - SylvainCorlay\n",

      "description": "API library for Open Mining Format, a new standard for mining data backed by the Global Mining Standards & Guidelines Group.\n\n**Note:**\nThis is a fork created by Mira Geoscience for interoperability with the geoh5 file format.\n",
      "dev_url": "https://github.com/MiraGeoscience/omf",
      "home": "https://www.mirageoscience.com/mining-industry-software/python-integration/",
      "license": "MIT",
      "license_file": [
        "LICENSE"
      ],
      "summary": "API library for Open Mining Format, a new standard for mining data backed by the Global Mining Standards & Guidelines Group."
    },
    "build": {
      "entry_points": [
        "geoh5_to_omf  = omf.scripts.geoh5_to_omf:main",
        "omf_to_geoh5 = omf.scripts.omf_to_geoh5:main"
      ],
      "noarch": "python",
      "number": "0",
      "script": "PYTHON -m pip install . -vv --no-deps --no-build-isolation"
    },
    "extra": {
      "recipe-maintainers": [
        "conda-forge/geoh5py"
      ]
    },
    "package": {
      "name": "mira-omf",
      "version": "3.3.0"
    },
    "requirements": {
      "host": [
        "pip",
        "python 3.10",
        "poetry-core >=1.0.0",
        "setuptools"
      ],
      "run": [
        "python >=3.10",
        "geoh5py >=0.10.0,<0.11.dev",
        "properties >=0.6.0,<0.7.dev",
        "pypng 0.20220715.*",
        "numpy >=1.26.0,<1.27.dev",
        "six >=1.16.0,<2.dev",
        "vectormath >=0.2.0,<0.2.1"
      ]
    },

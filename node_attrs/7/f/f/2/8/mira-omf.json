  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: mira-omf\n  version: \"3.3.2\"\n  python_min: '3.10'\n  module_name: omf\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/MiraGeoscience/omf/archive/v${{ version }}.tar.gz\n  sha256: 6efdeb9ab8abeb0ce15822bede4ed9a71c9df2fb065474d20eda5efd7779c54d\n\nbuild:\n  number: 0\n  noarch: python\n  script:\n    - export POETRY_DYNAMIC_VERSIONING_BYPASS=${{ version }}\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - geoh5_to_omf = omf.scripts.geoh5_to_omf:main\n      - omf_to_geoh5 = omf.scripts.omf_to_geoh5:main\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - poetry-core >=1.8.0\n    - poetry-dynamic-versioning >=1.9, 1.*\n    - setuptools\n  run:\n    - python >=${{ python_min }}\n    # Mira packages\n    - geoh5py 0.12.*\n    # direct dependencies\n    - numpy 1.26.*\n    - properties 0.6.*\n    - pypng 0.20220715.*\n    - six >=1.16.0, 1.*\n    - vectormath 0.2.*\n\ntests:\n  - python:\n      python_version: ${{ python_min }}.*\n      imports:\n        - ${{ module_name }}\n        - ${{ module_name }}._version\n        # dependency imports\n        - geoh5py\n        - properties\n      pip_check: false  # something wrong with properties 0.6.1, but installation seems correct nonetheless\n  - script:\n      - pytest --ignore=tests/version_test.py\n      - pip list\n    requirements:\n      run:\n        - pip\n        - pytest\n    files:\n      source:\n        - tests/\n        - docs/images/PointSetGeometry.png\n  - package_contents:\n      files:\n        - site-packages/${{ module_name }}/_version.py\n\nabout:\n  summary: API library for Open Mining Format, a new standard for mining data backed by the Global Mining Standards & Guidelines Group.\n  description: |\n    API library for Open Mining Format, a new standard for mining data backed by the Global Mining Standards & Guidelines Group.\n\n    **Note:**\n    This is a fork created by Mira Geoscience for interoperability with the geoh5 file format.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRD_PARTY_SOFTWARE.rst\n  homepage: https://www.mirageoscience.com/mining-industry-software/python-integration/\n  repository: https://github.com/MiraGeoscience/omf\n\nextra:\n  recipe-maintainers:\n    - conda-forge/geoh5py\n",

  "raw_meta_yaml": "context:\n  version: \"1.2.1\"\n\npackage:\n  name: rotz\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/volllly/rotz/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 61bae45578e988c627a8db36fcc934d8d21e30735f576c77312ba7dd66fd99bb\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - export OPENSSL_DIR=${PREFIX}\n          - export OPENSSL_NO_VENDOR=1\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n        else:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n      - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ compiler('rust') }}\n    - ${{ compiler('c') }}\n    - if: unix\n      then: pkg-config\n    - ${{ stdlib(\"c\") }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n  host:\n    - if: unix\n      then: openssl\ntests:\n  - script:\n      - rotz --help\n      - rotz --version\n\nabout:\n  homepage: https://volllly.github.io/rotz/\n  summary: Fully cross platform dotfile manager and dev environment bootstrapper written in Rust.\n  description: |\n    rotz is a fully cross platform dotfile manager and dev environment bootstrapper written in Rust.\n    It helps you manage your dotfiles across different platforms and environments with powerful\n    templating and linking capabilities.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  documentation: https://docs.rs/rotz/\n  repository: https://github.com/volllly/rotz\n\nextra:\n  recipe-maintainers:\n    - phreed\n",

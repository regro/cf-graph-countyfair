  "linux_64_meta_yaml": {
    "about": {
      "description": "A Python package for generating cubic splines in one, two, or three (hence, multiple)\ndimensions. The package supports a number of boundary conditions, but is restricted\nto interpolating data that is spaced on a uniform grid.\n",
      "dev_url": "https://github.com/znasipak/multispline",
      "home": "https://github.com/znasipak/multispline",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "A Python package for generating cubic splines in multiple dimensions"
    },
    "build": {
      "number": "0",
      "script": [
        "export CMAKE_GENERATOR=Ninja",
        "PYTHON -m pip install . -vv --config-settings=cmake.verbose=true --config-settings=logging.level=DEBUG"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "znasipak",
        "mpigou"
      ]
    },
    "package": {
      "name": "multispline",
      "version": "0.8.3"
    },
    "requirements": {
      "build": [
        "c_compiler_stub",
        "c_stdlib_stub",
        "cxx_compiler_stub",
        "ninja",
        "cmake",
        "make"
      ],
      "host": [
        "python",
        "pip",
        "scikit-build-core",
        "cython",
        "numpy"
      ],
      "run": [
        "python",
        "numpy"
      ]
    },
    "schema_version": 0,
    "source": {

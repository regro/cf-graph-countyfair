  "linux_64_meta_yaml": {
    "about": {
      "description": "Built on top of the popular open source project, Polars Cloud enables you to write DataFrame code once and run it anywhere. The distributed engine available with Polars Cloud allows you to scale your Polars queries beyond a single machine.",
      "dev_url": "https://github.com/pola-rs/polars-cloud-client",
      "doc_url": "https://cloud.pola.rs/",
      "home": "https://cloud.pola.rs/",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "client/LICENSE",
      "summary": "Python client for Polars Cloud"
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "cd client",
          "cp ${RECIPE_DIR}/cargo-auditable-wrapper.sh ${BUILD_PREFIX}/bin/cargo-auditable-wrapper",
          "python -m pip install . -vv",
          "cargo-bundle-licenses --format yaml --output ../THIRD_PARTY.yml"
        ],
        "env": {
          "CARGO": "cargo-auditable-wrapper",
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "pavelzw"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "polars-cloud",
        "requirements": {
          "build": [
            "c_compiler_stub",
            "rust_compiler_stub",
            "c_stdlib_stub",
            "cargo-auditable",
            "cargo-bundle-licenses",
            "libprotobuf"
          ],
          "host": [
            "python",
            "pip",
            "maturin >=1,<2",
            "libprotobuf"
          ],
          "run": [
            "python",
            "polars",
            "polars-runtime-64",
            "cloudpickle",
            "typing-extensions"
          ]
        },
        "tests": [
          {
            "python": {
              "imports": [
                "polars_cloud"
              ],
              "python_version": "3.10.*"
            }
          },
          {
            "requirements": {
              "run": [
                "abi3audit"
              ]
            },
            "script": [
              "export SP_DIR=$(python -c \"import site; print(site.getsitepackages()[0])\")",
              "abi3audit $SP_DIR/polars_cloud/polars_cloud.abi3.so -s -v --assume-minimum-abi3 ${{ python_min }}"
            ]
          }
        ],
        "version": "0.4.0"
      }
    ],

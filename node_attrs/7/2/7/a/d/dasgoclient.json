      "license_file": "src/LICENSE",
      "summary": "Go client for the CMS Data Aggregation System"
    },
    "build": {
      "number": "0",
      "script": [
        "cd src",
        "go-licenses save . --save_path ../library_licenses",
        "sed -i.bak -e \"s,{{VERSION}},v${{ version }},g\" main.go && rm main.go.bak",
        "go build -v -o $PREFIX/bin/dasgoclient -ldflags=\"-s -w\""
      ]
    },

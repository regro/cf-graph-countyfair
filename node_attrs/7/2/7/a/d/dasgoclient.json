  "raw_meta_yaml": "context:\n  version: \"02.04.52\"\n\npackage:\n  name: dasgoclient\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/dmwm/dasgoclient/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: dbf5eafe1276a520cde6c28b60ddd15710bde1a2aa321ade9f866f0cd32319d7\n  target_directory: src\n\nbuild:\n  number: 0\n  script:\n    - cd src\n    - go-licenses save . --save_path ../library_licenses\n    - if: unix\n      then: sed -i.bak -e \"s,{{VERSION}},v${{ version }},g\" main.go && rm main.go.bak\n      else: powershell -Command \"$content = [System.IO.File]::ReadAllText('main.go').Replace('{{VERSION}}', 'v${{ version }}'); $utf8 = New-Object System.Text.UTF8Encoding $false; [System.IO.File]::WriteAllText('main.go', $content, $utf8)\"\n    - if: unix\n      then: go build -v -o $PREFIX/bin/dasgoclient -ldflags=\"-s -w\"\n      else: go build -v -o %LIBRARY_BIN%\\dasgoclient.exe -ldflags=\"-s\"\n\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntests:\n  - script: dasgoclient -help\n  - package_contents:\n      bin:\n        - dasgoclient\n      strict: true\n\nabout:\n  homepage: https://github.com/dmwm/dasgoclient\n  summary: Go client for the CMS Data Aggregation System\n  description: |\n    dasgoclient is the Go implementation of the CMS Data Aggregation System\n    (DAS) client. It provides a command-line interface for querying CMS\n    data services and returning results in text or JSON formats.\n  license: MIT\n  license_file:\n    - src/LICENSE\n    - library_licenses/\n  documentation: https://pkg.go.dev/github.com/dmwm/dasgoclient\n  repository: https://github.com/dmwm/dasgoclient\n\nextra:\n  recipe-maintainers:\n    - clelange\n",

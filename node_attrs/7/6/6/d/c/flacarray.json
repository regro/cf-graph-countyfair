  "linux_64_meta_yaml": {
    "about": {
      "description": "Flacarray provides a set of tools for compressing multi-dimensional arrays\nwhere the last array dimension consists of \"streams\" of data. These streams\nare compressed with the FLAC algorithm and can be written to different file\nformats as well as decompressed back into numpy arrays.  This package is\nNOT intended for use with audio data.\n",
      "dev_url": "https://github.com/hpc4cmb/flacarray",
      "doc_url": "https://hpc4cmb.github.io/flacarray",
      "home": "https://github.com/hpc4cmb/flacarray",
      "license": "BSD-2-Clause",
      "license_family": "BSD",
      "license_file": "LICENSE",
      "summary": "Tools for FLAC compression of numpy arrays."
    },
    "build": {
      "number": "3",
      "script": [
        "PYTHON -m pip install . -vv --no-deps --no-build-isolation"
      ],
      "script_env": [
        "SETUPTOOLS_SCM_PRETEND_VERSION=0.4.0"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "tskisner"
      ]
    },
    "package": {
      "name": "flacarray",
      "version": "0.4.0"
    },

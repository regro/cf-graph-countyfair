    "about": {
      "description": "A fast command-line spider (web crawler) written in Rust for high-performance website scraping. Optionally allows to provide an API key for spider.cloud to\nuse their hosted services.",
      "dev_url": "https://github.com/spider-rs/spider",
      "doc_url": "https://github.com/spider-rs/spider/tree/main/spider_cli",
      "home": "https://spider.cloud/",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "spider (web crawler) CLI for high-performance website scraping."
    },
    "build": {
      "number": "1",
      "script": {
        "content": [
          "cd spider_cli",
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .",
          "cargo-bundle-licenses --format yaml --output ../THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "spider_cli",

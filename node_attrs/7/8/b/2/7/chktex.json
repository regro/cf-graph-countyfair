  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  version: \"1.7.10\"\n  am_version: \"1.15\"\n  posix_prefix: ${{ \"m2-\" if win else \"\" }}\n\npackage:\n  name: chktex\n  version: ${{ version }}\n\nsource:\n  url:\n    # https://github.com/conda-forge/chktex-feedstock/pull/8\n    ## 200 locally, 502 in CI\n    - https://download.savannah.gnu.org/releases/chktex/chktex-${{ version }}.tar.gz\n    - https://www.mirrorservice.org/sites/download.savannah.gnu.org/releases/chktex/chktex-${{ version }}.tar.gz\n  sha256: cea81a1cde2f151db2b5d2adf2271becfd3c0c1f40eca5cf45b52beeb4a636f9\n\nbuild:\n  # TODO: see https://github.com/conda-forge/chktex-feedstock/issues/9\n  skip: win\n  number: 0\n  script:\n    file: build-chktex\n  dynamic_linking:\n    missing_dso_allowlist:\n      - if: osx\n        then: /usr/lib/libncurses.5.4.dylib\n\nrequirements:\n  build:\n    - ${{ posix_prefix }}autoconf\n    - ${{ posix_prefix }}libtool\n    - ${{ posix_prefix }}make\n    - ${{ posix_prefix }}patch\n    - ${{ posix_prefix }}sed\n    - pkg-config\n    - if: unix\n      then:\n        - ${{ compiler(\"c\") }}\n        - ${{ compiler(\"cxx\") }}\n        - ${{ stdlib(\"c\") }}\n        - automake\n        - gettext\n        - gnuconfig\n      else:\n        - ${{ compiler(\"m2w64_c\") }}\n        - ${{ compiler(\"m2w64_cxx\") }}\n        - ${{ stdlib(\"m2w64_c\") }}\n        - m2-automake${{ am_version }}\n        - m2-base\n  host:\n    - ${{ posix_prefix }}ncurses\n    - ${{ posix_prefix }}perl\n\ntests:\n  - script:\n      - chktex --version\n      - deweb --version\n      - chkweb --version\n\nabout:\n  license: GPL-2.0-or-later\n  license_file: COPYING\n  summary: LaTeX semantic checker\n  description: |\n    This program has been written in frustration because some constructs in\n    LaTeX are sometimes non-intuitive, and easy to forget. It is _not_ a\n    replacement for the built-in checker in LaTeX; however it catches some\n    typographic errors LaTeX oversees. In other words, it is Lint for LaTeX.\n    Filters are also provided for checking the LaTeX parts of CWEB documents.\n  homepage: https://www.nongnu.org/chktex\n  repository: https://savannah.nongnu.org/projects/chktex\n\nextra:\n  recipe-maintainers:\n    - bollwyvl\n",

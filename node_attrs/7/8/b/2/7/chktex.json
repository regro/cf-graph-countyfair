  "linux_64_meta_yaml": {
    "about": {
      "description": "This program has been written in frustration because some constructs in\nLaTeX are sometimes non-intuitive, and easy to forget. It is _not_ a\nreplacement for the built-in checker in LaTeX; however it catches some\ntypographic errors LaTeX oversees. In other words, it is Lint for LaTeX.\nFilters are also provided for checking the LaTeX parts of CWEB documents.",
      "dev_url": "https://savannah.nongnu.org/projects/chktex",
      "home": "https://www.nongnu.org/chktex",
      "license": "GPL-2.0-or-later",
      "license_family": "GPL-2.0-or-later",
      "license_file": "COPYING",
      "summary": "LaTeX semantic checker"
    },
    "build": {
      "number": "0",
      "script": {
        "file": "build-chktex"
      }
    },
    "extra": {
      "recipe-maintainers": [
        "bollwyvl"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "chktex",
        "requirements": {
          "build": [
            "autoconf",
            "libtool",
            "make",
            "patch",
            "sed",
            "pkg-config",
            "c_compiler_stub",
            "cxx_compiler_stub",
            "c_stdlib_stub",
            "automake",
            "gettext",
            "gnuconfig"
          ],
          "host": [
            "ncurses",
            "perl"
          ],
          "run": []
        },
        "tests": [
          {
            "script": [
              "chktex --version",
              "deweb --version",
              "chkweb --version"
            ]
          }
        ],
        "version": "1.7.10"

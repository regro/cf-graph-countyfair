  "raw_meta_yaml": "context:\n  version: \"0.12.0\"\n\npackage:\n  name: hyalo\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/ractive/hyalo/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 43695661ed0786d778bd8389667662c146a181046e7386fbbbc20939cf0d273f\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - cd crates/hyalo-cli\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .\n          # generate shell completions\n          - mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions\n          - $PREFIX/bin/hyalo completion bash > $PREFIX/share/bash-completion/completions/hyalo\n          - $PREFIX/bin/hyalo completion fish > $PREFIX/share/fish/vendor_completions.d/hyalo.fish\n          - $PREFIX/bin/hyalo completion zsh > $PREFIX/share/zsh/site-functions/_hyalo\n      - if: win\n        then:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path .\n          # generate shell completions\n          - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n          - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n          - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n          - '%LIBRARY_BIN%\\hyalo.exe completion bash > %LIBRARY_PREFIX%\\share\\bash-completion\\completions\\hyalo'\n          - '%LIBRARY_BIN%\\hyalo.exe completion fish > %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\hyalo.fish'\n          - '%LIBRARY_BIN%\\hyalo.exe completion zsh > %LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_hyalo'\n      - cargo-bundle-licenses --format yaml --output ../../THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n\ntests:\n  - script:\n      - hyalo --help\n      - hyalo --version\n  - package_contents:\n      bin:\n        - hyalo\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/hyalo\n            - share/fish/vendor_completions.d/hyalo.fish\n            - share/zsh/site-functions/_hyalo\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/hyalo\n            - Library/share/fish/vendor_completions.d/hyalo.fish\n            - Library/share/zsh/site-functions/_hyalo\n      strict: true\n\nabout:\n  summary: Download and install release assets from GitHub\n  description: |\n    Hyalo is a high-performance CLI tool designed to query, manage, and bulk-edit Markdown collections\n    that use YAML frontmatter, such as Obsidian vaults, Zettelkastens, and static documentation sites.\n    Hyalo natively understands Markdown structures to offer advanced filtering, bulk metadata mutations,\n    and smart link refactoring across thousands of files in milliseconds. With native JSON output,\n    built-in AI agent integrations, and robust dry-run safety features, Hyalo provides a fast,\n    scriptable solution for maintaining and automating complex knowledge bases.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  homepage: https://github.com/ractive/hyalo\n  repository: https://github.com/ractive/hyalo\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

  "linux_64_meta_yaml": {
    "about": {
      "description": "Hyalo is a high-performance CLI tool designed to query, manage, and bulk-edit Markdown collections\nthat use YAML frontmatter, such as Obsidian vaults, Zettelkastens, and static documentation sites.\nHyalo natively understands Markdown structures to offer advanced filtering, bulk metadata mutations,\nand smart link refactoring across thousands of files in milliseconds. With native JSON output,\nbuilt-in AI agent integrations, and robust dry-run safety features, Hyalo provides a fast,\nscriptable solution for maintaining and automating complex knowledge bases.",
      "dev_url": "https://github.com/ractive/hyalo",
      "home": "https://github.com/ractive/hyalo",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Download and install release assets from GitHub"
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path crates/hyalo-cli",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "hyalo",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable"
          ],
          "host": [],
          "run": []
        },
        "tests": [

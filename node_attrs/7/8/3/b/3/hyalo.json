  "linux_64_meta_yaml": {
    "about": {
      "description": "Hyalo is a high-performance CLI tool designed to query, manage, and bulk-edit Markdown collections\nthat use YAML frontmatter, such as Obsidian vaults, Zettelkastens, and static documentation sites.\nHyalo natively understands Markdown structures to offer advanced filtering, bulk metadata mutations,\nand smart link refactoring across thousands of files in milliseconds. With native JSON output,\nbuilt-in AI agent integrations, and robust dry-run safety features, Hyalo provides a fast,\nscriptable solution for maintaining and automating complex knowledge bases.",
      "dev_url": "https://github.com/ractive/hyalo",
      "home": "https://github.com/ractive/hyalo",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Download and install release assets from GitHub"
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "cd crates/hyalo-cli",
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .",
          "mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions",
          "$PREFIX/bin/hyalo completion bash > $PREFIX/share/bash-completion/completions/hyalo",
          "$PREFIX/bin/hyalo completion fish > $PREFIX/share/fish/vendor_completions.d/hyalo.fish",
          "$PREFIX/bin/hyalo completion zsh > $PREFIX/share/zsh/site-functions/_hyalo",
          "cargo-bundle-licenses --format yaml --output ../../THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "hyalo",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-bundle-licenses",
            "cargo-auditable"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "hyalo --help",
              "hyalo --version"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "hyalo"
              ],
              "files": [
                "share/bash-completion/completions/hyalo",
                "share/fish/vendor_completions.d/hyalo.fish",
                "share/zsh/site-functions/_hyalo"
              ],
              "strict": true
            }
          }
        ],
        "version": "0.12.0"
      }
    ],

  "raw_meta_yaml": "context:\n  version: \"0.1.1\"\n  python_min: \"3.10\"\n\nrecipe:\n  name: conda-global-split\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/conda-incubator/conda-global/archive/refs/tags/${{ version }}.tar.gz\n  sha256: 7298d1ada2982d72ca7136e24ae426e182d13b452627a495cead81dc4b144d53\n\nbuild:\n  number: 2\n\noutputs:\n  - package:\n      name: conda-trampoline\n      version: ${{ version }}\n    build:\n      number: 2\n      python:\n        version_independent: true\n      script:\n        env:\n          CARGO_PROFILE_RELEASE_STRIP: symbols\n          CARGO_PROFILE_RELEASE_LTO: fat\n        content:\n          - if: unix\n            then:\n              - ${{ PYTHON }} -m pip install packages/conda-trampoline -vv --no-deps --no-build-isolation\n            else:\n              - ${{ PYTHON }} -m pip install packages\\conda-trampoline -vv --no-deps --no-build-isolation\n    requirements:\n      build:\n        - maturin >=1.0,<2.0\n        - ${{ compiler('rust') }}\n        - ${{ stdlib('c') }}\n        - if: build_platform != target_platform\n          then:\n            - python ${{ python_min }}.*\n            - cross-python_${{ target_platform }}\n      host:\n        - python ${{ python_min }}.*\n        - pip\n        - maturin >=1.0,<2.0\n      run:\n        - python >=${{ python_min }}\n    tests:\n      - python:\n          imports:\n            - conda_trampoline\n          pip_check: false\n      - package_contents:\n          files:\n            - python-scripts/_cg_trampoline*\n\n  - package:\n      name: conda-global\n      version: ${{ version }}\n    build:\n      number: 2\n      noarch: python\n      script:\n        env:\n          SETUPTOOLS_SCM_PRETEND_VERSION: ${{ version }}\n        content: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n      python:\n        entry_points:\n          - cg = conda_global.__main__:main\n    requirements:\n      build:\n        - if: build_platform != target_platform\n          then:\n            - python ${{ python_min }}.*\n            - cross-python_${{ target_platform }}\n      host:\n        - python ${{ python_min }}.*\n        - pip\n        - hatchling >=1.12.2\n        - hatch-vcs >=0.2.0\n      run:\n        - python >=${{ python_min }}\n        - conda >=25.1\n        - conda-trampoline ==${{ version }}\n        - tomlkit >=0.13\n        - rich >=13.0\n        - userpath >=1.9\n    tests:\n      - python:\n          imports:\n            - conda_global\n            - conda_global.plugin\n          pip_check: false\n          python_version: ${{ python_min }}.*\n      - script:\n          - cg --help\n\nabout:\n  homepage: https://github.com/conda-incubator/conda-global\n  repository: https://github.com/conda-incubator/conda-global\n  documentation: https://conda-incubator.github.io/conda-global/\n  license: BSD-3-Clause\n  license_file: LICENSE\n  summary: >\n    Global tool installation for conda — install CLI tools into isolated\n    environments and make them available on PATH via trampolines.\n\nextra:\n  feedstock-name: conda-global\n  recipe-maintainers:\n    - jezdez\n    - travishathaway\n",

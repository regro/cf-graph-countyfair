  "linux_64_meta_yaml": {
    "about": {
      "description": "`mise` (mise-en-place) is a unified CLI tool designed to simplify and manage local development environments.\nIt acts as a polyglot tool version manager, installing and seamlessly switching between versions of various\ndevelopment tools (replacing utilities like `asdf`, `nvm`, and `pyenv`). Additionally, it functions as an\nenvironment variable manager that dynamically loads project-specific env vars based on your current directory\n(replacing `direnv`), and serves as a built-in task runner to define and execute project workflows as a modern\nalternative to `make` or `npm` scripts.",
      "dev_url": "https://github.com/jdx/mise",
      "home": "https://mise.jdx.dev/",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "mise manages dev tools, env vars, and runs tasks."
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "export LIBCLANG_PATH=$BUILD_PREFIX/lib",
          "cargo auditable install --no-track --locked --bins --no-default-features --features ${{ base_features }}${{ extra_features }} --root ${{ PREFIX }} --path .",
          "mkdir -p $PREFIX/share/man/man1",
          "cp man/man1/mise.1 $PREFIX/share/man/man1/mise.1",
          "mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions",
          "$PREFIX/bin/mise completion bash > $PREFIX/share/bash-completion/completions/mise",
          "$PREFIX/bin/mise completion fish > $PREFIX/share/fish/vendor_completions.d/mise.fish",
          "$PREFIX/bin/mise completion zsh > $PREFIX/share/zsh/site-functions/_mise",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols",
          "OPENSSL_NO_VENDOR": "1"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "mise",
        "requirements": {
          "build": [
            "c_stdlib_stub",
            "c_compiler_stub",
            "rust_compiler_stub",
            "cargo-auditable",
            "cargo-bundle-licenses",
            "clang",
            "cmake",
            "libclang",
            "make",
            "ninja",
            "pkg-config"
          ],
          "host": [
            "openssl"
          ],
          "run": []
        },
        "tests": [
          {
            "script": {
              "content": [
                "mise version",
                "mise help"
              ],
              "env": {
                "MISE_NO_CONFIG": "1",
                "MISE_OFFLINE": "1"
              }
            }
          },
          {
            "package_contents": {
              "bin": [
                "mise"
              ],
              "files": [
                "share/bash-completion/completions/mise",
                "share/fish/vendor_completions.d/mise.fish",
                "share/zsh/site-functions/_mise",
                "share/man/man1/mise.1"
              ],
              "strict": true
            }
          }
        ],
        "version": "2026.4.11"
      }
    ],
    "package": {

  "raw_meta_yaml": "context:\n  name: mise\n  version: \"2026.4.11\"\n  # upstream refs: https://github.com/jdx/mise/blob/main/scripts/build-tarball.sh & https://github.com/jdx/mise/blob/main/scripts/build-tarball.ps1\n  base_features: native-tls,rustls-native-roots,vfox/vendored-lua\n  extra_features: ${{ \",aws-lc-rs\" if target_platform == \"linux-armv7l\" else \"\" }}\n\npackage:\n  name: mise\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/jdx/mise/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: a847ca56d6db11571cbf54611156e8d18e0e31f2e63bd9a59fd575af524f2f03\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n      OPENSSL_NO_VENDOR: 1\n    content:\n      # NOTE: we have to set LIBCLANG_PATH for bindgen to find libclang\n      # cf. https://github.com/conda-forge/clangdev-feedstock/issues/373 & https://github.com/rust-lang/rust-bindgen/issues/918\n      - if: unix\n        then:\n          - export LIBCLANG_PATH=$BUILD_PREFIX/lib\n          - cargo auditable install --no-track --locked --bins --no-default-features --features ${{ base_features }}${{ extra_features }} --root ${{ PREFIX }} --path .\n          # copy manpage and generate shell completions\n          - mkdir -p $PREFIX/share/man/man1\n          - cp man/man1/mise.1 $PREFIX/share/man/man1/mise.1\n          - mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions\n          - $PREFIX/bin/mise completion bash > $PREFIX/share/bash-completion/completions/mise\n          - $PREFIX/bin/mise completion fish > $PREFIX/share/fish/vendor_completions.d/mise.fish\n          - $PREFIX/bin/mise completion zsh > $PREFIX/share/zsh/site-functions/_mise\n      - if: win\n        then:\n          # bindgen expects libclang.dll; conda-forge only provides versioned DLLs on Windows\n          - powershell -Command \"cp (gci $env:BUILD_PREFIX\\Library\\bin\\libclang-*.dll)[0] $env:BUILD_PREFIX\\Library\\bin\\libclang.dll\"\n          - set \"LIBCLANG_PATH=%BUILD_PREFIX%\\Library\\bin\"\n          - cargo auditable install --no-track --locked --bins --no-default-features --features ${{ base_features }}${{ extra_features }} --root %LIBRARY_PREFIX% --path .\n          - cargo auditable install --no-track --locked --bins --root %LIBRARY_PREFIX% --path crates\\mise-shim\n          # copy manpage and generate shell completions\n          - mkdir %LIBRARY_PREFIX%\\share\\man\\man1\n          - powershell -Command \"Copy-Item -Path 'man/man1/mise.1' -Destination '%LIBRARY_PREFIX%\\share\\man\\man1\\mise.1'\"\n          - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n          - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n          - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n          - '%LIBRARY_BIN%\\mise.exe completion bash > %LIBRARY_PREFIX%\\share\\bash-completion\\completions\\mise'\n          - '%LIBRARY_BIN%\\mise.exe completion fish > %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\mise.fish'\n          - '%LIBRARY_BIN%\\mise.exe completion zsh > %LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_mise'\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-auditable\n    - cargo-bundle-licenses\n    - clang\n    - cmake\n    - libclang\n    - make\n    - ninja\n    - pkg-config\n  host:\n    - if: unix\n      then: openssl\n\ntests:\n  - script:\n      env:\n        MISE_NO_CONFIG: 1\n        MISE_OFFLINE: 1\n      content:\n        - mise version\n        - mise help\n  - package_contents:\n      bin:\n        - mise\n        - if: win\n          then: mise-shim\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/mise\n            - share/fish/vendor_completions.d/mise.fish\n            - share/zsh/site-functions/_mise\n            - share/man/man1/mise.1\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/mise\n            - Library/share/fish/vendor_completions.d/mise.fish\n            - Library/share/zsh/site-functions/_mise\n            - Library/share/man/man1/mise.1\n      strict: true\n\nabout:\n  summary: mise manages dev tools, env vars, and runs tasks.\n  description: |\n    `mise` (mise-en-place) is a unified CLI tool designed to simplify and manage local development environments.\n    It acts as a polyglot tool version manager, installing and seamlessly switching between versions of various\n    development tools (replacing utilities like `asdf`, `nvm`, and `pyenv`). Additionally, it functions as an\n    environment variable manager that dynamically loads project-specific env vars based on your current directory\n    (replacing `direnv`), and serves as a built-in task runner to define and execute project workflows as a modern\n    alternative to `make` or `npm` scripts.\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  homepage: https://mise.jdx.dev/\n  repository: https://github.com/jdx/mise\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

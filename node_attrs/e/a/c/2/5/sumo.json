    "about": {
      "description": "Sumo is a Python toolkit for plotting and analysis of ab initio\nsolid-state calculation data, built on existing Python packages from\nthe solid-state chemistry/physics community. It is hoped that these\ncommand-line tools will bring some of the benefits of these libraries\nto a wider user-base while providing publication-ready plotting\n(powered by Matplotlib.)",
      "dev_url": "https://github.com/SMTG-UCL/sumo",
      "doc_url": "https://sumo.readthedocs.io/en/latest/",
      "home": "https://github.com/SMTG-UCL/sumo",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Heavy weight plotting tools for ab initio solid-state calculations"
    },
    "build": {
      "noarch": "python",
      "number": "1",
      "script": "${{ PYTHON }} -m pip install . -vv"
    },
    "extra": {
      "recipe-maintainers": [
        "jan-janssen"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "sumo",
        "requirements": {
          "build": [],
          "host": [
            "pip",
            "python 3.10.*",
            "setuptools"
          ],
          "run": [
            "monty",
            "matplotlib-base",
            "numpy",
            "phonopy >=2.1.3",
            "pymatgen",
            "python >=3.10",
            "scipy",
            "seekpath",
            "spglib",
            "castepxbin 0.1.0.*",
            "colormath",

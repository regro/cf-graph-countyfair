  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: squashfs-tools\n  version: \"4.7.5\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/plougher/squashfs-tools/archive/refs/tags/${{ version }}.tar.gz\n  sha256: 547b7b7f4d2e44bf91b6fc554664850c69563701deab9fd9cd7e21f694c88ea6\n  patches:\n    - 0001-Compatability-define-for-macOS.patch\n\nbuild:\n  number: 0\n  skip: not unix\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - make\n    - help2man\n    - sed\n  host:\n    - lz4-c\n    - lzo\n    - liblzma-devel\n    - zlib\n    - zstd\n\ntests:\n  - script:\n      - mkdir testdir\n      - touch testdir/testfile\n      - mksquashfs testdir recipe.fs\n      - unsquashfs recipe.fs\n\nabout:\n  license: GPL-2.0-or-later\n  license_file: COPYING\n  summary: Tools for creating and unpacking squashfs filesystems\n  description: |\n    Squashfs is a highly compressed read-only filesystem for Linux.\n    It uses either gzip/xz/lzo/lz4 compression to compress both files, inodes\n    and directories.  Inodes in the system are very small and all blocks are\n    packed to minimise data overhead. Block sizes greater than 4K are supported\n    up to a maximum of 1Mbytes (default block size 128K).\n\n\n  homepage: https://sourceforge.net/projects/squashfs/\n\nextra:\n  recipe-maintainers:\n    - sodre\n    - mingwandroid\n    - xhochy\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  python_min: '3.11'\n  version: 3.25.1\n\npackage:\n  name: openquake.engine\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/o/openquake.engine/openquake_engine-${{ version }}.tar.gz\n  sha256: 5549a2fee88fec0339e8980b9bdeee266762ba0f15e69866128deee405ae52f4\n\nbuild:\n  number: 0\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - oq = openquake.commands.__main__:oq\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - setuptools >=69.0\n    - pip\n  run:\n    - python >=${{ python_min }}\n    - setuptools\n    - h5py >=2.10\n    - numpy >=1.20\n    - numba >=0.58\n    - scipy >=1.3\n    - pandas >=0.25\n    - pyzmq >=19.0\n    - psutil >=2.0\n    - shapely >=1.7\n    - docutils >=0.11\n    - decorator >=4.3\n    - django >=4.2,<5\n    - matplotlib-base\n    - requests >=2.20\n    - toml >=0.10.2\n    - pyproj >=1.9\n    - alpha-shapes >=1.1.0\n    - h3-py >=3.7\n    # not listed in the metadata but required\n    - fiona >=1.9.5\n\ntests:\n  - python:\n      imports:\n        - openquake._unc\n        - openquake._unc.processing\n      pip_check: true\n      python_version:\n        - ${{ python_min }}.*\n        - '*'\n  - requirements:\n      run:\n        - pip\n        - python ${{ python_min }}.*\n    script:\n      - oq --help\n\nabout:\n  summary: Computes earthquake hazard and risk.\n  license: AGPL-3.0-only\n  license_file:\n    - LICENSE\n  homepage: https://github.com/gem/oq-engine\n\nextra:\n  recipe-maintainers:\n    - cbworden\n    - emthompson-usgs\n    - mhearne-usgs\n    - ocefpaf\n",

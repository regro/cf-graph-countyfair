  "raw_meta_yaml": "context:\n  version: \"0.6.1\"\n\npackage:\n  name: zuban\n  version: ${{ version }}\n\nsource:\n  - url: https://github.com/zubanls/zuban/archive/refs/tags/v${{ version }}.tar.gz\n    sha256: 8e2548add41d89862988bfb1168df0955bbf792a9473d58c55ba334dd43e77bf\n  - url: https://github.com/python/typeshed/archive/0e9b8c99ba01717d737de8b01ed647ef2f2ac9e5.tar.gz\n    sha256: 8f1ab8e6bb78da727159acad2369dc0c63d9fc96db19d24ad4fdd9536796d0fb\n    target_directory: third_party/typeshed\n  - url: https://github.com/typeddjango/django-stubs/archive/e82f5d126b1e15281e2e32ce746ce38e25105952.tar.gz\n    sha256: 0fb632c75a31758a2f2bb5bf00354b2dac749f3a2d292848b3430bfc1c358541\n    target_directory: third_party/django-stubs\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path crates/zuban\n        else:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path crates/zuban\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n\ntests:\n  - script:\n      - zuban --help\n      - zmypy --help\n      - zubanls --help\n  - package_contents:\n      bin:\n        - zuban\n        - zmypy\n        - zubanls\n      strict: true\n\nabout:\n  homepage: https://zubanls.com\n  summary: A high-performance Python type checker and language server written in Rust\n  description: |\n    Zuban is a high-performance Python Language Server and type checker\n    implemented in Rust. It offers 20-200x faster performance than Mypy with\n    significantly less memory and CPU usage than Pyright/Pylance. It supports\n    both a PyRight-like mode and a Mypy-compatible mode, and provides LSP\n    features including diagnostics, completions, goto definition, references,\n    rename, hover, and document highlighting.\n  license: AGPL-3.0-only\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n    - third_party/django-stubs/LICENSE.md\n    - third_party/typeshed/LICENSE\n  documentation: https://zubanls.com\n  repository: https://github.com/zubanls/zuban\n\nextra:\n  recipe-maintainers:\n    - pavelzw\n",

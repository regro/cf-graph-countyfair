  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: ldas-tools-al\n  version: 2.8.0\n  # dependencies\n  ldas_tools_cmake_version: 1.4.0\n\npackage:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  url: http://software.ligo.org/lscsoft/source/${{ name }}-${{ version }}.tar.gz\n  sha256: c70aedfdf2081472a8f9c47c09da160b9f781e77b8e8ab5bdbcf6be05ea0bd92\n  patches:\n    # when cross-compiling without an emulator disable some checks that use try_run\n    # see https://git.ligo.org/ldastools/LDAS_Tools/-/issues/117\n    - if: osx and arm64\n      then: no-check-procfs.patch\n    # disable tPSInfo test on ppc64le\n    - arch-test-psinfo.patch\n    # fix https://git.ligo.org/computing/ldastools/LDAS_Tools/-/issues/228\n    - fix-reverse.hh.patch\n    # declare libs.private in pkg-config file\n    # seee https://git.ligo.org/computing/ldastools/LDAS_Tools/-/merge_requests/234\n    - libs.private.patch\n\nbuild:\n  number: 0\n  skip: win\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('cxx') }}\n    - cmake >=3.6\n    - make\n    - pkg-config\n  host:\n    - ldas-tools-cmake >=${{ ldas_tools_cmake_version }}\n    - libboost-devel\n  run_exports:\n    - ${{ pin_subpackage(\"ldas-tools-al\", upper_bound=\"x.x\") }}\n\ntests:\n  - package_contents:\n      lib:\n        - ldastoolsal\n      include:\n        - ldastoolsal/ldas_types.h\n  - requirements:\n      run:\n        - pkg-config\n    script:\n      - pkg-config --print-errors --exact-version ${{ version }} ldastoolsal\n\nabout:\n  summary: LDAS tools abstraction toolkit\n  homepage: https://wiki.ligo.org/Computing/LDASTools\n  repository: https://git.ligo.org/ldastools/LDAS_Tools\n  license: GPL-2.0-or-later\n  license_file: COPYING\n\nextra:\n  recipe-maintainers:\n    - duncanmmacleod\n    - emaros\n",

  "raw_meta_yaml": "context:\n  version: \"1.1.3\"\n\npackage:\n  name: colgrep\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/lightonai/next-plaid/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 4a43920227cb9481d2a281979898f7c506b7752e6a62559ef5a3b1b41756be64\n\nbuild:\n  number: 0\n  script:\n    env:\n      CARGO_PROFILE_RELEASE_STRIP: symbols\n      CARGO_PROFILE_RELEASE_LTO: fat\n    content:\n      - if: linux\n        then:\n          - export CFLAGS=\"${CFLAGS} -D_GNU_SOURCE\"\n      - if: unix\n        then:\n          - cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path colgrep\n        else:\n          - cargo auditable install --locked --no-track --bins --root %LIBRARY_PREFIX% --path colgrep\n      - cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml\n\nrequirements:\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n    - cargo-auditable\n    - if: unix\n      then:\n        - pkg-config\n  host:\n    - openssl\n\ntests:\n  - script: colgrep --help\n  - package_contents:\n      bin:\n        - colgrep\n      strict: true\n\nabout:\n  homepage: https://github.com/lightonai/next-plaid\n  summary: Semantic code search powered by ColBERT multi-vector embeddings\n  description: |\n    ColGREP is a terminal-based semantic code search tool that combines regex\n    filtering with semantic ranking using ColBERT-style multi-vector embeddings.\n    It uses Tree-sitter to parse code into structured units and ONNX Runtime for\n    local model inference. All processing happens locally — code never leaves\n    your machine.\n  license: Apache-2.0\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  repository: https://github.com/lightonai/next-plaid\n\nextra:\n  recipe-maintainers:\n    - moritzwilksch\n",

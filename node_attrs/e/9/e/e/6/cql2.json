  "raw_meta_yaml": "context:\n  name: cql2\n  version: \"0.5.3\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/cql2-${{ version }}.tar.gz\n  sha256: 4a9fb1034e6d7c37ed224598e09787cf393b0e2cccdb3dd55a3ecc1edaa788f2\n\nbuild:\n  number: 0\n  python:\n    entry_points:\n      - cql2 = cql2:main\n    version_independent: true\n  script:\n    - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n\nrequirements:\n  build:\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler(\"rust\") }}\n    - cargo-bundle-licenses\n  host:\n    - python ${{ python_min }}.*\n    - python-abi3\n    - maturin >=1.7,<2.0\n    - pip\n  run:\n    - python >=${{ python_min }}\n\ntests:\n  - python:\n      imports:\n        - cql2\n      pip_check: true\n      python_version: [\"${{ python_min ~ '.*' }}\"]\n  - requirements:\n      run:\n        - pip\n        - abi3audit\n    script:\n      - cql2 --help\n      - if: unix\n        then:\n          - export SP_DIR=$(python -c \"import site; print(site.getsitepackages()[0])\")\n          - abi3audit $SP_DIR/cql2/cql2.abi3.so -s -v --assume-minimum-abi3 ${{ python_min }}\n      - if: win\n        then:\n          - set \"SP_DIR=%PREFIX%\\\\Lib\\\\site-packages\"\n          - abi3audit %SP_DIR%\\\\cql2\\\\cql2.pyd -s -v --assume-minimum-abi3 ${{ python_min }}\n\nabout:\n  homepage: https://developmentseed.org/cql2-rs\n  repository: https://github.com/developmentseed/cql2-rs\n  summary: Parse, validate, and convert Common Query Language (CQL2) text and JSON\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n\nextra:\n  recipe-maintainers:\n    - gadomski\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: Magics\n  version: \"4.16.0\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://confluence.ecmwf.int/download/attachments/3473464/${{ name }}-${{ version }}-Source.tar.gz\n  sha256: b5cf365e10e43abbb2e0b14db8e8d8db90486031f6c0de24b0b01c17a0197cf5\n\nbuild:\n  number: 4\n  skip: win\n  prefix_detection:\n    ignore_binary_files: true\n\nrequirements:\n  build:\n    - cmake\n    - make\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('cxx') }}\n    - if: win\n      then:\n        - m2-bash\n        - m2-findutils\n        - m2-coreutils\n        - m2-grep\n        - m2-sed\n        - m2-gawk\n        - m2-diffutils\n        - m2-unzip\n  host:\n    - if: not win\n      then:\n        - pkg-config\n        - glib\n        - freetype\n        - pango\n        - xorg-xorgproto\n        - cairo\n    - expat\n    - proj\n    - eccodes >=2.21.0\n    - libnetcdf\n    - if: win\n      then:\n        - pthreads-win32\n        - libiconv\n    - zlib\n    - magics-python\n  run:\n    - expat\n    - if: not win\n      then:\n        - freetype\n        - pango\n        - xorg-xorgproto\n        - cairo\n    - proj\n    - eccodes >=2.21.0\n    - simplejson\n    - libnetcdf\n    - if: win\n      then:\n        - pthreads-win32\n        - libiconv\n    - zlib\n    - magics-python\n  run_constraints:\n    - magics-metview ==9999999999\n\ntests:\n  - python:\n      imports:\n        - Magics\n        - Magics.macro\n        - Magics.metgram\n        - Magics.toolbox\n      pip_check: false\n  - script:\n      - if: not win\n        then: printf \"%s\\n\" \"${MAGPLUS_HOME:?MAGPLUS_HOME is not set}\"\n\nabout:\n  license: Apache-2.0\n  license_file:\n    - LICENSE_for_source_files\n    - COPYING\n    - LICENSE\n  summary: ECMWF's Meteorological plotting software.\n  homepage: https://confluence.ecmwf.int/display/MAGP/\n\nextra:\n  recipe-maintainers:\n    - kynan\n    - carletes\n    - StephanSiemen\n    - dtip\n    - iainrussell\n",

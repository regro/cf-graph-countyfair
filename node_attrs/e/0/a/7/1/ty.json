  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\n\nschema_version: 1\n\ncontext:\n  name: ty\n  version: \"0.0.0a5\"\n\npackage:\n  name: \"${{ name|lower }}\"\n  version: \"${{ version }}\"\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ name }}-${{ version }}.tar.gz\n  sha256: 09af8204562d425ffdded570ff205239690ad6ca9d2acf5c9439aef9f0c39b11\n\nbuild:\n  number: 0\n  script:\n    content:\n      - maturin build --release\n      - ${{ PYTHON }} -m pip install --find-links=ruff/target/wheels ty\n      - cd ruff\n      - cargo-bundle-licenses --format yaml --output ../THIRDPARTY.yml\n\n  python:\n    version_independent: true\n\nrequirements:\n  build:\n    - cargo-bundle-licenses\n    - ${{ compiler('rust') }}\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - make\n  host:\n    - python ${{ python_min }}.*\n    - python-abi3\n    - maturin >=1.0,<2\n    - pip\n  run:\n    - python\n  ignore_run_exports:\n    from_package:\n      - cross-python_${{ target_platform }}\n\ntests:\n  - python:\n      imports:\n        - ty\n  - script:\n      - ty --help\n\nabout:\n  license: MIT\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  summary: An extremely fast Python type checker, written in Rust.\n  homepage: https://github.com/astral-sh/ty\n  repository: https://github.com/astral-sh/ty\n\nextra:\n  recipe-maintainers:\n    - pavelzw\n",

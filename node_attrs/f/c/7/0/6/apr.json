  "raw_meta_yaml": "context:\n  apr_ver: \"1.7.6\"\n  apu_ver: \"1.6.3\"\n  api_ver: \"1.2.2\"\n  mirror: https://archive.apache.org/dist\n\nrecipe:\n  name: apr-split\n  version: ${{ apr_ver }}\n\nbuild:\n  number: 0\n\noutputs:\n  - package:\n      name: libapr\n      version: ${{ apr_ver }}\n    source:\n      url: ${{ mirror }}/apr/apr-${{ apr_ver }}.tar.gz\n      sha256: 6a10e7f7430510600af25fabf466e1df61aaae910bf1dc5d10c44a4433ccc81d\n    build:\n      script: install_libapr\n    requirements:\n      build:\n        - ${{ compiler('c') }}\n        - ${{ stdlib('c') }}\n        - if: unix\n          then:\n            - make\n            - libtool\n        - if: win\n          then:\n            - cmake\n            - ninja\n      host:\n        - if: linux\n          then:\n            - libxcrypt\n      run_exports:\n        # https://abi-laboratory.pro/tracker/timeline/apr/\n        # This is only on the basis of libapr.so\n        - ${{ pin_subpackage('libapr', upper_bound='x') }}\n\n    tests:\n      - package_contents:\n          include:\n            - \"**/apr.h\"\n          lib:\n            - libapr-1\n      - if: unix\n        then:\n          script:\n            - apr-1-config --help\n\n  - package:\n      name: libapriconv\n      version: ${{ api_ver }}\n    source:\n      - url: ${{ mirror }}/apr/apr-iconv-${{ api_ver }}.tar.gz\n        sha256: ce94c7722ede927ce1e5a368675ace17d96d60ff9b8918df216ee5c1298c6a5e\n      - if: win\n        then:\n          - path: cmake/apr-iconv\n    build:\n      # apr-iconv version unchanged, keep incrementing build number\n      number: 7\n      script: install_libapriconv\n    requirements:\n      build:\n        - ${{ compiler('c') }}\n        - ${{ stdlib('c') }}\n        - if: unix\n          then:\n            - make\n            - libtool\n        - if: win\n          then:\n            - cmake\n            - ninja\n      host:\n        - ${{ pin_subpackage('libapr', exact=True) }}\n      run_exports:\n        - ${{ pin_subpackage('libapriconv', upper_bound='x') }}\n\n    tests:\n      - package_contents:\n          include:\n            - \"**/apr_iconv.h\"\n          lib:\n            - libapriconv-1\n\n  - package:\n      name: libaprutil\n      version: ${{ apu_ver }}\n    source:\n      url: ${{ mirror }}/apr/apr-util-${{ apu_ver }}.tar.gz\n      sha256: 2b74d8932703826862ca305b094eef2983c27b39d5c9414442e9976a9acf1983\n    build:\n      script: install_libaprutil\n    requirements:\n      build:\n        - ${{ compiler('c') }}\n        - ${{ stdlib('c') }}\n        - if: unix\n          then:\n            - make\n            - libtool\n        - if: win\n          then:\n            - cmake\n            - ninja\n      host:\n        - expat\n        - ${{ pin_subpackage('libapr', exact=True) }}\n        - ${{ pin_subpackage('libapriconv', exact=True) }}\n        - if: linux\n          then:\n            - libxcrypt\n      run_exports:\n        - ${{ pin_subpackage('libaprutil', upper_bound='x') }}\n\n    tests:\n      - package_contents:\n          include:\n            - \"**/apu.h\"\n          lib:\n            - libaprutil-1\n\n      - if: unix\n        then:\n          script:\n            - apu-1-config --help\n\n  - package:\n      name: apr\n      version: ${{ apr_ver }}\n    requirements:\n      run:\n        - ${{ pin_subpackage('libapr', exact=True) }}\n        - ${{ pin_subpackage('libaprutil', exact=True) }}\n        - ${{ pin_subpackage('libapriconv', exact=True) }}\n    tests:\n      - script:\n          - echo \"apr meta-package\"\n    about:\n      license_file: []\n\nabout:\n  homepage: http://apr.apache.org/\n  license: Apache-2.0\n  license_file: LICENSE\n  summary: Maintains a consistent API with predictable behaviour\n  description: |\n    Apache Portable Run-time libraries have been designed to provide a common\n    interface to low level routines across any platform. The original goal of APR\n    was to combine all code in Apache to one common code base.\n  documentation: https://apr.apache.org/docs/apr/1.6/index.html\n  repository: https://github.com/apache/apr\n\nextra:\n  recipe-maintainers:\n    - jakirkham\n    - mingwandroid\n    - nehaljwani\n    - seanyen\n    - erykoff\n    - mwittgen\n",

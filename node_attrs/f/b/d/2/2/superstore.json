  "raw_meta_yaml": "context:\n  name: superstore\n  version: \"0.3.2\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ name }}-${{ version }}.tar.gz\n  sha256: 8292b7e5f915768ebad26b732438422a76b11866c58302076072a2dd4a2b287b\n\nbuild:\n  number: 0\n  python:\n    version_independent: true\n  script:\n    - if: unix\n      then: export PYO3_PYTHON=\"$PYTHON\"\n      else: set \"PYO3_PYTHON=%PYTHON%\"\n    - cargo-bundle-licenses --format yaml --output THIRDPARTY.yml\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  skip: is_abi3 and not is_python_min\n\nrequirements:\n  build:\n    - if: build_platform != target_platform\n      then:\n        - python\n        - cross-python_${{ target_platform }}\n        - crossenv\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n  host:\n    - python\n    - pip\n    - hatchling\n    - hatch-rs\n    - if: is_abi3\n      then:\n      - python-abi3\n  run:\n    - python\n    - pydantic >=2\n  ignore_run_exports:\n    from_package:\n      - cross-python_${{ target_platform }}\n\ntests:\n  - python:\n      imports:\n        - superstore\n      pip_check: true\n      python_version: ${{ python_min }}.*\n\nabout:\n  license: Apache-2.0\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  summary: Categorical data generator\n  homepage: https://github.com/1kbgz/superstore\n  repository: https://github.com/1kbgz/superstore\n\nextra:\n  recipe-maintainers:\n    - timkpaine\n",

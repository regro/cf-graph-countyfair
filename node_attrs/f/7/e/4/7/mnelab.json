  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: \"mnelab\"\n  version: \"1.4.2\"\n  python_min: \"3.12\"\n\npackage:\n  name: ${{ name | lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/m/${{ name }}/${{ name }}-${{ version }}.tar.gz\n  sha256: da21a2a72bbbe5e712fa3cc722d8fd61e4d1cd35a949a3c80878d0fe8b656136\n\nbuild:\n  number: 0\n  noarch: python\n  script:\n    - ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - mnelab = mnelab.__main__:main\n    use_python_app_entrypoint: true\n\nrequirements:\n  build:\n    - if: build_platform != target_platform\n      then:\n        - python\n        - cross-python_${{ target_platform }}\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - uv-build\n  run:\n    - python >=${{ python_min }}\n    - if: osx\n      then:\n        - python.app\n        - pyobjc-framework-cocoa >=10.0\n    - black >=25.11.0\n    - edfio >=0.4.10\n    - isort >=7.0.0\n    - matplotlib-base >=3.8.0\n    - mne-base >=1.10.2\n    - mne-qt-browser >=0.6.2\n    - numpy >=2.0.0\n    - scipy >=1.14.1\n    - pyxdf >=1.16.4\n    - pyside6 >=6.9.3\n    - scikit-learn >=1.3.0\n    - python-picard >=0.8.0\n    - pybv >=0.7.4\n    - pybvrf >=0.1.0\n    - onnx >=1.20.0\n\ntests:\n  - python:\n      imports:\n        - mnelab\n        - mnelab.utils\n      python_version: ${{ python_min }}.*\n      pip_check: true\n\n  - script:\n      - python -c \"import mnelab; assert mnelab.__version__ == '${{ version }}', mnelab.__version__\"\n    requirements:\n      run:\n        - python ${{ python_min }}.*\n\nabout:\n  homepage: https://github.com/cbrnr/mnelab\n  repository: https://github.com/cbrnr/mnelab\n  license: BSD-3-Clause\n  license_file: LICENSE\n  summary: Graphical user interface (GUI) for MNE, a Python-based toolbox for EEG/MEG analysis.\n\nextra:\n  recipe-maintainers:\n    - larsoner\n    - hoechenberger\n",

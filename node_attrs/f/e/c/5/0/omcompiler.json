  "raw_meta_yaml": "context:\n  version: \"1.26.3\"\n\npackage:\n  name: omcompiler\n  version: ${{ version }}\n\nsource:\n  # use git because no tarball including submodules is available\n  git: https://github.com/OpenModelica/OpenModelica.git\n  tag: v${{ version }}\n  patches:\n    # error: expected '=', ',', ';', 'asm' or '__attribute__' before 'void'\n    - fmilib-gnusource.patch\n\nbuild:\n  number: 1\n  skip:\n    - not linux\n\nrequirements:\n  build:\n    - cmake\n    - ninja\n    - pkg-config\n    - autoconf\n    - automake\n    - make\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ compiler('fortran') }}\n  host:\n    - openjdk\n    - libblas\n    - liblapack\n    - libcurl\n    - libboost-devel\n    - libiconv\n  run:\n    - openjdk\n    - cmake\n    - make\n    - zip\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n\ntests:\n  - script:\n      - omc --version\n      - echo 'loadFile(\"OMCompiler/Examples/Circle.mo\"); getErrorString(); buildModelFMU(Circle); getErrorString();' > export.mos\n      - omc export.mos\n      - ls Circle.fmu\n      - echo 'loadFile(\"OMCompiler/Examples/Circle.mo\"); getErrorString(); buildModelFMU(Circle, platforms={\"dynamic\"}); getErrorString();' > export.mos\n      - omc --fmuCMakeBuild=true --fmuRuntimeDepends=modelica export.mos\n      - ls Circle.fmu\n    files:\n      source:\n        - OMCompiler/Examples/Circle.mo\n\nabout:\n   homepage: https://openmodelica.org/\n   license: LicenseRef-OSMC-PL\n   license_family: GPL\n   license_file: OSMC-License.txt\n   summary: The Open Source Modelica Suite - OpenModelica Compiler\n\nextra:\n  recipe-maintainers:\n    - jschueller\n",

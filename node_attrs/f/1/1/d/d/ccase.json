  "linux_64_meta_yaml": {
    "about": {
      "description": "ccase is a command line utility for converting between string cases such as\nsnake_case, kebab-case, camelCase, PascalCase, Title Case, and many more.\nIt is built on top of the `convert_case` Rust library.",
      "dev_url": "https://github.com/stringcase/ccase",
      "home": "https://github.com/stringcase/ccase",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE.md",
      "summary": "Command line interface to convert strings into any case"
    },
    "build": {
      "number": "1",
      "script": {
        "content": [
          "cargo auditable install --locked --no-track --bins --root ${{ PREFIX }} --path .",
          "cargo-bundle-licenses --format yaml --output ./THIRDPARTY.yml"
        ],
        "env": {
          "CARGO_PROFILE_RELEASE_LTO": "fat",
          "CARGO_PROFILE_RELEASE_STRIP": "symbols"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "salim-b"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "ccase",

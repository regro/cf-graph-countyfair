  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: 1.3.0\n\npackage:\n  name: capnproto\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/capnproto/capnproto/archive/v${{ version }}.tar.gz\n  sha256: 01ab2ba7f52fcc3c51a10e22935aae56f3bc5e99b726b7e507fe6700cb12147d\n  patches:\n    # MSVC miscompiles async.c++ file when /O2 is given\n    - fix-msvc.diff\n\nbuild:\n  number: 1\n  prefix_detection:\n    ignore:\n      - bin/capnp\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ stdlib('c') }}\n    - if: unix\n      then:\n        - make\n        - automake\n        - libtool\n    - if: linux\n      then:\n        - binutils\n    - if: win\n      then: cmake\n    # cross-compiling needs to use prebuilt capnproto\n    # https://github.com/capnproto/capnproto/issues/1815#issuecomment-1732327995\n    - if: build_platform != target_platform\n      then: capnproto\n  host:\n    - zlib\n    - openssl\n  run_exports:\n    - ${{ pin_subpackage('capnproto', upper_bound='x.x.x') }}\n\ntests:\n  - files:\n      source:\n        - c++/samples\n    script:\n      - capnp --help\n      - capnpc --help\n      - capnpc-c++ --help\n      - capnpc-capnp --help\n      - if: unix\n        then:\n          - capnpc -I\"${PREFIX}/include\" -oc++ c++/samples/addressbook.capnp\n          - test -f c++/samples/addressbook.capnp.c++\n      - if: win\n        then:\n          - capnpc -I\"%LIBRARY_INC%\" -oc++ c++/samples/addressbook.capnp\n          - if not exist c++/samples/addressbook.capnp.c++ exit 1\n  - package_contents:\n      lib:\n        - if: unix\n          then:\n            - capnp\n            - capnpc\n            - capnp-rpc\n            - kj\n            - kj-async\n      include:\n        - capnp/*.h\n      files:\n        - ${{ \"Library/\" if win }}lib/pkgconfig/*.pc\n        - ${{ \"Library/\" if win }}lib/cmake/CapnProto/*.cmake\n        - if: win\n          then:\n            # Static libraries on Windows\n            - Library/lib/capnp.lib\n            - Library/lib/capnpc.lib\n            - Library/lib/capnp-rpc.lib\n            - Library/lib/kj.lib\n            - Library/lib/kj-async.lib\n\nabout:\n  license_file: LICENSE\n  license: MIT\n  summary: An insanely fast data interchange format and capability-based RPC system.\n  homepage: https://capnproto.org\n  repository: https://github.com/capnproto/capnproto\n  documentation: https://capnproto.org\n\nextra:\n  recipe-maintainers:\n    - jdblischak\n    - isuruf\n    - LehMaxence\n    - ihnorton\n    - Shelnutt2\n    - munechika-koyo\n",

 "linux_64_meta_yaml": {
  "about": {
   "description": "The libmaxminddb library provides a C library for reading MaxMind DB files, including\nthe GeoIP2 databases from MaxMind. This is a custom binary format designed to facilitate\nfast lookups of IP addresses while allowing for great flexibility in the type of\ndata associated with an address.\n",
   "dev_url": "https://github.com/maxmind/libmaxminddb",
   "home": "https://maxmind.github.io/libmaxminddb/",
   "license": "Apache-2.0",
   "license_family": "Apache",
   "license_file": "LICENSE",
   "summary": "C library for the MaxMind DB file format"
  },
  "build": {
   "number": "1",
   "run_exports": [
    "libmaxminddb"
   ],
   "script": [
    "./configure --disable-debug --disable-dependency-tracking --disable-silent-rules --prefix=$PREFIX",
    "make",
    "make check",
    "make install"
   ]
  },
  "extra": {
   "recipe-maintainers": [
    "dbast"
   ]
  },
  "package": {
   "name": "libmaxminddb",
   "version": "1.11.0"
  },
  "requirements": {
   "build": [
    "c_stdlib_stub",
    "c_compiler_stub",
    "make"
   ]
  },

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: pyfes\n  version: \"2026.3.0\"\n  sha256: 71cc4e88d9ba2a76ae648a2655a865dc68ae2615daec2f6044da343c0bcb59c5\n  build_number: 0\n\npackage:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/CNES/aviso-fes/releases/download/${{ version }}/${{ name }}-${{ version }}.tar.gz\n  sha256: ${{ sha256 }}\n\nbuild:\n  number: ${{ build_number }}\n  skip:\n    - match(python, \"<3.10\")\n  script:\n    - ${{ PYTHON }} -m pip install . -vv --no-build-isolation ${{ '-Cgenerator=\"Visual Studio 17 2022\"' if win else '' }} ${{ '-Ccmake-args=-DCMAKE_CROSSCOMPILING=ON' if osx and arm64 else '' }}\n\nrequirements:\n  build:\n    - if: build_platform != target_platform\n      then:\n        - python\n        - cross-python_${{ target_platform }}\n        - setuptools\n    - if: linux or osx\n      then: ${{ compiler('cxx') }}\n    - ${{ stdlib('c') }}\n    - if: win\n      then: vs2017_win-64\n    - cmake\n    - if: linux or osx\n      then: make\n  host:\n    - python\n    - pip\n    - numpy\n    - cmake\n    - eigen\n    - if: linux or win\n      then: mkl\n    - setuptools\n    - setuptools-scm\n    - libboost-devel >=1.79\n  run:\n    - ${{ pin_compatible('numpy') }}\n    - python\n    - netcdf4\n    - pyyaml\n    - if: linux or win\n      then: mkl\n\ntests:\n  - python:\n      imports:\n        - pyfes\n\nabout:\n  homepage: https://github.com/CNES/aviso-fes\n  license: BSD-3-Clause\n  license_file: LICENSE\n  summary: FES prediction software\n  description: |\n    This package is the fully revised version of the FES distribution.\n    This distribution includes the FES tidal prediction software.\n  documentation: https://cnes.github.io/aviso-fes\n  repository: https://github.com/CNES/aviso-fes\n\nextra:\n  recipe-maintainers:\n    - fbriol\n",

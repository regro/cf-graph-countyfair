  "linux_64_meta_yaml": {
    "about": {
      "dev_url": "https://github.com/cli/cli",
      "doc_url": "https://cli.github.com/",
      "home": "https://github.com/cli/cli",
      "license": "Apache-2.0",
      "license_family": "Apache-2.0",
      "license_file": "src/LICENSE",
      "summary": "Github CLI."
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "cd src",
          "cd cmd/gh",
          "go-licenses save . --save_path ../../../library_licenses --ignore github.com/cyberphone/json-canonicalization --ignore github.com/in-toto/attestation --ignore github.com/in-toto/in-toto-golang",
          "go build -v -o $PREFIX/bin/gh -ldflags=\"-s -w -X github.com/cli/cli/v2/internal/build.Version=${{ version }}\"",
          "cd ../..",
          "make manpages",
          "mkdir -p $PREFIX/share/man/man1",
          "install -m644 ./share/man/man1/* $PREFIX/share/man/man1",
          "mkdir -p $PREFIX/share/zsh/site-functions $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d",
          "$PREFIX/bin/gh completion --shell zsh > $PREFIX/share/zsh/site-functions/_gh",
          "$PREFIX/bin/gh completion --shell bash > $PREFIX/share/bash-completion/completions/gh",
          "$PREFIX/bin/gh completion --shell fish > $PREFIX/share/fish/vendor_completions.d/gh.fish"
        ],
        "env": {
          "GH_VERSION": "v{{ version }}"
        }
      }
    },
    "extra": {
      "recipe-maintainers": [
        "mxr-conda",
        "rluria14",
        "oblute",
        "matthiasdiener",
        "pavelzw"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "gh",
        "requirements": {
          "build": [
            "go-nocgo_compiler_stub",
            "go-licenses",
            "make"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "gh help",
              "gh version"
            ]
          },
          {
            "package_contents": {
              "bin": [
                "gh"
              ],
              "files": [
                "share/bash-completion/completions/gh",
                "share/fish/vendor_completions.d/gh.fish",
                "share/zsh/site-functions/_gh",
                "share/man/man1/gh*"
              ],
              "strict": true
            }
          }
        ],
        "version": "2.91.0"
      }
    ],

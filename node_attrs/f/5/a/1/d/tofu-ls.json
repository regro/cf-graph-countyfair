  "raw_meta_yaml": "{% set goname = \"github.com/opentofu/tofu-ls\" %}\n{% set version = \"0.4.1\" %}\n\n{% set name = goname.split('/')[-1] %}\n{% set pkg_src = ('src/'+goname).replace(\"/\",os.sep) %}\n\npackage:\n  name: {{ name|lower }}\n  version: {{ version|replace(\"-\", \"_\") }}\n\nsource:\n  - folder: {{ pkg_src }}\n    url: https://{{ goname }}/archive/v{{ version }}.tar.gz\n    sha256: 20a71da45069cc2e28f9f2b58f6aed9da33457760adeb037a10aef94126b77f1\n\nbuild:\n  number: 0\n  script:\n    - pushd {{ pkg_src }}\n    - go build -ldflags \"-X main.revision=conda-forge\" -v -o $PREFIX/bin/tofu-ls  # [not win]\n    - go build -ldflags \"-X main.revision=conda-forge\" -v -o %LIBRARY_BIN%\\tofu-ls.exe  # [win]\n    # This is a purposefully broken symlink for testing that fails the build on windows\n    - rmdir /s /q internal\\features\\modules\\parser\\testdata\\invalid-links  # [win]\n    - go-licenses save . --save_path ../../../../library_licenses\n    # Clear out cache to avoid file not removable warnings\n    - chmod -R u+w $(go env GOPATH) && rm -r $(go env GOPATH)  # [unix]\n\nrequirements:\n  build:\n    - {{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntest:\n  commands:\n    - tofu-ls version\n\nabout:\n  home: https://opentofu.org\n  summary: OpenTofu Language Server\n  description: |\n    The official OpenTofu language server (tofu-ls) maintained by the\n    OpenTofu Core Team provides IDE features to any LSP-compatible editor.\n  license: MPL-2.0\n  license_family: MOZILLA\n  license_file:\n    - {{ pkg_src }}/LICENSE\n    - library_licenses/\n  doc_url: https://{{ goname }}/tree/main/docs\n  dev_url: https://{{ goname }}\n\nextra:\n  recipe-maintainers:\n    - brycekbargar\n",

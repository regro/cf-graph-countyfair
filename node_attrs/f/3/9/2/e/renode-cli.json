  "linux_64_meta_yaml": {
    "about": {
      "description": "Renode was created by Antmicro as a virtual development tool for multi-node\nembedded networks (both wired and wireless) and is intended to enable a scalable\nworkflow for creating effective, tested and secure IoT systems.\n\nWith Renode, developing, testing, debugging and simulating unmodified software\nfor IoT devices is fast, cost-effective and reliable.",
      "dev_url": "https://github.com/renode/renode",
      "doc_url": "https://renode.io/",
      "home": "https://github.com/renode/renode",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Antmicro's open source simulation and virtual development framework for complex embedded systems"
    },
    "build": {
      "number": "0"
    },
    "extra": {
      "recipe-maintainers": [
        "MementoRC",
        "danielnachun"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "renode-cli",
        "requirements": {
          "build": [
            "dotnet >=9",
            "nuget-license >=3.1",
            "sed",
            "bash"
          ],
          "host": [
            "renode-cores ==1.16.1"
          ],
          "run": [
            "dotnet >=9"
          ]
        },
        "tests": [
          {
            "package_contents": {
              "bin": [
                "renode"
              ],
              "files": [
                "libexec/renode-cli/OptionsParser.deps.json",
                "libexec/renode-cli/OptionsParser.runtimeconfig.json",
                "libexec/renode-cli/Renode",
                "libexec/renode-cli/Renode.deps.json",
                "libexec/renode-cli/Renode.runtimeconfig.json",
                "libexec/renode-cli/Sprache.xml",
                "libexec/renode-cli/build_type",
                "libexec/renode-cli/*.{dll,dylib,pdb,so}",
                "libexec/renode-cli/Lib/*.py",
                "libexec/renode-cli/Lib/site-packages/README.txt",
                "libexec/renode-cli/Lib/{ctypes,distutils,email,encodings,ensurepip}/*",
                "libexec/renode-cli/Lib/{lib2to3,multiprocessing,unittest,wsgiref,xml}/*",
                "libexec/renode-cli/{cs,de,es,fr,it,ja,ko,pl,ru,tr,zh-Hans,zh-Hant}/*.dll",
                "share/renode-cli/platforms/{boards,cpus}/*.repl",
                "share/renode-cli/scripts/monitor.py",
                "share/renode-cli/scripts/{complex,multi-node,single-node}/*",
                "share/renode-cli/scripts/pydev/*.py",
                "share/renode-cli/tools/sel4_extensions/*",
                "libexec/renode-cli/runtimes/*",
                "etc/conda/test-files/renode-cli/*"
              ],
              "strict": true
            }
          },
          {
            "files": {
              "recipe": [
                "test-bundle/"
              ]
            },
            "requirements": {
              "run": [
                "robotframework >=6.1",
                "psutil >=5.9.3",
                "python",
                "pyyaml >=6.0"
              ]
            },
            "script": [
              "renode --help",
              "LOCAL_TEST_PREFIX=./test-bundle test-bundle/${{ \"Library/\" if not unix }}bin/renode-test test-bundle/${{ \"Library/\" if not unix }}share/renode-cli/tests/unit-tests"
            ]
          }
        ],
        "version": "1.16.1"
      }
    ],

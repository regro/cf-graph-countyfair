  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: scitokens\n  version: 1.9.7\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/scitokens-${{ version }}.tar.gz\n  sha256: 9aabefbd68859e94a3909f3dc08bd73c0e7a9c08203c16de338c9512ace821e3\n\nbuild:\n  number: 0\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv\n  python:\n    entry_points:\n      - scitokens-admin-create-key = scitokens.tools.admin_create_key:main\n      - scitokens-admin-create-token = scitokens.tools.admin_create_token:main\n      - scitokens-verify-token = scitokens.tools.verify_token:main\n\nrequirements:\n  host:\n    - pip\n    - python ${{ python_min }}.*\n    - setuptools\n  run:\n    - cryptography\n    - pyjwt >=1.6.1\n    - python >=${{ python_min }}\n    - requests\n\ntests:\n  - files:\n      source:\n        - tests/\n    requirements:\n      run:\n        - pip\n        - pytest\n        - python ${{ python_min }}.*\n    script:\n      # Check metadata\n      - python -m pip check\n      - python -m pip show scitokens\n      # Run test suite\n      - python -m pytest -ra -v tests/\n      # Check entry points\n      - scitokens-admin-create-key --help\n      - scitokens-admin-create-token --help\n      - scitokens-verify-token --help\n\nabout:\n  summary: SciToken reference implementation library\n  description: |\n    This library aims to be a reference implementation of the\n    SciTokens\\' JSON Web Token (JWT) token format.\n\n    SciTokens is built on top of the PyJWT and cryptography libraries.\n    We aim to provide a safe, high-level interface for token manipulation,\n    avoiding common pitfalls of using the underling libraries directly.\n  homepage: https://scitokens.org\n  repository: https://github.com/scitokens/scitokens.git\n  documentation: https://scitokens.readthedocs.io\n  license: Apache-2.0\n  license_file: LICENSE\n\nextra:\n  recipe-maintainers:\n    
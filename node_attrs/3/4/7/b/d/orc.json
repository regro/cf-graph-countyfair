  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"2.3.0\"\n\npackage:\n  name: orc\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/apache/orc/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: d38b871c3989304d79c28c291bc80819b4585d7cea88d16243f74842a7e2a953\n  patches:\n    - patches/0001-Don-t-force-orc-to-be-a-static-library-let-end-user-.patch\n    - patches/0002-Allow-user-to-override-path-to-protoc.patch\n    - patches/0003-Link-to-abseil-libraries.patch\n\nbuild:\n  number: 0\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('cxx') }}\n    - if: unix\n      then: ninja\n    # `protoc` is also used for building\n    - libprotobuf\n    - cmake\n  host:\n    - zlib\n    - snappy\n    - libabseil\n    - libprotobuf\n    - lz4-c\n    - zstd\n  run:\n    # orc >=2.0.1 will prefer $CONDA_PREFIX/share/zoneinfo for tzdb\n    - tzdata\n  run_exports:\n    - ${{ pin_subpackage(\"orc\", upper_bound=\"x.x.x\") }}\n\ntests:\n  - script:\n      - if: unix\n        then: \n          - test -f $PREFIX/lib/liborc${SHLIB_EXT}\n          - test -f $PREFIX/include/orc/Common.hh\n          - test ! -f $PREFIX/lib/liborc.a\n      - if: win\n        then: \n          - if not exist %LIBRARY_BIN%\\orc.dll exit 1\n          - if not exist %LIBRARY_LIB%\\orc.lib exit 1\n          - if not exist %LIBRARY_INC%\\orc\\Common.hh exit 1\n\nabout:\n  license: Apache-2.0\n  license_file: LICENSE\n  summary: C++ libraries for Apache ORC\n  homepage: http://github.com/apache/orc\n  repository: https://github.com/apache/orc\n\nextra:\n  recipe-maintainers:\n    - wesm\n    - xhochy\n    - nehaljwani\n    - h-vetinari\n",

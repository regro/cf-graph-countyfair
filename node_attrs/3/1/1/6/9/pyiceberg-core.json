  "raw_meta_yaml": "context:\n  name: pyiceberg-core\n  python_name: pyiceberg_core\n  version: \"0.9.0\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ python_name }}-${{ version }}.tar.gz\n  sha256: c8493b99160c269e175757f46fc0ff06bc79314106865ec3cc49da07099194f4\n\nbuild:\n  number: 0\n  python:\n    version_independent: true\nrequirements:\n  build:\n    - if: build_platform != target_platform\n      then:\n        - python ${{ python_min }}.*\n        - cross-python_${{ target_platform }}\n        - maturin >=1.0,<2\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('rust') }}\n    - cargo-bundle-licenses\n  host:\n    - python ${{ python_min }}.*\n    - python-abi3\n    - maturin >=1.2.2,<2\n    - pip\n  run:\n    - python\n\ntests:\n    - python:\n        imports:\n          - pyiceberg_core\n        python_version:\n          - \"${{ python_min }}.*\"\n          - \"*\"\n    - requirements:\n        run:\n          - pip\n          - abi3audit\n      script:\n        - pip check\n        - if: unix\n          then:\n            - export SP_DIR=$(python -c \"import site; print(site.getsitepackages()[0])\")\n            - abi3audit $SP_DIR/pyiceberg_core/pyiceberg_core_rust.abi3.so -s -v --assume-minimum-abi3 ${{ python_min }}\n        - if: win\n          then:\n            - set \"SP_DIR=%PREFIX%\\\\Lib\\\\site-packages\"\n            - abi3audit %SP_DIR%\\\\pyiceberg_core\\\\pyiceberg_core_rust.pyd -s -v --assume-minimum-abi3 ${{ python_min }}\n\nabout:\n  homepage: https://github.com/apache/iceberg-rust/\n  license: Apache-2.0\n  license_file:\n    - LICENSE\n    - NOTICE\n    - bindings/python/THIRDPARTY.yml\n  summary: |\n    This project is used to build an iceberg-rust powered core for pyiceberg, and intended for use only by pyiceberg.\n  repository: https://github.com/apache/iceberg-rust/\n\nextra:\n  recipe-maintainers:\n    
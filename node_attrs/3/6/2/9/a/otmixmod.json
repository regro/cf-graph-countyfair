  "raw_meta_yaml": "context:\n  version: \"0.20\"\n\npackage:\n  name: otmixmod\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/openturns/otmixmod/archive/v${{ version }}.tar.gz\n  sha256: aab968bbf9a233db25ed5ccd5b1b05d478e731287d8d85bd09119ca4b459ade2\n  patches:\n    - 0001-Export-symbols.patch\n\nbuild:\n  number: 3\n  python:\n    version_independent: true\n\nrequirements:\n  build:\n    - cmake\n    - swig\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - ${{ compiler('cxx') }}\n    - if: unix\n      then: make\n      else: ninja\n    - if: win\n      then: m2-diffutils\n    - if: build_platform != target_platform\n      then:\n        - python-abi3 ${{ python_min }}.*\n        - python ${{ python_min }}.*\n        - cross-python_${{ target_platform }}\n  host:\n    - python-abi3 ${{ python_min }}.*\n    - python ${{ python_min }}.*\n    - openturns\n    - libmixmod\n  run:\n    - python >=${{ python_min }}\n  run_exports:\n    - ${{ pin_subpackage('otmixmod', upper_bound='x.x') }}\n\ntests:\n  - python:\n      imports:\n        - otmixmod\n\nabout:\n  homepage: http://openturns.org/\n  license: GPL-3.0-or-later\n  license_family: GPL\n  license_file: COPYING\n  summary: MixMod module\n  documentation: https://openturns.github.io/otmixmod/master/\n  repository: https://github.com/openturns/otmixmod\n\nextra:\n  recipe-maintainers:\n    - jschueller\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"5.5.0\"\n\npackage:\n  name: fastframes\n  version: ${{ version }}\n\nsource:\n  url: https://gitlab.cern.ch/atlas-amglab/fastframes/-/archive/v${{ version }}/fastframes-v${{ version }}.tar.gz\n  sha256: 77d0a1f0f5685b31f9d62a245fe571be7db062988b37e5915a6c3eb08c2f7bca\n  patches:\n    - fix-root-6-38-compat.patch\n    - install-python-files.patch\n    - fix-python-linking.patch\n    - fix-missing-tfile-include.patch\n\nbuild:\n  number: 1\n  skip:\n    - win\n    - match(root_base, \"<6.36\")\n  script:\n    - cmake ${CMAKE_ARGS} -DPython3_EXECUTABLE=$PYTHON -DPython3_INCLUDE_DIR=$PREFIX/include/python${PY_VER} -DFASTFRAMES_PYTHON_INSTALL_DIR=$SP_DIR -S . -B build\n    - cmake --build build --clean-first --parallel=\"${CPU_COUNT}\" --verbose\n    - cmake --install build\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ compiler(\"cxx\") }}\n    - ${{ stdlib(\"c\") }}\n    - cmake\n    - make\n    - if: build_platform != target_platform\n      then:\n        - cross-python_${{ target_platform }}\n        - python\n        - root_base\n        - root_cxx_standard\n  host:\n    - root_base\n    - root_cxx_standard\n    - libboost-python-devel\n    - python\n  run:\n    - python\n    - pyyaml\n\ntests:\n  - package_contents:\n      files:\n        - bin/fast-frames.exe\n  - script:\n      - FastFrames.py -h\n\nabout:\n  license: BSD-2-Clause\n  license_file: LICENSE\n  summary: 'FastFrames: RDataFrames for ATLAS analysis ntuples'\n  description: |\n    FastFrames is a package aimed at processing ntuples produced by\n    TopCPToolkit, or a similar CP algorithm based framework, into histograms or\n    ntuples.  FastFrames rely on ROOT's RDataFrame to do the event loop\n    processing.  The code allows users to define their own columns in a minimal\n    way while using all the functionality of the processing.\n  homepage: https://gitlab.cern.ch/atlas-amglab/fastframes\n  repository: https://gitlab.cern.ch/atlas-amglab/fastframes\n  documentation: https://atlas-project-topreconstruction.web.cern.ch/fastframesdocumentation/latest/\n\nextra:\n  recipe-maintainers:\n    - p-queue\n    - kratsg\n",

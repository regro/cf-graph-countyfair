    "about": {
      "description": "FastFrames is a package aimed at processing ntuples produced by\nTopCPToolkit, or a similar CP algorithm based framework, into histograms or\nntuples.  FastFrames rely on ROOT's RDataFrame to do the event loop\nprocessing.  The code allows users to define their own columns in a minimal\nway while using all the functionality of the processing.",
      "dev_url": "https://gitlab.cern.ch/atlas-amglab/fastframes",
      "doc_url": "https://atlas-project-topreconstruction.web.cern.ch/fastframesdocumentation/latest/",
      "home": "https://gitlab.cern.ch/atlas-amglab/fastframes",
      "license": "BSD-2-Clause",
      "license_family": "BSD-2-Clause",
      "license_file": "LICENSE",
      "summary": "FastFrames: RDataFrames for ATLAS analysis ntuples"
    },
    "build": {
      "number": "1",
      "script": [
        "cmake ${CMAKE_ARGS} -DPython3_EXECUTABLE=$PYTHON -DPython3_INCLUDE_DIR=$PREFIX/include/python${PY_VER} -DFASTFRAMES_PYTHON_INSTALL_DIR=$SP_DIR -S . -B build",
        "cmake --build build --clean-first --parallel=\"${CPU_COUNT}\" --verbose",
        "cmake --install build"
      ]
    },
    "extra": {
      "recipe-maintainers": [
        "p-queue",
        "kratsg"
      ]
    },

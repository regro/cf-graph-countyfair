  "raw_meta_yaml": "context:\n  version: \"2.3.1\"\n  libdovi_version: \"3.3.2\"\n  build_number: 0\n\nrecipe:\n  name: dovi_tool\n  version: ${{ version }}\n\nsource:\n  - url: https://github.com/quietvoid/dovi_tool/archive/refs/tags/${{ version }}.tar.gz\n    sha256: 090888c35da017e290614b70108653ea975034c23b48ddd459538a1a6e4cc05a\n    target_directory: dovi_tool_src\n  - url: https://github.com/quietvoid/dovi_tool/archive/refs/tags/libdovi-${{ libdovi_version }}.tar.gz\n    sha256: 8ccb1922d7dbb57bc4f2c15c10b90c462f7a5f292efe317c116db923728dd3f1\n    target_directory: libdovi_src\n\nbuild:\n  number: ${{ build_number }}\n\n\noutputs:\n  - package:\n      name: dovi_tool\n      version: ${{ version }}\n    build:\n      script: build-dovi_tool\n    requirements:\n      build:\n        - ${{ stdlib('c') }}\n        - ${{ compiler('c') }}\n        - ${{ compiler('rust') }}\n        - cargo-auditable\n        - cargo-bundle-licenses\n        - if: linux\n          then:\n            - pkg-config\n      host:\n        - if: linux\n          then:\n            - expat\n            - freetype\n            - fontconfig\n    tests:\n      - script: dovi_tool --help\n      - script: dovi_tool --version\n      - package_contents:\n          bin:\n            - dovi_tool\n    about:\n      homepage: https://github.com/quietvoid/dovi_tool\n      repository: https://github.com/quietvoid/dovi_tool\n      documentation: https://github.com/quietvoid/dovi_tool/blob/main/README.md\n      summary: CLI utilities for working with Dolby Vision metadata and HEVC streams\n      license: MIT\n      license_file:\n        - dovi_tool_src/LICENSE\n        - THIRDPARTY_dovi_tool.yml\n\n  - package:\n      name: libdovi\n      version: ${{ libdovi_version }}\n    build:\n      script: build-libdovi\n    requirements:\n      build:\n        - ${{ stdlib('c') }}\n        - ${{ compiler('c') }}\n        - ${{ compiler('rust') }}\n        - cargo-bundle-licenses\n        - cargo-c\n        - if: unix\n          then:\n            - pkg-config\n    tests:\n      - package_contents:\n          include:\n            - libdovi/rpu_parser.h\n          lib:\n            - dovi\n          files:\n            - \"**/pkgconfig/dovi.pc\"\n    about:\n      homepage: https://github.com/quietvoid/dovi_tool/tree/main/dolby_vision\n      repository: https://github.com/quietvoid/dovi_tool\n      documentation: https://github.com/quietvoid/dovi_tool/blob/main/dolby_vision/README.md\n      summary: C library to read and write Dolby Vision metadata\n      license: MIT\n      license_file:\n        - libdovi_src/dolby_vision/LICENSE\n        - THIRDPARTY_libdovi.yml\n\nabout:\n  homepage: https://github.com/quietvoid/dovi_tool\n  repository: https://github.com/quietvoid/dovi_tool\n  summary: CLI tools and a C library for working with Dolby Vision metadata\n  license: MIT\n  license_file: dovi_tool_src/LICENSE\n\n\nextra:\n  feedstock-name: dovi_tool\n  recipe-maintainers:\n    - ndeybach\n",

  "raw_meta_yaml": "context:\n  version: \"2.3.1\"\n  libdovi_version: \"3.3.2\"\n  build_number: 3\n\nrecipe:\n  name: dovi_tool\n  version: ${{ version }}\n\nsource:\n  - url: https://github.com/quietvoid/dovi_tool/archive/refs/tags/${{ version }}.tar.gz\n    sha256: 090888c35da017e290614b70108653ea975034c23b48ddd459538a1a6e4cc05a\n    target_directory: dovi_tool_src\n  - url: https://github.com/quietvoid/dovi_tool/archive/refs/tags/libdovi-${{ libdovi_version }}.tar.gz\n    sha256: 8ccb1922d7dbb57bc4f2c15c10b90c462f7a5f292efe317c116db923728dd3f1\n    target_directory: libdovi_src\n\nbuild:\n  number: ${{ build_number }}\n\n\noutputs:\n  - package:\n      name: dovi_tool\n      version: ${{ version }}\n    build:\n      script: build-dovi_tool\n    requirements:\n      build:\n        - ${{ stdlib('c') }}\n        - ${{ compiler('c') }}\n        - ${{ compiler('rust') }}\n        - cargo-auditable\n        - cargo-bundle-licenses\n        - if: linux\n          then:\n            - pkg-config\n      host:\n        - if: linux\n          then:\n            - freetype\n            - fontconfig\n      ignore_run_exports:\n        from_package:\n          - expat\n    tests:\n      - script:\n          - if: build_platform == target_platform or target_platform == \"linux-aarch64\" # no emulation for osx-arm64\n            then:\n              - dovi_tool --help\n              - dovi_tool --version\n      - package_contents:\n          bin:\n            - dovi_tool\n          files:\n      # check no static libs are present\n            not_exists:\n              - \"**/*.a\"\n              - \"**/pkgconfig/*.pc\"\n              - if: unix\n                then: include/**\n              - if: unix\n                then: lib/libdovi*\n              - if: win\n                then: Library/include/**\n              - if: win\n                then: Library/bin/dovi.dll\n              - if: win\n                then: Library/lib/dovi*.lib\n              - if: win\n                then: Library/lib/dovi.def\n      - script:\n          - if: build_platform == target_platform or target_platform == \"linux-aarch64\"\n            then:\n              - python check-no-static-libs.py dovi_tool\n        requirements:\n          run:\n            - python\n        files:\n          recipe:\n            - check-no-static-libs.py\n    about:\n      homepage: https://github.com/quietvoid/dovi_tool\n      repository: https://github.com/quietvoid/dovi_tool\n      documentation: https://github.com/quietvoid/dovi_tool/blob/main/README.md\n      summary: CLI utilities for working with Dolby Vision metadata and HEVC streams\n      license: MIT\n      license_file:\n        - dovi_tool_src/LICENSE\n        - THIRDPARTY_dovi_tool.yml\n\n  - package:\n      name: libdovi\n      version: ${{ libdovi_version }}\n    build:\n      script: build-libdovi\n    requirements:\n      build:\n        - ${{ stdlib('c') }}\n        - ${{ compiler('c') }}\n        - ${{ compiler('rust') }}\n        - cargo-bundle-licenses\n        - cargo-c\n        - if: unix\n          then:\n            - pkg-config\n      run_exports:\n        - ${{ pin_subpackage('libdovi', upper_bound='x') }}\n    tests:\n      - package_contents:\n          include:\n            - libdovi/rpu_parser.h\n          files:\n            exists:\n              - if: linux\n                then: lib/libdovi.so*\n              - if: osx\n                then: lib/libdovi*.dylib\n              - if: win\n                then: Library/bin/dovi.dll\n              - if: win\n                then: Library/lib/dovi.dll.lib\n              - \"**/pkgconfig/dovi.pc\"\n      # check no static libs are present\n            not_exists:\n              - \"**/*.a\"\n      - script:\n          - if: build_platform == target_platform or target_platform == \"linux-aarch64\"\n            then:\n              - python check-no-static-libs.py libdovi\n        requirements:\n          run:\n            - python\n        files:\n          recipe:\n            - check-no-static-libs.py\n      # test pkg-config can find the library and print the correct version (run export done ok)\n      - script:\n          - if: unix\n            then:\n              - export PKG_CONFIG_PATH=\"${PREFIX}/lib/pkgconfig\"\n              - pkg-config --exists dovi\n        requirements:\n          run:\n            - if: unix\n              then:\n                - pkg-config\n    about:\n      homepage: https://github.com/quietvoid/dovi_tool/tree/main/dolby_vision\n      repository: https://github.com/quietvoid/dovi_tool\n      documentation: https://github.com/quietvoid/dovi_tool/blob/main/dolby_vision/README.md\n      summary: C library to read and write Dolby Vision metadata\n      license: MIT\n      license_file:\n        - libdovi_src/dolby_vision/LICENSE\n        - THIRDPARTY_libdovi.yml\n\nabout:\n  homepage: https://github.com/quietvoid/dovi_tool\n  repository: https://github.com/quietvoid/dovi_tool\n  summary: CLI tools and a C library for working with Dolby Vision metadata\n  license: MIT\n  license_file: dovi_tool_src/LICENSE\n\n\nextra:\n  feedstock-name: dovi_tool\n  recipe-maintainers:\n    - ndeybach\n",

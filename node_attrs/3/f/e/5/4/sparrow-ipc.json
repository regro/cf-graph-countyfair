  "raw_meta_yaml": "context:\n  version: \"1.0.2\"\n  build_number: 0\n\npackage:\n  name: sparrow-ipc\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/sparrow-org/sparrow-ipc/archive/refs/tags/${{ version }}.tar.gz\n  sha256: 9c8b13806528a26f48be6271d56ae0a5540e3772d9fea4ef7d5b4838e32424e9\n\nbuild:\n  script: build\n  number: ${{ build_number }}\n\nrequirements:\n  build:\n    - ${{ compiler('cxx') }}\n    - ${{ stdlib('c') }}\n    - cmake\n    - flatbuffers\n    - if: unix\n      then: make\n    - if: win\n      then: ninja\n  host:\n    - sparrow-devel\n    - lz4-c\n    - zstd\n    - nlohmann_json\n  run_exports:\n    - ${{ pin_subpackage('sparrow-ipc', upper_bound='x.x') }}\n\ntests:\n  - package_contents:\n      include:\n        - sparrow_ipc/serialize.hpp\n        - sparrow_ipc/deserialize.hpp\n        - sparrow_ipc/config/sparrow_ipc_version.hpp\n      lib:\n        - sparrow-ipc\n\n  - script:\n      - if: unix\n        then:\n          - test -f ${PREFIX}/share/cmake/sparrow-ipc/sparrow-ipcConfig.cmake\n          - test -f ${PREFIX}/share/cmake/sparrow-ipc/sparrow-ipcConfigVersion.cmake\n          - test -f ${PREFIX}/share/cmake/sparrow-ipc/sparrow-ipcTargets.cmake\n      - if: win\n        then:\n          - if not exist %LIBRARY_PREFIX%\\share\\cmake\\sparrow-ipc\\sparrow-ipcConfig.cmake (exit 1)\n          - if not exist %LIBRARY_PREFIX%\\share\\cmake\\sparrow-ipc\\sparrow-ipcConfigVersion.cmake (exit 1)\n          - if not exist %LIBRARY_PREFIX%\\share\\cmake\\sparrow-ipc\\sparrow-ipcTargets.cmake (exit 1)\n\nabout:\n  homepage: https://github.com/sparrow-org/sparrow-ipc\n  summary: C++20 idiomatic APIs for the Apache Arrow Serialization and Interprocess Communication (IPC)\n  description: |\n    sparrow-ipc provides a high-level, C++20 idiomatic interface for working with\n    Apache Arrow IPC messages and streams. It leverages the sparrow library for\n    modern C++ memory management and data structures.\n  license: BSD-3-Clause AND 
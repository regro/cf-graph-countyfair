    "about": {
      "description": "The Buildah package provides a command line tool which can be used to:\n\n* Create a working container, either from scratch or using an image as a starting point.\n* Mount a working container's root filesystem for manipulation.\n* Unmount a working container's root filesystem.\n* Use the updated contents of a container's root filesystem as a filesystem layer to create a new image.\n* Delete a working container or an image.\n* Rename a local container.",
      "dev_url": "https://github.com/containers/buildah",
      "doc_url": "https://github.com/containers/buildah",
      "home": "https://buildah.io/",
      "license": "Apache-2.0",
      "license_family": "Apache-2.0",
      "license_file": "LICENSE",
      "summary": "A command line tool that facilitates building OCI container images."
    },
    "build": {
      "number": "0"
    },

    "0006-Enable-shared-libraries-for-conda-forge.patch",
    "0007-Remove-optional-dependencies-to-slim-package.patch",
    "0008-Adjust-compilation-of-immapp.patch",
    "single_patch.patch",
    "drop_float16.patch"
   ]
  },
  "test": {
   "commands": [
    "pip check"
   ],

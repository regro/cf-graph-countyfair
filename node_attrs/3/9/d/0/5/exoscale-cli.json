  "raw_meta_yaml": "context:\n  version: \"1.93.0\"\n\npackage:\n  name: exoscale-cli\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/exoscale/cli/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: 1aa22ed8f144b6e50f57266cf84131525ab6f1c5cc0928abfd4fff35a7c2394d\n  target_directory: src\n\nbuild:\n  number: 0\n  script:\n    - cd src\n    - go-licenses save . --save_path ../library_licenses\n    - if: unix\n      then: go build -v -o $PREFIX/bin/exo -ldflags=\"-s -w -X main.GitVersion=${{ version }}\"\n      else: go build -v -o %LIBRARY_BIN%\\exo.exe -ldflags=\"-s -X main.GitVersion=${{ version }}\"\n\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntests:\n  - script: exo version\n  - package_contents:\n      bin:\n        - exo\n      strict: true\n\nabout:\n  homepage: https://github.com/exoscale/cli\n  summary: Command-line tool for everything at Exoscale\n  description: |\n    Manage your Exoscale infrastructure easily from the command-line.\n    Provides access to compute, storage, DNS, and other Exoscale services\n    via the exo command.\n  license: Apache-2.0\n  license_file:\n    - src/LICENSE\n    - library_licenses/\n  documentation: https://community.exoscale.com/documentation/tools/exoscale-command-line-interface/\n  repository: https://github.com/exoscale/cli\n\nextra:\n  recipe-maintainers:\n    - ytausch\n",

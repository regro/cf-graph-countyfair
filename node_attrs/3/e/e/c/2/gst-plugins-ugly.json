  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"1.28.2\"\n\npackage:\n  name: gst-plugins-ugly\n  version: ${{ version }}\n\nsource:\n  url: https://gstreamer.freedesktop.org/src/gst-plugins-ugly/gst-plugins-ugly-${{ version }}.tar.xz\n  sha256: fe39a5ee7115e37de9eb65d899ec84c93e6e26ed3ffe25c6d5176cececbab572\n\nbuild:\n  number: 1\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - pkg-config\n    - meson\n    - ninja\n    - gettext-tools\n  host:\n    - if: linux\n      then: \n        - libgl-devel\n        - libegl-devel\n        - libdrm\n        - libxcb\n        - pthread-stubs\n        - xorg-libxext\n        - expat\n        - xorg-libxfixes\n        - xorg-libx11\n        - xorg-libxrender\n        - xorg-libxdamage\n        - xorg-libxxf86vm\n        - xorg-libxau\n        - xorg-xorgproto\n    - libiconv\n    - if: not linux\n      then: libintl-devel\n    - gstreamer         1.28.2.*\n    - gst-plugins-base  1.28.2.*\n    - gobject-introspection\n    - glib\n    - x264\n    - zlib\n  run:\n    # We want to pin harder than the run_export from gstreamer\n    - gstreamer         1.28.2.*\n  run_exports:\n    - ${{ pin_subpackage('gst-plugins-ugly', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - if: unix\n        then: \n            - test -f $PREFIX/lib/gstreamer-1.0/libgstasf${SHLIB_EXT}\n            - test -f $PREFIX/lib/gstreamer-1.0/libgstdvdlpcmdec${SHLIB_EXT}\n            - test -f $PREFIX/lib/gstreamer-1.0/libgstdvdsub${SHLIB_EXT}\n            - test -f $PREFIX/lib/gstreamer-1.0/libgstrealmedia${SHLIB_EXT}\n            - test -f $PREFIX/lib/gstreamer-1.0/libgstx264${SHLIB_EXT}\n      - if: win\n        then: \n            - if not exist %LIBRARY_LIB%\\\\gstreamer-1.0\\\\gstasf.dll exit 1\n            - if not exist %LIBRARY_LIB%\\\\gstreamer-1.0\\\\gstdvdlpcmdec.dll exit 1\n            - if not exist %LIBRARY_LIB%\\\\gstreamer-1.0\\\\gstdvdsub.dll exit 1\n            - if not exist %LIBRARY_LIB%\\\\gstreamer-1.0\\\\gstrealmedia.dll exit 1\n            - if not exist %LIBRARY_LIB%\\\\gstreamer-1.0\\\\gstx264.dll exit 1\n      - gst-inspect-1.0 --plugin x264\n\nabout:\n  license: LGPL-2.1-or-later\n  license_file: COPYING\n  summary: GStreamer Ugly Plug-ins\n  homepage: http://gstreamer.freedesktop.org/\n  repository: https://gitlab.freedesktop.org/gstreamer/gst-plugins-ugly\n\nextra:\n  recipe-maintainers:\n    - yishai1999\n    - tjwilli58\n    - scopatz\n    - kuepe-sl\n    - hmaarrfk\n",

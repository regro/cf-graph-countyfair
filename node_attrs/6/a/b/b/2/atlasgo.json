  "raw_meta_yaml": "context:\n  version: \"1.1.0\"\n\npackage:\n  name: atlasgo\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/ariga/atlas/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: ab15ecd8ad713ff8edbb3cdfd6025417ee3bc539f1594431ed744b0b16102e55\n  patches:\n    # NOTE: Required to circumvent issues with the atlas SDK (cf. https://github.com/ariga/atlas-go-sdk/pull/66).\n    - patches/001-remove-unofficial-string.patch\n    # NOTE: Required to bump vulnerable peer dependency go.opentelemetry.io/otel/sdk to >= 1.40.0\n    # xref: https://pkg.go.dev/vuln/GO-2026-4394\n    - patches/002-bump-vulnerable-deps.patch\n\nbuild:\n  number: 1\n  skip: ${{ win }}\n  script:\n    - cd cmd/atlas\n    # NOTE: github.com/libsql/sqlite-antlr4-parser is generated and does not include a license.\n    #       Licenses for ANTLR4 projects are already included for other dependencies.\n    # Last ignore line is a workaround for https://github.com/google/go-licenses/issues/244\n    - go-licenses save . --save_path ../../library_licenses --ignore ariga.io/atlas --ignore\n      github.com/libsql/sqlite-antlr4-parser --ignore github.com/jmespath/go-jmespath --ignore $(go\n      list std | awk 'NR > 1 { printf(\",\") } { printf(\"%s\",$0) } END { print \"\" }')\n    - go build -v -ldflags \"-s -w -X\n      'ariga.io/atlas/cmd/atlas/internal/cmdapi.version=v$PKG_VERSION'\" -o $PREFIX/bin/atlas\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - ${{ compiler('go-cgo') }} >=1.26.1\n    - go-licenses\n\ntests:\n  - script:\n      - atlas version | grep \"atlas version v${{ version }}\"\n      - atlas --help\n\nabout:\n  homepage: https://atlasgo.io\n  license: Apache-2.0\n  license_file:\n    - LICENSE\n    - library_licenses/\n  summary: Manage your database schema as code\n  documentation: https://atlasgo.io/getting-started\n  repository: https://github.com/ariga/atlas\n\nextra:\n  recipe-maintainers:\n    - borchero\n    - delsner\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"0.4.0\"\n\npackage:\n  name: conda-workspaces\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/c/conda-workspaces/conda_workspaces-${{ version }}.tar.gz\n  sha256: 7c86f27736e6b47725b8513d110a521bbc9cd403fefc085da357095efd85e28f\n\nbuild:\n  number: 0\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - cw = conda_workspaces.__main__:main\n      - ct = conda_workspaces.__main__:main_task\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - hatchling >=1.12.2\n    - hatch-vcs >=0.2.0\n    - pip\n  run:\n    - python >=${{ python_min }}\n    - conda >=24.7\n    - conda-lockfiles >=0.1\n    - conda-spawn >=0.0.5\n    - jinja2 >=3.0\n    - packaging >=21.0\n    - platformdirs >=3.0\n    - rich >=13.0\n    - tomlkit >=0.13\n  run_constraints:\n    - conda-pypi >=0.5.0\n    - conda-rattler-solver >=0.0.6\n\ntests:\n  - python:\n      imports:\n        - conda_workspaces\n      pip_check: true\n      python_version: ${{ python_min }}.*\n  - requirements:\n      run:\n        - pip\n        - python ${{ python_min }}.*\n    script:\n      - cw --help\n      - ct --help\n\nabout:\n  summary: Project-scoped multi-environment workspace management for conda, with pixi compatibility\n  description: |\n    conda-workspaces brings project-scoped multi-environment workspaces and\n    a task runner to conda as a plugin. Define environments, features,\n    dependencies, and tasks in a single manifest (conda.toml, pixi.toml,\n    or pyproject.toml) and let conda handle the solving and installation.\n\n    Optional dependencies for additional features:\n    - conda-pypi: PyPI dependency resolution and installation\n    - conda-rattler-solver: rattler solver backend (required for PyPI deps)\n  license: BSD-3-Clause\n  license_file: LICENSE\n  homepage: https://conda-incubator.github.io/conda-workspaces/\n  repository: https://github.com/conda-incubator/conda-workspaces\n  documentation: https://conda-incubator.github.io/conda-workspaces/\n\nextra:\n  recipe-maintainers:\n    - jezdez\n    - travishathaway\n",

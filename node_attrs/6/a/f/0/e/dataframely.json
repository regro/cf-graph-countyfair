  "raw_meta_yaml": "context:\n  name: dataframely\n  version: \"1.0.0\"\n  python_min: \"3.11.*\"\n\npackage:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/${{ name }}-${{ version }}.tar.gz\n  sha256: 56681a29e424dbc1e6b2c2decb879eea46abca06e416742dfccd565dda627c65\n\nbuild:\n  number: 1\n  skip: not (match(python, python_min) and is_abi3 == 'true')\n  python:\n    version_independent: true\n\nrequirements:\n  build:\n    - if: build_platform != target_platform\n      then:\n        - python\n        - cross-python_${{ target_platform }}\n        - crossenv\n        - maturin >=1.7,<2\n    - ${{ compiler('rust') }}\n    - ${{ stdlib('c') }}\n    - cargo-bundle-licenses\n  host:\n    - python\n    - python-abi3\n    - pip\n    - maturin >=1.7,<2\n  run:\n    - python\n    - numpy\n    - polars >=1.12\n  run_constraints:\n    - mypy >=1.12\n    - sqlalchemy >=2\n\ntests:\n  - python:\n      python_version: ${{ python_min }}\n      imports:\n        - dataframely\n      pip_check: true\n\nabout:\n  homepage: https://github.com/Quantco/dataframely\n  summary: A declarative, polars-native data frame validation library.\n  license: BSD-3-Clause\n  license_file:\n    - LICENSE\n    - THIRDPARTY.yml\n  documentation: https://dataframely.readthedocs.io/\n  repository: https://github.com/Quantco/dataframely\n\nextra:\n  recipe-maintainers:\n    - borchero\n    - delsner\n",

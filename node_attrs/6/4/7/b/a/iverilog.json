  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  version: \"12.0\"\n\npackage:\n  name: iverilog\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/steveicarus/iverilog/archive/v${{ version | replace(\".\", \"_\") }}.tar.gz\n  sha256: a68cb1ef7c017ef090ebedb2bc3e39ef90ecc70a3400afb4aa94303bc3beaa7d\n  patches:\n    - if: osx-64\n      then:\n        - patch_macos_mach-o.patch\n\nbuild:\n  number: 1\n  skip:\n    - win\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - ${{ stdlib('c') }}\n    - make\n    - if: not win\n      then: autoconf\n    - if: win\n      then:\n        - autotools_clang_conda\n        - m2-bison\n  host:\n    - if: not win\n      then:\n        - gperf >=3\n        - bison\n        - flex\n        - readline\n    - if: win\n      then:\n        - m2-libreadline\n        - m2-gperf\n        - m2-flex\n    - zlib\n\ntests:\n  - script:\n      - if: unix\n        then:\n          - test -f \"${PREFIX}/bin/iverilog\"\n          - test -f \"${PREFIX}/bin/iverilog-vpi\"\n          - test -f \"${PREFIX}/bin/vvp\"\n          - test -f \"${PREFIX}/lib/libveriuser.a\"\n          - test -f \"${PREFIX}/lib/libvpi.a\"\n          - test -f \"${PREFIX}/lib/ivl/ivl\"\n          - test -f \"${PREFIX}/lib/ivl/ivlpp\"\n          - test -f \"${PREFIX}/lib/ivl/vhdlpp\"\n      - iverilog -V\n      - vvp -V\n\nabout:\n  license: GPL-2.0-only\n  license_file: COPYING\n  summary: Icarus Verilog is intended to compile ALL of the Verilog HDL as described in the IEEE-1364 standard.\n  homepage: http://iverilog.icarus.com/home\n\nextra:\n  recipe-maintainers:\n    - tfors\n    - carlodri\n",

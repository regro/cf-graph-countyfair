  "raw_meta_yaml": "context:\n  version: \"6.11.0\"\n  maj_min: ${{ (version | split('.'))[:2] | join('.') }}\n\npackage:\n  name: qt6-multimedia\n  version: ${{ version }}\n\nsource:\n  url: https://download.qt.io/official_releases/qt/${{ maj_min }}/${{ version }}/submodules/qtmultimedia-everywhere-src-${{ version }}.tar.xz\n  sha256: 90c4cac0a7a983b68d1b0873d0714e7873b9a493403fa8593e8a4eea3ea26040\n\nbuild:\n  number: 0\n\nrequirements:\n  build:\n    - cmake\n    - ninja\n    - perl\n    - ${{ compiler('cxx') }}\n    - ${{ compiler('c') }}\n    - ${{ stdlib(\"c\") }}\n    - if: unix\n      then: make\n    - if: linux\n      then:\n        - ruby\n        - bison\n        - flex\n        - gperf\n    - if: build_platform != target_platform\n      then:\n        - qt6-main ${{ version }}.*\n        - ffmpeg\n        - ffmpeg * lgpl*\n        - if: linux\n          then:\n            - pulseaudio-client\n            - xorg-libx11\n            - xorg-libxext\n            - xorg-libxdamage\n            - xorg-libxrandr\n            - xorg-libxcomposite\n            - xorg-libxxf86vm\n            - xorg-libxtst\n            - xorg-xf86vidmodeproto\n            - pulseaudio-client\n  host:\n    - qt6-main ${{ version }}.*\n    - ffmpeg\n    - ffmpeg * lgpl*\n    - if: linux\n      then:\n        - pthread-stubs\n        - pulseaudio-client\n        - libgl-devel\n        - libglx-devel\n        - libegl-devel\n        - libopengl-devel\n        - xorg-libx11\n        - xorg-libxext\n        - xorg-libxdamage\n        - xorg-libxrandr\n        - xorg-libxcomposite\n        # https://github.com/conda-forge/staged-recipes/pull/22084\n        - xorg-libxxf86vm\n        - xorg-libxtst\n        - xorg-xf86vidmodeproto\n        - alsa-lib\n    - if: not osx\n      then:\n        - libvulkan-headers\n        - libvulkan-loader\n  run:\n    - qt6-main ${{ version }}.*\n    - if: linux\n      then:\n        - xorg-libx11\n        - xorg-libxrandr\n  run_exports:\n    - ${{ pin_subpackage('qt6-multimedia', upper_bound='x.x') }}\n\ntests:\n  - script:\n      - if: unix\n        then:\n          - test -d $PREFIX/include/qt6/QtSpatialAudio\n          - test -d $PREFIX/include/qt6/QtMultimedia\n          - test -f $PREFIX/lib/libQt6Multimedia${SHLIB_EXT}\n          - test -f $PREFIX/lib/qt6/plugins/multimedia/libffmpegmediaplugin${SHLIB_EXT}\n        else:\n          - if not exist %PREFIX%\\\\Library\\\\include\\\\qt6\\\\QtMultimedia exit 1\n          - if not exist %PREFIX%\\\\Library\\\\lib\\\\Qt6Multimedia.lib exit 1\n          - if not exist %PREFIX%\\\\Library\\\\bin\\\\Qt6Multimedia.dll exit 1\n          - if not exist %PREFIX%\\\\Library\\\\lib\\\\qt6\\\\plugins\\\\multimedia\\\\ffmpegmediaplugin.dll exit 1\n\nabout:\n  homepage: http://qt-project.org\n  license: GPL-3.0-only\n  license_file: LICENSES/GPL-3.0-only.txt\n  summary: Qt is a cross-platform application and UI framework.\n  description: |\n    Qt helps you create connected devices, UIs & applications that run\n    anywhere on any device, on any operating system at any time.\n  documentation: http://doc.qt.io/\n  repository: https://github.com/qt/qtmultimedia\n\nextra:\n  recipe-maintainers:\n    - mmcauliffe\n    - conda-forge/qt-main\n  feedstock-name: qt-multimedia\n",

  "raw_meta_yaml": "context:\n  name: spot-cpp-sdk\n  version: 5.1.4\n  build_number: 1\n\nrecipe:\n  name: ${{ name }}-split\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/boston-dynamics/spot-cpp-sdk/archive/refs/tags/v${{ version }}.zip\n  sha256: a5aa0b1d3fc4b58282d8fd94e9b89cb561d245403a472208312527cc13a37776\n  patches:\n    - 01-fix-protobuf-stringview.patch\n    - 02-fix-proto-shared-linkage.osx.patch\n    - if: osx\n      then:\n        - 03-fix-grpc-deadline.osx.patch\n        - 04-fix-std-max.osx.patch\n\nbuild:\n  skip: win\n  number: ${{ build_number }}\n\noutputs:\n  - package:\n      name: spot-cpp-sdk\n    build:\n      script:\n        - if: unix\n          then:\n            # Suppress deprecated warnings.\n            - export CFLAGS=\"${CFLAGS} -Wno-deprecated-declarations\"\n            - export CXXFLAGS=\"${CXXFLAGS} -Wno-deprecated-declarations\"\n            # Configure C++ project.\n            - echo ${CMAKE_ARGS}\n            - cmake -S cpp/ -B build/\n              ${CMAKE_ARGS}\n              -DCMAKE_FIND_PACKAGE_PREFER_CONFIG=ON\n              -GNinja\n        - if: win\n          then:\n            # Configure C++ project.\n            - echo %CMAKE_ARGS%\n            - cmake -S cpp/ -B build/\n              ${CMAKE_ARGS}\n              -DCMAKE_FIND_PACKAGE_PREFER_CONFIG=ON\n              -DCMAKE_CXX_COMPILER_WORKS=ON\n              -DCMAKE_CXX_FLAGS=\"%CXXFLAGS% /DNOMINMAX /wd4267 /wd4996 /WX- /EHsc\"\n              -GNinja\n        # Build and install C++ project.\n        - cmake --build build/ --config Release\n        - cmake --install build/ --config Release\n    requirements:\n      build:\n        - ${{ stdlib('c') }}\n        - ${{ compiler('c') }}\n        - ${{ compiler('cxx') }}\n        - cmake\n        - ninja\n      host:\n        - cli11\n        - eigen-abi-devel\n        - libabseil\n        - libgrpc\n        - libprotobuf\n  # TODO: move to this package headers and cmake config files\n  - package:\n      name: spot-cpp-sdk-devel\n    requirements:\n      run:\n        - ${{ pin_subpackage(\"spot-cpp-sdk\", exact=True) }}\n        - cli11\n        - eigen\n    tests:\n      - script:\n          - cmake-package-check bosdyn --targets bosdyn_client bosdyn_client_static\n          - cmake-package-check bosdyn --targets bosdyn_api bosdyn_api_obj bosdyn_api_static\n          - cmake-package-check bosdyn --targets bosdyn_api bosdyn_choreography_protos_obj bosdyn_choreography_protos bosdyn_choreography_protos_static\n        requirements:\n          run:\n            - ${{ compiler('c') }}\n            - ${{ compiler('cxx') }}\n            - cmake-package-check\n\nabout:\n  homepage: https://github.com/boston-dynamics/spot-cpp-sdk\n  license: LicenseRef-BostonDynamics\n  license_file: LICENSE\n  repository: https://github.com/boston-dynamics/spot-cpp-sdk\n  summary: Develop applications and payloads for Spot using the Boston Dynamics Spot C++ SDK.\n\nextra:\n  feedstock-name: spot-cpp-sdk\n  recipe-maintainers:\n    - diegoferigo\n",

  "raw_meta_yaml": "context:\n  version: \"0.2.0\"\n\npackage:\n  name: modctl\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/modelpack/modctl/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: aba507fa6e3a928590520cc267cf0ec1351e01c7b88e5c746404781f409a473d\n  target_directory: src\n\nbuild:\n  number: 1\n  script:\n    - cd src\n    - go-licenses save . --save_path ../library_licenses\n    - if: unix\n      then:\n        - BUILD_TIME=\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"\n        - SHORT_COMMIT_HASH=\"$(curl -s \"https://api.github.com/repos/modelpack/modctl/commits/v${{ version }}\" | jq -r '.sha' | cut -c 1-7)\"\n        - go build -v -o $PREFIX/bin/modctl -ldflags=\"-s -w -X github.com/modelpack/modctl/pkg/version.BuildTime=${BUILD_TIME} -X github.com/modelpack/modctl/pkg/version.GitCommit=${SHORT_COMMIT_HASH} -X github.com/modelpack/modctl/pkg/version.GitVersion=${{ version }}\" -trimpath .\n        # generate shell completions\n        - mkdir -p $PREFIX/share/bash-completion/completions $PREFIX/share/fish/vendor_completions.d $PREFIX/share/zsh/site-functions\n        - $PREFIX/bin/modctl completion bash > $PREFIX/share/bash-completion/completions/modctl\n        - $PREFIX/bin/modctl completion fish > $PREFIX/share/fish/vendor_completions.d/modctl.fish\n        - $PREFIX/bin/modctl completion zsh > $PREFIX/share/zsh/site-functions/_modctl\n    - if: win\n      then:\n        - for /f \"usebackq delims=\" %%T in (`powershell -Command \"[DateTime]::UtcNow.ToString('yyyy-MM-ddTHH:mm:ssZ')\"`) do set BUILD_TIME=%%T\n        - for /f \"usebackq delims=\" %%T in (`powershell -Command \"((Invoke-RestMethod 'https://api.github.com/repos/modelpack/modctl/commits/v${{ version }}').sha).Substring(0, 7)\"`) do set SHORT_COMMIT_HASH=%%T\n        - go build -v -o %LIBRARY_BIN%\\modctl.exe -ldflags=\"-s -w -X github.com/modelpack/modctl/pkg/version.BuildTime=%BUILD_TIME% -X github.com/modelpack/modctl/pkg/version.GitCommit=%SHORT_COMMIT_HASH% -X github.com/modelpack/modctl/pkg/version.GitVersion=${{ version }}\" -trimpath .\n        # generate shell completions\n        - mkdir %LIBRARY_PREFIX%\\share\\bash-completion\\completions\n        - mkdir %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\n        - mkdir %LIBRARY_PREFIX%\\share\\zsh\\site-functions\n        - '%LIBRARY_BIN%\\modctl.exe completion bash > %LIBRARY_PREFIX%\\share\\bash-completion\\completions\\modctl'\n        - '%LIBRARY_BIN%\\modctl.exe completion fish > %LIBRARY_PREFIX%\\share\\fish\\vendor_completions.d\\modctl.fish'\n        - '%LIBRARY_BIN%\\modctl.exe completion zsh > %LIBRARY_PREFIX%\\share\\zsh\\site-functions\\_modctl'\n  skip:\n    # Windows is currently unsupported, cf. https://github.com/modelpack/modctl/issues/472\n    - win\n\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntests:\n  - script:\n      - modctl --help\n      - modctl version\n  - package_contents:\n      bin:\n        - modctl\n      files:\n        - if: unix\n          then:\n            - share/bash-completion/completions/modctl\n            - share/fish/vendor_completions.d/modctl.fish\n            - share/zsh/site-functions/_modctl\n        - if: win\n          then:\n            - Library/share/bash-completion/completions/modctl\n            - Library/share/fish/vendor_completions.d/modctl.fish\n            - Library/share/zsh/site-functions/_modctl\n      strict: true\n\nabout:\n  summary: A CLI tool for managing OCI model artifacts bundled based on the ModelPack specification\n  description: |\n    Modctl is a user-friendly CLI tool for managing OCI model artifacts, which are\n    bundled based on the ModelPack Model Specification. It offers commands such as\n    build, pull, push, and more, making it easy to interact with AI/ML model registries.\n  license: Apache-2.0\n  license_file:\n    - src/LICENSE\n    - library_licenses/\n  homepage: https://modelpack.org/\n  repository: https://github.com/modelpack/modctl\n\nextra:\n  recipe-maintainers:\n    - salim-b\n",

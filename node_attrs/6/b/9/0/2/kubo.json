  "linux_64_meta_yaml": {
    "about": {
      "description": "Kubo (go-ipfs) the earliest and most widely used implementation of IPFS.\n\nIt includes:\n- an IPFS daemon server\n- extensive command line tooling\n- an HTTP Gateway (/ipfs/, /ipns/) for serving content to HTTP browsers\n- an HTTP RPC API (/api/v0) for controlling the daemon node",
      "dev_url": "https://github.com/ipfs/kubo",
      "doc_url": "https://docs.ipfs.tech/",
      "home": "https://ipfs.tech/",
      "license": "Apache-2.0 OR MIT",
      "license_family": "Apache-2.0 OR MIT",
      "license_file": "github.com/ipfs/kubo/LICENSE-APACHE",
      "summary": "IPFS implementation in Go"
    },
    "build": {
      "number": "0",
      "script": {
        "content": [
          "${{ \"export\" if unix else \"set\" }} \"GOPATH=${{ SRC_DIR }}\"",
          "cd ${{ go_mod }}",
          "${{ go_build }} -o \"${{ go_bin }}\" ${{ go_cmd }}",
          "go-licenses save ${{ go_cmd }} --save_path \"${{ SRC_DIR }}/library_licenses\" {% for i in license_ignore | split %}--ignore ${{ i }} {% endfor %}"
        ]
      }
    },
    "extra": {
      "recipe-maintainers": [
        "bollwyvl"
      ]
    },
    "outputs": [
      {
        "build": null,
        "name": "kubo",
        "requirements": {
          "build": [
            "go-nocgo_compiler_stub",
            "go-licenses",
            "make"
          ],
          "host": [],
          "run": []
        },
        "tests": [
          {
            "script": [
              "ipfs --version",
              "ipfs --help",
              "ipfs commands",
              "ipfs --debug init",
              "echo \"hello conda-forge\" > hello.txt",
              "ipfs --debug add hello.txt"
            ]
          }
        ],
        "version": "0.40.1"
      }
    ],
    "package": {

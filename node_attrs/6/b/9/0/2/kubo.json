  "raw_meta_yaml": "# yaml-language-server: $schema=https://raw.githubusercontent.com/prefix-dev/recipe-format/main/schema.json\nschema_version: 1\n\ncontext:\n  version: \"0.40.1\"\n  name: kubo\n  go_mod: github.com/ipfs/kubo\n  go_cmd: ./cmd/ipfs\n  go_build: go build -v -buildmode=pie -trimpath -modcacherw\n  go_bin: ${{ \"$PREFIX/bin/ipfs\" if unix else \"%LIBRARY_BIN%\\\\ipfs.exe\" }}\n  go_mod_fuse: bazil.org/fuse\n  license_ignore: |-\n    ${{ go_mod }}\n    ${{ go_mod_fuse }}\n\npackage:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  - url: https://${{ go_mod }}/releases/download/v${{ version }}/${{ name }}-source.tar.gz\n    sha256: 3ba9921432a3d43753306860e50e8bd2188b5bd094c94abdbb2173f578e69b8b\n    target_directory: github.com/ipfs/kubo\n  # manually-recovered licenses\n  - url: https://raw.githubusercontent.com/bazil/fuse/refs/heads/master/LICENSE\n    target_directory: library_licenses_manual/${{ go_mod_fuse }}\n    sha256: b0310b2546ffbf6433751c452c66e5548460e49d1a4fc8260ba3ba93c81b18d7\n\nbuild:\n  number: 0\n  script:\n    content:\n      - ${{ \"export\" if unix else \"set\" }} \"GOPATH=${{ SRC_DIR }}\"\n      - cd ${{ go_mod }}\n      - ${{ go_build }} -o \"${{ go_bin }}\" ${{ go_cmd }}\n      - go-licenses save ${{ go_cmd }} --save_path \"${{ SRC_DIR }}/library_licenses\" {% for i in license_ignore | split %}--ignore ${{ i }} {% endfor %}\n\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n    - make\n  run_constraints:\n    - go-ipfs >=9000\n\ntests:\n  - script:\n      - ipfs --version\n      - ipfs --help\n      - ipfs commands\n      - ipfs --debug init\n      - echo \"hello conda-forge\" > hello.txt\n      - ipfs --debug add hello.txt\n\nabout:\n  license: Apache-2.0 OR MIT\n  license_file:\n    # directly provided by upstream\n    - ${{ go_mod }}/LICENSE-APACHE\n    - ${{ go_mod }}/LICENSE-MIT\n    - library_licenses/\n    - library_licenses_manual/\n  summary: IPFS implementation in Go\n  description: |\n    Kubo (go-ipfs) the earliest and most widely used implementation of IPFS.\n\n    It includes:\n    - an IPFS daemon server\n    - extensive command line tooling\n    - an HTTP Gateway (/ipfs/, /ipns/) for serving content to HTTP browsers\n    - an HTTP RPC API (/api/v0) for controlling the daemon node\n\n  homepage: https://ipfs.tech\n  repository: https://${{ go_mod }}\n  documentation: https://docs.ipfs.tech\n\nextra:\n  recipe-maintainers:\n    - bollwyvl\n",

  "raw_meta_yaml": "context:\n  name: ministream\n  version: \"0.99.0\"\n\npackage:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  url: \"https://gitlab.gnome.org/-/project/37671/uploads/1caaee1f000934410df11677d1e1cccf/${{ name }}-${{ version }}.tar.xz\"\n  sha256: 6aa0ee83cd877fd86396a1d86294b1cd952da14c29e8f996315939bf961529e3\n\nbuild:\n  number: 0\n  script:\n    - if: win\n      then: |\n        meson setup %MESON_ARGS% ^\n          --prefix=%LIBRARY_PREFIX% ^\n          --default-library=shared ^\n          --wrap-mode=nofallback ^\n          -Dintrospection=enabled ^\n          -Dtests=false ^\n          builddir\n        ninja -v -C builddir -j %CPU_COUNT%\n        ninja -C builddir install -j %CPU_COUNT%\n      else: |\n        meson setup ${MESON_ARGS} \\\n            --prefix=$PREFIX \\\n            --default-library=shared \\\n            --wrap-mode=nofallback \\\n            -Dintrospection=enabled \\\n            -Dtests=false \\\n            builddir\n        ninja -v -C builddir -j ${CPU_COUNT}\n        ninja -C builddir install -j ${CPU_COUNT}\n\nrequirements:\n  build:\n    - ${{ compiler('c') }}\n    - ${{ stdlib('c') }}\n    - meson\n    - ninja\n    - pkg-config\n    - gobject-introspection\n    - glib\n  host:\n    - glib\n    - gobject-introspection\n    - zlib\n  run_exports:\n    # Conservative ABI compatibility, may be able to be relaxed after the 1.0.0 release\n    - ${{ pin_subpackage('ministream', upper_bound='x.x.x') }}\n\ntests:\n  - package_contents:\n      files:\n        - if: unix\n          then: lib/pkgconfig/ministream.pc\n        - if: win\n          then: Library/lib/pkgconfig/ministream.pc\n      lib:\n        # rattler-build doesn't detect DLLs in a <name>-<so>.dll format\n        - if: unix\n          then: ministream\n        - if: win\n          then:\n            - ministream.lib\n            - ministream-*.dll\n\nabout:\n  homepage: https://gitlab.gnome.org/sp1rit/ministream\n  summary: 'Minimal (subset) appstream metadata parser'\n  description: |\n    Provides a subset of AppStream support for building libraries like libadwaita\n  license: LGPL-2.1-or-later\n  license_file: COPYING\n  repository: https://gitlab.gnome.org/sp1rit/ministream\n\nextra:\n  recipe-maintainers:\n    - danyeaw\n",

  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  name: gmailsorter\n  version: 0.1.10\n  python_min: \"3.11\"\n\npackage:\n  name: ${{ name|lower }}\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/${{ name[0] }}/${{ name }}/gmailsorter-${{ version }}.tar.gz\n  sha256: ca366ed0b489632314fc36b27f0f86c35e6e0dcc25df957184735d4be58d21e4\n\nbuild:\n  number: 1\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - gmailsorter=gmailsorter.__main__:command_line_parser\n      - gmailsorter-daemon=gmailsorter.daemon.__main__:command_line_parser\n      - gmailsorter-app=gmailsorter.webapp.app:run_app\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - pip\n    - setuptools\n    - hatchling\n    - hatch-vcs\n  run:\n    - python >=${{ python_min }}\n    - google-api-python-client >=2.194.0\n    - google-auth >=2.49.2\n    - google-auth-oauthlib >=1.3.1\n    - numpy >=2.4.3\n    - tqdm >=4.67.3\n    - pandas >=3.0.2\n    - scikit-learn >=1.8.0\n    - sqlalchemy >=2.0.49\n\ntests:\n  - python:\n      imports:\n        - gmailsorter\n      pip_check: true\n      python_version: ${{ python_min }}.*\n  - requirements:\n      run:\n        - pip\n        - python ${{ python_min }}.*\n    script:\n      - gmailsorter --help\n      - gmailsorter-daemon --help\n\nabout:\n  summary: Assign labels to emails in Google Mail based on their similarity to other emails assigned to the same label.\n  license: BSD-3-Clause\n  license_file: LICENSE\n  homepage: https://github.com/jan-janssen/gmailsorter\n\nextra:\n  recipe-maintainers:\n    - jan-janssen\n",

  "raw_meta_yaml": "{% set name = \"getfem\" %}\n{% set version = \"5.4.4\" %}\n\npackage:\n  name: {{ name }}\n  version: {{ version }}\n\nsource:\n  url: https://github.com/{{ name }}/{{ name }}/archive/refs/tags/v{{ version }}.tar.gz\n  sha256: d552106065afa15146efb5eb179cf0c69b17b170ce153444599d5cccf618f17c\n\nbuild:\n  number: 1\n\nrequirements:\n  build:\n    - {{ compiler('c') }}\n    - {{ compiler('cxx') }}\n    - {{ compiler(\"fortran\") }}\n    - {{ stdlib(\"c\") }}\n    - cmake\n    - ninja\n  host:\n    - python\n    - setuptools\n    - numpy\n    - scipy\n    - qhull\n    - mumps-seq\n    - openblas\n  run:\n    - numpy\n    - scipy\n    - qhull\n    - mumps-seq\n    - libopenblas\n    - python\n\ntest:\n  imports:\n    - getfem\n  commands:\n    # 1. Verify standard Python module execution\n    - |\n      python -c \"import getfem; print(f'GetFEM imported successfully from: {getfem.__file__}')\"\n\n    # 2. Cross the C++ boundary by instantiating a core GetFEM object.\n    # This physically forces the OS to load _getfem.pyd and all its linked DLLs (MUMPS, OpenBLAS, etc.)\n    - |\n      python -c \"import getfem; m = getfem.Mesh('empty', 2); print('GetFEM C++ extension loaded and executed successfully.')\"\n\nabout:\n  home: https://getfem.org/\n  license: LGPL-3.0-or-later AND BSD-3-Clause\n  license_family: LGPL\n  license_file:\n    - COPYING\n    - dep-licenses/\n  summary: 'GetFEM++ is a generic finite element C++ library with interfaces for Python, Matlab and Scilab.'\n  description: |\n    The GetFEM project focuses on the development of a generic and efficient C++ library for finite element methods elementary computations.\n  doc_url: https://getfem.readthedocs.io\n  dev_url: https://github.com/getfem-doc/getfem\n\nextra:\n  recipe-maintainers:\n    - logari81\n    - yvesrenard\n    - tkoyama010\n    - daviddanan\n    - ldallolio\n",

  "raw_meta_yaml": "context:\n  version: \"1.12.1\"\n\npackage:\n  name: sbb-tui\n  version: ${{ version }}\n\nsource:\n  - url: https://github.com/Necrom4/sbb-tui/archive/refs/tags/v${{ version }}.tar.gz\n    sha256: e4c11ce5c2ca3c93b0f88f244a24382a33f3c4497df1350c1227a968e5b6dab3\n    target_directory: src\n  - if: win\n    then:\n      url: https://raw.githubusercontent.com/mattn/go-localereader/refs/heads/master/LICENSE\n      sha256: dceede03550621e65ec7b79fcba87cf6dbb9d31132a8ae71a8fe8ceec0af7da3\n      file_name: LICENSE-go-localereader\n\nbuild:\n  number: 0\n  script:\n    - cd src\n    - if: unix\n      then:\n        - go-licenses save . --save_path ../library_licenses\n        - go build -v -o $PREFIX/bin/sbb-tui -ldflags=\"-s -w -X main.version=${{ version }}\"\n      else:\n        - go-licenses save . --save_path ../library_licenses --ignore github.com/mattn/go-localereader\n        - go build -v -o %LIBRARY_BIN%\\sbb-tui.exe -ldflags=\"-s -X main.version=${{ version }}\"\n\nrequirements:\n  build:\n    - ${{ compiler(\"go-nocgo\") }}\n    - go-licenses\n\ntests:\n  - script: sbb-tui --version\n  - package_contents:\n      bin:\n        - sbb-tui\n      strict: true\n\nabout:\n  homepage: https://github.com/Necrom4/sbb-tui\n  summary: TUI client for Switzerland's public transport timetables\n  description: |\n    A terminal user interface client for Switzerland's public transport\n    timetables (SBB/CFF/FFS), inspired by the official SBB app.\n  license: MIT\n  license_file:\n    - src/LICENSE\n    - library_licenses/\n    - if: win\n      then:\n        - LICENSE-go-localereader\n  repository: https://github.com/Necrom4/sbb-tui\n\nextra:\n  recipe-maintainers:\n    - pavelzw\n",

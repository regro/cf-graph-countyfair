  "raw_meta_yaml": "schema_version: 1\n\ncontext:\n  python_min: \"3.12\"\n  version: \"0.3.0\"\n\npackage:\n  name: aris_lite\n  version: ${{ version }}\n\nsource:\n  url: https://pypi.org/packages/source/a/aris_lite/aris_lite-${{ version }}.tar.gz\n  sha256: 80b04175d7ff4e02f4a66f53b36f9a7ecf4dba39c79f09220102fc0e0f748673\n\nbuild:\n  number: 0\n  noarch: python\n  script: ${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation\n  python:\n    entry_points:\n      - aris = aris_lite.cli.main:main_cli\n      - aris-1go = aris_lite.cli.legacy_wrappers:legacy_1go_cli\n      - aris-calc-waterbudget = aris_lite.cli.legacy_wrappers:legacy_waterbudget_cli\n      - aris-calc-pheno = aris_lite.cli.legacy_wrappers:legacy_pheno_cli\n      - aris-calc-yield = aris_lite.cli.legacy_wrappers:legacy_yield_cli\n\nrequirements:\n  host:\n    - python ${{ python_min }}.*\n    - flit-core >=3.11,<4\n    - pip\n  run:\n    - python >=${{ python_min }}\n    - dask-core\n    - numpy\n    - pandas\n    - snowmaus\n    - xarray\n    - zarr >=3\n\ntests:\n  - python:\n      imports:\n        - aris_lite\n      pip_check: true\n      python_version: ${{ python_min }}.*\n  - files:\n      source:\n        - tests/\n    requirements:\n      run:\n        - python ${{ python_min }}.*\n    script:\n      - aris --help\n      - aris 1go --help\n      - aris calc waterbudget --help\n      - aris calc pheno --help\n      - aris calc yield --help\n      - python -m unittest discover -s tests -p \"test_*.py\"\n\nabout:\n  summary: Crop growth and yield modeling with ARIS-lite.\n  description: |\n    ARIS-lite models crop development, water budget, and yield response\n    from environmental input data.\n  license: MIT\n  license_file: LICENSE.txt\n  homepage: https://github.com/boku-met/aris_lite\n  documentation: https://aris-lite.readthedocs.io\n  repository: https://github.com/boku-met/aris_lite\n\nextra:\n  recipe-maintainers:\n    - j-haacker\n",

  "linux_64_meta_yaml": {
    "about": {
      "description": "Elegant is an accelerator code that computes beta functions, matrices,\norbits, floor coordinates, amplification factors, dynamic aperture, and\nmore. It does 6-D tracking with matrices and/or canonical integrators, and\nsupports a variety of time-dependent elements. It also does optimization\n(e.g., matching), including optimization of tracking results. It is the\nprinciple accelerator code used at APS.\n",
      "dev_url": "https://github.com/rtsoliday/elegant",
      "doc_url": "https://ops.aps.anl.gov/manuals/elegant_latest/elegant.html",
      "home": "https://github.com/rtsoliday/elegant",
      "license": "EPICS",
      "license_file": [
        "elegant/LICENSE",
        "SDDS/meschach/LICENSE",
        "SDDS/xlslib/LICENSE",
        "SDDS/pgapack/COPYING"
      ],
      "summary": "Pelegant is Parallel Elegant, a parallelized accelerator code that\ncomputes beta functions, matrices, orbits, floor coordinates, amplification\nfactors, dynamic aperture, and more\n"
    },
    "build": {
      "ignore_run_exports": [
        "libaec"
      ],
      "number": "0",
      "run_exports": [
        "elegant * mpi_mpich_*",
        "elegant * mpi_openmpi_*"
      ],
      "string": "mpi_openmpi_h1234567_0"
    },
    "extra": {
      "recipe-maintainers": [
        "ken-lauer"
      ]
    },

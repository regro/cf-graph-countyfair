  "raw_meta_yaml": "context:\n  version: \"0.9\"\n\nrecipe:\n  name: nebi-packages\n  version: ${{ version }}\n\nsource:\n  url: https://github.com/nebari-dev/nebi/archive/refs/tags/v${{ version }}.tar.gz\n  sha256: a9af97cbadfa4218bc0ba229bf989f3c5ec8f72c30f3435bf3e4e9efd7f27d16\n  target_directory: src\n\nbuild:\n  number: 0\n\noutputs:\n  - package:\n      name: nebi\n      version: ${{ version }}\n    build:\n      script:\n        - if: unix\n          then: build-cli.sh\n        - if: win\n          then: build-cli.bat\n    requirements:\n      build:\n        - ${{ compiler(\"go-nocgo\") }}\n        - go-licenses\n        - nodejs >=20\n    tests:\n      - script:\n          - nebi version\n          - nebi --help\n      - package_contents:\n          bin:\n            - nebi\n          strict: true\n    about:\n      summary: Local-first workspace management for Pixi (CLI)\n      description: |\n        Nebi manages Pixi workspaces locally and syncs them to remote servers.\n        It provides a CLI and embedded web UI for tracking, pushing, and pulling\n        workspace configurations.\n\n  - package:\n      name: nebi-desktop\n      version: ${{ version }}\n    build:\n      script:\n        - if: unix\n          then: build-desktop.sh\n        - if: win\n          then: build-desktop.bat\n    requirements:\n      build:\n        - ${{ compiler(\"go-cgo\") }}\n        - ${{ compiler(\"c\") }}\n        - ${{ compiler(\"cxx\") }}\n        - ${{ stdlib(\"c\") }}\n        - go-licenses\n        - nodejs >=20\n        - if: linux\n          then:\n            - pkg-config\n      host:\n        - if: linux\n          then:\n            - gtk3\n            - webkit2gtk4.1\n            - glib\n            - libsoup\n            - gdk-pixbuf\n            - zlib\n            - expat\n            - fontconfig\n      run:\n        - menuinst >=2.1\n      ignore_run_exports:\n        from_package:\n          - if: linux\n            then:\n              - zlib\n              - expat\n              - fontconfig\n    tests:\n      - script:\n          - if: unix\n            then:\n              - test -f $PREFIX/bin/nebi-desktop\n          - if: win\n            then:\n              - if exist %LIBRARY_BIN%\\nebi-desktop.exe (exit 0) else (exit 1)\n      - package_contents:\n          files:\n            - Menu/nebi-desktop-menu.json\n    about:\n      summary: Nebi desktop application - local-first workspace management for Pixi\n      description: |\n        Nebi Desktop is a native desktop application for managing Pixi workspaces.\n        It provides a graphical interface for tracking, pushing, and pulling\n        workspace configurations with built-in web UI.\n\nabout:\n  homepage: https://github.com/nebari-dev/nebi\n  summary: Local-first workspace management for Pixi\n  license: Apache-2.0\n  license_file:\n    - src/LICENSE\n    - library_licenses/\n  documentation: https://github.com/nebari-dev/nebi\n  repository: https://github.com/nebari-dev/nebi\n\nextra:\n  recipe-maintainers:\n    - Adam-D-Lewis\n",
  "req": {
    "__set__": true,
    "elements": [
      "c_compiler_stub",
      "c_stdlib_stub",
      "cxx_compiler_stub",
      "expat",
      "fontconfig",
      "gdk-pixbuf",
      "glib",

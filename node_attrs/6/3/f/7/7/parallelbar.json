    "about": {
      "description": "Parallelbar displays the progress of tasks in the process pool for Pool class methods such as map,\nstarmap (since 1.2 version), imap and imap_unordered.\nParallelbar is based on the tqdm module and the standard python multiprocessing library.\nAlso, it is possible to handle exceptions that occur within a separate process,\nas well as set a timeout for the execution of a task by a process.",
      "home": "https://github.com/dubovikmaster/parallelbar",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Parallel processing with progress bars"
    },
    "build": {
      "noarch": "python",
      "number": "1",
      "script": "${{ PYTHON }} -m pip install . -vv --no-deps --no-build-isolation"

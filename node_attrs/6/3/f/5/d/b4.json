 "linux_64_meta_yaml": {
  "about": {
   "description": "This is a helper utility to work with patches made available via a\npublic-inbox archive like lore.kernel.org. It is written to make it easier\nto participate in a patch-based workflows, like those used in the Linux\nkernel development.\n",
   "doc_source_url": "https://git.kernel.org/pub/scm/utils/b4/b4.git/tree/docs",
   "doc_url": "https://b4.docs.kernel.org/",
   "home": "https://git.kernel.org/pub/scm/utils/b4/b4.git/",
   "license": "GPL-2.0-or-later",
   "license_family": "GPL",
   "license_file": "COPYING",
   "summary": "A tool to work with public-inbox and patch archives"
  },
  "build": {
   "entry_points": [
    "b4 = b4.command:cmd"
   ],
   "noarch": "python",
   "number": "0",
   "script": [
    "PYTHON -m pip install . -vv --no-deps --no-build-isolation",
    "mkdir -p \"$PREFIX/share/bash-completion/completions/\" \"$PREFIX/share/zsh/site-functions/\"",
    "./misc/tc-generate.sh bash >\"$PREFIX/share/bash-completion/completions/b4\"",
    "./misc/tc-generate.sh zsh >\"$PREFIX/share/zsh/site-functions/_b4\""
   ]
  },
  "extra": {
   "recipe-maintainers": [
    "blmaier"
   ]
  },
  "package": {
   "name": "b4",
   "version": "0.14.2"
  },
  "requirements": {
   "host": [
    "python >=3.8",
    "coreutils",
    "setuptools",
    "wheel",
    "pip",
    "shtab",
    "requests >=2.24,<3.0"
   ],
   "run": [
    "python >=3.8",
    "requests >=2.24,<3.0",
    "git-filter-repo >=2.30,<3.0",
    "dkimpy >=1.0,<2.0",
    "patatt >=0.6,<2.0",
    "__unix"
   ]
  },
  "schema_version": 0,
  "source": {
   "sha256": "62e739777d7963c72acf65b06a3f80762162e62eaabb53b5129a73291f2d4fa1",
   "url": "https://mirrors.edge.kernel.org/pub/software/devel/b4/b4-0.14.2.tar.gz"
  },
  "test": {
   "commands": [
    "pip check",
    "b4 --help",
    "pytest"
   ],
   "imports": [
    "b4"
   ],
   "requires": [
    "pip",
    "pytest"
   ],
   "source_files": [
    "src/tests/**"
   ]
  }

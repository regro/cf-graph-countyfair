  "linux_64_meta_yaml": {
    "about": {
      "description": "The Open Free Energy (OpenFE) project is dedicated to the maintenance and\ndevelopment of open source tools for free energy calculations to guide\npharmaceutical drug design and discovery. This package enables researchers\nto plan, execute, and analyze networks of free energy calculations.\n",
      "dev_url": "https://github.com/OpenFreeEnergy/openfe",
      "doc_url": "https://openfe.rtfd.io/",
      "home": "https://github.com/OpenFreeEnergy/openfe",
      "license": "MIT",
      "license_family": "MIT",
      "license_file": "LICENSE",
      "summary": "Free software for Free Energies."
    },
    "build": {
      "entry_points": [
        "openfe = openfecli.cli:main"
      ],
      "noarch": "python",
      "number": "1",
      "script": "SETUPTOOLS_SCM_PRETEND_VERSION=1.4.0 PYTHON -m pip install . -vv --no-deps"
    },
    "extra": {
      "recipe-maintainers": [
        "mikemhenry",
        "IAlibay",
        "dwhswenson",
        "atravitz"
      ]
    },
    "package": {
      "name": "openfe",
      "version": "1.4.0"
    },
    "requirements": {
      "host": [
        "pip",
        "python 3.10",
        "setuptools",
        "setuptools_scm"
      ],
      "run": [
        "cinnabar ~=0.4.0",
        "click",
        "gufe ~=1.3.0",
        "kartograf ~=1.0",
        "lomap2 >=3.2.1",
        "matplotlib-base",
        "networkx",
        "numpy <2.0.0",
        "openfe-analysis ~=0.3.1",
        "openff-toolkit >=0.16,<0.17",
        "openmmforcefields <0.15",
        "openmm !=8.1.0,>=8.0.0,<8.2",
        "openmmtools >=0.24.1,<0.25",
        "packaging",
        "plugcli",
        "pooch",
        "py3dmol",
        "pydantic >=1.10.17",
        "pygraphviz",
        "pymbar >=4.0",
        "pytest",
        "pytest-regressions",
        "python >=3.10",
        "rdkit <=2025.03.1",
        "rich",
        "threadpoolctl",
        "typing-extensions"
      ]
    },
    "schema_version": 0,
    "source": {
      "sha256": "3c3a94884174346f20810746029096a2bd4074d5590802f041f2c26c4e3d6fc5",
      "url": "https://github.com/OpenFreeEnergy/openfe/archive/refs/tags/v1.4.0.tar.gz"
    },
    "test": {
      "commands": [
        "openfe --help",
        "openfe --version",
        "python -c \"import openfe; print(openfe.__version__)\"",
        "python -c \"import openfe; assert(openfe.__version__ == '1.4.0')\"",
        "pytest -v -n auto --pyargs openfe openfecli"
      ],
      "imports": [
        "openfe"
      ],
      "requires": [
        "pip",
        "pytest",
        "pytest-xdist",
        "openmmforcefields =0.12",
        "python 3.10"
      ]
    }
  },

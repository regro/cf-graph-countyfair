 "linux_64_meta_yaml": {
  "about": {
   "description": "GeoStatTools provides geostatistical tools for various purposes:\n- random field generation\n- simple, ordinary, universal and external drift kriging\n- conditioned field generation\n- incompressible random vector field generation\n- (automatted) variogram estimation and fitting\n- directional variogram estimation and modelling\n- data normalization and transformation\n- many readily provided and even user-defined covariance models\n- metric spatio-temporal modelling\n- plotting and exporting routines\n",
   "dev_url": "https://github.com/GeoStat-Framework/GSTools",
   "doc_url": "https://gstools.readthedocs.io",
   "home": "https://github.com/GeoStat-Framework/GSTools",
   "license": "LGPL-3.0-or-later",
   "license_family": "LGPL",
   "license_file": "LICENSE",
   "summary": "GSTools: A geostatistical toolbox."
  },
  "build": {
   "number": "1",
   "script": [
    "PYTHON -m pip install . --no-deps --no-build-isolation -vv"
   ],
   "script_env": [
    "GSTOOLS_BUILD_PARALLEL=1"
   ]
  },
  "extra": {
   "recipe-maintainers": [
    "MuellerSeb",
    "LSchueler"
   ]
  },
  "package": {
   "name": "gstools",
   "version": "1.6.0"
  },
  "requirements": {
   "build": [
    "libgomp",
    "c_compiler_stub",

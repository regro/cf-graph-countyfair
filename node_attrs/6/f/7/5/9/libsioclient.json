  "raw_meta_yaml": "context:\n  name: libsioclient\n  version: \"3.1.0\"\n\npackage:\n  name: ${{ name }}\n  version: ${{ version }}\n\nsource:\n  - url: https://github.com/socketio/socket.io-client-cpp/archive/refs/tags/${{ version }}.tar.gz\n    sha256: f54dd36b8e5618d028c7c42f0c1a83a0d3a58f9239cf4b770f6b02b925909597\n    patches:\n      - patches/fix-windows-dll-install.patch\n\nbuild:\n  number: 0\n  script:\n      content:\n      - if: unix\n        then:\n          - cmake -B build -GNinja $CMAKE_ARGS -DCMAKE_POLICY_VERSION_MINIMUM=3.5 -DBUILD_SHARED_LIBS=ON .\n          - cmake --build build --parallel ${CPU_COUNT}\n        else:\n          - cmake -B build -GNinja %CMAKE_ARGS% -DCMAKE_POLICY_VERSION_MINIMUM=3.5 -DBUILD_SHARED_LIBS=ON -DCMAKE_WINDOWS_EXPORT_ALL_SYMBOLS=ON .\n          - cmake --build build --parallel %CPU_COUNT%\n      - cmake --install build\n\nrequirements:\n  run_exports:\n    - ${{ pin_subpackage(name, upper_bound='x.x.x') }}\n  build:\n    - ${{ stdlib('c') }}\n    - ${{ compiler('c') }}\n    - ${{ compiler('cxx') }}\n    - cmake\n    - ninja\n  host:\n    - openssl\n    # The websocketpp dependency doesn't work with asio >= 1.28.0, so we need to pin it to a version < 1.28.0\n    - asio <1.28.0\n    - websocketpp\n    - rapidjson\n    \n\ntests:\n  - package_contents:\n      lib:\n        - sioclient\n        - sioclient_tls\n      include:\n        - sio_client.h\n        - sio_message.h\n        - sio_socket.h\n\nabout:\n  homepage: https://github.com/socketio/socket.io-client-cpp\n  repository: https://github.com/socketio/socket.io-client-cpp\n  license: MIT\n  license_file: LICENSE\n  summary: C++ implementation of the socket.io client\n  description: |\n    C++ implementation of the socket.io client, which is a library for real-time communication between a client and a server.\n\nextra:\n  recipe-maintainers:\n    - ruben-arts\n",
